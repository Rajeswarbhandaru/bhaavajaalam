<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Memory Match!</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --font-body: 'Plus Jakarta Sans', 'Segoe UI', sans-serif;
      --radius-md: 12px;
      --radius-lg: 20px;
      --radius-xl: 30px;
      --space-1: 4px; --space-2: 8px; --space-3: 12px;
      --space-4: 16px; --space-6: 24px; --space-8: 32px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; }

    body {
      font-family: var(--font-body);
      min-height: 100dvh;
      background: linear-gradient(145deg, #4c1d95 0%, #7c3aed 35%, #a855f7 65%, #ec4899 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    /* ── Floating star bg ── */
    #star-bg { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .bg-star {
      position: absolute;
      border-radius: 50%;
      background: rgba(255,255,255,0.55);
      animation: twinkle var(--d,2s) ease-in-out infinite;
      animation-delay: var(--dl,0s);
    }
    @keyframes twinkle {
      0%,100% { opacity: .1; transform: scale(.8); }
      50%      { opacity: 1;  transform: scale(1.3); }
    }

    /* ── Confetti canvas ── */
    #confetti { position: fixed; inset: 0; pointer-events: none; z-index: 200; }

    /* ── Screens ── */
    .screen { display: none; flex-direction: column; align-items: center;
              width: 100%; max-width: 660px; padding: var(--space-4); position: relative; z-index: 1; }
    .screen.active { display: flex; }

    /* ─── TITLE SCREEN ─── */
    .logo-wrap { text-align: center; margin-bottom: var(--space-6); }
    .logo-emoji { font-size: clamp(3rem, 10vw, 5rem); display: block; animation: bob 2s ease-in-out infinite; }
    @keyframes bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    .logo-title {
      font-size: clamp(2.2rem, 7vw, 3.5rem); font-weight: 800;
      color: #fff; text-shadow: 0 4px 24px rgba(0,0,0,.35);
      line-height: 1.1;
    }
    .logo-sub { font-size: 1rem; color: rgba(255,255,255,.8); margin-top: 6px; font-weight: 600; }

    .diff-label { font-size: 1rem; font-weight: 700; color: rgba(255,255,255,.9);
                  margin-bottom: var(--space-3); letter-spacing: .03em; }
    .diff-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }

    /* ─── BUTTONS ─── */
    .btn {
      border: none; border-radius: var(--radius-xl); cursor: pointer;
      font-family: var(--font-body); font-weight: 700;
      transition: transform 150ms cubic-bezier(.16,1,.3,1), box-shadow 150ms;
      min-height: 44px; display: inline-flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      line-height: 1.2;
    }
    .btn:hover { transform: translateY(-3px); }
    .btn:active { transform: translateY(1px); }

    .btn-diff {
      padding: 14px 22px;
      font-size: 1rem;
      min-width: 130px;
    }
    .btn-diff small { font-size: .75rem; font-weight: 500; opacity: .85; }
    .btn-easy   { background: linear-gradient(135deg,#4ade80,#16a34a); color: #fff; box-shadow: 0 6px 20px rgba(22,163,74,.45); }
    .btn-medium { background: linear-gradient(135deg,#fbbf24,#d97706); color: #fff; box-shadow: 0 6px 20px rgba(217,119,6,.45); }
    .btn-hard   { background: linear-gradient(135deg,#f87171,#dc2626); color: #fff; box-shadow: 0 6px 20px rgba(220,38,38,.45); }

    .btn-sm {
      padding: 10px 20px; font-size: .9rem;
      background: rgba(255,255,255,.2); color: #fff;
      border: 2px solid rgba(255,255,255,.4);
      backdrop-filter: blur(8px);
    }
    .btn-sm:hover { background: rgba(255,255,255,.3); }
    .btn-primary {
      padding: 14px 32px; font-size: 1.05rem;
      background: linear-gradient(135deg,#ffd700,#f59e0b); color: #1e1040;
      box-shadow: 0 6px 24px rgba(245,158,11,.45);
    }

    /* ─── HUD ─── */
    .hud {
      display: flex; justify-content: center; align-items: center;
      gap: 10px; width: 100%; margin-bottom: var(--space-4); flex-wrap: wrap;
    }
    .hud-chip {
      background: rgba(255,255,255,.18); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: var(--radius-xl);
      padding: 8px 18px;
      color: #fff; font-weight: 700; font-size: .95rem;
      display: flex; align-items: center; gap: 7px;
      min-width: 90px; justify-content: center;
    }
    .hud-chip .icon { font-size: 1.15rem; }
    .hud-chip .val  { font-variant-numeric: tabular-nums; font-size: 1.15rem; }

    /* ─── CARD GRID ─── */
    .card-grid {
      display: grid; gap: 10px;
      width: 100%; margin-bottom: var(--space-4);
    }

    .card {
      aspect-ratio: 1; perspective: 700px; cursor: pointer;
      border-radius: var(--radius-lg); outline: none;
    }
    .card-inner {
      width: 100%; height: 100%; position: relative;
      transform-style: preserve-3d;
      transition: transform .5s cubic-bezier(.16,1,.3,1);
      border-radius: var(--radius-lg);
    }
    .card.flipped .card-inner,
    .card.matched .card-inner { transform: rotateY(180deg); }

    .card-back, .card-front {
      position: absolute; inset: 0;
      backface-visibility: hidden;
      border-radius: var(--radius-lg);
      display: flex; align-items: center; justify-content: center;
      user-select: none;
    }
    /* Back face */
    .card-back {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #3730a3 100%);
      border: 3px solid rgba(255,255,255,.3);
      box-shadow: 0 4px 16px rgba(0,0,0,.35);
      font-size: clamp(1.4rem,4vw,2.2rem);
    }
    /* Front face - per color */
    .card-front {
      transform: rotateY(180deg);
      font-size: clamp(1.8rem,5vw,3rem);
      border: 3px solid rgba(255,255,255,.55);
      box-shadow: 0 4px 20px rgba(0,0,0,.2);
    }
    .cc0 .card-front { background: linear-gradient(135deg,#fef08a,#fbbf24); }
    .cc1 .card-front { background: linear-gradient(135deg,#bfdbfe,#60a5fa); }
    .cc2 .card-front { background: linear-gradient(135deg,#bbf7d0,#4ade80); }
    .cc3 .card-front { background: linear-gradient(135deg,#fecaca,#f87171); }
    .cc4 .card-front { background: linear-gradient(135deg,#e9d5ff,#c084fc); }
    .cc5 .card-front { background: linear-gradient(135deg,#fed7aa,#fb923c); }
    .cc6 .card-front { background: linear-gradient(135deg,#cffafe,#22d3ee); }
    .cc7 .card-front { background: linear-gradient(135deg,#fce7f3,#f472b6); }
    .cc8 .card-front { background: linear-gradient(135deg,#d1fae5,#34d399); }
    .cc9 .card-front { background: linear-gradient(135deg,#e0e7ff,#818cf8); }

    .card.matched .card-front { filter: brightness(1.15); }
    .card.matched .card-inner { animation: matchBounce .45s cubic-bezier(.16,1,.3,1); }
    @keyframes matchBounce {
      0%   { transform: rotateY(180deg) scale(1); }
      40%  { transform: rotateY(180deg) scale(1.2); }
      70%  { transform: rotateY(180deg) scale(.95); }
      100% { transform: rotateY(180deg) scale(1); }
    }
    /* Matched sparkle ring */
    .card.matched::after {
      content: '';
      position: absolute; inset: -6px;
      border-radius: calc(var(--radius-lg) + 6px);
      background: transparent;
      border: 3px solid rgba(255,220,50,.7);
      animation: sparkleRing .6s ease forwards;
      pointer-events: none;
    }
    @keyframes sparkleRing {
      0%   { opacity:1; transform: scale(.9); }
      100% { opacity:0; transform: scale(1.25); }
    }

    .game-actions { display: flex; gap: 10px; margin-top: 4px; }

    /* ─── WIN SCREEN ─── */
    .win-trophies { font-size: clamp(2.5rem,8vw,4.5rem); margin-bottom: 8px;
                    animation: tropBounce 1s ease infinite alternate; }
    @keyframes tropBounce { from{transform:scale(1)} to{transform:scale(1.12) rotate(4deg)} }
    .win-title {
      font-size: clamp(2rem,7vw,3.2rem); font-weight: 800; color: #fff;
      text-shadow: 0 4px 20px rgba(0,0,0,.3);
      margin-bottom: 8px; text-align: center;
    }
    .win-msg { font-size: 1rem; color: rgba(255,255,255,.8); margin-bottom: var(--space-4); text-align: center; font-weight: 600; }
    .win-stats { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: var(--space-6); }
    .win-stat {
      background: rgba(255,255,255,.18); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.3);
      border-radius: var(--radius-lg); padding: 16px 22px; text-align: center; color: #fff;
      min-width: 100px;
    }
    .win-stat-val   { font-size: 2rem; font-weight: 800; display: block; font-variant-numeric: tabular-nums; }
    .win-stat-label { font-size: .78rem; opacity: .75; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; }
    .win-btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }

    /* ─── Responsive ─── */
    @media (max-width: 440px) {
      .card-grid { gap: 7px; }
      .hud-chip { padding: 7px 12px; font-size: .85rem; }
      .win-stat { padding: 12px 16px; }
    }

    /* Focus ring for keyboard nav */
    .card:focus-visible { outline: 3px solid #ffd700; outline-offset: 3px; }

    /* Shake animation for wrong pair */
    @keyframes shake {
      0%,100%{transform:translateX(0)}
      20%{transform:translateX(-6px)}
      40%{transform:translateX(6px)}
      60%{transform:translateX(-4px)}
      80%{transform:translateX(4px)}
    }
    .card.shake { animation: shake .4s ease; }
  </style>
</head>
<body>

<div id="star-bg"></div>
<canvas id="confetti"></canvas>

<!-- ══ TITLE SCREEN ══════════════════════════════════════════ -->
<div class="screen active" id="screen-title">
  <div class="logo-wrap">
    <span class="logo-emoji">🧩</span>
    <div class="logo-title">Memory Match!</div>
    <div class="logo-sub">Flip cards & find the matching pairs 🎯</div>
  </div>

  <div class="diff-label">Choose your challenge:</div>
  <div class="diff-row">
    <button class="btn btn-diff btn-easy"   onclick="startGame('easy')">
      🌟 Easy<br><small>4×3 · 6 pairs</small>
    </button>
    <button class="btn btn-diff btn-medium" onclick="startGame('medium')">
      🔥 Medium<br><small>4×4 · 8 pairs</small>
    </button>
    <button class="btn btn-diff btn-hard"   onclick="startGame('hard')">
      💥 Hard<br><small>5×4 · 10 pairs</small>
    </button>
  </div>
</div>

<!-- ══ GAME SCREEN ════════════════════════════════════════════ -->
<div class="screen" id="screen-game">
  <div class="hud">
    <div class="hud-chip"><span class="icon">⭐</span><span class="val" id="hScore">0</span></div>
    <div class="hud-chip"><span class="icon">🔄</span><span class="val" id="hMoves">0</span></div>
    <div class="hud-chip"><span class="icon">⏱️</span><span class="val" id="hTimer">0:00</span></div>
  </div>
  <div class="card-grid" id="cardGrid"></div>
  <div class="game-actions">
    <button class="btn btn-sm" onclick="goHome()">🏠 Home</button>
    <button class="btn btn-sm" onclick="restartGame()">🔄 Restart</button>
  </div>
</div>

<!-- ══ WIN SCREEN ═════════════════════════════════════════════ -->
<div class="screen" id="screen-win">
  <div class="win-trophies">🎉🏆🎊</div>
  <div class="win-title">You Won!</div>
  <div class="win-msg">🌟 Amazing! All pairs found! 🌟</div>
  <div class="win-stats">
    <div class="win-stat"><span class="win-stat-val" id="wTime">—</span><span class="win-stat-label">Time</span></div>
    <div class="win-stat"><span class="win-stat-val" id="wMoves">—</span><span class="win-stat-label">Moves</span></div>
    <div class="win-stat"><span class="win-stat-val" id="wScore">—</span><span class="win-stat-label">Score</span></div>
  </div>
  <div class="win-btns">
    <button class="btn btn-primary" onclick="restartGame()">🔄 Play Again</button>
    <button class="btn btn-sm"      onclick="goHome()">🏠 Menu</button>
  </div>
</div>

<script>
// ─── Config ───────────────────────────────────────────────────────────────────
const EMOJIS = [
  '🐶','🐱','🐭','🐹','🐰','🦊','🐻','🐼','🐨','🐯',
  '🦁','🐮','🐸','🐙','🦋','🦄','🐬','🦀','🐳','🦉'
];
const DIFFICULTIES = {
  easy:   { cols: 4, rows: 3, pairs: 6  },
  medium: { cols: 4, rows: 4, pairs: 8  },
  hard:   { cols: 5, rows: 4, pairs: 10 }
};

// ─── State ────────────────────────────────────────────────────────────────────
let G = {};

// ─── Utility ──────────────────────────────────────────────────────────────────
function shuffle(a) {
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function fmtTime(sec) {
  return `${Math.floor(sec/60)}:${String(sec%60).padStart(2,'0')}`;
}

// ─── Stars background ─────────────────────────────────────────────────────────
(function buildStars() {
  const bg = document.getElementById('star-bg');
  for (let i = 0; i < 35; i++) {
    const s = document.createElement('div');
    s.className = 'bg-star';
    const sz = Math.random() * 4 + 2;
    s.style.cssText = `
      left:${Math.random()*100}%;top:${Math.random()*100}%;
      width:${sz}px;height:${sz}px;
      --d:${(Math.random()*2+1.5).toFixed(2)}s;
      --dl:${(Math.random()*3).toFixed(2)}s;
    `;
    bg.appendChild(s);
  }
})();

// ─── Confetti ─────────────────────────────────────────────────────────────────
const cCvs = document.getElementById('confetti');
const cCtx = cCvs.getContext('2d');
let cParts = [];
let cRAF   = null;
const CONF_COLORS = ['#ffd700','#ff6b9d','#4ade80','#60a5fa','#c084fc','#fb923c','#fff'];

function resizeConfetti() {
  cCvs.width  = window.innerWidth;
  cCvs.height = window.innerHeight;
}
resizeConfetti();
window.addEventListener('resize', resizeConfetti);

function launchConfetti() {
  cParts = Array.from({length: 140}, () => ({
    x:  Math.random() * cCvs.width,
    y:  -20,
    vx: (Math.random() - .5) * 7,
    vy: Math.random() * 5 + 2,
    col: CONF_COLORS[Math.floor(Math.random() * CONF_COLORS.length)],
    sz: Math.random() * 9 + 5,
    ang: Math.random() * Math.PI * 2,
    spin: (Math.random() - .5) * .3,
    shape: Math.random() > .5 ? 'rect' : 'circle'
  }));
  if (cRAF) cancelAnimationFrame(cRAF);
  animateConf();
}

function animateConf() {
  cCtx.clearRect(0, 0, cCvs.width, cCvs.height);
  cParts.forEach(p => {
    p.x += p.vx; p.y += p.vy; p.vy += .1; p.ang += p.spin;
    const alpha = Math.max(0, 1 - p.y / cCvs.height);
    cCtx.save();
    cCtx.globalAlpha = alpha;
    cCtx.translate(p.x, p.y);
    cCtx.rotate(p.ang);
    cCtx.fillStyle = p.col;
    if (p.shape === 'rect') cCtx.fillRect(-p.sz/2, -p.sz/4, p.sz, p.sz/2);
    else { cCtx.beginPath(); cCtx.arc(0,0,p.sz/2,0,Math.PI*2); cCtx.fill(); }
    cCtx.restore();
  });
  cParts = cParts.filter(p => p.y < cCvs.height + 30);
  if (cParts.length) cRAF = requestAnimationFrame(animateConf);
  else cCtx.clearRect(0,0,cCvs.width,cCvs.height);
}

// ─── Audio ────────────────────────────────────────────────────────────────────
let aCtx = null;
function getACtx() {
  if (!aCtx) aCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (aCtx.state === 'suspended') aCtx.resume();
  return aCtx;
}
function playSFX(type) {
  try {
    const ctx = getACtx();
    const t = ctx.currentTime;
    if (type === 'flip') {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.type = 'sine';
      o.frequency.setValueAtTime(440, t);
      o.frequency.exponentialRampToValueAtTime(900, t + .1);
      g.gain.setValueAtTime(.2, t);
      g.gain.exponentialRampToValueAtTime(.001, t + .15);
      o.start(t); o.stop(t + .15);
    } else if (type === 'match') {
      [523, 659, 784, 1047].forEach((f, i) => {
        const o = ctx.createOscillator(), g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'triangle'; o.frequency.value = f;
        const ts = t + i * .1;
        g.gain.setValueAtTime(.3, ts);
        g.gain.exponentialRampToValueAtTime(.001, ts + .35);
        o.start(ts); o.stop(ts + .35);
      });
    } else if (type === 'nomatch') {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.type = 'sawtooth';
      o.frequency.setValueAtTime(220, t);
      o.frequency.exponentialRampToValueAtTime(100, t + .22);
      g.gain.setValueAtTime(.15, t);
      g.gain.exponentialRampToValueAtTime(.001, t + .28);
      o.start(t); o.stop(t + .28);
    } else if (type === 'win') {
      [523,659,784,1047,1319].forEach((f,i) => {
        const o = ctx.createOscillator(), g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'triangle'; o.frequency.value = f;
        const ts = t + i * .14;
        g.gain.setValueAtTime(.4, ts);
        g.gain.exponentialRampToValueAtTime(.001, ts + .45);
        o.start(ts); o.stop(ts + .45);
      });
    }
  } catch(e) {}
}

// ─── Screen management ────────────────────────────────────────────────────────
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ─── Timer ────────────────────────────────────────────────────────────────────
function startTimer() {
  G.startTime = Date.now();
  clearInterval(G.timerInterval);
  G.timerInterval = setInterval(() => {
    const s = Math.floor((Date.now() - G.startTime) / 1000);
    document.getElementById('hTimer').textContent = fmtTime(s);
  }, 500);
}
function stopTimer() { clearInterval(G.timerInterval); G.timerInterval = null; }
function getElapsed() { return G.startTime ? Math.floor((Date.now() - G.startTime) / 1000) : 0; }

// ─── Game init ────────────────────────────────────────────────────────────────
function startGame(diff) {
  G.difficulty = diff;
  restartGame();
}

function restartGame() {
  stopTimer();
  const diff = DIFFICULTIES[G.difficulty];
  const picked = shuffle([...EMOJIS]).slice(0, diff.pairs);
  const cardData = shuffle([...picked, ...picked]);

  G.cards    = cardData.map((emoji, i) => ({ id: i, emoji, colorIdx: picked.indexOf(emoji) % 10, flipped: false, matched: false }));
  G.flipped  = [];
  G.matched  = [];
  G.moves    = 0;
  G.score    = 0;
  G.locked   = false;
  G.started  = false;

  updateHUD();
  buildGrid(diff.cols);
  showScreen('screen-game');
}

function goHome() { stopTimer(); showScreen('screen-title'); }

// ─── Render grid ──────────────────────────────────────────────────────────────
function buildGrid(cols) {
  const grid = document.getElementById('cardGrid');
  grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
  grid.innerHTML = '';

  G.cards.forEach(c => {
    const el = document.createElement('div');
    el.className = `card cc${c.colorIdx}`;
    el.tabIndex = 0;
    el.dataset.id = c.id;
    el.setAttribute('aria-label', `Card ${c.id + 1}`);
    el.innerHTML = `
      <div class="card-inner">
        <div class="card-back">⭐</div>
        <div class="card-front">${c.emoji}</div>
      </div>`;
    el.addEventListener('click', () => flipCard(c.id));
    el.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') flipCard(c.id); });
    grid.appendChild(el);
  });
}

// ─── Flip logic ───────────────────────────────────────────────────────────────
function flipCard(id) {
  if (G.locked) return;
  const c = G.cards[id];
  if (c.flipped || c.matched) return;

  if (!G.started) { G.started = true; startTimer(); }

  playSFX('flip');
  c.flipped = true;
  G.flipped.push(id);
  getCardEl(id).classList.add('flipped');

  if (G.flipped.length === 2) {
    G.moves++;
    updateHUD();
    G.locked = true;
    checkMatch();
  }
}

function checkMatch() {
  const [a, b] = G.flipped;
  if (G.cards[a].emoji === G.cards[b].emoji) {
    setTimeout(() => {
      G.cards[a].matched = G.cards[b].matched = true;
      G.matched.push(a, b);
      getCardEl(a).classList.add('matched');
      getCardEl(b).classList.add('matched');
      G.score += 100;
      G.flipped = [];
      G.locked = false;
      updateHUD();
      playSFX('match');
      if (G.matched.length === G.cards.length) setTimeout(handleWin, 600);
    }, 350);
  } else {
    // Shake both cards
    setTimeout(() => {
      getCardEl(a).classList.add('shake');
      getCardEl(b).classList.add('shake');
      playSFX('nomatch');
    }, 300);
    setTimeout(() => {
      G.cards[a].flipped = G.cards[b].flipped = false;
      const elA = getCardEl(a), elB = getCardEl(b);
      elA.classList.remove('flipped', 'shake');
      elB.classList.remove('flipped', 'shake');
      G.flipped = [];
      G.locked = false;
    }, 900);
  }
}

function handleWin() {
  stopTimer();
  playSFX('win');
  launchConfetti();
  const elapsed = getElapsed();
  document.getElementById('wTime').textContent  = fmtTime(elapsed);
  document.getElementById('wMoves').textContent = G.moves;
  document.getElementById('wScore').textContent = G.score;
  setTimeout(() => showScreen('screen-win'), 200);
}

function updateHUD() {
  document.getElementById('hScore').textContent = G.score;
  document.getElementById('hMoves').textContent = G.moves;
}

function getCardEl(id) {
  return document.querySelector(`.card[data-id="${id}"]`);
}

// ─── Testing hooks ────────────────────────────────────────────────────────────
window.render_game_to_text = () => JSON.stringify({
  screen: document.querySelector('.screen.active')?.id,
  difficulty: G.difficulty,
  totalCards: G.cards?.length,
  matched: G.matched?.length,
  moves: G.moves,
  score: G.score,
  flipped: G.flipped
});
window.advanceTime = ms => {
  if (G.startTime) G.startTime -= ms;
};

// Unlock audio on first interaction
document.addEventListener('click', () => { try { getACtx(); } catch(e) {} }, { once: true });
</script>

<script src="session-tracker.js"></script>

</body>
</html>
