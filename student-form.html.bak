      <button class="btn btn-primary" id="submitBtn" onclick="submitForm()">
        🚀 Submit Enrollment
      </button>
    </div>
  </div>

  <!-- ===== SUCCESS SCREEN ===== -->
  <div class="screen" id="screen-success">
    <span class="success-burst">🏆</span>
    <div class="success-title">Mission Complete!</div>
    <p class="success-sub">Your enrollment has been received. You\'ve unlocked your Brain Gym journey!</p>
    <div class="success-card">
      <p>✅ <strong>Your data has been saved successfully.</strong><br><br>
      📲 Our team will contact you on <strong>WhatsApp within 2 hours</strong> to schedule your session.<br><br>
      📧 A confirmation will also be sent to your <strong>email address</strong>.<br><br>
      🧠 Get ready to <strong>unlock your brain\'s true potential!</strong></p>
    </div>
    <p style="font-size:.82rem;color:var(--muted);margin-bottom:24px;">
      In the meantime, explore our Brain Games to warm up your brain!
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="index.html" class="btn btn-ghost">← Back to Website</a>
      <a href="Bhaava-Brain-Quest.html" class="btn btn-primary" target="_blank">🎮 Play Brain Quest</a>
    </div>
  </div>

</div><!-- /wrapper -->

<footer>Bhāva Tech — Brain Gym & IQ Enhancing Center &nbsp;|&nbsp; 📍 Visakhapatnam, India &nbsp;|&nbsp; 🌍 Online Worldwide &nbsp;|&nbsp; © 2026</footer>

<script>
// ── STARS ──
const starsEl = document.getElementById('stars');
for(let i=0;i<120;i++){
  const s = document.createElement('div');
  s.className = 'star';
  const size = Math.random()*2.5+0.5;
  s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${2+Math.random()*4}s;--delay:${Math.random()*5}s;opacity:${Math.random()*.6+.1}`;
  starsEl.appendChild(s);
}

// ── LEVELS CONFIG ──
const LEVELS = [
  {badge:'WELCOME',xp:''},
  {badge:'LEVEL 1',xp:'Player Profile'},
  {badge:'LEVEL 2',xp:'School Quest'},
  {badge:'LEVEL 3',xp:'Daily Stats'},
  {badge:'LEVEL 4',xp:'Gaming Zone'},
  {badge:'LEVEL 5',xp:'Guardian Base'},
  {badge:'COMPLETE',xp:'Mission Done!'}
];

const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwP1IlDOy_cnziKJlZqJjGrF9GoL6ygtsWtk3K4KCoSNPSAvroYkIZ_ACV3MTqYjbT9ZQ/exec";
let currentScreen = 0;

function startForm(){
  document.getElementById('progressArea').style.display = 'block';
  goScreen(1);
}

function goScreen(n){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const target = n === 'success' ? document.getElementById('screen-success') : document.getElementById('screen-'+n);
  if(target) target.classList.add('active');
  currentScreen = n;

  if(n !== 0 && n !== 'success'){
    const pct = ((n-1)/5)*100;
    document.getElementById('progressFill').style.width = pct+'%';
    document.getElementById('levelBadge').textContent = LEVELS[n]?.badge || '';
    document.getElementById('xpText').textContent = LEVELS[n]?.xp || '';
    // dots
    const dots = document.getElementById('levelDots');
    dots.innerHTML = [1,2,3,4,5].map(i =>
      `<div class="ldot ${i<n?'done':i===n?'active':''}"></div>`
    ).join('');
  }
  if(n === 'success'){
    document.getElementById('progressArea').style.display = 'none';
    launchConfetti();
  }
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── COLLECT DATA ──
function getChecked(name){
  return [...document.querySelectorAll(`input[name="${name}"]:checked`)].map(e=>e.value).join(', ');
}
function getRadio(name){
  const el = document.querySelector(`input[name="${name}"]:checked`);
  return el ? el.value : '';
}

function collectData(){
  return {
    // Level 1
    childName:       document.getElementById('childName').value,
    childAge:        document.getElementById('childAge').value,
    childDob:        document.getElementById('childDob').value,
    childGender:     document.getElementById('childGender').value,
    childCity:       document.getElementById('childCity').value,
    childCountry:    document.getElementById('childCountry').value,
    childPhone:      document.getElementById('childPhone').value,
    moodRating:      getRadio('mood'),
    // Level 2
    schoolName:      document.getElementById('schoolName').value,
    childClass:      document.getElementById('childClass').value,
    schoolBoard:     document.getElementById('schoolBoard').value,
    academicPerf:    document.getElementById('academicPerf').value,
    favSubject:      document.getElementById('favSubject').value,
    hardSubject:     document.getElementById('hardSubject').value,
    learningDiff:    getChecked('ld'),
    schoolStruggle:  document.getElementById('schoolStruggle').value,
    // Level 3
    screenTime:      document.getElementById('screenTime').value,
    screenUse:       getChecked('screen_use'),
    sleepHours:      document.getElementById('sleepHours').value,
    bedtime:         document.getElementById('bedtime').value,
    deviceBed:       document.getElementById('deviceBed').value,
    physicalActivity:getRadio('physical_activity'),
    dietQuality:     document.getElementById('dietQuality').value,
    healthConditions:document.getElementById('healthConditions').value,
    // Level 4
    playsGames:      getRadio('plays_games'),
    gamingHours:     document.getElementById('gamingHours').value,
    platform:        getChecked('platform'),
    gameType:        getChecked('game_type'),
    gamingEffectStudy: getRadio('gaming_effect_study'),
    gamingEffectSleep: getRadio('gaming_effect_sleep'),
    angerOnStop:     getRadio('anger_on_stop'),
    hobbies:         document.getElementById('hobbies').value,
    // Level 5
    parentName:      document.getElementById('parentName').value,
    parentRelation:  document.getElementById('parentRelation').value,
    parentOcc:       document.getElementById('parentOcc').value,
    parentPhone:     document.getElementById('parentPhone').value,
    parentEmail:     document.getElementById('parentEmail').value,
    timezone:        document.getElementById('timezone').value,
    contactTime:     document.getElementById('contactTime').value,
    referral:        document.getElementById('referral').value,
    mainConcern:     document.getElementById('mainConcern').value,
    goalExpected:    document.getElementById('goalExpected').value,
    prevAssessment:  getRadio('prev_assessment'),
    extraNotes:      document.getElementById('extraNotes').value,
    // Meta
    submittedAt:     new Date().toISOString(),
    sheetTarget:     'Public Intake'
  };
}

// ── VALIDATION ──
function validateScreen(n){
  const required = {
    1: ['childName','childAge','childGender','childCity','childCountry'],
    2: ['schoolName','childClass','academicPerf'],
    3: [],
    4: [],
    5: ['parentName','parentRelation','parentPhone','parentEmail','timezone','mainConcern']
  };
  if(!required[n]) return true;
  for(const id of required[n]){
    const el = document.getElementById(id);
    if(el && !el.value.trim()){
      el.focus();
      el.style.borderColor = '#ff4d6d';
      setTimeout(()=>el.style.borderColor='',2000);
      return false;
    }
  }
  return true;
}

// Override goScreen for validation
const _go = goScreen;
window.goScreen = function(n){
  if(typeof n === 'number' && n > currentScreen){
    if(!validateScreen(currentScreen)) return;
  }
  _go(n);
};

// ── SUBMIT ──
async function submitForm(){
  if(!validateScreen(5)) return;
  const btn = document.getElementById('submitBtn');
  btn.textContent = '⏳ Saving...';
  btn.disabled = true;
  const data = collectData();
  try {
    await fetch(SCRIPT_URL, {
      method:'POST',
      mode:'no-cors',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(data)
    });
  } catch(e){ console.warn('Sheet sync error:',e); }
  goScreen('success');
}

// ── CONFETTI ──
function launchConfetti(){
  const colors = ['#00d4ff','#7c3aed','#e67e22','#00e676','#f59e0b','#ff6b9d'];
  for(let i=0;i<80;i++){
    const c = document.createElement('div');
    c.className = 'confetti-piece';
    c.style.cssText = `
      left:${Math.random()*100}%;
      top:-10px;
      background:${colors[Math.floor(Math.random()*colors.length)]};
      width:${6+Math.random()*8}px;
      height:${6+Math.random()*8}px;
      border-radius:${Math.random()>0.5?'50%':'2px'};
      animation-delay:${Math.random()*1.5}s;
      animation-duration:${2+Math.random()*2}s;
    `;
    document.body.appendChild(c);
    setTimeout(()=>c.remove(), 4000);
  }
}
</script>
</body>
</html>'''

with open('/root/student-form.html', 'w', encoding='utf-8') as f:
    f.write(html_content)

import os
size = os.path.getsize('/root/student-form.html')
print(f"File created successfully! Size: {size:,} bytes ({size//1024} KB)")
print("Filename: student-form.html")