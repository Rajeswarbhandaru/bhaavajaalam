          <label class="form-label">Main concern — why are you seeking help? <span class="req">*</span></label>
          <textarea class="form-textarea" id="mainConcern" placeholder="Tell us what made you reach out today..." required></textarea>
        </div>
        <div class="form-group full">
          <label class="form-label">What do you hope your child achieves from this program?</label>
          <textarea class="form-textarea" id="goalExpected" placeholder="e.g. Better focus, improved grades, less gaming..."></textarea>
        </div>
        <div class="form-group full">
          <label class="form-label">Has your child had any cognitive / psychological assessment before?</label>
          <div class="chip-group">
            <div class="chip-opt"><input type="radio" id="prev-yes" name="prev_assessment" value="Yes"><label for="prev-yes">Yes</label></div>
            <div class="chip-opt"><input type="radio" id="prev-no" name="prev_assessment" value="No"><label for="prev-no">No</label></div>
            <div class="chip-opt"><input type="radio" id="prev-unsure" name="prev_assessment" value="Unsure"><label for="prev-unsure">Not sure</label></div>
          </div>
        </div>
        <div class="form-group full">
          <label class="form-label">Anything else you\'d like us to know?</label>
          <textarea class="form-textarea" id="extraNotes" placeholder="Any medical conditions, special needs, or additional notes..."></textarea>
        </div>
