            <div class="chip-opt"><input type="radio" id="pa2" name="physical_activity" value="2–3 days"><label for="pa2">2–3 days</label></div>
            <div class="chip-opt"><input type="radio" id="pa3" name="physical_activity" value="4–5 days"><label for="pa3">4–5 days</label></div>
