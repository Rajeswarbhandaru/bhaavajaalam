            <div class="chip-opt"><input type="radio" id="ang-some" name="anger_on_stop" value="Sometimes"><label for="ang-some">Sometimes</label></div>
            <div class="chip-opt"><input type="radio" id="ang-no" name="anger_on_stop" value="Rarely / No"><label for="ang-no">Rarely / No</label></div>
          </div>
