            <div class="chip-opt"><input type="checkbox" id="sc-yt" name="screen_use" value="YouTube"><label for="sc-yt">📺 YouTube</label></div>
            <div class="chip-opt"><input type="checkbox" id="sc-sm" name="screen_use" value="Social Media"><label for="sc-sm">📱 Social Media</label></div>
            <div class="chip-opt"><input type="checkbox" id="sc-study" name="screen_use" value="Study"><label for="sc-study">📚 Study</label></div>
            <div class="chip-opt"><input type="checkbox" id="sc-chat" name="screen_use" value="Chatting"><label for="sc-chat">💬 Chatting</label></div>
            <div class="chip-opt"><input type="checkbox" id="sc-reel" name="screen_use" value="Reels/Shorts"><label for="sc-reel">🎵 Reels/Shorts</label></div>
          </div>
        </div>
        <div class="form-group full">
          <label class="form-label">Sleep per night (hours) <span class="req">*</span></label>
