            <div class="chip-opt"><input type="radio" id="eff-some" name="gaming_effect_study" value="Somewhat"><label for="eff-some">Somewhat</label></div>
            <div class="chip-opt"><input type="radio" id="eff-no" name="gaming_effect_study" value="No"><label for="eff-no">No</label></div>
          </div>
        </div>
        <div class="form-group full">
          <label class="form-label">Has gaming / screen use affected sleep?</label>
          <div class="chip-group">
            <div class="chip-opt"><input type="radio" id="sl-yes" name="gaming_effect_sleep" value="Yes — stays up late gaming"><label for="sl-yes">Yes — stays up late</label></div>
            <div class="chip-opt"><input type="radio" id="sl-some" name="gaming_effect_sleep" value="Sometimes"><label for="sl-some">Sometimes</label></div>
            <div class="chip-opt"><input type="radio" id="sl-no" name="gaming_effect_sleep" value="No"><label for="sl-no">No</label></div>
