<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Empathy Quest 🌟</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --purple:#7c3aed; --pink:#ec4899; --teal:#06b6d4; --yellow:#f59e0b;
  --green:#10b981; --orange:#f97316; --red:#ef4444; --blue:#3b82f6;
  --dark:#0f0a2e; --font:'Nunito','Segoe UI',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:var(--font);min-height:100vh;background:var(--dark);display:flex;align-items:center;justify-content:center;overflow:hidden;}

/* ── ANIMATED BG ── */
.bg{position:fixed;inset:0;z-index:0;overflow:hidden;}
.bubble{position:absolute;border-radius:50%;opacity:.12;animation:drift linear infinite;}
@keyframes drift{0%{transform:translateY(110vh) rotate(0deg);}100%{transform:translateY(-20vh) rotate(360deg);}}

/* ── APP SHELL ── */
#app{position:relative;z-index:1;width:100%;max-width:780px;min-height:100svh;display:flex;flex-direction:column;background:rgba(15,10,46,.95);border-radius:28px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.6);}

/* ── SCREEN SYSTEM ── */
.screen{display:none;flex-direction:column;flex:1;}
.screen.active{display:flex;}

/* ════════════════════════════════════
   WELCOME SCREEN
════════════════════════════════════ */
#welcome{align-items:center;justify-content:center;text-align:center;gap:18px;padding:30px 28px;background:radial-gradient(ellipse at top,#2d1b69 0%,#0f0a2e 70%);}
.logo-wrap{position:relative;display:flex;align-items:center;justify-content:center;}
.logo-glow{position:absolute;width:110px;height:110px;border-radius:50%;background:var(--purple);filter:blur(30px);opacity:.6;animation:pulse-glow 2s ease-in-out infinite;}
@keyframes pulse-glow{0%,100%{transform:scale(1);opacity:.6}50%{transform:scale(1.3);opacity:.9}}
.logo-emoji{font-size:80px;position:relative;z-index:1;animation:float 3s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.game-title{font-size:44px;font-weight:900;background:linear-gradient(135deg,#a78bfa,#ec4899,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;letter-spacing:-1px;}
.game-tagline{font-size:14px;color:#94a3b8;letter-spacing:3px;text-transform:uppercase;}
.intro-box{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:18px 22px;max-width:440px;}
.intro-box p{color:#cbd5e1;font-size:15px;line-height:1.7;}
.intro-box strong{color:#fbbf24;}
.features{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;}
.feat{background:rgba(255,255,255,.07);border-radius:14px;padding:12px 16px;color:#e2e8f0;font-size:13px;font-weight:700;display:flex;flex-direction:column;align-items:center;gap:4px;min-width:90px;}
.feat span:first-child{font-size:26px;}
.start-btn{background:linear-gradient(135deg,#7c3aed,#ec4899);border:none;border-radius:50px;padding:18px 55px;font-size:20px;font-weight:900;color:white;cursor:pointer;box-shadow:0 8px 30px rgba(124,58,237,.5);transition:all .2s;font-family:var(--font);letter-spacing:.5px;animation:btn-pulse 2s ease-in-out infinite;}
@keyframes btn-pulse{0%,100%{box-shadow:0 8px 30px rgba(124,58,237,.5)}50%{box-shadow:0 8px 50px rgba(236,72,153,.8)}}
.start-btn:hover{transform:translateY(-4px) scale(1.04);}
.age-note{color:#64748b;font-size:12px;}

/* ════════════════════════════════════
   GAME SCREEN
════════════════════════════════════ */
#game{flex:1;}

/* HUD */
.hud{background:linear-gradient(135deg,#1e1158,#2d1b69);padding:14px 20px;display:flex;align-items:center;justify-content:space-between;gap:8px;flex-shrink:0;}
.lives{display:flex;gap:4px;align-items:center;}
.life-heart{font-size:22px;transition:all .3s;filter:drop-shadow(0 0 6px rgba(239,68,68,.8));}
.life-heart.lost{filter:grayscale(1) opacity(.3);transform:scale(.8);}
.hud-score{background:rgba(255,255,255,.1);border-radius:30px;padding:7px 16px;color:white;font-size:16px;font-weight:900;display:flex;align-items:center;gap:6px;}
.streak-badge{background:linear-gradient(135deg,#f59e0b,#f97316);border-radius:30px;padding:7px 14px;color:white;font-size:14px;font-weight:900;display:flex;align-items:center;gap:5px;min-width:62px;justify-content:center;transition:all .3s;}
.streak-badge.hot{animation:streak-shake .3s ease;}
@keyframes streak-shake{0%,100%{transform:scale(1)}50%{transform:scale(1.3) rotate(-5deg)}}

/* Progress */
.prog-wrap{padding:10px 20px;background:rgba(255,255,255,.03);display:flex;align-items:center;gap:10px;flex-shrink:0;}
.prog-bar{flex:1;height:8px;background:rgba(255,255,255,.1);border-radius:4px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--pink));border-radius:4px;transition:width .6s ease;}
.prog-text{color:#94a3b8;font-size:12px;font-weight:700;white-space:nowrap;}

/* Scene Area */
.scene-area{padding:16px 20px 0;flex-shrink:0;}
.scene-bg{border-radius:22px;padding:18px 20px;display:flex;gap:14px;align-items:flex-start;position:relative;overflow:hidden;}
.scene-deco{position:absolute;right:-20px;bottom:-20px;font-size:80px;opacity:.08;transform:rotate(-15deg);}
.char-col{display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0;}
.char-blob{width:74px;height:74px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:44px;position:relative;animation:char-float 2.5s ease-in-out infinite;}
@keyframes char-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.char-name-tag{background:rgba(0,0,0,.35);border-radius:20px;padding:3px 10px;color:white;font-size:11px;font-weight:800;white-space:nowrap;}
.scene-text-col{flex:1;}
.scene-label{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;opacity:.8;}
.scene-desc{font-size:14px;line-height:1.65;color:rgba(255,255,255,.88);}

/* Question */
.q-area{padding:12px 20px 0;flex-shrink:0;}
.phase-pills{display:flex;gap:8px;margin-bottom:10px;}
.phase-pill{padding:4px 14px;border-radius:20px;font-size:11px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;}
.phase-pill.active{background:linear-gradient(135deg,var(--purple),var(--pink));color:white;}
.phase-pill.done{background:rgba(16,185,129,.25);color:#6ee7b7;}
.phase-pill.pending{background:rgba(255,255,255,.08);color:#64748b;}
.q-text{font-size:18px;font-weight:900;color:white;line-height:1.3;}

/* Choice Cards */
.choices{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:12px 20px 20px;flex:1;}
.choice{background:rgba(255,255,255,.06);border:2px solid rgba(255,255,255,.1);border-radius:18px;padding:14px 14px 14px 16px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:12px;text-align:left;font-family:var(--font);}
.choice:hover{border-color:var(--purple);background:rgba(124,58,237,.15);transform:translateY(-3px);box-shadow:0 8px 20px rgba(124,58,237,.25);}
.choice:active{transform:scale(.97);}
.choice .ci{font-size:28px;flex-shrink:0;}
.choice .ct{font-size:13px;font-weight:700;color:#e2e8f0;line-height:1.4;}
.choice.correct{border-color:#10b981;background:rgba(16,185,129,.2);animation:correct-glow .6s ease;}
@keyframes correct-glow{0%{box-shadow:0 0 0 rgba(16,185,129,0)}50%{box-shadow:0 0 30px rgba(16,185,129,.6)}100%{box-shadow:0 0 0 rgba(16,185,129,0)}}
.choice.wrong{border-color:#ef4444;background:rgba(239,68,68,.15);animation:wrong-shake .4s ease;}
@keyframes wrong-shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}
.choice.best-show{border-color:#06b6d4;background:rgba(6,182,212,.18);}
.choice.good-show{border-color:#10b981;background:rgba(16,185,129,.15);}
.choice.neutral-show{border-color:#f59e0b;background:rgba(245,158,11,.12);}
.choice.bad-show{border-color:#ef4444;background:rgba(239,68,68,.12);}
.choice:disabled,.choice[disabled]{cursor:not-allowed;opacity:.7;}

/* ════════════════════════════════════
   FEEDBACK MODAL
════════════════════════════════════ */
#fb-modal{position:fixed;inset:0;z-index:100;display:none;align-items:center;justify-content:center;padding:20px;background:rgba(0,0,0,.65);backdrop-filter:blur(6px);}
#fb-modal.open{display:flex;animation:fade-in .25s ease;}
@keyframes fade-in{from{opacity:0}to{opacity:1}}
.fb-card{background:linear-gradient(160deg,#1e1158,#0f172a);border-radius:28px;padding:30px 28px;max-width:440px;width:100%;box-shadow:0 30px 60px rgba(0,0,0,.6);animation:card-pop .35s cubic-bezier(.34,1.56,.64,1);}
@keyframes card-pop{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
.fb-result-icon{font-size:60px;text-align:center;display:block;margin-bottom:6px;animation:result-bounce .5s cubic-bezier(.34,1.56,.64,1);}
@keyframes result-bounce{from{transform:scale(0) rotate(-30deg)}to{transform:scale(1) rotate(0)}}
.fb-pts{text-align:center;font-size:22px;font-weight:900;margin-bottom:12px;}
.fb-pts.pos{color:#fbbf24;}
.fb-pts.neg{color:#f87171;}
.fb-explanation{background:rgba(255,255,255,.06);border-radius:16px;padding:14px 16px;color:#cbd5e1;font-size:14px;line-height:1.65;margin-bottom:16px;}
.fb-lesson{background:linear-gradient(135deg,rgba(124,58,237,.25),rgba(236,72,153,.15));border:1px solid rgba(167,139,250,.3);border-radius:16px;padding:14px 16px;display:none;}
.fb-lesson.show{display:block;}
.fb-lesson-label{font-size:11px;font-weight:800;color:#a78bfa;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:5px;}
.fb-lesson-text{color:#e2e8f0;font-size:13.5px;line-height:1.6;font-weight:600;}
.fb-continue{display:block;width:100%;margin-top:18px;background:linear-gradient(135deg,var(--purple),var(--pink));border:none;border-radius:50px;padding:15px;font-size:17px;font-weight:900;color:white;cursor:pointer;font-family:var(--font);transition:all .2s;}
.fb-continue:hover{transform:translateY(-2px);box-shadow:0 10px 25px rgba(124,58,237,.5);}

/* ── SCORE POPUP ── */
.score-pop{position:fixed;pointer-events:none;font-size:22px;font-weight:900;color:#fbbf24;z-index:200;animation:pop-fly 1.2s ease forwards;white-space:nowrap;}
@keyframes pop-fly{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-80px) scale(1.4)}}

/* ════════════════════════════════════
   RESULTS SCREEN
════════════════════════════════════ */
#results{align-items:center;justify-content:center;text-align:center;gap:16px;padding:30px 24px;background:radial-gradient(ellipse at top,#2d1b69 0%,#0f0a2e 70%);overflow-y:auto;}
.res-trophy{font-size:80px;animation:trophy-bounce 1s cubic-bezier(.34,1.56,.64,1);}
@keyframes trophy-bounce{from{transform:scale(0) rotate(-20deg)}to{transform:scale(1) rotate(0)}}
.res-title{font-size:30px;font-weight:900;color:white;line-height:1.2;}
.res-scores{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
.res-score-box{background:rgba(255,255,255,.08);border-radius:18px;padding:14px 22px;min-width:100px;}
.res-score-num{font-size:36px;font-weight:900;color:white;}
.res-score-lbl{font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;}
.badge-unlock{background:linear-gradient(135deg,rgba(124,58,237,.3),rgba(236,72,153,.2));border:2px solid rgba(167,139,250,.4);border-radius:24px;padding:22px 28px;display:flex;flex-direction:column;align-items:center;gap:8px;animation:badge-appear .7s .3s cubic-bezier(.34,1.56,.64,1) both;}
@keyframes badge-appear{from{transform:scale(0.5) rotate(-10deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.badge-emoji-big{font-size:64px;}
.badge-title{font-size:20px;font-weight:900;color:#fbbf24;}
.badge-desc{font-size:13px;color:#94a3b8;max-width:300px;line-height:1.6;}
.lessons-box{background:rgba(255,255,255,.04);border-radius:20px;padding:20px;max-width:480px;width:100%;text-align:left;}
.lessons-box h3{color:#a78bfa;font-size:13px;font-weight:900;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;}
.lessons-box ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
.lessons-box li{color:#cbd5e1;font-size:13px;line-height:1.55;padding-left:22px;position:relative;}
.lessons-box li::before{content:"💡";position:absolute;left:0;}
.replay-btn{background:linear-gradient(135deg,#7c3aed,#ec4899);border:none;border-radius:50px;padding:16px 50px;font-size:18px;font-weight:900;color:white;cursor:pointer;font-family:var(--font);box-shadow:0 8px 25px rgba(124,58,237,.5);transition:all .2s;}
.replay-btn:hover{transform:translateY(-3px) scale(1.03);}

/* ── SCENE THEMES ── */
.theme-school{background:linear-gradient(135deg,#1e3a5f,#1e4d2b);}
.theme-sport{background:linear-gradient(135deg,#1a4731,#2d4a1e);}
.theme-art{background:linear-gradient(135deg,#3b1f6b,#5b1f6b);}
.theme-home{background:linear-gradient(135deg,#5b2d1e,#3b1e3b);}
.theme-social{background:linear-gradient(135deg,#1e3b5f,#1b3a4b);}
.theme-outdoor{background:linear-gradient(135deg,#1e4a1e,#1e3a5f);}
.theme-perform{background:linear-gradient(135deg,#4a1e5b,#1e1e5b);}
.theme-class{background:linear-gradient(135deg,#1e1e5b,#2d1b69);}

/* ── MISC ── */
@media(max-width:520px){.choices{grid-template-columns:1fr;}.game-title{font-size:34px;}}
.confetti-piece{position:fixed;pointer-events:none;z-index:300;animation:confetti-fall linear forwards;}
@keyframes confetti-fall{0%{opacity:1;transform:translateY(-20px) rotate(0)}100%{opacity:0;transform:translateY(100vh) rotate(720deg)}}
</style>
</head>
<body>

<!-- Animated background -->
<div class="bg" id="bg"></div>

<div id="app">

  <!-- ═══════════════ WELCOME ═══════════════ -->
  <div id="welcome" class="screen active">
    <div class="logo-wrap"><div class="logo-glow"></div><div class="logo-emoji">🕵️</div></div>
    <div class="game-title">EmpathyQuest</div>
    <div class="game-tagline">Heart Detective Adventure</div>
    <div class="intro-box">
      <p>Step into the shoes of a <strong>Heart Detective</strong> 🔍. Read real-life stories, discover what others are feeling, and choose the kindest response. The world needs YOUR empathy! 🌍</p>
    </div>
    <div class="features">
      <div class="feat"><span>❤️</span><span>3 Lives</span></div>
      <div class="feat"><span>🔥</span><span>Streaks</span></div>
      <div class="feat"><span>🎵</span><span>Sounds</span></div>
      <div class="feat"><span>🏆</span><span>8 Missions</span></div>
    </div>
    <button class="start-btn" onclick="startGame()">🚀 Begin Mission</button>
    <div class="age-note">Ages 7 – 15 &nbsp;•&nbsp; ~10 mins</div>
  </div>

  <!-- ═══════════════ GAME ═══════════════ -->
  <div id="game" class="screen">
    <!-- HUD -->
    <div class="hud">
      <div class="lives" id="lives-display"></div>
      <div class="hud-score">⭐ <span id="score-display">0</span></div>
      <div class="streak-badge" id="streak-badge">🔥 <span id="streak-num">0</span></div>
    </div>
    <!-- Progress bar -->
    <div class="prog-wrap">
      <div class="prog-bar"><div class="prog-fill" id="prog-fill" style="width:0%"></div></div>
      <div class="prog-text" id="prog-text">Mission 1 / 8</div>
    </div>
    <!-- Scene -->
    <div class="scene-area">
      <div class="scene-bg" id="scene-bg">
        <div class="scene-deco" id="scene-deco"></div>
        <div class="char-col">
          <div class="char-blob" id="char-blob" style="background:rgba(255,255,255,.12)"></div>
          <div class="char-name-tag" id="char-name"></div>
        </div>
        <div class="scene-text-col">
          <div class="scene-label" id="scene-label"></div>
          <div class="scene-desc" id="scene-desc"></div>
        </div>
      </div>
    </div>
    <!-- Question -->
    <div class="q-area">
      <div class="phase-pills" id="phase-pills">
        <div class="phase-pill active" id="pill0">🎯 Feeling</div>
        <div class="phase-pill pending" id="pill1">💡 Action</div>
      </div>
      <div class="q-text" id="q-text"></div>
    </div>
    <!-- Choices -->
    <div class="choices" id="choices"></div>
  </div>

  <!-- ═══════════════ RESULTS ═══════════════ -->
  <div id="results" class="screen">
    <div class="res-trophy" id="res-trophy">🏆</div>
    <div class="res-title" id="res-title">Amazing Work!</div>
    <div class="res-scores">
      <div class="res-score-box"><div class="res-score-num" id="res-pts">0</div><div class="res-score-lbl">Points</div></div>
      <div class="res-score-box"><div class="res-score-num" id="res-empathy">0%</div><div class="res-score-lbl">Empathy</div></div>
      <div class="res-score-box"><div class="res-score-num" id="res-streak">0</div><div class="res-score-lbl">Best Streak</div></div>
    </div>
    <div class="badge-unlock">
      <div class="badge-emoji-big" id="res-badge">⭐</div>
      <div class="badge-title" id="res-badge-name">Empathy Star</div>
      <div class="badge-desc" id="res-badge-desc">You have a kind heart!</div>
    </div>
    <div class="lessons-box">
      <h3>🧠 Lessons Learned</h3>
      <ul id="res-lessons"></ul>
    </div>
    <button class="replay-btn" onclick="restartGame()">🔄 Play Again</button>
  </div>

</div>

<!-- ═══════════════ FEEDBACK MODAL ═══════════════ -->
<div id="fb-modal">
  <div class="fb-card">
    <span class="fb-result-icon" id="fb-icon">🎉</span>
    <div class="fb-pts" id="fb-pts">+3 ⭐</div>
    <div class="fb-explanation" id="fb-exp"></div>
    <div class="fb-lesson" id="fb-lesson">
      <div class="fb-lesson-label">🧠 Heart Lesson</div>
      <div class="fb-lesson-text" id="fb-lesson-text"></div>
    </div>
    <button class="fb-continue" id="fb-continue" onclick="continueGame()"></button>
  </div>
</div>

<script>
// ── DATA ──────────────────────────────────────────
const SCENARIOS = [
  {
    id:1,char:"Priya",avatar:"👧",theme:"theme-school",deco:"📚",bg:"#2563eb",
    title:"Mission 1: The Forgotten Lunch",label:"🏫 School Cafeteria",
    scene:"It is lunchtime. Priya opens her bag and realises she forgot her lunch box at home. She sits quietly staring at her empty desk while everyone else eats.",
    eq:"How is Priya feeling right now?",
    emotions:[
      {i:"😄",t:"Happy & Excited",c:false,fb:"Priya would not be happy — she has no food and is embarrassed. Look for clues: quiet, staring at empty desk."},
      {i:"😟",t:"Worried & Hungry",c:true,fb:"Spot on! Priya is worried about being hungry and probably embarrassed that she forgot her lunch. Reading body language matters!"},
      {i:"😠",t:"Angry at Teacher",c:false,fb:"There is no reason for anger here. Her quiet behaviour shows worry, not anger."},
      {i:"😴",t:"Sleepy & Bored",c:false,fb:"Priya has a real problem — missing lunch — so she would feel worried, not just sleepy."}
    ],
    aq:"You notice Priya has no lunch. What do you do?",
    actions:[
      {i:"🙈",t:"Ignore her and enjoy your meal",e:0,fb:"Ignoring someone in need means they face it alone. Priya might feel invisible and even sadder.",type:"neutral"},
      {i:"🍱",t:"Share your lunch and sit with her",e:3,fb:"AMAZING! Sharing your food shows Priya her feelings matter and that she has a caring friend. That is true empathy in action!",type:"best"},
      {i:"📢",t:"Tell everyone Priya forgot her lunch",e:-1,fb:"Announcing it publicly humiliates Priya. Always think — would you want someone to do this to YOU?",type:"bad"},
      {i:"🤫",t:"Quietly ask if she is okay and offer to share",e:2,fb:"Great! Asking quietly and offering help respects Priya's feelings. This is kind and thoughtful!",type:"good"}
    ],
    lesson:"When someone is in trouble, noticing their feelings and offering help — even something small — makes a huge difference."
  },
  {
    id:2,char:"Arjun",avatar:"👦",theme:"theme-sport",deco:"⚽",bg:"#16a34a",
    title:"Mission 2: The Big Fall",label:"🏃 PE Class",
    scene:"During PE, Arjun trips and falls while running. Several students start laughing. Arjun quickly gets up but his face turns red and he looks down at the ground.",
    eq:"What is Arjun feeling right now?",
    emotions:[
      {i:"😎",t:"Cool & Confident",c:false,fb:"Arjun's red face and looking down at the ground are clear signs that he is NOT confident right now."},
      {i:"😔",t:"Embarrassed & Hurt",c:true,fb:"Exactly! Arjun is deeply embarrassed. Being laughed at hurts on the inside, even if the fall did not hurt on the outside."},
      {i:"😂",t:"Laughing & Happy",c:false,fb:"Arjun is not laughing — the red face and downward gaze show embarrassment, not happiness."},
      {i:"😡",t:"Furious & Ready to Fight",c:false,fb:"Looking down quietly shows embarrassment more than anger. His body language tells the real story."}
    ],
    aq:"You see what happened to Arjun. What would you do?",
    actions:[
      {i:"😂",t:"Join in the laughter — it was funny!",e:-1,fb:"Laughing at someone who fell makes their pain twice as bad. Put yourself in Arjun's shoes — how would that feel?",type:"bad"},
      {i:"🤝",t:"Help him up and say 'You okay? Happens to everyone!'",e:3,fb:"PERFECT! You acknowledged his feeling AND normalised the experience. That is exactly what deep empathy looks like!",type:"best"},
      {i:"👀",t:"Pretend you did not see anything",e:0,fb:"Staying silent leaves Arjun alone with his embarrassment. One small kind word from you could change everything.",type:"neutral"},
      {i:"🛑",t:"Tell others to stop laughing, then check on him",e:2,fb:"Standing up against mockery AND checking on Arjun is both brave and deeply empathetic!",type:"good"}
    ],
    lesson:"When someone is embarrassed, your reaction can either deepen their pain or heal it. Choose kindness — always."
  },
  {
    id:3,char:"Meera",avatar:"👧",theme:"theme-art",deco:"🎨",bg:"#7c3aed",
    title:"Mission 3: The Art Prize",label:"🎨 Art Class",
    scene:"The art teacher announces that Meera's painting was selected as the best in class and will be displayed in the school hall. Meera's face lights up with a huge smile.",
    eq:"How is Meera feeling?",
    emotions:[
      {i:"😢",t:"Sad & Upset",c:false,fb:"Meera's big glowing smile is a clear sign she is NOT sad. Facial expressions are powerful clues!"},
      {i:"😊",t:"Proud & Overjoyed",c:true,fb:"YES! Meera worked hard and now her effort is recognised. She feels proud, validated, and truly happy. You read her emotion perfectly!"},
      {i:"😐",t:"Neutral & Unbothered",c:false,fb:"The lit-up face tells us she cares a lot. She is definitely not neutral — her joy is very visible!"},
      {i:"😰",t:"Nervous & Scared",c:false,fb:"While some attention might feel a bit scary, her beaming smile clearly says this is a joyful moment for Meera."}
    ],
    aq:"Meera's painting was selected. What do you do?",
    actions:[
      {i:"😤",t:"Say 'Mine was better, teacher was wrong'",e:-1,fb:"This spoils Meera's special moment and is hurtful. Saying this shows jealousy rather than kindness.",type:"bad"},
      {i:"🥳",t:"Tell Meera 'Congratulations! Your painting is beautiful!'",e:3,fb:"WONDERFUL! Celebrating someone else's success — even when you did not win — shows incredible emotional maturity and true empathy!",type:"best"},
      {i:"🤐",t:"Say nothing and walk away",e:0,fb:"While you are not being mean, staying silent misses a wonderful chance to make Meera feel truly seen and valued.",type:"neutral"},
      {i:"🙄",t:"Roll your eyes and ignore the announcement",e:-1,fb:"Visible jealousy hurts Meera's feelings and creates a cold atmosphere around her joy.",type:"bad"}
    ],
    lesson:"Celebrating others' happiness — even when you did not win — is one of the most powerful signs of empathy."
  },
  {
    id:4,char:"Ravi",avatar:"👦",theme:"theme-home",deco:"🏥",bg:"#dc2626",
    title:"Mission 4: The Heavy Worry",label:"📖 Classroom",
    scene:"Ravi is unusually quiet all day and has not joined any conversations. He sits alone at recess. You heard from a classmate that Ravi's mother is seriously ill in hospital.",
    eq:"What is Ravi going through emotionally?",
    emotions:[
      {i:"😴",t:"Tired from too much homework",c:false,fb:"Ravi's complete withdrawal and silence suggest something far deeper than homework fatigue."},
      {i:"😞",t:"Deeply worried & sad about his mother",c:true,fb:"Exactly right. When someone we love is seriously ill, it is one of the heaviest feelings a person can carry. Ravi is struggling inside."},
      {i:"😤",t:"Angry at his classmates",c:false,fb:"Nothing in his behaviour points to anger at classmates. His quiet isolation points to deep sadness and worry."},
      {i:"🤩",t:"Excited about something secret",c:false,fb:"Ravi's quiet and withdrawn behaviour is not a sign of excitement. Body language tells us the opposite."}
    ],
    aq:"How would you approach Ravi?",
    actions:[
      {i:"📢",t:"Ask loudly 'Why are you so sad today?'",e:-1,fb:"Asking publicly can embarrass Ravi and make him feel like he is on display during a very painful time.",type:"bad"},
      {i:"🧡",t:"Sit quietly next to him. 'I am here if you want to talk or just sit together.'",e:3,fb:"BEAUTIFUL! Sometimes people do not need words — just presence and quiet support. This is one of the deepest forms of empathy.",type:"best"},
      {i:"😄",t:"Tell him funny jokes to cheer him up",e:1,fb:"Good intention! But Ravi may need space to feel his sadness. Ask him first before trying to shift his mood.",type:"neutral"},
      {i:"🚶",t:"Leave him completely alone — maybe he wants privacy",e:1,fb:"Respecting space is thoughtful. But even sitting quietly nearby shows you care without forcing anything.",type:"neutral"}
    ],
    lesson:"Sometimes the most empathetic thing is just BEING THERE. Quiet presence can be more powerful than any words."
  },
  {
    id:5,char:"Leela",avatar:"👧",theme:"theme-social",deco:"🏫",bg:"#0ea5e9",
    title:"Mission 5: The New Student",label:"🆕 First Day of School",
    scene:"Leela just joined your class today. She sits in a corner looking at her hands, not knowing anyone. Everyone else is chatting with their friends as usual.",
    eq:"How is Leela most likely feeling?",
    emotions:[
      {i:"😊",t:"Happy to be somewhere new",c:false,fb:"While she might be curious, sitting alone and staring at her hands suggests anxiety, not happiness."},
      {i:"😨",t:"Nervous, lonely and unsure",c:true,fb:"YES! Being in a completely new place with strangers is overwhelming. Leela is experiencing anxiety and loneliness. You spotted it!"},
      {i:"😠",t:"Angry at her old school",c:false,fb:"Nothing in her behaviour suggests anger. Her isolation shows nervousness, not anger."},
      {i:"😎",t:"Cool and completely confident",c:false,fb:"Looking at her hands in a corner is not a sign of confidence. It is a classic sign of nervousness and feeling out of place."}
    ],
    aq:"You notice Leela sitting alone. What do you do?",
    actions:[
      {i:"⏳",t:"Wait for someone else to talk to her first",e:0,fb:"Waiting means Leela could spend the whole day alone. The best time to help someone is NOW — be the first to step forward!",type:"neutral"},
      {i:"👋",t:"Walk up, smile, say 'Hi! I am [your name]. Want to sit with us?'",e:3,fb:"PERFECT! This one small act of inclusion can transform Leela's entire first day. You might even make a lifelong friend!",type:"best"},
      {i:"🤫",t:"Whisper to friends 'The new girl seems weird'",e:-1,fb:"Judging someone before knowing them and gossiping pushes Leela even further into isolation. That is unkind.",type:"bad"},
      {i:"😊",t:"Smile at her from a distance but do not go over",e:1,fb:"A smile is kind! But taking one step further and actually saying hello would be so much more powerful for Leela.",type:"good"}
    ],
    lesson:"Including someone who is alone costs you nothing, but it can mean EVERYTHING to them. Be the first to step forward."
  },
  {
    id:6,char:"Sai",avatar:"👦",theme:"theme-outdoor",deco:"🏃",bg:"#059669",
    title:"Mission 6: Last Place",label:"🏅 School Sports Day",
    scene:"Sai practised running every single day for two whole months. On race day he gives his absolute best — but comes in last place. He walks off the track with his head down.",
    eq:"What is Sai most likely feeling?",
    emotions:[
      {i:"😄",t:"Happy he participated",c:false,fb:"After 2 months of daily practice and coming last, Sai would feel deep disappointment right now — not just happy."},
      {i:"😞",t:"Deeply disappointed despite his effort",c:true,fb:"Yes. When we try our absolute hardest and still do not succeed, the disappointment can be very powerful. His feelings are completely valid."},
      {i:"😡",t:"Angry at the runners who beat him",c:false,fb:"His head-down body language shows sadness and disappointment, not anger directed at others."},
      {i:"😴",t:"Just physically tired",c:false,fb:"He is not just physically tired — he is emotionally hurt after months of effort leading to this result."}
    ],
    aq:"What would you say to Sai after the race?",
    actions:[
      {i:"😬",t:"'You lost! Try a different sport next time!'",e:-1,fb:"Rubbing in a loss when someone is already hurting is cruel and can cause lasting damage to their confidence.",type:"bad"},
      {i:"🌟",t:"'You trained SO hard every day. I am proud of your courage — that is the real win.'",e:3,fb:"INCREDIBLE! You focused on his EFFORT and COURAGE, not just the result. That is what true empathy sounds like. This can rebuild his confidence completely!",type:"best"},
      {i:"🤷",t:"'Better luck next time!' and walk away",e:1,fb:"Kind but too brief. Sai needs more than a quick comment — take a moment to truly acknowledge his months of hard work.",type:"neutral"},
      {i:"🤝",t:"Sit with him and ask how he is feeling",e:2,fb:"Sitting with him and genuinely asking shows you truly care about his feelings, not just the race outcome.",type:"good"}
    ],
    lesson:"Recognising someone's EFFORT and COURAGE matters more than the outcome. Your words of support can rebuild confidence."
  },
  {
    id:7,char:"Ananya",avatar:"👧",theme:"theme-perform",deco:"🎤",bg:"#7c3aed",
    title:"Mission 7: Stage Fear",label:"🎤 Before the Assembly",
    scene:"Ananya has to give a speech in front of the whole school tomorrow. Today you see her hands shaking while she practises and she keeps saying 'I cannot do this, I am going to mess up.'",
    eq:"What is Ananya feeling?",
    emotions:[
      {i:"😤",t:"Overconfident and proud",c:false,fb:"Ananya's shaking hands and negative self-talk are the opposite of confidence. Always look at both words AND body language!"},
      {i:"😰",t:"Anxious and scared of failing",c:true,fb:"Exactly! Ananya is experiencing stage fright — fear of making mistakes in public. This is very real and very common. You understood her!"},
      {i:"😐",t:"Completely unbothered",c:false,fb:"Shaking hands and saying 'I cannot do this' are unmistakable signs of anxiety — definitely not being unbothered."},
      {i:"😂",t:"Joking around with friends",c:false,fb:"Ananya is genuinely scared, not joking. Her distress is real and deserves a genuine caring response."}
    ],
    aq:"How would you help Ananya feel better?",
    actions:[
      {i:"🙄",t:"'Stop being nervous — it is not a big deal!'",e:-1,fb:"Saying 'not a big deal' dismisses her fear entirely. This makes Ananya feel misunderstood and even more alone.",type:"bad"},
      {i:"💛",t:"'I understand you are scared. Everyone gets nervous. You have practised so much — I believe in you!'",e:3,fb:"TRIPLE EMPATHY! You validated her fear, normalised it, reminded her of her preparation, AND gave her your belief. That is the perfect empathy formula!",type:"best"},
      {i:"👍",t:"'You will be fine!' and change the subject",e:1,fb:"Encouraging but too brief. Ananya needs to feel truly heard first, before being reassured.",type:"neutral"},
      {i:"📝",t:"Help her practise her speech one more time",e:2,fb:"Practical support is wonderful! Pair it with first acknowledging her fear and it becomes even more powerful.",type:"good"}
    ],
    lesson:"When someone is scared, first ACKNOWLEDGE their fear (never dismiss it), THEN encourage them. That is the empathy formula."
  },
  {
    id:8,char:"Deepak",avatar:"👦",theme:"theme-class",deco:"📖",bg:"#4f46e5",
    title:"Mission 8: The Wrong Answer",label:"💬 Class Discussion",
    scene:"During class, Deepak gives an answer that turns out to be wrong. Some students snicker and whisper. Deepak's voice trails off, he looks down and stops participating for the rest of class.",
    eq:"What is Deepak feeling?",
    emotions:[
      {i:"😎",t:"Confident and unbothered",c:false,fb:"Deepak's trailing voice and complete withdrawal from class show he is deeply affected — the opposite of confident."},
      {i:"😔",t:"Humiliated and afraid to try again",c:true,fb:"YES! Being laughed at for trying causes humiliation and fear of participating again. This can damage someone's confidence for a long time. You read it perfectly."},
      {i:"😠",t:"Angry at the teacher for asking",c:false,fb:"His withdrawal (not outward anger) suggests humiliation and embarrassment more than anger at the teacher."},
      {i:"😄",t:"Happy he at least tried",c:false,fb:"If Deepak felt happy about trying, he would not have stopped participating completely for the rest of the lesson."}
    ],
    aq:"What would you do to help Deepak?",
    actions:[
      {i:"😂",t:"Laugh along — the answer was pretty funny",e:-1,fb:"Adding to the laughter crushes Deepak. Think about the last time YOU felt embarrassed in public. Always choose kindness.",type:"bad"},
      {i:"🌈",t:"After class, tell him: 'Wrong answers happen to everyone. Trying is what matters. You were brave to speak up.'",e:3,fb:"POWERFUL! You addressed his pain privately and reframed his courage. This one conversation could fully restore Deepak's confidence.",type:"best"},
      {i:"👁️",t:"Ignore it — he will get over it eventually",e:0,fb:"The impact of public humiliation can last for weeks or longer. One small act of kindness from you could completely change that.",type:"neutral"},
      {i:"🛑",t:"Tell the students who laughed to stop",e:2,fb:"Standing up against mockery is brave and empathetic! Also check on Deepak privately afterward.",type:"good"}
    ],
    lesson:"Mockery kills the courage to try. Defending others and offering private kindness rebuilds that courage."
  }
];

// ── AUDIO (Web Audio API) ──────────────────────────
let audioCtx=null;
function initAudio(){if(!audioCtx){try{audioCtx=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}}}
function tone(freq,dur,type='sine',vol=0.25){
  if(!audioCtx)return;
  const o=audioCtx.createOscillator(),g=audioCtx.createGain();
  o.connect(g);g.connect(audioCtx.destination);
  o.type=type;o.frequency.value=freq;
  g.gain.setValueAtTime(vol,audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+dur);
  o.start();o.stop(audioCtx.currentTime+dur);
}
function playCorrect(){initAudio();[523,659,784,1047].forEach((f,i)=>setTimeout(()=>tone(f,.18),i*80));}
function playWrong(){initAudio();[300,250,200].forEach((f,i)=>setTimeout(()=>tone(f,.15,'sawtooth',.15),i*90));}
function playGreat(){initAudio();[523,659,784,659,784,1047,784,1047,1319].forEach((f,i)=>setTimeout(()=>tone(f,.12),i*70));}
function playWin(){initAudio();[523,587,659,698,784,880,988,1047].forEach((f,i)=>setTimeout(()=>tone(f,.2),i*90));}
function playCoin(){initAudio();[880,1047].forEach((f,i)=>setTimeout(()=>tone(f,.1,'triangle',.3),i*80));}

// ── STATE ──────────────────────────────────────────
let cur=0,score=0,lives=3,streak=0,bestStreak=0,phase=0; // phase: 0=emotion,1=action
let emotionDone=false,actionDone=false,fbCallback=null;

// ── INIT ──────────────────────────────────────────
function makeBg(){
  const bg=document.getElementById('bg');
  const cols=['#7c3aed','#ec4899','#06b6d4','#f59e0b','#10b981','#3b82f6'];
  for(let i=0;i<18;i++){
    const b=document.createElement('div');
    const size=40+Math.random()*120;
    b.className='bubble';
    b.style.cssText=`width:${size}px;height:${size}px;left:${Math.random()*100}%;bottom:-150px;background:${cols[i%cols.length]};animation-duration:${8+Math.random()*15}s;animation-delay:${Math.random()*10}s;`;
    bg.appendChild(b);
  }
}
makeBg();

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ── START ──────────────────────────────────────────
function startGame(){
  initAudio();
  cur=0;score=0;lives=3;streak=0;bestStreak=0;phase=0;
  emotionDone=false;actionDone=false;
  showScreen('game');
  updateHUD();
  loadScenario();
}

// ── LOAD SCENARIO ──────────────────────────────────
function loadScenario(){
  const s=SCENARIOS[cur];
  phase=0;emotionDone=false;actionDone=false;
  // Progress
  document.getElementById('prog-fill').style.width=((cur/8)*100)+'%';
  document.getElementById('prog-text').textContent=`Mission ${cur+1} / 8`;
  // Scene
  document.getElementById('scene-bg').className='scene-bg '+s.theme;
  document.getElementById('scene-deco').textContent=s.deco;
  document.getElementById('char-blob').textContent=s.avatar;
  document.getElementById('char-blob').style.background=s.bg+'44';
  document.getElementById('char-name').textContent=s.char;
  document.getElementById('scene-label').textContent=s.label;
  document.getElementById('scene-label').style.color=s.bg;
  document.getElementById('scene-desc').textContent=s.scene;
  // Pills
  document.getElementById('pill0').className='phase-pill active';
  document.getElementById('pill0').textContent='🎯 Feeling';
  document.getElementById('pill1').className='phase-pill pending';
  document.getElementById('pill1').textContent='💡 Action';
  // Question
  document.getElementById('q-text').textContent=s.eq;
  // Choices
  renderChoices(s.emotions,'emotion');
}

function renderChoices(options,mode){
  const grid=document.getElementById('choices');
  grid.innerHTML='';
  options.forEach((o,i)=>{
    const btn=document.createElement('button');
    btn.className='choice';
    btn.innerHTML=`<span class="ci">${o.i}</span><span class="ct">${o.t}</span>`;
    btn.onclick=()=>mode==='emotion'?answerEmotion(i):answerAction(i);
    grid.appendChild(btn);
  });
}

// ── ANSWERS ───────────────────────────────────────
function answerEmotion(idx){
  if(emotionDone)return;
  emotionDone=true;
  const s=SCENARIOS[cur];
  const e=s.emotions[idx];
  const btns=document.querySelectorAll('.choice');
  btns.forEach((b,i)=>{b.disabled=true;if(s.emotions[i].c)b.classList.add('correct');else if(i===idx)b.classList.add('wrong');});
  if(e.c){
    score+=2;streak++;if(streak>bestStreak)bestStreak=streak;
    updateHUD();playCorrect();spawnPopup('+2 ⭐');
    showFeedback('🎯','+2 Points! Sharp observation!',e.fb,null,()=>showActionPhase());
  } else {
    lives=Math.max(0,lives-1);streak=0;
    updateHUD();playWrong();
    if(lives===0){showFeedback('💔','Oops! Out of lives!',e.fb,null,()=>showActionPhase());}
    else{showFeedback('🤔','Not quite — but keep going!',e.fb,null,()=>showActionPhase());}
  }
}

function showActionPhase(){
  const s=SCENARIOS[cur];
  phase=1;
  document.getElementById('pill0').className='phase-pill done';
  document.getElementById('pill1').className='phase-pill active';
  document.getElementById('pill1').textContent='💡 Action';
  document.getElementById('q-text').textContent=s.aq;
  renderChoices(s.actions,'action');
}

function answerAction(idx){
  if(actionDone)return;
  actionDone=true;
  const s=SCENARIOS[cur];
  const a=s.actions[idx];
  const btns=document.querySelectorAll('.choice');
  btns.forEach((b,i)=>{
    b.disabled=true;
    const t=s.actions[i].type;
    if(t==='best')b.classList.add('best-show');
    else if(t==='good')b.classList.add('good-show');
    else if(t==='neutral')b.classList.add('neutral-show');
    else b.classList.add('bad-show');
  });
  const pts=Math.max(0,a.e);
  score+=pts;
  if(a.e>=2){streak++;if(streak>bestStreak)bestStreak=streak;}else{streak=0;}
  updateHUD();
  if(a.e===3){playGreat();spawnPopup('+3 ⭐ PERFECT!');}
  else if(a.e===2){playCoin();spawnPopup('+2 ⭐ Great!');}
  else if(a.e===1){playCoin();spawnPopup('+1 ⭐');}
  else{playWrong();}
  const icon=a.e===3?'🌟':a.e>=1?'👍':'💔';
  const ptTxt=a.e===3?'+3 ⭐ PERFECT EMPATHY!':a.e>=1?`+${pts} ⭐ Good thinking!`:'Hmm — could we do better?';
  showFeedback(icon,ptTxt,a.fb,s.lesson,()=>nextScenario());
}

// ── FEEDBACK MODAL ─────────────────────────────────
function showFeedback(icon,pts,exp,lesson,cb){
  fbCallback=cb;
  document.getElementById('fb-icon').textContent=icon;
  document.getElementById('fb-pts').textContent=pts;
  document.getElementById('fb-pts').className='fb-pts '+(pts.includes('+')&&!pts.includes('Hmm')?'pos':'neg');
  document.getElementById('fb-exp').textContent=exp;
  const lEl=document.getElementById('fb-lesson');
  if(lesson){document.getElementById('fb-lesson-text').textContent=lesson;lEl.className='fb-lesson show';}
  else{lEl.className='fb-lesson';}
  const contBtn=document.getElementById('fb-continue');
  contBtn.textContent=lesson?(cur<SCENARIOS.length-1?'Next Mission ➡️':'See My Results 🏆'):'Got it! 💪';
  document.getElementById('fb-modal').classList.add('open');
}

function continueGame(){
  document.getElementById('fb-modal').classList.remove('open');
  if(fbCallback)fbCallback();
}

// ── NEXT SCENARIO ──────────────────────────────────
function nextScenario(){
  cur++;
  if(cur>=SCENARIOS.length){showResults();}
  else{loadScenario();}
}

// ── HUD ─────────────────────────────────────────────
function updateHUD(){
  // Lives
  const lv=document.getElementById('lives-display');
  lv.innerHTML='';
  for(let i=0;i<3;i++){
    const h=document.createElement('div');
    h.className='life-heart'+(i>=lives?' lost':'');
    h.textContent='❤️';lv.appendChild(h);
  }
  document.getElementById('score-display').textContent=score;
  const sb=document.getElementById('streak-badge');
  document.getElementById('streak-num').textContent=streak;
  if(streak>=3)sb.classList.add('hot');else sb.classList.remove('hot');
}

// ── SCORE POPUP ────────────────────────────────────
function spawnPopup(txt){
  const el=document.createElement('div');
  el.className='score-pop';el.textContent=txt;
  const x=Math.random()*60+20;
  el.style.cssText=`left:${x}%;top:40%;`;
  document.body.appendChild(el);
  setTimeout(()=>el.remove(),1300);
}

// ── RESULTS ───────────────────────────────────────
function showResults(){
  showScreen('results');
  playWin();confetti();
  const pct=Math.round((score/(8*(2+3)))*100);
  document.getElementById('res-pts').textContent=score;
  document.getElementById('res-empathy').textContent=pct+'%';
  document.getElementById('res-streak').textContent=bestStreak;
  let badge,bname,bdesc,trophy,title;
  if(pct>=85){badge='👑';bname='Heart Master';bdesc='You deeply understand others and always choose the most empathetic path. You are a true Heart Master!';trophy='🏆';title='Outstanding! You are a Heart Master!';}
  else if(pct>=65){badge='🦸';bname='Empathy Hero';bdesc='You have strong empathy skills and care deeply about others feelings. Keep shining!';trophy='🌟';title='Amazing! You are an Empathy Hero!';}
  else if(pct>=40){badge='⭐';bname='Empathy Star';bdesc='You are growing your empathy skills beautifully. A little more practice and you will shine even brighter!';trophy='😊';title='Great Job! You are an Empathy Star!';}
  else{badge='🌱';bname='Empathy Seedling';bdesc='You are just starting your empathy journey. Every expert was once a beginner — keep going, you can do it!';trophy='💪';title='Good Start! Keep Growing!';}
  document.getElementById('res-trophy').textContent=trophy;
  document.getElementById('res-title').textContent=title;
  document.getElementById('res-badge').textContent=badge;
  document.getElementById('res-badge-name').textContent=bname;
  document.getElementById('res-badge-desc').textContent=bdesc;
  const ul=document.getElementById('res-lessons');
  ul.innerHTML=SCENARIOS.map(s=>`<li>${s.lesson}</li>`).join('');
}

function confetti(){
  const cols=['#7c3aed','#ec4899','#f59e0b','#10b981','#06b6d4','#f97316'];
  for(let i=0;i<90;i++){
    setTimeout(()=>{
      const c=document.createElement('div');
      const sz=7+Math.random()*10;
      c.className='confetti-piece';
      c.style.cssText=`left:${Math.random()*100}%;background:${cols[~~(Math.random()*cols.length)]};width:${sz}px;height:${sz}px;border-radius:${Math.random()>.5?'50%':'3px'};animation-duration:${2.5+Math.random()*2.5}s;`;
      document.body.appendChild(c);
      setTimeout(()=>c.remove(),5000);
    },i*35);
  }
}

function restartGame(){showScreen('welcome');}
</script>
<script src="session-tracker.js"></script>
</body>
</html>