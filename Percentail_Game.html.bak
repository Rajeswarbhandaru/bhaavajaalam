import os
os.makedirs(os.path.expanduser("~/output"), exist_ok=True)

html = r"""<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PercentQuest</title>
<link href="https://api.fontshare.com/v2/css?f[]=chillax@400,500,600,700&display=swap" rel="stylesheet">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root,[data-theme="light"]{
  --font-display:'Chillax','Plus Jakarta Sans',sans-serif;
  --font-body:'Plus Jakarta Sans',sans-serif;
  --color-bg:#fdf8f0;--color-surface:#ffffff;--color-surface-2:#faf6ef;
  --color-surface-offset:#f3ede2;--color-divider:#e8e0d4;--color-border:#ddd5c8;
  --color-text:#2d2420;--color-text-muted:#7a6e65;--color-text-faint:#b8ada4;
  --color-primary:#00897b;--color-primary-hover:#00695c;--color-primary-light:#b2dfdb;--color-primary-bg:#e0f2f1;
  --color-accent:#f4511e;
  --color-success:#43a047;--color-success-bg:#e8f5e9;
  --color-error:#e53935;--color-error-bg:#ffebee;
  --color-warning:#fb8c00;--color-warning-bg:#fff3e0;
  --radius-sm:.375rem;--radius-md:.75rem;--radius-lg:1.25rem;--radius-xl:1.75rem;--radius-full:9999px;
  --shadow-sm:0 1px 3px rgba(45,36,32,.08);--shadow-md:0 4px 16px rgba(45,36,32,.1);--shadow-lg:0 8px 32px rgba(45,36,32,.12);
  --tr:200ms cubic-bezier(.16,1,.3,1);
  --text-xs:clamp(.75rem,.7rem + .25vw,.875rem);--text-sm:clamp(.875rem,.8rem + .35vw,1rem);
  --text-base:clamp(1rem,.95rem + .25vw,1.125rem);--text-lg:clamp(1.125rem,1rem + .75vw,1.5rem);
  --text-xl:clamp(1.5rem,1.2rem + 1.25vw,2.25rem);--text-2xl:clamp(2rem,1.2rem + 2.5vw,3.5rem);
  --sp1:.25rem;--sp2:.5rem;--sp3:.75rem;--sp4:1rem;--sp5:1.25rem;--sp6:1.5rem;--sp8:2rem;--sp10:2.5rem;--sp12:3rem;
}
[data-theme="dark"]{
  --color-bg:#1a1512;--color-surface:#231e1a;--color-surface-2:#2a2420;
  --color-surface-offset:#332d28;--color-divider:#3d3530;--color-border:#4a4238;
  --color-text:#f0ebe5;--color-text-muted:#9e9189;--color-text-faint:#6e6560;
  --color-primary:#4db6ac;--color-primary-hover:#26a69a;--color-primary-light:#1a3836;--color-primary-bg:#1a3836;
  --color-accent:#ff7043;
  --color-success:#66bb6a;--color-success-bg:#1b3620;
  --color-error:#ef5350;--color-error-bg:#3c1515;
  --color-warning:#ffa726;--color-warning-bg:#3d2800;
  --shadow-sm:0 1px 3px rgba(0,0,0,.25);--shadow-md:0 4px 16px rgba(0,0,0,.35);--shadow-lg:0 8px 32px rgba(0,0,0,.45);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{-webkit-font-smoothing:antialiased}
body{min-height:100dvh;font-family:var(--font-body);font-size:var(--text-base);color:var(--color-text);background:var(--color-bg);overflow-x:hidden}
button{cursor:pointer;background:none;border:none;font:inherit;color:inherit}
.screen{display:none;min-height:100dvh}
.screen.active{display:flex}
.theme-toggle{position:fixed;top:var(--sp4);right:var(--sp4);z-index:200;width:40px;height:40px;border-radius:var(--radius-full);background:var(--color-surface);border:1px solid var(--color-border);box-shadow:var(--shadow-sm);display:flex;align-items:center;justify-content:center;color:var(--color-text-muted);transition:all var(--tr)}
.theme-toggle:hover{color:var(--color-primary);box-shadow:var(--shadow-md)}
#screen-title{flex-direction:column;align-items:center;justify-content:center;padding:var(--sp12) var(--sp4) var(--sp8);position:relative;overflow:hidden;background:linear-gradient(145deg,var(--color-bg) 0%,var(--color-primary-bg) 100%)}
.bg-deco{position:absolute;font-family:var(--font-display);font-weight:700;color:var(--color-primary);opacity:.06;pointer-events:none;user-select:none;line-height:1}
.title-logo{margin-bottom:var(--sp5)}
.title-logo svg{width:76px;height:76px}
.title-heading{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:700;text-align:center;line-height:1.1;margin-bottom:var(--sp3)}
.title-heading em{font-style:normal;color:var(--color-primary)}
.title-sub{font-size:var(--text-base);color:var(--color-text-muted);text-align:center;margin-bottom:var(--sp8)}
.section-label{font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--color-text-muted);margin-bottom:var(--sp3);text-align:center}
.mode-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(180px,100%),1fr));gap:var(--sp3);width:100%;max-width:620px;margin-bottom:var(--sp6)}
.mode-card{background:var(--color-surface);border:2px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--sp5) var(--sp4);text-align:center;cursor:pointer;transition:all var(--tr);box-shadow:var(--shadow-sm)}
.mode-card:hover{border-color:var(--color-primary);box-shadow:var(--shadow-lg);transform:translateY(-2px)}
.mode-card.active{border-color:var(--color-primary);background:var(--color-primary-bg)}
.mode-icon{font-size:2rem;margin-bottom:var(--sp2)}
.mode-title{font-family:var(--font-display);font-size:var(--text-lg);font-weight:600;margin-bottom:var(--sp1)}
.mode-desc{font-size:var(--text-xs);color:var(--color-text-muted);line-height:1.5}
.diff-row{display:flex;gap:var(--sp3);margin-bottom:var(--sp8)}
.diff-btn{padding:var(--sp2) var(--sp5);border-radius:var(--radius-full);border:2px solid var(--color-border);font-size:var(--text-sm);font-weight:600;background:var(--color-surface);transition:all var(--tr)}
.diff-btn[data-diff="easy"]{color:#43a047}.diff-btn[data-diff="medium"]{color:#fb8c00}.diff-btn[data-diff="hard"]{color:#e53935}
.diff-btn.active[data-diff="easy"]{border-color:#43a047;background:var(--color-success-bg)}
.diff-btn.active[data-diff="medium"]{border-color:#fb8c00;background:var(--color-warning-bg)}
.diff-btn.active[data-diff="hard"]{border-color:#e53935;background:var(--color-error-bg)}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:var(--sp2);padding:var(--sp4) var(--sp10);background:var(--color-primary);color:#fff;border-radius:var(--radius-full);font-family:var(--font-display);font-size:var(--text-lg);font-weight:600;transition:all var(--tr);box-shadow:0 4px 16px rgba(0,137,123,.35)}
.btn-primary:hover{background:var(--color-primary-hover);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,137,123,.45)}
.btn-primary:active{transform:translateY(0)}
#screen-game{flex-direction:column;background:var(--color-bg)}
.game-hud{display:flex;align-items:center;justify-content:space-between;padding:var(--sp3) var(--sp6);background:var(--color-surface);border-bottom:1px solid var(--color-divider);box-shadow:var(--shadow-sm);position:sticky;top:0;z-index:10;gap:var(--sp4)}
.hud-item{display:flex;flex-direction:column;align-items:center;gap:2px}
.hud-label{font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-text-muted)}
.hud-val{font-family:var(--font-display);font-size:var(--text-lg);font-weight:700;color:var(--color-text);line-height:1;font-variant-numeric:tabular-nums lining-nums}
.hud-lives{display:flex;gap:var(--sp1)}
.life{font-size:1.2rem;transition:all var(--tr)}.life.lost{opacity:.2;transform:scale(.85)}
.timer-ring{position:relative;width:48px;height:48px}
.timer-ring svg{position:absolute;inset:0;transform:rotate(-90deg)}
.timer-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:var(--text-sm);font-weight:700;font-variant-numeric:tabular-nums}
.q-progress{height:4px;background:var(--color-surface-offset)}
.q-progress-fill{height:100%;background:linear-gradient(to right,var(--color-primary),var(--color-accent));transition:width .6s ease;border-radius:2px}
.game-body{flex:1;display:flex;flex-direction:column;align-items:center;padding:var(--sp6) var(--sp4) var(--sp8);max-width:700px;margin:0 auto;width:100%}
.diff-badge{display:inline-flex;align-items:center;gap:var(--sp2);padding:var(--sp1) var(--sp4);border-radius:var(--radius-full);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:var(--sp4)}
.diff-badge.easy{background:var(--color-success-bg);color:var(--color-success)}
.diff-badge.medium{background:var(--color-warning-bg);color:var(--color-warning)}
.diff-badge.hard{background:var(--color-error-bg);color:var(--color-error)}
.combo-strip{display:none;align-items:center;gap:var(--sp2);padding:var(--sp2) var(--sp5);background:linear-gradient(135deg,var(--color-warning-bg),var(--color-success-bg));border-radius:var(--radius-full);margin-bottom:var(--sp4);animation:comboPop .4s ease}
.combo-strip.show{display:flex}
.combo-txt{font-family:var(--font-display);font-size:var(--text-sm);font-weight:700;color:var(--color-warning)}
@keyframes comboPop{0%{transform:scale(.8);opacity:0}60%{transform:scale(1.1)}100%{transform:scale(1);opacity:1}}
.q-card{background:var(--color-surface);border-radius:var(--radius-xl);padding:var(--sp8) var(--sp6);width:100%;box-shadow:var(--shadow-md);border:1px solid var(--color-divider);margin-bottom:var(--sp5);text-align:center;position:relative;overflow:hidden}
.q-type{font-size:var(--text-xs);color:var(--color-text-muted);font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:var(--sp3)}
.q-text{font-family:var(--font-display);font-size:var(--text-xl);font-weight:600;line-height:1.3;margin-bottom:var(--sp5)}
.hl{color:var(--color-primary)}.hla{color:var(--color-accent)}
.vis-bar-wrap{margin-bottom:var(--sp5)}
.vis-bar-labels{display:flex;justify-content:space-between;font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--sp2)}
.vis-bar-track{height:32px;background:var(--color-surface-offset);border-radius:var(--radius-full);overflow:hidden;border:1px solid var(--color-divider)}
.vis-bar-fill{height:100%;background:linear-gradient(to right,var(--color-primary),#26c6da);border-radius:var(--radius-full);transition:width .9s cubic-bezier(.16,1,.3,1);display:flex;align-items:center;justify-content:flex-end;padding-right:var(--sp3)}
.vis-bar-val{font-size:var(--text-xs);font-weight:700;color:#fff}
.vis-pie-wrap{display:flex;flex-direction:column;align-items:center;margin-bottom:var(--sp5)}
.vis-pie-wrap svg{filter:drop-shadow(0 4px 8px rgba(0,137,123,.2))}
.q-hint{font-size:var(--text-sm);color:var(--color-text-muted);background:var(--color-surface-2);border-radius:var(--radius-md);padding:var(--sp3) var(--sp4);margin-top:var(--sp3);border-left:3px solid var(--color-primary-light);text-align:left;display:none}
.answers{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp3);width:100%;margin-bottom:var(--sp5)}
.ans-btn{background:var(--color-surface);border:2px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--sp4) var(--sp5);font-family:var(--font-display);font-size:var(--text-lg);font-weight:600;text-align:center;cursor:pointer;transition:all var(--tr);box-shadow:var(--shadow-sm);min-height:64px;display:flex;align-items:center;justify-content:center}
.ans-btn:hover:not(:disabled){border-color:var(--color-primary);background:var(--color-primary-bg);transform:translateY(-2px);box-shadow:var(--shadow-md)}
.ans-btn:active:not(:disabled){transform:scale(.97)}
.ans-btn.correct{border-color:var(--color-success)!important;background:var(--color-success-bg)!important;color:var(--color-success);animation:correctPulse .4s ease}
.ans-btn.wrong{border-color:var(--color-error)!important;background:var(--color-error-bg)!important;color:var(--color-error);animation:wrongShake .4s ease}
.ans-btn.reveal{border-color:var(--color-success)!important;background:var(--color-success-bg)!important;color:var(--color-success);opacity:.7}
.ans-btn:disabled{cursor:not-allowed}
@keyframes correctPulse{0%{transform:scale(1)}30%{transform:scale(1.06)}100%{transform:scale(1)}}
@keyframes wrongShake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}
.feedback{display:none;width:100%;border-radius:var(--radius-lg);padding:var(--sp4) var(--sp5);margin-bottom:var(--sp4);animation:slideIn .3s ease}
.feedback.show{display:flex;align-items:flex-start;gap:var(--sp3)}
.feedback.ok{background:var(--color-success-bg);border:1px solid var(--color-success);color:var(--color-success)}
.feedback.err{background:var(--color-error-bg);border:1px solid var(--color-error);color:var(--color-error)}
.fb-ico{font-size:1.5rem;flex-shrink:0}.fb-title{font-weight:700;margin-bottom:2px}.fb-detail{font-size:var(--text-sm)}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.score-pop{position:fixed;font-family:var(--font-display);font-size:1.4rem;font-weight:700;pointer-events:none;z-index:1000;animation:scoreFloat 1.2s ease forwards}
.score-pop.pos{color:var(--color-success)}.score-pop.neg{color:var(--color-error)}
@keyframes scoreFloat{0%{opacity:1;transform:translateY(0) scale(1)}50%{opacity:1;transform:translateY(-30px) scale(1.2)}100%{opacity:0;transform:translateY(-60px) scale(.8)}}
.explain{display:none;background:var(--color-surface-2);border:1px solid var(--color-divider);border-radius:var(--radius-lg);padding:var(--sp5);width:100%;margin-bottom:var(--sp4)}
.explain.show{display:block;animation:slideIn .3s ease}
.explain-title{font-size:var(--text-xs);font-weight:700;color:var(--color-primary);text-transform:uppercase;letter-spacing:.08em;margin-bottom:var(--sp3)}
.explain-steps{list-style:none;display:flex;flex-direction:column;gap:var(--sp3)}
.explain-steps li{display:flex;align-items:flex-start;gap:var(--sp3);font-size:var(--text-sm);color:var(--color-text-muted)}
.step-n{flex-shrink:0;width:20px;height:20px;border-radius:var(--radius-full);background:var(--color-primary-bg);color:var(--color-primary);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
.btn-next{display:none;align-items:center;gap:var(--sp2);padding:var(--sp3) var(--sp8);background:var(--color-primary);color:#fff;border-radius:var(--radius-full);font-family:var(--font-display);font-size:var(--text-base);font-weight:600;transition:all var(--tr);box-shadow:0 4px 12px rgba(0,137,123,.3)}
.btn-next.show{display:inline-flex}
.btn-next:hover{background:var(--color-primary-hover);transform:translateY(-1px)}
#screen-results{flex-direction:column;align-items:center;justify-content:center;padding:var(--sp8) var(--sp4);background:linear-gradient(145deg,var(--color-bg),var(--color-primary-bg))}
.res-icon{font-size:4rem;margin-bottom:var(--sp4);animation:bounceIn .6s cubic-bezier(.16,1,.3,1)}
@keyframes bounceIn{0%{transform:scale(0);opacity:0}60%{transform:scale(1.2)}100%{transform:scale(1);opacity:1}}
.grade-circle{display:inline-flex;align-items:center;justify-content:center;width:80px;height:80px;border-radius:var(--radius-full);font-family:var(--font-display);font-size:2rem;font-weight:700;margin-bottom:var(--sp4);box-shadow:var(--shadow-lg)}
.grade-A{background:var(--color-success-bg);color:var(--color-success);border:3px solid var(--color-success)}
.grade-B{background:var(--color-primary-bg);color:var(--color-primary);border:3px solid var(--color-primary)}
.grade-C{background:var(--color-warning-bg);color:var(--color-warning);border:3px solid var(--color-warning)}
.grade-D{background:var(--color-error-bg);color:var(--color-error);border:3px solid var(--color-error)}
.res-title{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:700;text-align:center;margin-bottom:var(--sp2)}
.res-sub{font-size:var(--text-base);color:var(--color-text-muted);text-align:center;margin-bottom:var(--sp8)}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp4);width:100%;max-width:480px;margin-bottom:var(--sp6)}
.stat-box{background:var(--color-surface);border-radius:var(--radius-xl);padding:var(--sp5) var(--sp4);text-align:center;box-shadow:var(--shadow-md)}
.stat-val{font-family:var(--font-display);font-size:var(--text-xl);font-weight:700;color:var(--color-primary);margin-bottom:var(--sp1)}
.stat-lbl{font-size:var(--text-xs);color:var(--color-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.08em}
.acc-wrap{width:100%;max-width:400px;margin-bottom:var(--sp8)}
.acc-header{display:flex;justify-content:space-between;font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--sp2)}
.acc-track{height:12px;background:var(--color-surface-offset);border-radius:var(--radius-full);overflow:hidden}
.acc-fill{height:100%;border-radius:var(--radius-full);background:linear-gradient(to right,var(--color-primary),var(--color-success));transition:width 1s cubic-bezier(.16,1,.3,1)}
.actions{display:flex;gap:var(--sp4);flex-wrap:wrap;justify-content:center}
.btn-sec{display:inline-flex;align-items:center;gap:var(--sp2);padding:var(--sp3) var(--sp6);background:var(--color-surface);border:2px solid var(--color-border);color:var(--color-text);border-radius:var(--radius-full);font-family:var(--font-display);font-size:var(--text-base);font-weight:600;transition:all var(--tr)}
.btn-sec:hover{border-color:var(--color-primary);color:var(--color-primary)}
@media(max-width:480px){.answers{grid-template-columns:1fr}.mode-grid{grid-template-columns:1fr}.game-hud{padding:var(--sp2) var(--sp4);gap:var(--sp2)}.q-card{padding:var(--sp5) var(--sp4)}.q-text{font-size:var(--text-lg)}}
</style>
</head>
<body>
<button class="theme-toggle" data-theme-toggle aria-label="Toggle theme">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
</button>
<canvas id="pcanvas" style="position:fixed;inset:0;pointer-events:none;z-index:999"></canvas>

<!-- TITLE -->
<div id="screen-title" class="screen active">
  <div class="bg-deco" style="font-size:9rem;top:2%;left:0%;transform:rotate(-18deg)">%</div>
  <div class="bg-deco" style="font-size:5rem;top:12%;right:5%;transform:rotate(12deg)">50%</div>
  <div class="bg-deco" style="font-size:6rem;bottom:8%;left:8%;transform:rotate(-8deg)">1/4</div>
  <div class="bg-deco" style="font-size:4rem;bottom:22%;right:4%;transform:rotate(22deg)">75%</div>
  <div class="title-logo">
    <svg viewBox="0 0 76 76" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="38" cy="38" r="36" fill="var(--color-primary)" opacity=".1"/>
      <circle cx="38" cy="38" r="28" fill="var(--color-primary)" opacity=".15"/>
      <circle cx="26" cy="26" r="7" fill="var(--color-primary)"/>
      <circle cx="50" cy="50" r="7" fill="var(--color-primary)"/>
      <line x1="22" y1="54" x2="54" y2="22" stroke="var(--color-primary)" stroke-width="3.5" stroke-linecap="round"/>
      <circle cx="38" cy="38" r="5" fill="var(--color-accent)"/>
    </svg>
  </div>
  <h1 class="title-heading">Percent<em>Quest</em></h1>
  <p class="title-sub">Master percentages through interactive challenges!</p>
  <p class="section-label">Choose Your Mode</p>
  <div class="mode-grid">
    <div class="mode-card active" data-mode="classic" onclick="pickMode(this)">
      <div class="mode-icon">&#127919;</div>
      <div class="mode-title">Classic</div>
      <div class="mode-desc">4 choices, step-by-step explanations</div>
    </div>
    <div class="mode-card" data-mode="blitz" onclick="pickMode(this)">
      <div class="mode-icon">&#9889;</div>
      <div class="mode-title">Speed Blitz</div>
      <div class="mode-desc">10 seconds per question!</div>
    </div>
    <div class="mode-card" data-mode="visual" onclick="pickMode(this)">
      <div class="mode-icon">&#128202;</div>
      <div class="mode-title">Visual</div>
      <div class="mode-desc">Read bars and pie charts</div>
    </div>
  </div>
  <p class="section-label">Difficulty</p>
  <div class="diff-row">
    <button class="diff-btn active" data-diff="easy" onclick="pickDiff(this)">Easy</button>
    <button class="diff-btn" data-diff="medium" onclick="pickDiff(this)">Medium</button>
    <button class="diff-btn" data-diff="hard" onclick="pickDiff(this)">Hard</button>
  </div>
  <button class="btn-primary" onclick="startGame()">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    Play Now
  </button>
</div>

<!-- GAME -->
<div id="screen-game" class="screen">
  <div class="game-hud">
    <div class="hud-item"><span class="hud-label">Score</span><span class="hud-val" id="h-score">0</span></div>
    <div class="hud-item" id="h-lives-wrap">
      <span class="hud-label">Lives</span>
      <div class="hud-lives" id="h-lives"><span class="life">&#10084;&#65039;</span><span class="life">&#10084;&#65039;</span><span class="life">&#10084;&#65039;</span></div>
    </div>
    <div class="hud-item" id="h-timer-wrap" style="display:none">
      <span class="hud-label">Time</span>
      <div class="timer-ring">
        <svg width="48" height="48" viewBox="0 0 48 48">
          <circle cx="24" cy="24" r="20" fill="none" stroke="var(--color-surface-offset)" stroke-width="4"/>
          <circle id="t-ring" cx="24" cy="24" r="20" fill="none" stroke="var(--color-primary)" stroke-width="4" stroke-dasharray="125.66" stroke-dashoffset="0" stroke-linecap="round"/>
        </svg>
        <span class="timer-num" id="h-time">10</span>
      </div>
    </div>
    <div class="hud-item"><span class="hud-label">Question</span><span class="hud-val" id="h-qnum">1/10</span></div>
  </div>
  <div class="q-progress"><div class="q-progress-fill" id="qprogress"></div></div>
  <div class="game-body">
    <div class="diff-badge easy" id="g-badge">Easy</div>
    <div class="combo-strip" id="combo-strip"><span>&#128293;</span><span class="combo-txt" id="combo-txt">2x Combo!</span></div>
    <div class="q-card" id="q-card">
      <div class="q-type" id="q-type">Find the Value</div>
      <div class="q-text" id="q-text">Loading...</div>
      <div class="vis-bar-wrap" id="vis-bar-wrap" style="display:none">
        <div class="vis-bar-labels"><span>0</span><span id="vb-total">100</span></div>
        <div class="vis-bar-track"><div class="vis-bar-fill" id="vb-fill" style="width:0%"><span class="vis-bar-val" id="vb-val">?</span></div></div>
      </div>
      <div class="vis-pie-wrap" id="vis-pie-wrap" style="display:none">
        <svg id="pie-svg" width="160" height="160" viewBox="0 0 160 160"></svg>
        <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--sp2)">Shaded region = ?%</p>
      </div>
      <div class="q-hint" id="q-hint"></div>
    </div>
    <div class="feedback" id="feedback">
      <span class="fb-ico" id="fb-ico">&#9989;</span>
      <div><div class="fb-title" id="fb-title">Correct!</div><div class="fb-detail" id="fb-detail"></div></div>
    </div>
    <div class="answers" id="answers"></div>
    <div class="explain" id="explain">
      <div class="explain-title">&#128208; Step-by-step solution</div>
      <ul class="explain-steps" id="explain-steps"></ul>
    </div>
    <button class="btn-next" id="btn-next" onclick="nextQ()">Next Question &#8594;</button>
  </div>
</div>

<!-- RESULTS -->
<div id="screen-results" class="screen">
  <div class="res-icon" id="r-icon">&#127881;</div>
  <div class="grade-circle grade-A" id="r-grade">A</div>
  <h2 class="res-title" id="r-title">Excellent!</h2>
  <p class="res-sub" id="r-sub">You are a percentage master!</p>
  <div class="stats-row">
    <div class="stat-box"><div class="stat-val" id="r-score">0</div><div class="stat-lbl">Score</div></div>
    <div class="stat-box"><div class="stat-val" id="r-correct">0/10</div><div class="stat-lbl">Correct</div></div>
    <div class="stat-box"><div class="stat-val" id="r-combo">0x</div><div class="stat-lbl">Best Combo</div></div>
  </div>
  <div class="acc-wrap">
    <div class="acc-header"><span>Accuracy</span><span id="r-acc">0%</span></div>
    <div class="acc-track"><div class="acc-fill" id="r-acc-fill" style="width:0%"></div></div>
  </div>
  <div class="actions">
    <button class="btn-sec" onclick="goMenu()">&#127968; Menu</button>
    <button class="btn-primary" onclick="startGame()">&#8635; Play Again</button>
  </div>
</div>

<script>
(function(){
  var t=document.querySelector('[data-theme-toggle]'),r=document.documentElement;
  var d=matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';
  r.setAttribute('data-theme',d);
  if(t) t.addEventListener('click',function(){d=d==='dark'?'light':'dark';r.setAttribute('data-theme',d);});
})();

var pcanvas=document.getElementById('pcanvas');
var pctx=pcanvas.getContext('2d');
var particles=[];
function resizePCanvas(){pcanvas.width=innerWidth;pcanvas.height=innerHeight;}
resizePCanvas();addEventListener('resize',resizePCanvas);
function Particle(x,y,col){
  this.x=x;this.y=y;this.vx=(Math.random()-.5)*9;this.vy=Math.random()*-11-2;
  this.col=col;this.sz=Math.random()*10+4;this.life=1;this.g=.38;
  this.sq=Math.random()>.5;this.rot=Math.random()*Math.PI*2;this.rs=(Math.random()-.5)*.14;
}
Particle.prototype.update=function(){this.vy+=this.g;this.x+=this.vx;this.y+=this.vy;this.rot+=this.rs;this.life-=.024;this.vx*=.98;};
Particle.prototype.draw=function(ctx){
  ctx.save();ctx.globalAlpha=Math.max(0,this.life);ctx.translate(this.x,this.y);ctx.rotate(this.rot);
  ctx.fillStyle=this.col;
  if(this.sq)ctx.fillRect(-this.sz/2,-this.sz/2,this.sz,this.sz);
  else{ctx.beginPath();ctx.arc(0,0,this.sz/2,0,Math.PI*2);ctx.fill();}
  ctx.restore();
};
function confetti(x,y,n){
  n=n||28;
  var cols=['#00897b','#f4511e','#43a047','#fb8c00','#4db6ac','#ff7043','#26c6da','#ffca28','#ab47bc','#42a5f5'];
  for(var i=0;i<n;i++) particles.push(new Particle(x,y,cols[i%cols.length]));
}
(function animP(){
  pctx.clearRect(0,0,pcanvas.width,pcanvas.height);
  particles=particles.filter(function(p){return p.life>0;});
  particles.forEach(function(p){p.update();p.draw(pctx);});
  requestAnimationFrame(animP);
})();

var actx=null;
function initAudio(){if(!actx)actx=new (window.AudioContext||window.webkitAudioContext)();}
function tone(f,dur,type,vol){
  type=type||'sine';vol=vol||.28;
  if(!actx)return;
  try{var o=actx.createOscillator(),g=actx.createGain();
    o.type=type;o.frequency.value=f;
    g.gain.setValueAtTime(vol,actx.currentTime);
    g.gain.exponentialRampToValueAtTime(.001,actx.currentTime+dur);
    o.connect(g);g.connect(actx.destination);o.start();o.stop(actx.currentTime+dur);
  }catch(e){}
}
function sfx(t){
  switch(t){
    case'ok':tone(523,.1);setTimeout(function(){tone(659,.1);},100);setTimeout(function(){tone(784,.2);},200);break;
    case'no':tone(220,.3,'square',.12);setTimeout(function(){tone(180,.3,'square',.08);},100);break;
    case'click':tone(800,.05,'sine',.08);break;
    case'lvl':[523,659,784,1047].forEach(function(f,i){setTimeout(function(){tone(f,.2);},i*110);});break;
    case'tick':tone(1100,.05,'square',.07);break;
  }
}
document.addEventListener('click',function(){initAudio();},{once:true});

var EASY_P=[10,20,25,50,75,100];
var MED_P=[5,15,30,40,60,80,90];
var HARD_P=[12,17,33,37,45,66,83,87];
var EASY_V=[10,20,40,50,80,100,200];
var MED_V=[25,30,60,75,120,150,250];
var HARD_V=[36,48,72,84,96,144,180];
function rnd(a){return a[Math.floor(Math.random()*a.length)];}
function r2(n){return Math.round(n*10)/10;}
function getPool(diff){
  var p=diff==='easy'?EASY_P:diff==='medium'?EASY_P.concat(MED_P):EASY_P.concat(MED_P).concat(HARD_P);
  var v=diff==='easy'?EASY_V:diff==='medium'?EASY_V.concat(MED_V):EASY_V.concat(MED_V).concat(HARD_V);
  return{p:p,v:v};
}
function mkQuestion(diff,mode){
  var pool=getPool(diff);
  var types;
  if(mode==='visual') types=['bar','pie','findPct'];
  else if(diff==='easy') types=['findVal','whatPct','findVal','whatPct'];
  else if(diff==='medium') types=['findVal','whatPct','findWhole','pctInc','findVal','whatPct'];
  else types=['findVal','whatPct','findWhole','pctInc','pctDec','findVal','whatPct'];
  return build(rnd(types),pool.p,pool.v,diff);
}
function build(type,p,v,diff){
  var q={type:type,diff:diff,isPercent:false};
  if(type==='findVal'){
    q.pct=rnd(p);q.whole=rnd(v);q.answer=r2(q.pct/100*q.whole);
    q.text='What is <span class="hl">'+q.pct+'%</span> of <span class="hla">'+q.whole+'</span>?';
    q.typeLabel='Find the Value';q.hint='Formula: '+q.whole+' x ('+q.pct+' / 100)';
    q.steps=['Convert '+q.pct+'% to decimal: '+q.pct+' / 100 = <b>'+q.pct/100+'</b>','Multiply: '+q.whole+' x '+(q.pct/100)+' = <b>'+q.answer+'</b>'];
    if(q.pct===10) q.steps=['10% means divide by 10: '+q.whole+' / 10 = <b>'+q.answer+'</b>'];
    if(q.pct===25) q.steps=['25% = 1/4, so divide by 4: '+q.whole+' / 4 = <b>'+q.answer+'</b>'];
    if(q.pct===50) q.steps=['50% = half, so divide by 2: '+q.whole+' / 2 = <b>'+q.answer+'</b>'];
  } else if(type==='whatPct'){
    q.whole=rnd(v);q.pct=rnd(p);q.part=r2(q.pct/100*q.whole);
    if(q.part===0||q.part===q.whole){q.pct=25;q.part=r2(q.whole/4);}
    q.answer=q.pct;q.isPercent=true;
    q.text='<span class="hl">'+q.part+'</span> is what <span class="hla">percent</span> of '+q.whole+'?';
    q.typeLabel='Find the Percentage';q.hint='Formula: ('+q.part+' / '+q.whole+') x 100';
    q.steps=['Divide: '+q.part+' / '+q.whole+' = '+r2(q.part/q.whole*1000)/1000,'Multiply by 100: = <b>'+q.answer+'%</b>'];
  } else if(type==='findWhole'){
    q.pct=rnd(p);q.whole=rnd(v);q.part=r2(q.pct/100*q.whole);q.answer=q.whole;
    q.text='<span class="hl">'+q.pct+'%</span> of a number is <span class="hla">'+q.part+'</span>. What is the number?';
    q.typeLabel='Find the Whole';q.hint='Formula: '+q.part+' / ('+q.pct+'/100)';
    q.steps=['If '+q.pct+'% = '+q.part+', then 1% = '+q.part+' / '+q.pct+' = '+r2(q.part/q.pct),'Multiply by 100: '+r2(q.part/q.pct)+' x 100 = <b>'+q.answer+'</b>'];
  } else if(type==='pctInc'){
    var filtP=p.filter(function(x){return x<=75;});
    q.pct=rnd(filtP.length?filtP:p);q.whole=rnd(v);
    var inc=r2(q.pct/100*q.whole);q.answer=r2(q.whole+inc);
    q.text='A value of <span class="hla">'+q.whole+'</span> increases by <span class="hl">'+q.pct+'%</span>. New value?';
    q.typeLabel='Percentage Increase';q.hint='New = Original + (Original x '+q.pct+'/100)';
    q.steps=['Increase: '+q.whole+' x '+q.pct+'% = '+inc,'Add: '+q.whole+' + '+inc+' = <b>'+q.answer+'</b>'];
  } else if(type==='pctDec'){
    var filtP2=p.filter(function(x){return x<100;});
    q.pct=rnd(filtP2.length?filtP2:p);q.whole=rnd(v);
    var dec=r2(q.pct/100*q.whole);q.answer=r2(q.whole-dec);
    q.text='A value of <span class="hla">'+q.whole+'</span> decreases by <span class="hl">'+q.pct+'%</span>. New value?';
    q.typeLabel='Percentage Decrease';q.hint='New = Original - (Original x '+q.pct+'/100)';
    q.steps=['Decrease: '+q.whole+' x '+q.pct+'% = '+dec,'Subtract: '+q.whole+' - '+dec+' = <b>'+q.answer+'</b>'];
  } else if(type==='bar'){
    var bps=[10,20,25,30,40,50,60,70,75,80,90];
    q.pct=rnd(bps);q.whole=rnd([50,100,200]);q.part=r2(q.pct/100*q.whole);
    q.answer=q.pct;q.isPercent=true;q.showBar=true;q.barPct=q.pct;q.barTotal=q.whole;q.barVal=q.part;
    q.text='What percentage does the bar represent?';
    q.typeLabel='Read the Bar Chart';q.hint='Look at the filled portion vs. total length.';
    q.steps=['Bar shows '+q.part+' out of '+q.whole,''+q.part+' / '+q.whole+' x 100 = <b>'+q.pct+'%</b>'];
  } else if(type==='pie'){
    var pps=[10,20,25,30,40,50,60,70,75,80];
    q.pct=rnd(pps);q.answer=q.pct;q.isPercent=true;q.showPie=true;
    q.text='What percentage is shaded in the pie chart?';
    q.typeLabel='Read the Pie Chart';q.hint='The full circle = 100%. Estimate the shaded portion.';
    q.steps=['The shaded sector covers '+q.pct+' out of 100 equal parts','Answer: <b>'+q.pct+'%</b>'];
  } else {
    return build('findVal',p,v,diff);
  }
  return q;
}
function wrongAnswers(correct,isPct){
  var s=[];
  var tries=[r2(correct*.5),r2(correct*2),r2(correct+correct*.25||5),r2(correct-correct*.2||3),r2(correct*1.5),r2(correct*.75),r2(correct+(isPct?10:r2(correct*.3))),r2(correct-(isPct?5:r2(correct*.15))),r2(correct+correct*.1+2),r2(correct-correct*.1-2)];
  for(var i=0;i<tries.length&&s.length<3;i++){
    var w=tries[i];
    if(w!==correct&&w>0&&(!isPct||w<=100)&&s.indexOf(w)===-1) s.push(w);
  }
  var attempts=0;
  while(s.length<3&&attempts<50){
    attempts++;
    var off=(Math.floor(Math.random()*8)+2)*(Math.random()>.5?1:-1);
    var ww=r2(correct+off);
    if(ww!==correct&&ww>0&&(!isPct||ww<=100)&&s.indexOf(ww)===-1) s.push(ww);
  }
  return s.slice(0,3);
}
function drawPie(pct){
  var svg=document.getElementById('pie-svg');
  var r=70,cx=80,cy=80;
  var angle=(pct/100)*Math.PI*2;
  var x1=cx+r*Math.sin(0),y1=cy-r*Math.cos(0);
  var x2=cx+r*Math.sin(angle),y2=cy-r*Math.cos(angle);
  var large=pct>50?1:0;
  var st=getComputedStyle(document.documentElement);
  var bg=st.getPropertyValue('--color-surface-offset').trim()||'#f3ede2';
  var fill=st.getPropertyValue('--color-primary').trim()||'#00897b';
  svg.innerHTML='<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="'+bg+'" stroke="var(--color-border)" stroke-width="1.5"/><path d="M'+cx+','+cy+' L'+x1+','+y1+' A'+r+','+r+' 0 '+large+',1 '+x2+','+y2+' Z" fill="'+fill+'" opacity=".85"/><circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="var(--color-border)" stroke-width="1.5"/>';
}
var G={mode:'classic',diff:'easy',score:0,lives:3,qi:0,total:10,correct:0,combo:0,maxCombo:0,qs:[],answered:false,timer:null,timeLeft:10,timerMax:10};
function showScreen(id){document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});document.getElementById(id).classList.add('active');}
function goMenu(){sfx('click');showScreen('screen-title');}
function pickMode(el){sfx('click');document.querySelectorAll('.mode-card').forEach(function(c){c.classList.remove('active');});el.classList.add('active');G.mode=el.dataset.mode;}
function pickDiff(el){sfx('click');document.querySelectorAll('.diff-btn').forEach(function(b){b.classList.remove('active');});el.classList.add('active');G.diff=el.dataset.diff;}
function updateHUD(){
  document.getElementById('h-score').textContent=G.score;
  document.getElementById('h-qnum').textContent=(G.qi+1)+'/'+G.total;
  document.getElementById('qprogress').style.width=(G.qi/G.total*100)+'%';
  var lives=document.querySelectorAll('.life');
  lives.forEach(function(l,i){l.classList.toggle('lost',i>=G.lives);});
  var cb=document.getElementById('combo-strip');
  if(G.combo>=2){cb.classList.add('show');document.getElementById('combo-txt').textContent=G.combo+'x Combo!';}
  else cb.classList.remove('show');
}
function startTimer(secs){
  stopTimer();G.timeLeft=secs;G.timerMax=secs;
  var te=document.getElementById('h-time'),ring=document.getElementById('t-ring'),C=125.66;
  te.textContent=secs;ring.style.stroke='var(--color-primary)';te.style.color='';
  G.timer=setInterval(function(){
    G.timeLeft--;te.textContent=G.timeLeft;
    var prog=G.timeLeft/G.timerMax;
    ring.style.strokeDashoffset=C*(1-prog);
    if(prog<.33){ring.style.stroke='var(--color-error)';te.style.color='var(--color-error)';if(G.timeLeft<=3)sfx('tick');}
    else if(prog<.6){ring.style.stroke='var(--color-warning)';te.style.color='var(--color-warning)';}
    if(G.timeLeft<=0){stopTimer();timeUp();}
  },1000);
}
function stopTimer(){clearInterval(G.timer);document.getElementById('h-time').style.color='';}
function timeUp(){
  if(G.answered)return;G.answered=true;G.combo=0;G.lives--;updateHUD();sfx('no');
  var q=G.qs[G.qi];
  document.querySelectorAll('.ans-btn').forEach(function(b){b.disabled=true;if(+b.dataset.val===q.answer)b.classList.add('reveal');});
  showFB(false,"Time's up! Answer: "+q.answer+(q.isPercent?'%':''),q);
  if(G.lives<=0){setTimeout(endGame,1800);}
  else document.getElementById('btn-next').classList.add('show');
}
function scorePop(x,y,pts){
  var el=document.createElement('div');
  el.className='score-pop '+(pts>0?'pos':'neg');
  el.textContent=pts>0?('+'+pts):String(pts);
  el.style.left=x+'px';el.style.top=y+'px';
  document.body.appendChild(el);
  setTimeout(function(){el.remove();},1300);
}
function startGame(){
  sfx('click');
  G.score=0;G.lives=3;G.qi=0;G.correct=0;G.combo=0;G.maxCombo=0;G.answered=false;G.qs=[];
  for(var i=0;i<G.total;i++) G.qs.push(mkQuestion(G.diff,G.mode));
  G.timerMax=G.mode==='blitz'?10:30;
  document.getElementById('h-timer-wrap').style.display=G.mode==='blitz'?'flex':'none';
  showScreen('screen-game');updateHUD();loadQ();
}
function loadQ(){
  var q=G.qs[G.qi];G.answered=false;
  document.getElementById('feedback').className='feedback';
  document.getElementById('explain').classList.remove('show');
  document.getElementById('btn-next').classList.remove('show');
  document.getElementById('q-hint').style.display='none';
  var badge=document.getElementById('g-badge');
  badge.className='diff-badge '+q.diff;
  badge.textContent=q.diff==='easy'?'Easy':q.diff==='medium'?'Medium':'Hard';
  document.getElementById('q-type').textContent=q.typeLabel||'Question';
  document.getElementById('q-text').innerHTML=q.text;
  var bw=document.getElementById('vis-bar-wrap'),pw=document.getElementById('vis-pie-wrap');
  bw.style.display='none';pw.style.display='none';
  if(q.showBar){
    bw.style.display='block';
    document.getElementById('vb-total').textContent=q.barTotal;
    var fill=document.getElementById('vb-fill');fill.style.width='0%';
    document.getElementById('vb-val').textContent=String(q.barVal);
    setTimeout(function(){fill.style.width=q.barPct+'%';},300);
  }
  if(q.showPie){pw.style.display='flex';setTimeout(function(){drawPie(q.pct);},100);}
  var wrongs=wrongAnswers(q.answer,q.isPercent);
  var all=[q.answer].concat(wrongs).sort(function(){return Math.random()-.5;});
  var grid=document.getElementById('answers');grid.innerHTML='';
  all.forEach(function(a){
    var btn=document.createElement('button');
    btn.className='ans-btn';btn.dataset.val=a;
    btn.textContent=q.isPercent?(a+'%'):String(a);
    btn.onclick=function(){onAnswer(btn,q,a);};
    grid.appendChild(btn);
  });
  updateHUD();
  if(G.mode==='blitz') startTimer(G.timerMax);
}
function onAnswer(btn,q,sel){
  if(G.answered)return;G.answered=true;stopTimer();initAudio();
  var rect=btn.getBoundingClientRect();
  var ok=sel===q.answer;
  document.querySelectorAll('.ans-btn').forEach(function(b){
    b.disabled=true;if(+b.dataset.val===q.answer)b.classList.add(ok?'correct':'reveal');
  });
  if(!ok) btn.classList.add('wrong');
  if(ok){
    G.correct++;G.combo++;G.maxCombo=Math.max(G.maxCombo,G.combo);
    var base=q.diff==='easy'?100:q.diff==='medium'?150:200;
    var tb=G.mode==='blitz'?G.timeLeft*5:0;
    var cb=(G.combo-1)*25;
    var pts=base+tb+cb;
    G.score+=pts;sfx(G.combo>=3?'lvl':'ok');
    confetti(rect.left+rect.width/2,rect.top);
    scorePop(rect.left+rect.width/2,rect.top-10,pts);
    showFB(true,combo2msg(),q);
  } else {
    G.combo=0;G.lives--;sfx('no');scorePop(rect.left+rect.width/2,rect.top-10,0);
    var disp=q.isPercent?(q.answer+'%'):String(q.answer);
    showFB(false,'Not quite! The correct answer is '+disp,q);
    if(G.lives<=0){setTimeout(endGame,1800);return;}
  }
  updateHUD();document.getElementById('btn-next').classList.add('show');
}
function combo2msg(){
  if(G.combo>=3)return G.combo+'x Combo! On fire!';
  var m=['Excellent!','Perfect!','Spot on!','Brilliant!','Great job!','Awesome!'];
  return m[Math.floor(Math.random()*m.length)];
}
function showFB(ok,msg,q){
  var fb=document.getElementById('feedback');
  fb.className='feedback show '+(ok?'ok':'err');
  document.getElementById('fb-ico').textContent=ok?'✅':'❌';
  document.getElementById('fb-title').textContent=ok?'Correct!':'Not quite...';
  document.getElementById('fb-detail').textContent=msg;
  if(q.steps){
    var box=document.getElementById('explain');
    document.getElementById('explain-steps').innerHTML=q.steps.map(function(s,i){return '<li><span class="step-n">'+(i+1)+'</span><span>'+s+'</span></li>';}).join('');
    box.classList.add('show');
  }
  if(!ok){var h=document.getElementById('q-hint');h.textContent='Hint: '+q.hint;h.style.display='block';}
}
function nextQ(){G.qi++;if(G.qi>=G.total)endGame();else loadQ();}
function endGame(){
  stopTimer();showScreen('screen-results');
  var acc=Math.round(G.correct/G.total*100);
  var grade,icon,title,sub;
  if(acc>=90){grade='A';icon='🏆';title='Outstanding!';sub="You're a percentage master!";}
  else if(acc>=70){grade='B';icon='🌟';title='Great Work!';sub='Solid grasp of percentages!';}
  else if(acc>=50){grade='C';icon='📚';title='Keep Practicing!';sub='Review the explanations to improve.';}
  else{grade='D';icon='💪';title="Don't Give Up!";sub='Every attempt builds skill!';}
  document.getElementById('r-icon').textContent=icon;
  document.getElementById('r-grade').textContent=grade;
  document.getElementById('r-grade').className='grade-circle grade-'+grade;
  document.getElementById('r-title').textContent=title;
  document.getElementById('r-sub').textContent=sub;
  document.getElementById('r-score').textContent=G.score;
  document.getElementById('r-correct').textContent=G.correct+'/'+G.total;
  document.getElementById('r-combo').textContent=G.maxCombo+'x';
  document.getElementById('r-acc').textContent=acc+'%';
  setTimeout(function(){document.getElementById('r-acc-fill').style.width=acc+'%';},300);
  if(acc>=90){sfx('lvl');for(var i=0;i<5;i++)(function(j){setTimeout(function(){confetti(innerWidth*Math.random(),0,20);},j*180);})(i);}
  else sfx('ok');
}
</script>

<script src="session-tracker.js"></script>
</body>
</html>