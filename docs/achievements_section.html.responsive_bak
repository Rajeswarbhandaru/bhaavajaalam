<!-- ── PASTE THIS SCRIPT at the bottom of your <script> block ────────────
     (or just before <script src="bhava-bridge.js"></script>
<script src="bhava-session.js"></script>
<script src="bhava-game-nav.js"></script>
<script>document.title = "Achievements Section";</script>
</body> — after the existing report JS) ────────────── -->
<script id="bhava-badge-script">
// ── renderAchievements ─────────────────────────────────────────────────────
// Called after getBadges + getCertificates IPC calls resolve.
// badgeData: { earned: [...], unearned: [...], total_earned, total_badges }
// certData:  array of cert definitions with earned/progress info
function renderAchievements(badgeData, certData) {
  if (!badgeData || !certData) return;

  const section = document.getElementById('achievements-section');
  if (section) section.style.display = '';

  // ── Domain badges ────────────────────────────────────────────────────────
  const domainGrid = document.getElementById('domain-badge-grid');
  if (domainGrid) {
    const domainBadges = [
      ...badgeData.earned.filter(b => b.tier === 'domain'),
      ...badgeData.unearned.filter(b => b.tier === 'domain'),
    ];
    domainGrid.innerHTML = domainBadges.map(b => badgeCardHTML(b)).join('');
  }

  // ── Milestone badges ─────────────────────────────────────────────────────
  const milestoneGrid = document.getElementById('milestone-badge-grid');
  if (milestoneGrid) {
    const milestoneBadges = [
      ...badgeData.earned.filter(b => b.tier === 'milestone'),
      ...badgeData.unearned.filter(b => b.tier === 'milestone'),
    ];
    milestoneGrid.innerHTML = milestoneBadges.map(b => badgeCardHTML(b)).join('');
  }

  // ── Certificates ─────────────────────────────────────────────────────────
  const certGrid = document.getElementById('cert-grid');
  if (certGrid) {
    certGrid.innerHTML = certData.map(c => certCardHTML(c)).join('');

    // Wire up download buttons
    certGrid.querySelectorAll('.cert-download-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const level = btn.dataset.level;
        btn.disabled = true;
        btn.textContent = 'Generating…';
        try {
          const result = await window.bhava.generateCertificate(
            window._bhavaStudentId || sessionStorage.getItem('studentId'),
            level
          );
          if (result.ok) {
            btn.textContent = '✓ Saved to Downloads';
            setTimeout(() => {
              btn.textContent = '↓ Download / Print';
              btn.disabled = false;
            }, 3000);
          } else {
            btn.textContent = 'Error — try again';
            btn.disabled = false;
          }
        } catch (e) {
          btn.textContent = 'Error — try again';
          btn.disabled = false;
        }
      });
    });
  }
}

function badgeCardHTML(b) {
  const dateStr = b.awarded_at
    ? new Date(b.awarded_at).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' })
    : null;
  return `
    <div class="badge-card ${b.earned ? 'earned' : 'unearned'}">
      ${b.earned ? '<span class="badge-earned-tag">Earned</span>' : ''}
      <span class="badge-emoji">${b.badge_emoji}</span>
      <div class="badge-label">${b.badge_label}</div>
      <div class="badge-domain">${b.domain}</div>
      ${!b.earned && b.progress
          ? `<div class="badge-progress">${b.progress}</div>`
          : ''}
      ${b.earned && dateStr
          ? `<div class="badge-awarded-date">${dateStr}</div>`
          : ''}
    </div>`;
}

function certCardHTML(c) {
  const pct = c.progress_pct ?? 0;
  if (c.earned) {
    return `
      <div class="cert-card earned">
        <div class="cert-emoji">${c.emoji}</div>
        <div class="cert-title">${c.title}</div>
        <div class="cert-unlock" style="color:var(--color-success)">✓ Earned</div>
        <span class="cert-code">${c.certificate_code}</span>
        <button class="cert-download-btn" data-level="${c.level}">↓ Download / Print</button>
      </div>`;
  }
  return `
    <div class="cert-card unearned">
      <div class="cert-emoji">${c.emoji}</div>
      <div class="cert-title">${c.title}</div>
      <div class="cert-unlock">${c.unlock_requires}</div>
      <div class="cert-progress-bar-wrap">
        <div class="cert-progress-bar" style="width:${pct}%"></div>
      </div>
      <div style="font-size:0.7rem;color:var(--color-text-muted)">${pct}% complete</div>
    </div>`;
}

// ── showNewBadgePopup ───────────────────────────────────────────────────────
// Call this if you want to celebrate when a new badge is just earned.
// Pass an array of newly-earned badge objects from getBadges response.
function showNewBadgePopups(newBadges) {
  if (!newBadges || !newBadges.length) return;
  newBadges.forEach((b, i) => {
    setTimeout(() => {
      const popup = document.createElement('div');
      popup.className = 'badge-new-popup';
      popup.innerHTML = `
        <span class="popup-emoji">${b.badge_emoji}</span>
        <div class="popup-text">
          <div class="popup-title">Badge Unlocked!</div>
          <div class="popup-sub">${b.badge_label}</div>
        </div>`;
      document.body.appendChild(popup);
      setTimeout(() => popup.remove(), 4000);
    }, i * 800);
  });
}
</script>
<!-- ── END SCRIPT ──────────────────────────────────────────────────────── -->

