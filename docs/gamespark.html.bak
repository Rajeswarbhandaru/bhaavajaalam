<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bhāva GameSpark 2026 | 1st National Learn-with-Fun Game Challenge</title>
  <meta name="description" content="Bhāva GameSpark 2026 — India's first national educational game development competition for ages 16-20. Win ₹10,000 in prizes!"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
  <style>
    :root {
      --primary: #7c3aed; --secondary: #f59e0b;
      --accent1: #06b6d4; --accent2: #10b981; --accent3: #f43f5e;
      --dark: #0a0a1a; --text: #e2e8f0; --muted: rgba(226,232,240,0.55);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Poppins', sans-serif; background: var(--dark); color: var(--text); overflow-x: hidden; }

    .bg-fixed { position: fixed; inset: 0; z-index: 0; background: linear-gradient(160deg, #0a0a1a 0%, #0f0c29 45%, #0a1520 100%); }
    .orb { position: fixed; border-radius: 50%; filter: blur(90px); pointer-events: none; z-index: 0; animation: orbDrift 12s ease-in-out infinite; }
    .o1 { width:500px;height:500px;background:#7c3aed;opacity:.1;top:-100px;left:-100px; }
    .o2 { width:400px;height:400px;background:#06b6d4;opacity:.08;top:30%;right:-100px;animation-delay:4s; }
    .o3 { width:350px;height:350px;background:#f59e0b;opacity:.07;bottom:10%;left:30%;animation-delay:8s; }
    @keyframes orbDrift { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-40px) scale(1.06)} }

    nav { position:fixed;top:0;left:0;right:0;z-index:1000;padding:14px 40px;display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,26,0.75);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.07); }
    .nav-logo { display:flex;align-items:center;gap:10px;text-decoration:none; }
    .nav-logo-icon { width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#7c3aed,#06b6d4);display:grid;place-items:center;font-size:18px; }
    .nav-logo span { font-family:'Playfair Display',serif;font-size:1.2rem;color:#fff; }
    .nav-back { display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.65);text-decoration:none;font-size:0.85rem;font-weight:600;padding:8px 18px;border-radius:20px;border:1px solid rgba(255,255,255,0.15);transition:all .3s; }
    .nav-back:hover { background:rgba(255,255,255,0.08);color:#fff; }

    .wrap { position:relative;z-index:1; }

    /* HERO */
    .hero { min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 20px 60px; }
    .hero-badge { display:inline-flex;align-items:center;gap:8px;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.4);padding:8px 22px;border-radius:50px;font-size:0.78rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#c4b5fd;margin-bottom:24px;animation:fadeDown .8s ease both; }
    .hero-tag { font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent2);margin-bottom:8px;animation:fadeDown .8s ease .1s both; }
    .hero h1 { font-family:'Playfair Display',serif;font-size:clamp(2.2rem,6vw,4.8rem);font-weight:800;line-height:1.12;background:linear-gradient(90deg,#f7971e,#ffd200,#21d4fd,#b721ff,#f7971e);background-size:400%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmer 5s linear infinite,fadeDown .9s ease .2s both;margin-bottom:20px; }
    @keyframes shimmer { 0%{background-position:0%} 100%{background-position:400%} }
    .hero-sub { font-size:1.05rem;color:var(--muted);max-width:580px;line-height:1.8;margin-bottom:36px;animation:fadeDown 1s ease .35s both; }
    .hero-pills { display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-bottom:40px;animation:fadeDown 1s ease .5s both; }
    .hpill { padding:8px 20px;border-radius:30px;font-size:0.82rem;font-weight:700;border:1px solid; }
    .hp1{background:rgba(124,58,237,.12);border-color:rgba(124,58,237,.4);color:#c4b5fd;}
    .hp2{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.4);color:#fde68a;}
    .hp3{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.4);color:#6ee7b7;}
    .hp4{background:rgba(6,182,212,.1);border-color:rgba(6,182,212,.4);color:#67e8f9;}
    .hero-cta { display:flex;gap:16px;flex-wrap:wrap;justify-content:center;animation:fadeDown 1s ease .65s both; }
    .btn-primary { display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;font-weight:800;font-size:1rem;padding:16px 36px;border-radius:50px;text-decoration:none;box-shadow:0 6px 28px rgba(124,58,237,.45);transition:transform .2s,box-shadow .2s;animation:btnPulse 2.5s ease-in-out infinite alternate; }
    .btn-primary:hover { transform:translateY(-3px);box-shadow:0 12px 36px rgba(124,58,237,.6); }
    .btn-outline { display:inline-flex;align-items:center;gap:10px;background:transparent;color:#fff;font-weight:700;font-size:0.95rem;padding:15px 32px;border-radius:50px;text-decoration:none;border:2px solid rgba(255,255,255,.25);transition:all .2s; }
    .btn-outline:hover { border-color:#fff;background:rgba(255,255,255,.08); }
    @keyframes btnPulse { from{box-shadow:0 6px 28px rgba(124,58,237,.45)} to{box-shadow:0 8px 36px rgba(6,182,212,.5)} }
    @keyframes fadeDown { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }

    /* COUNTDOWN */
    .countdown-section { padding:60px 20px;text-align:center; }
    .countdown-label { font-size:0.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--accent1);margin-bottom:24px; }
    .countdown-wrap { display:flex;gap:20px;justify-content:center;flex-wrap:wrap; }
    .cd-box { background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:24px 28px;min-width:90px;text-align:center; }
    .cd-num { font-size:2.8rem;font-weight:900;color:#c4b5fd;line-height:1; }
    .cd-label { font-size:0.7rem;color:var(--muted);font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-top:6px; }
    .timeline-strip { display:flex;flex-wrap:wrap;justify-content:center;gap:0;max-width:860px;margin:48px auto 0; }
    .tl-item { flex:1;min-width:160px;text-align:center;padding:20px 16px;position:relative; }
    .tl-item:not(:last-child)::after { content:'→';position:absolute;right:-8px;top:50%;transform:translateY(-50%);color:rgba(124,58,237,.5);font-size:1.2rem; }
    .tl-dot { width:44px;height:44px;border-radius:50%;display:grid;place-items:center;margin:0 auto 12px;font-size:1.2rem; }
    .tl-date { font-size:0.82rem;font-weight:700;color:#fff;margin-bottom:4px; }
    .tl-event { font-size:0.74rem;color:var(--muted); }

    /* SECTIONS */
    .section { padding:80px 20px; }
    .section-inner { max-width:1060px;margin:0 auto; }
    .sec-eyebrow { font-size:0.72rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--accent1);text-align:center;margin-bottom:10px; }
    .sec-title { font-family:'Playfair Display',serif;font-size:clamp(1.7rem,3.5vw,2.5rem);font-weight:800;text-align:center;color:#fff;margin-bottom:10px; }
    .sec-sub { text-align:center;color:var(--muted);font-size:0.95rem;max-width:520px;margin:0 auto 48px;line-height:1.75; }

    /* PRIZES */
    .prizes-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px; }
    .prize-card { border-radius:22px;padding:36px 24px;text-align:center;position:relative;overflow:hidden;transition:transform .3s,box-shadow .3s;cursor:default; }
    .prize-card:hover { transform:translateY(-8px); }
    .prize-card.gold { background:linear-gradient(145deg,#3b2000,#7a4800);border:1px solid rgba(245,158,11,.4);box-shadow:0 8px 32px rgba(245,158,11,.2); }
    .prize-card.silver { background:linear-gradient(145deg,#1a1a2e,#2a2a4a);border:1px solid rgba(148,163,184,.3); }
    .prize-card.bronze { background:linear-gradient(145deg,#2a1000,#5a2800);border:1px solid rgba(180,83,9,.3); }
    .prize-rank { font-size:3rem;margin-bottom:12px;display:block; }
    .prize-amount { font-size:2.2rem;font-weight:900;margin-bottom:8px; }
    .gold .prize-amount{color:#fde68a;}.silver .prize-amount{color:#cbd5e1;}.bronze .prize-amount{color:#fb923c;}
    .prize-label { font-size:0.85rem;color:var(--muted);margin-bottom:16px; }
    .prize-perks { list-style:none;font-size:0.8rem;text-align:left; }
    .prize-perks li { padding:6px 0;border-bottom:1px solid rgba(255,255,255,.07);display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.75); }
    .prize-perks li:last-child { border-bottom:none; }
    .prize-total { text-align:center;margin-top:32px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.3);border-radius:14px;padding:20px; }
    .prize-total span { font-size:1.05rem;font-weight:800;color:#c4b5fd; }

    /* RULES */
    .rules-grid { display:grid;grid-template-columns:1fr 1fr;gap:24px; }
    .rules-box { background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:28px 24px; }
    .rules-box h3 { font-size:1rem;font-weight:800;margin-bottom:18px;display:flex;align-items:center;gap:10px; }
    .rules-box ul { list-style:none; }
    .rules-box ul li { font-size:0.85rem;color:rgba(255,255,255,.72);padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:flex-start;gap:10px;line-height:1.55; }
    .rules-box ul li:last-child { border-bottom:none; }
    .li-dot { width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:6px; }

    /* JUDGING */
    .judging-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:18px; }
    .judge-criteria { background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:24px 18px;text-align:center;transition:transform .3s; }
    .judge-criteria:hover { transform:translateY(-5px); }
    .jc-icon { font-size:2rem;margin-bottom:12px;display:block; }
    .jc-title { font-size:0.88rem;font-weight:700;color:#fff;margin-bottom:6px; }
    .jc-pct { font-size:1.5rem;font-weight:900;margin-bottom:4px; }
    .jc-desc { font-size:0.75rem;color:var(--muted);line-height:1.5; }
    .judge-panel-note { text-align:center;margin-top:32px;background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.25);border-radius:14px;padding:20px 28px;font-size:0.88rem;color:rgba(255,255,255,.7);max-width:600px;margin-left:auto;margin-right:auto; }

    /* FORM */
    .form-section { padding:80px 20px 100px; }
    .form-container { max-width:800px;margin:0 auto;background:rgba(255,255,255,.97);border-radius:28px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.5); }
    .form-header { padding:36px 44px 28px;background:linear-gradient(135deg,#7c3aed,#06b6d4);text-align:center; }
    .form-header h2 { font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:800;color:#fff;margin-bottom:6px; }
    .form-header p { color:rgba(255,255,255,.82);font-size:0.9rem; }
    .form-tabs { display:flex;background:#fff;border-bottom:1px solid #eee; }
    .ftab { flex:1;padding:16px;text-align:center;font-size:0.82rem;font-weight:700;color:#aaa;cursor:pointer;border-bottom:3px solid transparent;transition:all .3s; }
    .ftab.active { color:#7c3aed;border-bottom-color:#7c3aed; }
    .form-body { padding:36px 44px; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block;animation:stepIn .4s ease; }
    @keyframes stepIn { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
    .form-row { display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px; }
    .form-row.full { grid-template-columns:1fr; }
    .field { display:flex;flex-direction:column;gap:5px; }
    .field label { font-size:0.8rem;font-weight:700;color:#4a4a6a; }
    .field label .req { color:#f43f5e; }
    .field input,.field select,.field textarea { padding:12px 15px;border-radius:10px;border:2px solid #e8e4f4;font-family:'Poppins',sans-serif;font-size:0.86rem;color:#2a2a4a;background:#faf9ff;outline:none;transition:all .3s;width:100%; }
    .field input:focus,.field select:focus,.field textarea:focus { border-color:#7c3aed;box-shadow:0 0 0 4px rgba(124,58,237,.1);background:#fff; }
    .field textarea { resize:vertical;min-height:90px; }
    .field-note { font-size:0.74rem;color:#888;margin-top:4px; }
    .payment-box { background:linear-gradient(135deg,#f5f3ff,#ede9fe);border:2px dashed #7c3aed;border-radius:16px;padding:28px;text-align:center;margin-bottom:20px; }
    .payment-box h4 { font-size:1rem;font-weight:800;color:#4c1d95;margin-bottom:6px; }
    .payment-box p { font-size:0.82rem;color:#6d28d9;margin-bottom:16px; }
    .qr-img { width:180px;height:180px;object-fit:contain;border-radius:12px;border:3px solid #7c3aed;display:block;margin:0 auto 12px; }
    .payment-steps { list-style:none;text-align:left;font-size:0.8rem;color:#5b21b6;margin-top:14px;display:inline-block; }
    .payment-steps li { padding:4px 0;display:flex;align-items:center;gap:8px; }
    .terms-check { display:flex;align-items:flex-start;gap:10px;font-size:0.8rem;color:#4a4a6a;line-height:1.5;margin:16px 0; }
    .terms-check input { accent-color:#7c3aed;width:16px;height:16px;flex-shrink:0;margin-top:2px; }
    .terms-check a { color:#7c3aed;font-weight:600; }
    .btn-submit-form { width:100%;padding:15px;background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;font-family:'Poppins',sans-serif;font-size:1rem;font-weight:800;border:none;border-radius:12px;cursor:pointer;transition:all .3s;display:flex;align-items:center;justify-content:center;gap:10px; }
    .btn-submit-form:hover { transform:translateY(-2px);box-shadow:0 8px 24px rgba(124,58,237,.4); }
    .btn-submit-form:disabled { opacity:.7;cursor:not-allowed;transform:none; }
    .success-box { display:none;padding:48px 36px;text-align:center; }
    .success-box.show { display:block; }
    .success-icon { width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#10b981,#06b6d4);display:grid;place-items:center;margin:0 auto 20px;font-size:2rem;animation:popIn .5s cubic-bezier(.68,-.55,.27,1.55); }
    @keyframes popIn { from{transform:scale(0)} to{transform:scale(1)} }
    .success-box h3 { font-family:'Playfair Display',serif;font-size:1.6rem;color:#2a2a4a;margin-bottom:10px; }
    .success-box p { color:#666;font-size:0.9rem;line-height:1.75; }

    /* TERMS */
    .terms-section { padding:60px 20px;background:rgba(0,0,0,.25); }
    .terms-box { max-width:860px;margin:0 auto;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:40px 44px; }
    .terms-box h2 { font-size:1.2rem;font-weight:800;color:#fff;margin-bottom:20px;display:flex;align-items:center;gap:10px; }
    .terms-box ol { padding-left:20px; }
    .terms-box ol li { font-size:0.83rem;color:rgba(255,255,255,.65);padding:7px 0;line-height:1.65;border-bottom:1px solid rgba(255,255,255,.05); }
    .terms-box ol li:last-child { border-bottom:none; }
    .terms-box ol li strong { color:rgba(255,255,255,.9); }
    .terms-highlight { background:rgba(244,63,94,.08);border:1px solid rgba(244,63,94,.3);border-radius:12px;padding:16px 20px;margin-top:20px;font-size:0.82rem;color:#fda4af;line-height:1.65; }

    .footer { text-align:center;padding:28px 20px;border-top:1px solid rgba(255,255,255,.07);color:rgba(255,255,255,.35);font-size:0.78rem;position:relative;z-index:1; }
    .footer a { color:var(--accent1);text-decoration:none; }
    .sr { opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease; }
    .sr.visible { opacity:1;transform:translateY(0); }
    .sr.d1{transition-delay:.05s}.sr.d2{transition-delay:.12s}.sr.d3{transition-delay:.18s}
    .sr.d4{transition-delay:.24s}.sr.d5{transition-delay:.30s}

    @media(max-width:700px){
      nav{padding:12px 18px;}
      .rules-grid{grid-template-columns:1fr;}
      .form-row{grid-template-columns:1fr;}
      .form-body{padding:24px 18px;}
      .form-header{padding:24px 18px 18px;}
      .terms-box{padding:28px 18px;}
      .tl-item:not(:last-child)::after{display:none;}
      .hero-cta{flex-direction:column;align-items:center;}
      .btn-primary,.btn-outline{width:100%;justify-content:center;}
    }
  </style>
</head>
<body>
<div class="bg-fixed"></div>
<div class="orb o1"></div><div class="orb o2"></div><div class="orb o3"></div>

<nav>
  <a class="nav-logo" href="index.html">
    <div class="nav-logo-icon">🧠</div>
    <span>Bhāva Tech</span>
  </a>
  <a class="nav-back" href="index.html"><i class="fas fa-arrow-left"></i> Back to Home</a>
</nav>

<div class="wrap">

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">🎮 1st Edition · National Competition</div>
  <p class="hero-tag">Bhāva Tech Presents</p>
  <h1>Bhāva GameSpark<br/>2026</h1>
  <p class="hero-sub">India's first national educational game development competition for young minds aged 16–20. Build a game that makes learning fun — and win big.</p>
  <div class="hero-pills">
    <span class="hpill hp1">🏆 ₹22,000 in Prizes</span>
    <span class="hpill hp2">🎮 Any Platform, Any Language</span>
    <span class="hpill hp3">📅 25 Apr – 25 May 2026</span>
    <span class="hpill hp4">🌍 Open to All India</span>
  </div>
  <div class="hero-cta">
    <a href="#register" class="btn-primary"><i class="fas fa-rocket"></i> Register Now — ₹100</a>
    <a href="#rules" class="btn-outline"><i class="fas fa-scroll"></i> View Rules</a>
  </div>
</section>

<!-- COUNTDOWN -->
<section class="countdown-section">
  <p class="countdown-label">⏳ Submission Closes In</p>
  <div class="countdown-wrap">
    <div class="cd-box"><div class="cd-num" id="cd-days">00</div><div class="cd-label">Days</div></div>
    <div class="cd-box"><div class="cd-num" id="cd-hours">00</div><div class="cd-label">Hours</div></div>
    <div class="cd-box"><div class="cd-num" id="cd-mins">00</div><div class="cd-label">Minutes</div></div>
    <div class="cd-box"><div class="cd-num" id="cd-secs">00</div><div class="cd-label">Seconds</div></div>
  </div>
  <div class="timeline-strip">
    <div class="tl-item sr d1"><div class="tl-dot" style="background:rgba(124,58,237,.2);border:2px solid #7c3aed;">🚀</div><div class="tl-date">25 Apr 2026</div><div class="tl-event">Registration Opens</div></div>
    <div class="tl-item sr d2"><div class="tl-dot" style="background:rgba(245,158,11,.2);border:2px solid #f59e0b;">🛠️</div><div class="tl-date">25 Apr – 25 May</div><div class="tl-event">Development Period</div></div>
    <div class="tl-item sr d3"><div class="tl-dot" style="background:rgba(6,182,212,.2);border:2px solid #06b6d4;">📥</div><div class="tl-date">25 May 2026</div><div class="tl-event">Submission Deadline</div></div>
    <div class="tl-item sr d4"><div class="tl-dot" style="background:rgba(16,185,129,.2);border:2px solid #10b981;">⚖️</div><div class="tl-date">26–31 May 2026</div><div class="tl-event">Judging Period</div></div>
    <div class="tl-item sr d5"><div class="tl-dot" style="background:rgba(244,63,94,.2);border:2px solid #f43f5e;">🏆</div><div class="tl-date">1 Jun 2026</div><div class="tl-event">Results Announced</div></div>
  </div>
</section>

<!-- PRIZES -->
<section class="section" id="prizes">
  <div class="section-inner">
    <p class="sec-eyebrow sr">🏆 Win Big</p>
    <h2 class="sec-title sr">Prize Pool</h2>
    <p class="sec-sub sr">Top 3 winners take home cash prizes — plus a permanent place on the Bhāva Tech platform.</p>
    <div class="prizes-grid">
      <div class="prize-card gold sr d1">
        <span class="prize-rank">🥇</span>
        <div class="prize-amount">₹10,000</div>
        <div class="prize-label">1st Place</div>
        <ul class="prize-perks">
          <li>✅ Cash Prize ₹10,000</li>
          <li>🎮 Game published on Bhāva Tech</li>
          <li>🏅 Winner Certificate</li>
          <li>📣 Featured on social media</li>
          <li>🌟 "GameSpark Champion" badge</li>
        </ul>
      </div>
      <div class="prize-card silver sr d2">
        <span class="prize-rank">🥈</span>
        <div class="prize-amount">₹7,000</div>
        <div class="prize-label">2nd Place</div>
        <ul class="prize-perks">
          <li>✅ Cash Prize ₹7,000</li>
          <li>🎮 Game published on Bhāva Tech</li>
          <li>🏅 Runner-Up Certificate</li>
          <li>📣 Social media mention</li>
        </ul>
      </div>
      <div class="prize-card bronze sr d3">
        <span class="prize-rank">🥉</span>
        <div class="prize-amount">₹5,000</div>
        <div class="prize-label">3rd Place</div>
        <ul class="prize-perks">
          <li>✅ Cash Prize ₹5,000</li>
          <li>🏅 Merit Certificate</li>
          <li>📣 Social media mention</li>
        </ul>
      </div>
    </div>
    <div class="prize-total sr">
      <span>🎯 Total Prize Pool: ₹22,000 · Special Mentions also receive certificates & optional game publication</span>
    </div>
  </div>
</section>

<!-- RULES -->
<section class="section" id="rules" style="background:rgba(0,0,0,.2)">
  <div class="section-inner">
    <p class="sec-eyebrow sr">📜 Guidelines</p>
    <h2 class="sec-title sr">Rules & Eligibility</h2>
    <p class="sec-sub sr">Read carefully before registering. Violation of any rule leads to disqualification.</p>
    <div class="rules-grid">
      <div class="rules-box sr d1">
        <h3 style="color:#c4b5fd;">✅ Eligibility</h3>
        <ul>
          <li><span class="li-dot" style="background:#7c3aed;"></span>Age 16–20 years as on 25th April 2026</li>
          <li><span class="li-dot" style="background:#7c3aed;"></span>Open to all Indian students — school, junior college, or undergraduate (1st/2nd year)</li>
          <li><span class="li-dot" style="background:#7c3aed;"></span>Individual or team participation (max 3 members per team)</li>
          <li><span class="li-dot" style="background:#7c3aed;"></span>Each team may submit only one game</li>
          <li><span class="li-dot" style="background:#7c3aed;"></span>Registration fee: ₹100 per team (non-refundable)</li>
        </ul>
      </div>
      <div class="rules-box sr d2">
        <h3 style="color:#6ee7b7;">🎮 Game Requirements</h3>
        <ul>
          <li><span class="li-dot" style="background:#10b981;"></span>Build using any programming language, engine, or tool you prefer</li>
          <li><span class="li-dot" style="background:#10b981;"></span>Must have an educational theme — math, science, language, life skills, history, etc.</li>
          <li><span class="li-dot" style="background:#10b981;"></span>Must be playable by our judges — via a link, downloadable file, or APK</li>
          <li><span class="li-dot" style="background:#10b981;"></span>Games requiring paid software or special hardware to run will not be accepted</li>
        </ul>
      </div>
      <div class="rules-box sr d3">
        <h3 style="color:#67e8f9;">📥 Submission Rules</h3>
        <ul>
          <li><span class="li-dot" style="background:#06b6d4;"></span>Submit only through the official submission form on this page</li>
          <li><span class="li-dot" style="background:#06b6d4;"></span>Provide at least one of: a playable link, downloadable file URL, or GitHub repository with clear run instructions</li>
          <li><span class="li-dot" style="background:#06b6d4;"></span>Deadline: 25th May 2026, 11:59 PM IST — no extensions under any circumstances</li>
          <li><span class="li-dot" style="background:#06b6d4;"></span>Include a brief description of what the game teaches and how</li>
          <li><span class="li-dot" style="background:#06b6d4;"></span>Game must remain accessible until 1st June 2026</li>
        </ul>
      </div>
      <div class="rules-box sr d4">
        <h3 style="color:#fde68a;">⚠️ Disqualification</h3>
        <ul>
          <li><span class="li-dot" style="background:#f59e0b;"></span>Plagiarism or use of others' code without credit</li>
          <li><span class="li-dot" style="background:#f59e0b;"></span>False age or identity information</li>
          <li><span class="li-dot" style="background:#f59e0b;"></span>Submitting the same game under multiple teams</li>
          <li><span class="li-dot" style="background:#f59e0b;"></span>Any offensive, inappropriate, or harmful content</li>
          <li><span class="li-dot" style="background:#f59e0b;"></span>Attempting to influence judges directly</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- JUDGING -->
<section class="section">
  <div class="section-inner">
    <p class="sec-eyebrow sr">⚖️ Evaluation</p>
    <h2 class="sec-title sr">Judging Criteria</h2>
    <p class="sec-sub sr">Games are evaluated on five dimensions by our expert panel.</p>
    <div class="judging-grid">
      <div class="judge-criteria sr d1"><span class="jc-icon">🎮</span><div class="jc-pct" style="color:#c4b5fd;">30%</div><div class="jc-title">Gameplay & Fun Factor</div><div class="jc-desc">Is it genuinely engaging and enjoyable to play?</div></div>
      <div class="judge-criteria sr d2"><span class="jc-icon">📚</span><div class="jc-pct" style="color:#6ee7b7;">25%</div><div class="jc-title">Educational Value</div><div class="jc-desc">Does it effectively teach a concept or skill?</div></div>
      <div class="judge-criteria sr d3"><span class="jc-icon">💡</span><div class="jc-pct" style="color:#fde68a;">20%</div><div class="jc-title">Creativity & Originality</div><div class="jc-desc">Is the idea and execution unique and innovative?</div></div>
      <div class="judge-criteria sr d4"><span class="jc-icon">💻</span><div class="jc-pct" style="color:#67e8f9;">15%</div><div class="jc-title">Code Quality</div><div class="jc-desc">Clean, readable, and well-structured code.</div></div>
      <div class="judge-criteria sr d5"><span class="jc-icon">🎨</span><div class="jc-pct" style="color:#f9a8d4;">10%</div><div class="jc-title">Design & UI</div><div class="jc-desc">Visually appealing and user-friendly interface.</div></div>
    </div>
    <div class="judge-panel-note sr">
      ⚖️ <strong>Judging Panel:</strong> Bhāva GameSpark 2026 is evaluated by a panel of experts with backgrounds in technology, education, and professional software development. The decision of the judging panel is <strong>final and binding</strong> in all matters.
    </div>
  </div>
</section>

<!-- FORM -->
<section class="form-section" id="register">
  <div style="text-align:center;margin-bottom:44px;">
    <p class="sec-eyebrow">📝 Apply Now</p>
    <h2 class="sec-title">Register & Submit</h2>
    <p class="sec-sub">Registration closes 25th May 2026 · Entry fee ₹100 per team (non-refundable)</p>
  </div>
  <div class="form-container">
    <div class="form-header">
      <h2>🎮 Bhāva GameSpark 2026</h2>
      <p>Official Registration & Game Submission Form</p>
    </div>
    <div class="form-tabs">
      <div class="ftab active" onclick="switchTab('registration')">📝 Step 1: Register</div>
      <div class="ftab" onclick="switchTab('submission')">🎮 Step 2: Submit Game</div>
    </div>
    <div class="form-body">

      <!-- REGISTRATION -->
      <div class="tab-panel active" id="panel-registration">
        <div class="payment-box">
          <h4>💳 Pay ₹100 Registration Fee First</h4>
          <p>Scan with any UPI app (GPay, PhonePe, Paytm, or any bank app)</p>
          <img src="QR_CODE" alt="Scan to Pay ₹100 Registration Fee" class="qr-img"/>
          <ul class="payment-steps">
            <li>1️⃣ Scan QR → Pay exactly ₹100</li>
            <li>2️⃣ Take a screenshot of the confirmation</li>
            <li>3️⃣ Upload screenshot in the form below</li>
          </ul>
        </div>
        <div class="form-row">
          <div class="field"><label>Team / Participant Name <span class="req">*</span></label><input type="text" id="r-team" placeholder="Team name or your full name" required/></div>
          <div class="field"><label>Participation Type <span class="req">*</span></label><select id="r-type" required><option value="">— Select —</option><option>Individual</option><option>Team of 2</option><option>Team of 3</option></select></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Your Full Name <span class="req">*</span></label><input type="text" id="r-name" placeholder="Primary contact person" required/></div>
          <div class="field"><label>Age <span class="req">*</span></label><input type="number" id="r-age" placeholder="16–20" min="16" max="20" required/></div>
        </div>
        <div class="form-row">
          <div class="field"><label>School / College Name <span class="req">*</span></label><input type="text" id="r-school" placeholder="Name of your institution" required/></div>
          <div class="field"><label>City & State <span class="req">*</span></label><input type="text" id="r-city" placeholder="e.g. Visakhapatnam, AP" required/></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Email Address <span class="req">*</span></label><input type="email" id="r-email" placeholder="your@email.com" required/></div>
          <div class="field"><label>WhatsApp Number <span class="req">*</span></label><input type="tel" id="r-phone" placeholder="+91 XXXXX XXXXX" required/></div>
        </div>
        <div class="form-row full">
          <div class="field"><label>Other Team Members' Names</label><input type="text" id="r-members" placeholder="Member 2, Member 3 (leave blank if individual)"/></div>
        </div>
        <div class="form-row full">
          <div class="field">
            <label>Payment Screenshot <span class="req">*</span></label>
            <input type="file" id="r-payment" accept="image/*" required/>
            <span class="field-note">Upload your UPI payment confirmation screenshot (JPG/PNG)</span>
          </div>
        </div>
        <div class="terms-check">
          <input type="checkbox" id="r-terms" required/>
          <label for="r-terms">I have read and agree to the <a href="#terms">Terms & Conditions</a> of Bhāva GameSpark 2026. I understand that all decisions by Bhāva Tech are final and binding.</label>
        </div>
        <button class="btn-submit-form" onclick="submitRegistration()"><i class="fas fa-paper-plane"></i> Submit Registration</button>
        <div class="success-box" id="reg-success">
          <div class="success-icon">✅</div>
          <h3>Registration Submitted!</h3>
          <p>We have received your registration. Payment will be verified within 24 hours and a confirmation sent to your email.<br/><br/>After confirmation, return here and use <strong>Step 2</strong> to submit your game.</p>
        </div>
      </div>

      <!-- SUBMISSION -->
      <div class="tab-panel" id="panel-submission">
        <div class="form-row">
          <div class="field"><label>Registered Team Name <span class="req">*</span></label><input type="text" id="s-team" placeholder="Exactly as registered" required/></div>
          <div class="field"><label>Registered Email <span class="req">*</span></label><input type="email" id="s-email" placeholder="Same email used during registration" required/></div>
        </div>
        <div class="form-row full">
          <div class="field"><label>Game Name <span class="req">*</span></label><input type="text" id="s-gamename" placeholder="Name of your game" required/></div>
        </div>
        <div class="form-row">
          <div class="field"><label>GitHub / Hosted Game Link</label><input type="url" id="s-github" placeholder="https://github.com/... or https://itch.io/..."/><span class="field-note">Provide at least one playable link or downloadable URL</span></div>
          <div class="field"><label>Download Link (if applicable)</label><input type="url" id="s-url" placeholder="Direct download link for .exe / .apk etc."/></div>
        </div>
        <div class="form-row full">
          <div class="field"><label>Run Instructions <span class="req">*</span></label><input type="text" id="s-howrun" placeholder="e.g. Open index.html in browser / Run main.py / Install APK" required/></div>
        </div>
        <div class="form-row full">
          <div class="field"><label>Educational Theme / Subject <span class="req">*</span></label>
            <select id="s-theme" required>
              <option value="">— Select Subject —</option>
              <option>Mathematics</option><option>Science</option>
              <option>Language & Vocabulary</option><option>History & Geography</option>
              <option>Life Skills</option><option>Logic & Problem Solving</option>
              <option>Environmental Awareness</option><option>Health & Nutrition</option>
              <option>Other</option>
            </select>
          </div>
        </div>
        <div class="form-row full">
          <div class="field"><label>What does your game teach? <span class="req">*</span></label><textarea id="s-desc" placeholder="Describe the educational concept or skill your game teaches and how it makes learning fun..." required></textarea></div>
        </div>
        <div class="form-row full">
          <div class="field"><label>How to Play <span class="req">*</span></label><textarea id="s-howto" placeholder="Briefly explain the game mechanics — what does the player do?" required></textarea></div>
        </div>
        <div class="terms-check">
          <input type="checkbox" id="s-consent" required/>
          <label for="s-consent">I confirm this is my original work. I grant Bhāva Tech the right to publish this game on their platform if selected. I agree that the decision of the judging panel is final and binding.</label>
        </div>
        <button class="btn-submit-form" onclick="submitGame()"><i class="fas fa-gamepad"></i> Submit My Game</button>
        <div class="success-box" id="sub-success">
          <div class="success-icon">🎮</div>
          <h3>Game Submitted!</h3>
          <p>Excellent! Your game has been received. Our panel will evaluate it between 26th–31st May 2026.<br/><br/>Results announced on <strong>1st June 2026</strong>. Good luck! 🚀</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- TERMS -->
<section class="terms-section" id="terms">
  <div class="terms-box sr">
    <h2>⚖️ Terms & Conditions — Bhāva GameSpark 2026</h2>
    <ol>
      <li><strong>Organiser:</strong> Bhāva GameSpark 2026 is organized solely by <strong>Bhāva Tech</strong>, Visakhapatnam, Andhra Pradesh. All rights, decisions, and authority in connection with this competition are exclusively and absolutely vested in Bhāva Tech.</li>
      <li><strong>Eligibility:</strong> Open only to Indian participants aged 16–20 years as on 25th April 2026. False information regarding age or identity will result in immediate disqualification and forfeiture of any prize.</li>
      <li><strong>Registration Fee:</strong> The ₹100 registration fee is strictly non-refundable under any circumstances, including withdrawal, disqualification, or cancellation by the participant.</li>
      <li><strong>Originality:</strong> All submitted games must be original work created by the registered team during the competition period. Plagiarised code, fully AI-generated games, or assets copied without attribution are strictly prohibited and will result in disqualification.</li>
      <li><strong>Technology Freedom:</strong> Participants are free to use any programming language, game engine, or development tool. The game must be playable by judges via a provided link, downloadable file, or repository. Games requiring paid software or special hardware to run will not be accepted.</li>
      <li><strong>Intellectual Property:</strong> Participants retain full ownership of their submitted game. By submitting, participants grant Bhāva Tech a non-exclusive, royalty-free licence to showcase and promote the game on its platforms, with appropriate credit to the creator.</li>
      <li><strong>Publication Right:</strong> Winners and special mentions who consent to publication will have their game hosted on the Bhāva Tech website. Participants may opt out of publication at any time by informing Bhāva Tech in writing.</li>
      <li><strong>Final Authority:</strong> All decisions made by Bhāva Tech and its judging panel — including shortlisting, scoring, results, and prize distribution — are <strong>final, absolute, and binding</strong>. No correspondence, dispute, appeal, argument, or legal challenge regarding any decision will be entertained under any circumstances.</li>
      <li><strong>Disqualification:</strong> Bhāva Tech reserves the absolute right to disqualify any participant at any stage, without prior notice, if any rule violation, misconduct, or fraudulent activity is detected.</li>
      <li><strong>Prize Distribution:</strong> Prizes will be distributed via UPI/bank transfer within 7 working days of results. Winners must provide valid bank details within 7 days of announcement. Failure to do so will result in forfeiture of the prize.</li>
      <li><strong>Cancellation:</strong> Bhāva Tech reserves the right to cancel, postpone, or modify the competition at any time without prior notice. In the event of cancellation solely by Bhāva Tech, registration fees will be refunded.</li>
      <li><strong>Liability:</strong> Bhāva Tech is not liable for any technical failures, internet issues, or submission errors on the participant's side. Participants are advised to submit well before the deadline.</li>
      <li><strong>Governing Law:</strong> This competition is subject to the laws of India. Any disputes shall be subject to the exclusive jurisdiction of courts in Visakhapatnam, Andhra Pradesh only.</li>
      <li><strong>Acceptance:</strong> By registering, all participants unconditionally and irrevocably accept every term and condition stated herein. Bhāva Tech's interpretation of these terms shall be final in all cases.</li>
    </ol>
    <div class="terms-highlight">
      ⚠️ <strong>Important Notice:</strong> Bhāva Tech holds sole and absolute authority over all aspects of Bhāva GameSpark 2026 — including judging, scoring, prize awarding, disqualification, and publication. All decisions are final, non-negotiable, and not subject to any dispute, argument, complaint, or legal challenge whatsoever. Participants agree to this fully and unconditionally upon registration.
    </div>
  </div>
</section>

<div class="footer">
  © 2026 Bhāva Tech · Visakhapatnam, Andhra Pradesh · All Rights Reserved ·
  <a href="index.html">Back to Home</a>
</div>

</div>

<script>
// COUNTDOWN
const deadline = new Date('2026-05-25T23:59:59+05:30');
function updateCD(){
  const diff = deadline - new Date();
  if(diff<=0){ document.querySelector('.countdown-wrap').innerHTML='<p style="color:#f43f5e;font-weight:800;font-size:1.2rem;">⏰ Submissions Closed!</p>'; return; }
  document.getElementById('cd-days').textContent  = String(Math.floor(diff/86400000)).padStart(2,'0');
  document.getElementById('cd-hours').textContent = String(Math.floor((diff%86400000)/3600000)).padStart(2,'0');
  document.getElementById('cd-mins').textContent  = String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
  document.getElementById('cd-secs').textContent  = String(Math.floor((diff%60000)/1000)).padStart(2,'0');
}
updateCD(); setInterval(updateCD,1000);

// TABS
function switchTab(tab){
  document.querySelectorAll('.ftab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  if(tab==='registration'){
    document.querySelectorAll('.ftab')[0].classList.add('active');
    document.getElementById('panel-registration').classList.add('active');
  } else {
    document.querySelectorAll('.ftab')[1].classList.add('active');
    document.getElementById('panel-submission').classList.add('active');
  }
}

const v = id => document.getElementById(id)?.value?.trim()||'';
function validateRequired(ids){
  let ok=true;
  ids.forEach(id=>{
    const el=document.getElementById(id);
    if(!el) return;
    if(el.type==='checkbox'){ if(!el.checked){el.style.outline='2px solid #f43f5e';ok=false;} else el.style.outline=''; return; }
    if(!el.value.trim()){ el.style.borderColor='#f43f5e'; el.addEventListener('input',()=>el.style.borderColor='',{once:true}); ok=false; }
  });
  return ok;
}

// REPLACE WITH YOUR DEPLOYED APPS SCRIPT URL
const GAS_URL = 'https://script.google.com/macros/s/AKfycbxKCg6I3HyKegui6H3ouHl7cqBQ3OMNw_0KVjoLClGTg8zxxAANa3G_udmfsr0zqdnG/exec';

async function submitRegistration(){
  if(!validateRequired(['r-team','r-type','r-name','r-age','r-school','r-city','r-email','r-phone','r-terms'])) return;
  const age=parseInt(v('r-age'));
  if(age<16||age>20){ alert('Age must be between 16 and 20 years.'); return; }
  const btn=document.querySelector('#panel-registration .btn-submit-form');
  btn.disabled=true; btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Submitting…';
  const payload={ formType:'REGISTRATION', timestamp:new Date().toLocaleString('en-IN',{timeZone:'Asia/Kolkata'}),
    team:v('r-team'), participationType:v('r-type'), name:v('r-name'), age:v('r-age'),
    school:v('r-school'), city:v('r-city'), email:v('r-email'), phone:v('r-phone'),
    members:v('r-members'), paymentNote:'Screenshot uploaded separately' };
  try {
    await fetch(GAS_URL,{method:'POST',body:JSON.stringify(payload)});
    document.getElementById('reg-success').classList.add('show');
    btn.style.display='none';
  } catch(e){
    btn.disabled=false; btn.innerHTML='<i class="fas fa-paper-plane"></i> Submit Registration';
    alert('Submission failed. Please try again.');
  }
}

async function submitGame(){
  if(!validateRequired(['s-team','s-email','s-gamename','s-theme','s-howrun','s-desc','s-howto','s-consent'])) return;
  if(!v('s-github')&&!v('s-url')){ alert('Please provide at least a game link or download URL.'); return; }
  const btn=document.querySelector('#panel-submission .btn-submit-form');
  btn.disabled=true; btn.innerHTML='<i class="fas fa-spinner fa-spin"></i> Submitting…';
  const payload={ formType:'GAME_SUBMISSION', timestamp:new Date().toLocaleString('en-IN',{timeZone:'Asia/Kolkata'}),
    team:v('s-team'), email:v('s-email'), gameName:v('s-gamename'),
    gameLink:v('s-github'), downloadLink:v('s-url'), runInstructions:v('s-howrun'),
    theme:v('s-theme'), description:v('s-desc'), howToPlay:v('s-howto') };
  try {
    await fetch(GAS_URL,{method:'POST',body:JSON.stringify(payload)});
    document.getElementById('sub-success').classList.add('show');
    btn.style.display='none';
  } catch(e){
    btn.disabled=false; btn.innerHTML='<i class="fas fa-gamepad"></i> Submit My Game';
    alert('Submission failed. Please try again.');
  }
}

// SCROLL REVEAL
const srObs=new IntersectionObserver(entries=>{ entries.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('visible');srObs.unobserve(e.target);} }); },{threshold:0.12});
document.querySelectorAll('.sr').forEach(el=>srObs.observe(el));
</script>
</body>
</html>