<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Imagina Quest</title>
<style>
:root{--bg:#060712;--text:#f7f7ff;--muted:#b9bdd8;--glass:rgba(255,255,255,.08);--line:rgba(255,255,255,.15);--shadow:0 20px 50px rgba(0,0,0,.4);--p1:#7c3aed;--p2:#ec4899;--p3:#38bdf8;--good:#22c55e;--bad:#ef4444;--gold:#fbbf24;--font:system-ui,Segoe UI,Arial,sans-serif}
*{box-sizing:border-box} html,body{margin:0;height:100%;overflow:hidden;background:radial-gradient(circle at top,#181a3c 0,#070915 45%,#03040a 100%);color:var(--text);font-family:var(--font)}
canvas{position:fixed;inset:0;width:100%;height:100%;display:block}
button{font:inherit}
#ui{position:fixed;inset:0;z-index:10;pointer-events:none}
.screen{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:18px;pointer-events:auto;transition:.35s cubic-bezier(.16,1,.3,1)}
.hide{opacity:0;transform:scale(.98);pointer-events:none}
.card{width:min(1380px,99vw);border-radius:32px;padding:22px;background:linear-gradient(180deg,rgba(255,255,255,.10),rgba(255,255,255,.05));border:1px solid var(--line);box-shadow:var(--shadow);backdrop-filter:blur(16px);position:relative;overflow:hidden}
.card:before{content:'';position:absolute;inset:-2px;background:linear-gradient(120deg,rgba(124,58,237,.14),rgba(236,72,153,.12),rgba(56,189,248,.10));filter:blur(24px);z-index:-1}
.title{font-size:clamp(2rem,6vw,5rem);font-weight:1000;letter-spacing:-.05em;background:linear-gradient(90deg,#a855f7,#ec4899,#38bdf8,#22c55e);-webkit-background-clip:text;background-clip:text;color:transparent;text-align:center;animation:float 3.2s ease-in-out infinite}
@keyframes float{50%{transform:translateY(-8px)}}
.sub{color:var(--muted);text-align:center;max-width:880px;line-height:1.45}
.btn{border:0;border-radius:999px;padding:16px 28px;color:#fff;font-weight:900;cursor:pointer;pointer-events:auto;background:linear-gradient(135deg,#7c3aed,#ec4899);box-shadow:0 0 0 1px rgba(255,255,255,.12) inset,0 12px 34px rgba(124,58,237,.30);transition:.16s transform,.16s filter}
.btn:hover{transform:translateY(-2px) scale(1.02);filter:brightness(1.08)}
.btn:active{transform:scale(.98)}
.topbar{position:absolute;top:14px;left:14px;right:14px;display:flex;justify-content:space-between;align-items:center;pointer-events:none;z-index:20}
.pill{pointer-events:auto;background:rgba(255,255,255,.08);border:1px solid var(--line);backdrop-filter:blur(12px);border-radius:999px;padding:10px 14px;min-width:92px;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 10px 24px rgba(0,0,0,.18)}
#levelPill{font-weight:900}
.heroWrap{display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;margin:20px 0 8px}
.hero{width:156px;height:156px;border-radius:40px;background:radial-gradient(circle at 30% 25%,rgba(255,255,255,.22),transparent 35%),linear-gradient(180deg,rgba(124,58,237,.95),rgba(7,8,22,.92));border:1px solid rgba(255,255,255,.14);position:relative;overflow:hidden;box-shadow:0 0 38px rgba(124,58,237,.30),inset 0 0 24px rgba(255,255,255,.05);animation:heroBounce 4s ease-in-out infinite}
@keyframes heroBounce{50%{transform:translateY(-6px) rotate(-1deg)}}
.hero:before,.hero:after{content:'';position:absolute;border-radius:999px;background:#fff;opacity:.98}
.hero:before{width:18px;height:18px;left:42px;top:50px;box-shadow:46px 0 0 #fff}
.hero:after{width:60px;height:22px;left:48px;bottom:28px;border-radius:0 0 30px 30px;background:linear-gradient(90deg,#fff,#ffd7ec)}
.hero .spark{position:absolute;inset:0;animation:spin 10s linear infinite}
.hero .spark:before,.hero .spark:after{content:'✨';position:absolute;font-size:1.15rem;opacity:.9}
.hero .spark:before{left:12px;top:18px}.hero .spark:after{right:18px;bottom:18px}
.hero .halo{position:absolute;inset:16px;border-radius:28px;border:1px dashed rgba(255,255,255,.18);animation:spin 12s linear infinite reverse}
@keyframes spin{to{transform:rotate(360deg)}}
#map{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.node{width:72px;height:72px;border-radius:22px;display:grid;place-items:center;background:rgba(255,255,255,.06);border:1px solid var(--line);position:relative;box-shadow:inset 0 0 0 1px rgba(255,255,255,.05)}
.node small{position:absolute;bottom:-22px;font-size:11px;color:var(--muted)}
.node.on{background:linear-gradient(135deg,rgba(124,58,237,.95),rgba(236,72,153,.95));box-shadow:0 0 28px rgba(236,72,153,.28)}
.node.boss{border-color:rgba(251,191,36,.45)}
.adventure{display:grid;grid-template-columns:minmax(420px,0.92fr) minmax(520px,1.08fr);gap:16px;align-items:stretch;margin-top:12px}
.scene,.storyCard{min-height:430px}
.scene{border-radius:28px;overflow:hidden;position:relative;background:linear-gradient(180deg,rgba(14,18,42,.88),rgba(8,9,20,.97));border:1px solid rgba(255,255,255,.09)}
.scene::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 20%,rgba(124,58,237,.18),transparent 34%),radial-gradient(circle at 20% 70%,rgba(236,72,153,.12),transparent 30%),radial-gradient(circle at 80% 70%,rgba(34,197,94,.10),transparent 28%)}
.sceneTitle{position:absolute;top:16px;left:18px;font-size:14px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.65)}
.sceneArt{position:absolute;inset:0;display:grid;place-items:center;font-size:clamp(6rem,18vw,10rem);animation:sceneBob 4s ease-in-out infinite;filter:drop-shadow(0 10px 18px rgba(0,0,0,.20))}
@keyframes sceneBob{50%{transform:translateY(-10px) scale(1.03)}}
.sceneNotes{position:absolute;bottom:14px;left:14px;right:14px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:rgba(255,255,255,.7)}
.storyCard{background:linear-gradient(180deg,rgba(255,255,255,.09),rgba(255,255,255,.04));border:1px solid rgba(255,255,255,.16);border-radius:24px;padding:14px;display:flex;flex-direction:column;justify-content:space-between;gap:12px;box-shadow:inset 0 1px 0 rgba(255,255,255,.05);min-width:0}
.storyLine{font-size:clamp(1.4rem,3vw,2.05rem);font-weight:1000;line-height:1.07;color:#fff;text-shadow:0 2px 14px rgba(0,0,0,.24)}
.storyMini{color:#dfe2ff;font-size:14px;line-height:1.45;opacity:.95}
.choiceGrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px}
.choice{min-height:94px;border-radius:24px;border:1px solid rgba(255,255,255,.20);background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(255,255,255,.07));color:var(--text);display:flex;align-items:center;justify-content:center;gap:12px;cursor:pointer;pointer-events:auto;position:relative;overflow:hidden;font-weight:900;box-shadow:inset 0 1px 0 rgba(255,255,255,.05),0 12px 24px rgba(0,0,0,.14);transition:.16s transform,.16s border-color,.16s background,.16s box-shadow}
.choice:hover{transform:translateY(-3px) scale(1.01);border-color:rgba(124,58,237,.65);box-shadow:0 16px 32px rgba(124,58,237,.22)}
.choice .e{font-size:2.1rem;filter:drop-shadow(0 2px 6px rgba(0,0,0,.25))}.choice .l{font-size:12px;color:#f2f3ff;font-weight:800;letter-spacing:.01em;max-width:100px;white-space:normal;line-height:1.05}
.choice.good{border-color:rgba(34,197,94,.90);background:linear-gradient(180deg,rgba(34,197,94,.30),rgba(34,197,94,.14));box-shadow:0 0 22px rgba(34,197,94,.18)}
.choice.bad{border-color:rgba(239,68,68,.88);background:linear-gradient(180deg,rgba(239,68,68,.24),rgba(239,68,68,.12))}
.hud{display:flex;gap:10px;align-items:center;justify-content:center;flex-wrap:wrap;margin-top:12px}
.bar{height:10px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;border:1px solid var(--line);width:min(760px,94vw);margin:10px auto 0}
.fill{height:100%;width:0%;background:linear-gradient(90deg,#7c3aed,#ec4899,#22c55e);transition:width .3s ease}
.ring{width:56px;height:56px;position:relative}
.ring svg{transform:rotate(-90deg)}
.ring span{position:absolute;inset:0;display:grid;place-items:center;font-size:12px;font-weight:900}
#mapScene{width:100%;min-height:280px;border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03));border:1px solid var(--line);position:relative;overflow:hidden;margin-top:14px}
.path{position:absolute;left:10%;right:10%;top:50%;height:4px;background:linear-gradient(90deg,rgba(255,255,255,.12),rgba(255,255,255,.2),rgba(255,255,255,.12));border-radius:999px}
.stop{position:absolute;top:50%;transform:translate(-50%,-50%);width:76px;height:76px;border-radius:24px;background:rgba(255,255,255,.08);border:1px solid var(--line);display:grid;place-items:center;box-shadow:0 10px 24px rgba(0,0,0,.18)}
.stop small{position:absolute;bottom:-22px;font-size:11px;color:var(--muted)}
.stop.on{background:linear-gradient(135deg,rgba(124,58,237,.95),rgba(236,72,153,.95));box-shadow:0 0 28px rgba(236,72,153,.28)}
.avatar{position:absolute;top:50%;transform:translate(-50%,-50%);width:54px;height:54px;border-radius:18px;display:grid;place-items:center;font-size:32px;z-index:3;transition:left .55s cubic-bezier(.16,1,.3,1)}
.avatar .glow{position:absolute;inset:-10px;border-radius:22px;background:radial-gradient(circle,rgba(56,189,248,.23),transparent 70%);filter:blur(2px)}
.avatar span{position:relative;animation:avatarBob 1.8s ease-in-out infinite}
@keyframes avatarBob{50%{transform:translateY(-3px) rotate(-2deg)}}
.treasure{position:absolute;width:46px;height:46px;border-radius:16px;background:linear-gradient(135deg,#f59e0b,#fbbf24);display:grid;place-items:center;font-size:24px;box-shadow:0 0 18px rgba(251,191,36,.3);animation:treasureFloat 2.4s ease-in-out infinite}
@keyframes treasureFloat{50%{transform:translateY(-8px) rotate(4deg)}}
.key{position:absolute;width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#38bdf8,#7c3aed);display:grid;place-items:center;font-size:16px;box-shadow:0 0 14px rgba(56,189,248,.3)}
.lockDoor{position:absolute;right:24px;bottom:18px;width:160px;height:126px;border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03));border:1px solid var(--line);display:grid;place-items:center;font-size:64px;box-shadow:0 10px 24px rgba(0,0,0,.18)}
.lockDoor.open{background:linear-gradient(135deg,rgba(34,197,94,.20),rgba(56,189,248,.16));border-color:rgba(34,197,94,.55)}
.bossArt{position:absolute;right:18px;top:16px;font-size:70px;filter:drop-shadow(0 10px 22px rgba(0,0,0,.18));animation:bossFloat 2.8s ease-in-out infinite;opacity:.98}
@keyframes bossFloat{50%{transform:translateY(-8px) scale(1.03)}}
.bossAura{position:absolute;inset:auto 18px 18px auto;width:220px;height:220px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,248,.16),transparent 62%);filter:blur(1px)}
.bossBar{position:absolute;left:12px;right:12px;bottom:12px;height:14px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid var(--line);overflow:hidden}
.bossFill{height:100%;width:0%;background:linear-gradient(90deg,#22c55e,#38bdf8,#a855f7);transition:width .3s ease}
#bossMsg,#reward,#toast,#combo,#hintMsg,#bossDistance,#petMsg{position:fixed;left:50%;transform:translateX(-50%);z-index:25;pointer-events:none;opacity:0;transition:.22s}
#toast{top:18px;background:linear-gradient(135deg,#7c3aed,#ec4899);padding:10px 16px;border-radius:999px;font-weight:900}
#combo{top:50%;font-size:clamp(2rem,6vw,4rem);font-weight:900;color:#fbbf24;text-shadow:0 0 18px rgba(251,191,36,.45)}
#reward{bottom:18px;background:rgba(255,255,255,.08);border:1px solid var(--line);padding:10px 14px;border-radius:999px}
#bossMsg{top:80px;font-size:clamp(1.3rem,4vw,2.6rem);font-weight:1000;color:#ffe59a;text-shadow:0 0 16px rgba(251,191,36,.28)}
#hintMsg{top:128px;background:rgba(255,255,255,.08);border:1px solid var(--line);padding:8px 12px;border-radius:999px;font-size:13px;color:#fff}
#bossDistance{top:164px;background:rgba(34,197,94,.14);border:1px solid rgba(34,197,94,.35);padding:8px 12px;border-radius:999px;font-size:13px;color:#d9ffe8}
#petMsg{right:14px;bottom:14px;transform:none;background:rgba(255,255,255,.08);border:1px solid var(--line);padding:10px 12px;border-radius:18px 18px 18px 6px;max-width:260px;line-height:1.3}
.show{opacity:1}
.particle{position:fixed;border-radius:50%;pointer-events:none;z-index:30;animation:fly .8s ease-out forwards}
@keyframes fly{to{transform:translate(var(--x),var(--y)) scale(0);opacity:0}}
#pet{position:fixed;right:16px;bottom:16px;z-index:15;width:96px;height:96px;display:grid;place-items:center;font-size:58px;filter:drop-shadow(0 10px 18px rgba(0,0,0,.22));animation:petBob 2.2s ease-in-out infinite}
@keyframes petBob{50%{transform:translateY(-8px) rotate(-2deg)}}
#pet .ring{position:absolute;inset:-6px;border-radius:24px;border:1px dashed rgba(255,255,255,.15);animation:spin 16s linear infinite}
#pet .pulse{position:absolute;inset:12px;border-radius:20px;background:radial-gradient(circle,rgba(56,189,248,.18),transparent 70%);animation:petPulse 2.6s ease-in-out infinite}
@keyframes petPulse{50%{transform:scale(1.15);opacity:.65}}
</style>
</head>
<body>
<canvas id="bg"></canvas>
<div id="ui">
  <div id="toast"></div><div id="combo"></div><div id="reward"></div><div id="bossMsg"></div><div id="hintMsg"></div><div id="bossDistance"></div><div id="petMsg"></div>
  <div id="pet"><div class="ring"></div><div class="pulse"></div><span id="petFace">🧚</span></div>
  <div id="start" class="screen">
    <div class="card">
      <div class="title">ImaginaQuest Luxury</div>
      <div class="sub">Adventure first, worksheet last. Elegant boss, clear choices, more space, more delight. 🌌</div>
      <div class="heroWrap">
        <div class="hero"><div class="spark"></div><div class="halo"></div></div>
        <div style="max-width:500px;min-width:min(500px,92vw)">
          <div class="sub" style="text-align:left">Explore scenes, collect 3 keys, find hidden treasure, and meet a classy final boss. ✨</div>
          <div id="map"></div>
        </div>
      </div>
      <div style="display:flex;justify-content:center;margin-top:10px"><button class="btn" id="playBtn">▶ ENTER QUEST</button></div>
    </div>
  </div>
  <div id="game" class="screen hide">
    <div class="topbar">
      <div class="pill">⭐ <span id="score">0</span></div>
      <div class="pill" id="levelPill">Lv 1</div>
      <div class="pill">❤️ <span id="lives">3</span></div>
    </div>
    <div class="card" style="margin-top:36px">
      <div class="bar"><div class="fill" id="prog"></div></div>
      <div class="hud">
        <div class="pill">🗝️ <span id="keys">0</span>/3</div>
        <div class="pill">🪙 <span id="coins">0</span></div>
        <div class="pill">✨ <span id="comboNum">0</span></div>
        <div class="ring"><svg width="56" height="56" viewBox="0 0 56 56"><circle cx="28" cy="28" r="22" fill="none" stroke="rgba(255,255,255,.12)" stroke-width="6"></circle><circle id="ringF" cx="28" cy="28" r="22" fill="none" stroke="#22c55e" stroke-linecap="round" stroke-width="6" stroke-dasharray="138.2" stroke-dashoffset="0"></circle></svg><span id="time">30</span></div>
      </div>
      <div class="adventure">
        <div class="scene">
          <div class="sceneTitle" id="sceneTitle">Forest Gate</div>
          <div class="sceneArt" id="sceneArt">🌲</div>
          <div class="bossAura"></div>
          <div class="sceneNotes"><span id="sceneLeft">collect</span><span id="sceneRight">choose</span></div>
          <div class="bossArt" id="bossArt">🤵‍♂️</div>
          <div class="bossBar"><div class="bossFill" id="bossFill"></div></div>
        </div>
        <div class="storyCard">
          <div>
            <div class="storyLine" id="storyLine">A glowing path appears.</div>
            <div class="storyMini" id="storyMini">Choose the best move.</div>
          </div>
          <div class="choiceGrid" id="choices"></div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-start;margin-top:4px">
            <button class="btn" id="hintBtn" style="padding:12px 18px;font-size:14px;background:linear-gradient(135deg,#38bdf8,#7c3aed)">💡 Hint -20</button>
            <button class="btn" id="skipBtn" style="padding:12px 18px;font-size:14px;background:linear-gradient(135deg,#f59e0b,#ec4899)">⏭️ Skip -30</button>
          </div>
        </div>
      </div>
    </div>
    <div id="mapScene"></div>
  </div>
  <div id="end" class="screen hide">
    <div class="card" style="text-align:center">
      <div style="font-size:4rem">🏆</div>
      <div class="title" id="rank">Cosmic Imaginator</div>
      <div class="sub" id="stats">0</div>
      <div id="endingLine" class="sub" style="margin-top:8px;font-weight:700;color:#fff"></div>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:10px"><button class="btn" id="again">↻ PLAY AGAIN</button></div>
    </div>
  </div>
</div>
<script>
const SCENES=[{title:'Forest Gate',art:'🌲',left:'treasure',right:'path'},{title:'Cloud Steps',art:'☁️',left:'drift',right:'jump'},{title:'Moon Pond',art:'🌙',left:'reflect',right:'glow'},{title:'Crystal Cave',art:'💎',left:'echo',right:'shimmer'},{title:'Sky Ship',art:'🚀',left:'fly',right:'dock'}];
const Q=[{scene:0,p:'🔴🔵🔴🔵🔴',c:['🔵','Blue'],w:[['🔴','Red'],['🟢','Green'],['🟡','Yellow']],story:'The forest pulses in rhythm.'},{scene:0,p:'🐛→❓→🦋',c:['🫥','Cocoon'],w:[['🌸','Flower'],['🪨','Stone'],['🍂','Leaf']],story:'A hidden shell glows under moss.'},{scene:0,p:'🌱+☀️+💧=?',c:['🌸','Bloom'],w:[['🪨','Rock'],['🔥','Fire'],['🧊','Ice']],story:'A seed asks for help.'},{scene:0,p:'🌸→🐝→❓',c:['🍯','Honey'],w:[['🧊','Ice'],['🔥','Fire'],['🌧️','Rain']],story:'Flowers hide a sweet secret.'},{scene:1,p:'⭐🌙⭐🌙⭐',c:['🌙','Moon'],w:[['⭐','Star'],['☀️','Sun'],['💧','Drop']],story:'Clouds make a staircase.'},{scene:1,p:'☁️→🌧️→🌈',c:['✨','Magic'],w:[['❄️','Snow'],['🔥','Fire'],['🪨','Stone']],story:'The sky opens a secret door.'},{scene:1,p:'🟥🟩🟥🟩🟥',c:['🟩','Green'],w:[['🟥','Red'],['🟦','Blue'],['🟨','Yellow']],story:'The forest path blinks.'},{scene:1,p:'🛰️→🌌→❓',c:['🪐','Planet'],w:[['🌈','Rainbow'],['🏠','House'],['🍞','Bread']],story:'A planet blinks in the sky.'},{scene:2,p:'🌧️ comes from ❓',c:['☁️','Clouds'],w:[['🔥','Fire'],['🪨','Rock'],['🌈','Rainbow']],story:'Moonlight ripples in water.'},{scene:2,p:'💧→❓→⛅',c:['🌊','Ocean'],w:[['☀️','Sun'],['❄️','Ice'],['🌲','Tree']],story:'A quiet pond starts speaking.'},{scene:2,p:'😊+🎁=?',c:['🥰','Joy'],w:[['😢','Sad'],['😠','Angry'],['😱','Scared']],story:'A moon spirit offers a gift.'},{scene:2,p:'🐁<🐈<❓',c:['🐘','Elephant'],w:[['🐕','Dog'],['🦊','Fox'],['🐇','Rabbit']],story:'A giant shadow crosses the clouds.'},{scene:3,p:'🏔️→🪞→❓',c:['💎','Gem'],w:[['🌊','Wave'],['🌧️','Rain'],['🪨','Rock']],story:'Crystals sing softly.'},{scene:3,p:'🏠↔❓',c:['🧱','Bricks'],w:[['🪵','Wood'],['🌿','Leaves'],['💎','Crystal']],story:'The cave wants a key.'},{scene:3,p:'🍞 comes from ❓',c:['🌾','Wheat'],w:[['🥛','Milk'],['🥚','Egg'],['🍯','Honey']],story:'A glowing recipe appears.'},{scene:3,p:'🧠+💡=?',c:['🎨','Idea'],w:[['🔥','Fire'],['🌧️','Rain'],['🪨','Stone']],story:'The cave reward is a thought.'},{scene:4,p:'🌟✨🌟✨❓',c:['✨','Spark'],w:[['🌙','Moon'],['🪨','Stone'],['🐠','Fish']],story:'The sky ship awakens.'},{scene:4,p:'🧠💡🧠💡❓',c:['💡','Idea'],w:[['🔥','Fire'],['🌧️','Rain'],['🪵','Wood']],story:'The captain asks for a brilliant idea.'},{scene:4,p:'🚀🌌🚀🌌❓',c:['🌌','Space'],w:[['🌈','Rainbow'],['🏠','House'],['🍞','Bread']],story:'The final gate opens.'},{scene:4,p:'👑💎👑💎❓',c:['💎','Gem'],w:[['🪨','Stone'],['🌊','Wave'],['🪵','Wood']],story:'The crown room shines.'},{scene:4,p:'🎁+⭐=?',c:['🏆','Prize'],w:[['🪨','Stone'],['🍞','Bread'],['🧊','Ice']],story:'The last chest is ready.'},{scene:0,p:'🦁🐯🐻🐠',c:['🐠','Fish'],w:[['🦁','Lion'],['🐯','Tiger'],['🐻','Bear']],story:'A strange creature blocks the path.'},{scene:1,p:'🌞🌙🌞🌙🌞',c:['🌙','Moon'],w:[['🌞','Sun'],['⭐','Star'],['🌈','Rainbow']],story:'Night and day dance.'},{scene:2,p:'🌊→🌬️→❓',c:['🏄','Wave'],w:[['🌋','Volcano'],['🌴','Tree'],['🧊','Ice']],story:'The sea responds to the wind.'},{scene:3,p:'🧱+🪵=?',c:['🏠','Home'],w:[['🚗','Car'],['🪞','Mirror'],['🎈','Balloon']],story:'Build a safe place.'},{scene:4,p:'❓→🔥',c:['⚡','Lightning'],w:[['💧','Water'],['❄️','Ice'],['🌬️','Wind']],story:'The cave remembers a storm.'}];
let S={i:0,score:0,lives:3,coins:0,keys:0,combo:0,best:0,correct:0,ans:0,t:30,lock:false,q:[],foundChests:0,bossHp:5};
const el=id=>document.getElementById(id);const bg=el('bg'),cx=bg.getContext('2d');
function resize(){bg.width=innerWidth;bg.height=innerHeight}resize();onresize=resize;
const stars=Array.from({length:220},()=>({x:Math.random()*innerWidth,y:Math.random()*innerHeight,r:Math.random()*1.7+.4,s:Math.random()*0.35+.05,a:Math.random()*6.28,v:Math.random()*0.4+.1}));
function draw(){cx.fillStyle='#060712';cx.fillRect(0,0,bg.width,bg.height);let g=cx.createRadialGradient(bg.width/2,bg.height*.2,0,bg.width/2,bg.height*.4,bg.height);g.addColorStop(0,'rgba(124,58,237,.20)');g.addColorStop(1,'transparent');cx.fillStyle=g;cx.fillRect(0,0,bg.width,bg.height);stars.forEach(s=>{s.a+=s.s;s.y+=(Math.sin(s.a)*s.v)*.15;cx.beginPath();cx.arc(s.x,s.y,s.r,0,7);cx.fillStyle=`rgba(255,255,255,${.35+.65*(.5+.5*Math.sin(s.a))})`;cx.fill()});requestAnimationFrame(draw)}draw();
function sh(a){return a.sort(()=>Math.random()-.5)}
const A={ctx:null};function unlock(){if(!A.ctx)A.ctx=new (AudioContext||webkitAudioContext)();if(A.ctx.state==='suspended')A.ctx.resume()}
['pointerdown','keydown','touchstart'].forEach(e=>addEventListener(e,unlock,{once:true,passive:true}));
function beep(type,f,d,v){try{if(!A.ctx)return;let o=A.ctx.createOscillator(),g=A.ctx.createGain(),fi=A.ctx.createBiquadFilter();fi.type='lowpass';fi.frequency.value=2200;o.type=type;o.frequency.value=f;g.gain.value=v;o.connect(fi).connect(g).connect(A.ctx.destination);o.start();g.gain.exponentialRampToValueAtTime(.001,A.ctx.currentTime+d);o.stop(A.ctx.currentTime+d)}catch(e){}}
function sfx(ok){if(!A.ctx)return; if(ok){[523,659,784].forEach((f,i)=>setTimeout(()=>beep('sine',f,.12,.15),i*55));}else{beep('square',180,.22,.12)}}
function bigWin(){[392,523,659,784,1047].forEach((f,i)=>setTimeout(()=>beep('triangle',f,.11,.13),i*35))}
function rewardSound(){[784,988,1175].forEach((f,i)=>setTimeout(()=>beep('sine',f,.09,.12),i*45))}
function bossSound(){[220,277,330,415].forEach((f,i)=>setTimeout(()=>beep('triangle',f,.14,.08),i*70))}
function map(){el('map').innerHTML='';['1','2','3','BOSS'].forEach((n,i)=>{let d=document.createElement('div');d.className='node'+(i===3?' boss':'');d.innerHTML=(i===3?'👑':'🗺️')+`<small>${n}</small>`;el('map').appendChild(d)})}
map();
function mkQ(){S.q=sh([...Q])}
function level(){return S.i<8?1:S.i<16?2:S.i<24?3:4}
function scr(){el('score').textContent=S.score;el('lives').textContent=S.lives;el('coins').textContent=S.coins;el('keys').textContent=S.keys;el('comboNum').textContent=S.combo;el('prog').style.width=((S.i)/S.q.length*100)+'%';el('levelPill').textContent='Lv '+level();document.querySelectorAll('.node').forEach((n,idx)=>n.classList.toggle('on', idx===Math.min(3, level()-1)));el('bossFill').style.width=((5-S.bossHp)/5*100)+'%';el('bossDistance').textContent='Boss distance: ' + Math.max(0,5-S.bossHp) + ' steps away'}
function toast(t){let x=el('toast');x.textContent=t;x.classList.add('show');clearTimeout(toast.t);toast.t=setTimeout(()=>x.classList.remove('show'),900)}
function combo(t){let x=el('combo');x.textContent=t;x.classList.add('show');clearTimeout(combo.t);combo.t=setTimeout(()=>x.classList.remove('show'),850)}
function reward(t){let x=el('reward');x.textContent=t;x.classList.add('show');clearTimeout(reward.t);reward.t=setTimeout(()=>x.classList.remove('show'),1200)}
function boss(t){let x=el('bossMsg');x.textContent=t;x.classList.add('show');clearTimeout(boss.t);boss.t=setTimeout(()=>x.classList.remove('show'),1200);el('petFace').textContent='👑'}
function pet(t){let x=el('petMsg');x.textContent=t;x.classList.add('show');clearTimeout(pet.t);pet.t=setTimeout(()=>x.classList.remove('show'),1200)}
function hint(t){let x=el('hintMsg');x.textContent=t;x.classList.add('show');clearTimeout(hint.t);hint.t=setTimeout(()=>x.classList.remove('show'),1200)}
function particle(x,y,c){for(let i=0;i<14;i++){let p=document.createElement('div');p.className='particle';let a=Math.random()*6.28,d=28+Math.random()*78;p.style.cssText=`left:${x}px;top:${y}px;width:${6+Math.random()*8}px;height:${6+Math.random()*8}px;background:${c};--x:${Math.cos(a)*d}px;--y:${Math.sin(a)*d}px`;document.body.appendChild(p);setTimeout(()=>p.remove(),900)}}
const stops=[15,40,65,90,115];
function buildMap(){let m=el('mapScene');m.innerHTML='';let p=document.createElement('div');p.className='path';m.appendChild(p);stops.forEach((x,i)=>{let s=document.createElement('div');s.className='stop';s.style.left=x+'%';s.innerHTML=(i<3?'🗝️':'🎁')+`<small>${i+1}</small>`;m.appendChild(s)});let door=document.createElement('div');door.className='lockDoor';door.id='door';door.textContent='🔒';m.appendChild(door);let av=document.createElement('div');av.className='avatar';av.id='avatar';av.innerHTML='<div class="glow"></div><span>🧚</span>';m.appendChild(av);[...Array(3)].forEach((_,i)=>{let t=document.createElement('div');t.className='treasure';t.textContent='🎁';t.style.left=(20+i*22)+'%';t.style.top=(25+((i%2)*38))+'%';m.appendChild(t)});let k=document.createElement('div');k.className='key';k.textContent='🗝️';k.style.left='58%';k.style.top='38%';m.appendChild(k)}
buildMap();
function moveAvatar(){el('avatar').style.left=stops[Math.min(S.keys,3)]+'%';[...document.querySelectorAll('.stop')].forEach((s,i)=>s.classList.toggle('on',i===Math.min(S.i/8,3)))}
function render(){let q=S.q[S.i];if(!q)return end();S.lock=false;let sc=SCENES[q.scene];el('sceneTitle').textContent=sc.title;el('sceneArt').textContent=sc.art;el('sceneLeft').textContent=sc.left;el('sceneRight').textContent=sc.right;el('storyLine').textContent=q.story;el('storyMini').textContent=S.keys<3?'Find keys + solve scenes.':'The final door is waiting.';let ops=sh([[...q.c],[...q.w[0]],[...q.w[1]],[...q.w[2]]]);el('choices').innerHTML='';ops.forEach(o=>{let b=document.createElement('button');b.className='choice';b.innerHTML=`<div class="e">${o[0]}</div><div class="l">${o[1]}</div>`;b.title=o[1];b.onclick=()=>pick(o,b);el('choices').appendChild(b)});S.t=30;time();clearInterval(S.tm);S.tm=setInterval(()=>{S.t-=.1;time();if(S.t<=0&&!S.lock){S.lock=true;S.lives--;S.combo=0;S.ans++;pet('⏳ Keep exploring!');scr();sfx(false);next()}} ,100);scr();moveAvatar();if(S.i>=24)boss('🤵‍♂️ Elegant boss waiting');else if([8,16].includes(S.i))pet('🌟 New zone!')}
function time(){let p=S.t/30;el('time').textContent=Math.ceil(S.t);el('ringF').style.strokeDashoffset=138.2*(1-p);el('ringF').style.stroke=p>.5?'#22c55e':p>.25?'#f59e0b':'#ef4444'}
function openSecret(){if(S.foundChests<3){S.foundChests++;S.coins+=5;S.score+=120;reward('🎁 Secret chest!');rewardSound();pet('🔓 Hidden!');moveAvatar();scr();if(S.foundChests===3){S.keys=3;reward('🗝️ All keys!');rewardSound();el('door').classList.add('open');el('door').textContent='🚪';hint('Final door is open');}}}
function pick(o,b){if(S.lock)return;S.lock=true;clearInterval(S.tm);S.ans++;let q=S.q[S.i],ok=o[0]===q.c[0];document.querySelectorAll('.choice').forEach(z=>{if(z.textContent.includes(q.c[0]))z.classList.add('good')});if(ok){b.classList.add('good');S.correct++;S.combo++;S.best=Math.max(S.best,S.combo);let gain=100+Math.round(S.t*5)+(S.combo>1?(S.combo-1)*18:0);S.score+=gain;S.coins+=1;sfx(true);bigWin();let r=b.getBoundingClientRect();particle(r.left+r.width/2,r.top+r.height/2,'#22c55e');if(S.combo>=3)combo('✨ x'+S.combo+'!');if(S.combo===5){reward('🪙 Treasure');rewardSound()}if(S.combo===8){reward('💎 Gem Found');rewardSound()}if(S.score>=1000&&S.best>=4){reward('🎁 Epic Chest');rewardSound()}if(S.i>=24){reward('👑 Final opened');rewardSound()} if(S.keys<3&&Math.random()>.42){S.keys++;pet('🗝️ Key found!');if(S.keys===3){el('door').classList.add('open');el('door').textContent='🚪';reward('🚪 Door ready');rewardSound()}} else if(Math.random()>.72){openSecret()} S.bossHp=Math.max(0,S.bossHp-1);scr();hint(`Boss is ${5-S.bossHp}/5 steps away`);pet('🌈 Great choice!')}else{b.classList.add('bad');S.lives--;S.combo=0;sfx(false);let r=b.getBoundingClientRect();particle(r.left+r.width/2,r.top+r.height/2,'#ef4444');pet('💫 Try another path!');if(Math.random()>.55){S.score=Math.max(0,S.score-20);hint('Hint used: -20 score')}}scr();moveAvatar();setTimeout(next,900)}
function next(){S.i++;if(S.lives<=0||S.i>=S.q.length)return end();if(S.i>=24){boss('🤵‍♂️ Elegant boss waiting');bossSound()}render()}
function end(){clearInterval(S.tm);el('game').classList.add('hide');el('end').classList.remove('hide');let acc=S.ans?Math.round(S.correct/S.ans*100):0;let ending='';if(S.keys>=3&&acc>=80)ending='You opened the final door and found the sky treasure!';else if(S.keys>=3)ending='You opened the final door, but the stars were shy.';else ending='You explored the world and collected many sparks.';el('rank').textContent=acc>=90?'Cosmic Imaginator':acc>=75?'Star Dreamer':acc>=60?'Vision Seeker':acc>=40?'Explorer':'Dream Apprentice';el('stats').textContent=`⭐ ${S.score}   •   🎯 ${acc}%   •   🔥 x${S.best}   •   🗝️ ${S.keys}/3`;el('endingLine').textContent=ending;pet('🌟 Quest complete!')}
function start(){unlock();S={i:0,score:0,lives:3,coins:0,keys:0,combo:0,best:0,correct:0,ans:0,t:30,lock:false,q:[],foundChests:0,bossHp:5};mkQ();el('start').classList.add('hide');el('end').classList.add('hide');el('game').classList.remove('hide');toast('QUEST START');pet('🧚 Follow the light!');el('door').classList.remove('open');el('door').textContent='🔒';el('bossFill').style.width='0%';el('bossDistance').textContent='Boss distance: 5 steps away';render();sfx(true)}
el('playBtn').onclick=start;el('again').onclick=start;el('hintBtn').onclick=()=>{if(S.score>=20){S.score-=20;hint('Clue revealed');pet('💡 Hint used');scr()}};el('skipBtn').onclick=()=>{if(S.score>=30&&!S.lock){S.score-=30;S.combo=0;S.ans++;pet('⏭️ Skipped');scr();next()}};
</script>
</body>
</html>
<style>@media (min-width: 1100px){.adventure{grid-template-columns:minmax(370px,.88fr) minmax(640px,1.12fr)} .storyCard{padding:18px}} @media (max-width: 900px){.adventure{grid-template-columns:1fr}.scene,.storyCard{min-height:360px}.choice{min-height:86px}}</style>

<style>.choice{padding:10px 12px}.choice .l{word-break:break-word}</style>

<style>.choiceGrid{grid-auto-rows:minmax(118px,auto)} .choice .l{display:block}</style>
