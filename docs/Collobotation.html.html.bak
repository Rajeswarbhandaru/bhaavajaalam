<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Partner With Bhāva Tech | Collaborate</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
  <style>
    :root {
      --primary:    #6c3fcf;
      --secondary:  #f5a623;
      --accent1:    #00c2cb;
      --accent2:    #e94f77;
      --accent3:    #43c59e;
      --dark:       #1a1035;
      --light:      #f8f6ff;
      --glass:      rgba(255,255,255,0.12);
      --card-bg:    rgba(255,255,255,0.97);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--dark);
      color: #fff;
      overflow-x: hidden;
    }

    /* ─── ANIMATED BACKGROUND ─── */
    .bg-wrap {
      position: fixed; inset: 0; z-index: 0;
      background: linear-gradient(135deg, #1a1035 0%, #2d1b6e 40%, #0d2b52 100%);
      overflow: hidden;
    }
    .orb {
      position: absolute; border-radius: 50%;
      filter: blur(80px); opacity: 0.35; animation: drift 12s ease-in-out infinite;
    }
    .orb1 { width:520px; height:520px; background:#6c3fcf; top:-120px; left:-100px; animation-delay:0s; }
    .orb2 { width:400px; height:400px; background:#00c2cb; bottom:-100px; right:-80px; animation-delay:-4s; }
    .orb3 { width:300px; height:300px; background:#e94f77; top:40%; left:60%; animation-delay:-8s; }
    @keyframes drift {
      0%,100% { transform: translate(0,0) scale(1); }
      33%      { transform: translate(40px,-30px) scale(1.08); }
      66%      { transform: translate(-30px,40px) scale(0.95); }
    }

    /* floating particles */
    .particles { position:fixed; inset:0; z-index:0; pointer-events:none; }
    .particle {
      position:absolute; border-radius:50%;
      background: rgba(255,255,255,0.6);
      animation: floatUp linear infinite;
    }

    @keyframes floatUp {
      0%   { transform: translateY(100vh) scale(0); opacity:0; }
      10%  { opacity:1; }
      90%  { opacity:0.4; }
      100% { transform: translateY(-10vh) scale(1); opacity:0; }
    }

    /* ─── NAVBAR ─── */
    nav {
      position: fixed; top:0; left:0; right:0; z-index:1000;
      padding: 16px 40px;
      display: flex; align-items:center; justify-content:space-between;
      background: rgba(26,16,53,0.7);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .nav-logo { display:flex; align-items:center; gap:12px; text-decoration:none; }
    .nav-logo-icon {
      width:40px; height:40px; border-radius:10px;
      background: linear-gradient(135deg, var(--primary), var(--accent1));
      display:grid; place-items:center;
      font-size:20px; box-shadow:0 4px 15px rgba(108,63,207,0.5);
    }
    .nav-logo span { font-family:'Playfair Display',serif; font-size:1.3rem; color:#fff; }
    .nav-back {
      display:flex; align-items:center; gap:8px;
      color:rgba(255,255,255,0.7); text-decoration:none;
      font-size:0.88rem; font-weight:500;
      padding:8px 18px; border-radius:20px;
      border:1px solid rgba(255,255,255,0.2);
      transition: all 0.3s;
    }
    .nav-back:hover { background:rgba(255,255,255,0.1); color:#fff; }

    /* ─── HERO ─── */
    .hero {
      position:relative; z-index:1;
      min-height: 100vh;
      display:flex; flex-direction:column;
      align-items:center; justify-content:center;
      text-align:center; padding: 120px 20px 60px;
    }
    .hero-badge {
      display:inline-flex; align-items:center; gap:8px;
      background: rgba(255,255,255,0.1);
      border:1px solid rgba(255,255,255,0.2);
      backdrop-filter:blur(10px);
      padding:8px 20px; border-radius:50px;
      font-size:0.82rem; font-weight:600; letter-spacing:1.5px;
      text-transform:uppercase; color:var(--secondary);
      margin-bottom:24px;
      animation: fadeSlideDown 0.8s ease both;
    }
    .hero h1 {
      font-family:'Playfair Display',serif;
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      font-weight:800; line-height:1.15;
      background: linear-gradient(135deg, #fff 0%, #c9b3ff 50%, var(--accent1) 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      background-clip:text;
      animation: fadeSlideDown 0.9s ease 0.15s both;
    }
    .hero p {
      margin-top:20px; font-size:1.1rem; color:rgba(255,255,255,0.72);
      max-width:620px; line-height:1.8;
      animation: fadeSlideDown 1s ease 0.3s both;
    }

    /* partnership pills */
    .partner-pills {
      display:flex; flex-wrap:wrap; gap:12px;
      justify-content:center; margin-top:36px;
      animation: fadeSlideDown 1s ease 0.5s both;
    }
    .pill {
      display:flex; align-items:center; gap:8px;
      padding: 10px 20px; border-radius:40px;
      font-size:0.85rem; font-weight:600;
      cursor:pointer; transition: all 0.3s;
      border:2px solid transparent;
    }
    .pill:hover { transform:translateY(-3px); box-shadow:0 8px 25px rgba(0,0,0,0.3); }
    .pill-school   { background:rgba(108,63,207,0.25); border-color:rgba(108,63,207,0.6); color:#c9b3ff; }
    .pill-college  { background:rgba(0,194,203,0.2);   border-color:rgba(0,194,203,0.5);  color:#7ff5f9; }
    .pill-research { background:rgba(245,166,35,0.2);  border-color:rgba(245,166,35,0.5); color:#ffd580; }
    .pill-ngo      { background:rgba(67,197,158,0.2);  border-color:rgba(67,197,158,0.5); color:#a0f5d8; }
    .pill-edtech   { background:rgba(233,79,119,0.2);  border-color:rgba(233,79,119,0.5); color:#ffadc4; }
    .pill-indiv    { background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.3);color:#fff; }

    .hero-scroll {
      margin-top:50px; display:flex; flex-direction:column;
      align-items:center; gap:8px; color:rgba(255,255,255,0.4);
      font-size:0.78rem; animation: fadeSlideDown 1s ease 0.7s both;
    }
    .scroll-dot {
      width:24px; height:40px; border:2px solid rgba(255,255,255,0.3);
      border-radius:12px; display:grid; place-items:start center; padding-top:6px;
    }
    .scroll-dot::after {
      content:''; width:4px; height:8px; background:#fff;
      border-radius:2px; animation: scrollBounce 1.6s ease-in-out infinite;
    }
    @keyframes scrollBounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(10px)} }

    /* ─── WHY PARTNER ─── */
    .why-section {
      position:relative; z-index:1;
      padding: 80px 20px;
      text-align:center;
    }
    .section-label {
      font-size:0.75rem; font-weight:700; letter-spacing:3px;
      text-transform:uppercase; color:var(--accent1); margin-bottom:12px;
    }
    .section-title {
      font-family:'Playfair Display',serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight:800; color:#fff; margin-bottom:12px;
    }
    .section-sub {
      color:rgba(255,255,255,0.6); font-size:1rem; max-width:500px;
      margin:0 auto 50px;
    }

    .why-grid {
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap:24px; max-width:1100px; margin:0 auto;
    }
    .why-card {
      background: var(--glass);
      border:1px solid rgba(255,255,255,0.12);
      backdrop-filter:blur(20px);
      border-radius:20px; padding:36px 28px;
      text-align:left; transition: all 0.4s;
      animation: fadeSlideUp 0.6s ease both;
    }
    .why-card:hover {
      transform:translateY(-8px);
      border-color:rgba(255,255,255,0.3);
      background:rgba(255,255,255,0.16);
    }
    .why-icon {
      width:54px; height:54px; border-radius:14px;
      display:grid; place-items:center; font-size:1.5rem;
      margin-bottom:18px;
    }
    .why-card h3 { font-size:1.05rem; font-weight:700; margin-bottom:8px; color:#fff; }
    .why-card p  { font-size:0.88rem; color:rgba(255,255,255,0.6); line-height:1.7; }

    /* ─── WHAT WE OFFER ─── */
    .offer-section {
      position:relative; z-index:1;
      padding:80px 20px; background:rgba(0,0,0,0.2);
    }
    .collab-types {
      display:grid;
      grid-template-columns: repeat(auto-fit, minmax(190px,1fr));
      gap:20px; max-width:1100px; margin:0 auto;
    }
    .collab-card {
      border-radius:18px; padding:28px 20px;
      text-align:center; cursor:pointer;
      transition: all 0.35s; border:2px solid transparent;
      animation: fadeSlideUp 0.6s ease both;
    }
    .collab-card:hover { transform:translateY(-6px) scale(1.03); }
    .collab-card .cc-icon { font-size:2.4rem; margin-bottom:14px; }
    .collab-card h4 { font-size:0.95rem; font-weight:700; margin-bottom:6px; }
    .collab-card p  { font-size:0.78rem; line-height:1.6; opacity:0.85; }

    .cc-school   { background:linear-gradient(135deg,#3a1d96,#6c3fcf); color:#e8dfff; border-color:#6c3fcf; }
    .cc-college  { background:linear-gradient(135deg,#005f73,#00c2cb); color:#ccfafc; border-color:#00c2cb; }
    .cc-research { background:linear-gradient(135deg,#7b4f00,#f5a623); color:#fff5d6; border-color:#f5a623; }
    .cc-ngo      { background:linear-gradient(135deg,#1b4332,#43c59e); color:#d4f7ec; border-color:#43c59e; }
    .cc-edtech   { background:linear-gradient(135deg,#6b0f2b,#e94f77); color:#ffd6e3; border-color:#e94f77; }
    .cc-indiv    { background:linear-gradient(135deg,#2a2a4a,#5b5b9e); color:#e0e0ff; border-color:#5b5b9e; }

    /* ─── FORM SECTION ─── */
    .form-section {
      position:relative; z-index:1;
      padding:80px 20px 100px;
    }
    .form-container {
      max-width:820px; margin:0 auto;
      background:var(--card-bg);
      border-radius:28px; overflow:hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,0.5);
      animation: fadeSlideUp 0.8s ease both;
    }
    .form-header {
      padding:40px 48px 30px;
      background:linear-gradient(135deg, #6c3fcf, #00c2cb);
      text-align:center;
    }
    .form-header h2 {
      font-family:'Playfair Display',serif;
      font-size:1.9rem; font-weight:800; color:#fff; margin-bottom:8px;
    }
    .form-header p { color:rgba(255,255,255,0.85); font-size:0.93rem; }

    .form-progress {
      display:flex; align-items:center; justify-content:center;
      gap:0; padding:0 48px;
      background:#fff; border-bottom:1px solid #eee;
    }
    .step-item {
      display:flex; align-items:center; gap:8px;
      padding:18px 20px; font-size:0.8rem; font-weight:600;
      color:#aaa; cursor:pointer; transition:all 0.3s;
      border-bottom:3px solid transparent;
    }
    .step-item.active { color:var(--primary); border-bottom-color:var(--primary); }
    .step-item.done   { color:var(--accent3); border-bottom-color:var(--accent3); }
    .step-num {
      width:26px; height:26px; border-radius:50%;
      display:grid; place-items:center;
      background:#eee; font-size:0.75rem; font-weight:700; transition:all 0.3s;
    }
    .step-item.active .step-num { background:var(--primary); color:#fff; }
    .step-item.done   .step-num { background:var(--accent3); color:#fff; }

    form { padding:40px 48px; }
    .form-step { display:none; }
    .form-step.active { display:block; animation: stepIn 0.4s ease both; }
    @keyframes stepIn { from{opacity:0;transform:translateX(30px)} to{opacity:1;transform:translateX(0)} }

    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px; }
    .form-row.full { grid-template-columns:1fr; }

    .field-group { display:flex; flex-direction:column; gap:6px; }
    .field-group label {
      font-size:0.82rem; font-weight:600; color:#4a4a6a;
      display:flex; align-items:center; gap:6px;
    }
    .field-group label .req { color:var(--accent2); }
    .field-group input,
    .field-group select,
    .field-group textarea {
      padding:13px 16px; border-radius:12px;
      border:2px solid #e8e4f4;
      font-family:'Poppins',sans-serif; font-size:0.88rem; color:#2a2a4a;
      background:#faf9ff; outline:none; transition:all 0.3s;
      width:100%;
    }
    .field-group input:focus,
    .field-group select:focus,
    .field-group textarea:focus {
      border-color:var(--primary);
      box-shadow:0 0 0 4px rgba(108,63,207,0.1);
      background:#fff;
    }
    .field-group textarea { resize:vertical; min-height:110px; }

    /* checkbox group */
    .check-group-label {
      font-size:0.82rem; font-weight:600; color:#4a4a6a; margin-bottom:10px;
    }
    .check-grid {
      display:grid; grid-template-columns:1fr 1fr;
      gap:10px; margin-bottom:20px;
    }
    .check-item {
      display:flex; align-items:center; gap:10px;
      padding:12px 14px; border-radius:12px;
      border:2px solid #e8e4f4; background:#faf9ff;
      cursor:pointer; transition:all 0.3s; font-size:0.82rem; color:#4a4a6a;
    }
    .check-item:hover { border-color:var(--primary); background:#f3f0ff; }
    .check-item input[type=checkbox] { accent-color:var(--primary); width:16px; height:16px; }
    .check-item.checked { border-color:var(--primary); background:#f0ebff; color:var(--primary); font-weight:600; }

    /* step nav buttons */
    .step-nav {
      display:flex; justify-content:space-between;
      align-items:center; margin-top:32px; gap:16px;
    }
    .btn-prev, .btn-next, .btn-submit {
      padding:14px 32px; border-radius:12px;
      font-family:'Poppins',sans-serif; font-size:0.92rem;
      font-weight:700; cursor:pointer; transition:all 0.3s;
      display:flex; align-items:center; gap:8px; border:none;
    }
    .btn-prev {
      background:transparent; color:#888;
      border:2px solid #ddd;
    }
    .btn-prev:hover { background:#f5f5f5; color:#444; }
    .btn-next {
      background:linear-gradient(135deg,var(--primary),#9b59e8);
      color:#fff; margin-left:auto;
      box-shadow:0 6px 20px rgba(108,63,207,0.4);
    }
    .btn-next:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(108,63,207,0.5); }
    .btn-submit {
      background:linear-gradient(135deg,#f5a623,#e94f77);
      color:#fff; margin-left:auto;
      box-shadow:0 6px 20px rgba(233,79,119,0.4);
    }
    .btn-submit:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(233,79,119,0.5); }
    .btn-submit:disabled { opacity:0.7; cursor:not-allowed; transform:none; }

    /* ─── SUCCESS ─── */
    .success-screen {
      display:none; padding:60px 48px;
      text-align:center; animation: fadeSlideUp 0.6s ease both;
    }
    .success-screen.show { display:block; }
    .success-anim {
      width:90px; height:90px; border-radius:50%;
      background:linear-gradient(135deg,var(--accent3),var(--accent1));
      display:grid; place-items:center; margin:0 auto 28px;
      font-size:2.5rem;
      animation:popIn 0.5s cubic-bezier(.68,-.55,.27,1.55) both;
    }
    @keyframes popIn { from{transform:scale(0)} to{transform:scale(1)} }
    .success-screen h2 {
      font-family:'Playfair Display',serif;
      font-size:2rem; color:#2a2a4a; margin-bottom:14px;
    }
    .success-screen p { color:#666; font-size:0.95rem; line-height:1.8; max-width:480px; margin:0 auto; }
    .success-steps {
      display:flex; justify-content:center; gap:20px;
      flex-wrap:wrap; margin:32px 0;
    }
    .ss-step {
      display:flex; align-items:center; gap:10px;
      background:#f8f6ff; border:1px solid #e8e4f4;
      border-radius:12px; padding:14px 20px;
      font-size:0.83rem; color:#4a4a6a; font-weight:600;
    }
    .ss-step .ss-icon {
      width:32px; height:32px; border-radius:8px;
      background:linear-gradient(135deg,var(--primary),var(--accent1));
      display:grid; place-items:center; color:#fff; font-size:1rem;
    }

    /* ─── FOOTER STRIP ─── */
    .footer-strip {
      position:relative; z-index:1;
      text-align:center; padding:30px 20px;
      border-top:1px solid rgba(255,255,255,0.08);
      color:rgba(255,255,255,0.4); font-size:0.8rem;
    }
    .footer-strip a { color:var(--accent1); text-decoration:none; }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeSlideDown {
      from { opacity:0; transform:translateY(-25px); }
      to   { opacity:1; transform:translateY(0); }
    }
    @keyframes fadeSlideUp {
      from { opacity:0; transform:translateY(25px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width:700px) {
      nav { padding:12px 20px; }
      form { padding:28px 20px; }
      .form-header { padding:28px 20px 20px; }
      .form-progress { padding:0 10px; overflow-x:auto; }
      .step-item { padding:14px 10px; font-size:0.72rem; }
      .form-row { grid-template-columns:1fr; }
      .check-grid { grid-template-columns:1fr; }
      .form-header h2 { font-size:1.4rem; }
      .success-screen { padding:40px 20px; }
      .step-nav { flex-wrap:wrap; }
      .btn-next, .btn-submit { width:100%; justify-content:center; }
    }
  </style>
</head>
<body>

<!-- Background -->
<div class="bg-wrap">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
</div>
<div class="particles" id="particles"></div>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="index.html">
    <div class="nav-logo-icon">🧠</div>
    <span>Bhāva Tech</span>
  </a>
  <a class="nav-back" href="index.html">
    <i class="fas fa-arrow-left"></i> Back to Home
  </a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">✦ Open Collaborations 2026</div>
  <h1>Partner With<br/>Bhāva Tech</h1>
  <p>Join a growing ecosystem of schools, researchers, developers, and changemakers building the future of whole-brain education — together.</p>

  <div class="partner-pills">
    <div class="pill pill-school">🏫 Schools</div>
    <div class="pill pill-college">🎓 Colleges</div>
    <div class="pill pill-research">🔬 Research Orgs</div>
    <div class="pill pill-ngo">🌱 NGOs</div>
    <div class="pill pill-edtech">💻 EdTech</div>
    <div class="pill pill-indiv">🙋 Individuals</div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-dot"></div>
    <span>Scroll to explore</span>
  </div>
</section>

<!-- WHY PARTNER -->
<section class="why-section">
  <div class="section-label">Why Collaborate?</div>
  <div class="section-title">What You Gain</div>
  <p class="section-sub">Every partnership is built on shared purpose — not just paperwork.</p>

  <div class="why-grid">
    <div class="why-card" style="animation-delay:0.1s">
      <div class="why-icon" style="background:rgba(108,63,207,0.2)">🧠</div>
      <h3>World-Class Cognitive Tools</h3>
      <p>Deploy Bhāva's IQ, EQ & SQ assessment games directly in your classrooms or research environments.</p>
    </div>
    <div class="why-card" style="animation-delay:0.2s">
      <div class="why-icon" style="background:rgba(0,194,203,0.2)">📊</div>
      <h3>Research-Grade Data</h3>
      <p>Access anonymised cognitive development data for child psychology studies, B.Ed. projects and academic publications.</p>
    </div>
    <div class="why-card" style="animation-delay:0.3s">
      <div class="why-icon" style="background:rgba(245,166,35,0.2)">🚀</div>
      <h3>Co-Create the Future</h3>
      <p>Build new tools, games, or AI models together — your domain expertise meets our platform and tech stack.</p>
    </div>
    <div class="why-card" style="animation-delay:0.4s">
      <div class="why-icon" style="background:rgba(67,197,158,0.2)">🌍</div>
      <h3>Social Impact at Scale</h3>
      <p>Bring subsidised or free cognitive programs to under-resourced schools, tribal communities, and rural children.</p>
    </div>
    <div class="why-card" style="animation-delay:0.5s">
      <div class="why-icon" style="background:rgba(233,79,119,0.2)">🔗</div>
      <h3>API & White-Label Access</h3>
      <p>Embed Bhāva's language learning and IQ games directly into your own LMS or educational platform.</p>
    </div>
    <div class="why-card" style="animation-delay:0.6s">
      <div class="why-icon" style="background:rgba(255,255,255,0.1)">🏅</div>
      <h3>Official Partner Recognition</h3>
      <p>Get featured as a Bhāva Tech partner — on our homepage, reports and social media, boosting your institution's profile.</p>
    </div>
  </div>
</section>

<!-- COLLAB TYPES -->
<section class="offer-section">
  <div style="max-width:1100px;margin:0 auto;text-align:center">
    <div class="section-label">Who Can Apply?</div>
    <div class="section-title">Collaboration Types</div>
    <p class="section-sub">We welcome every kind of collaborator — big institutions and solo changemakers alike.</p>

    <div class="collab-types">
      <div class="collab-card cc-school" style="animation-delay:0.1s">
        <div class="cc-icon">🏫</div>
        <h4>School Partner</h4>
        <p>Deploy tools, run group sessions, get class-level cognitive reports.</p>
      </div>
      <div class="collab-card cc-college" style="animation-delay:0.2s">
        <div class="cc-icon">🎓</div>
        <h4>Academic Partner</h4>
        <p>Research collaboration, student internships, joint paper publication.</p>
      </div>
      <div class="collab-card cc-research" style="animation-delay:0.3s">
        <div class="cc-icon">🔬</div>
        <h4>Research Partner</h4>
        <p>Co-design studies, share datasets, apply for joint research grants.</p>
      </div>
      <div class="collab-card cc-ngo" style="animation-delay:0.4s">
        <div class="cc-icon">🌱</div>
        <h4>Impact Partner</h4>
        <p>Subsidised tools for underprivileged children and community programs.</p>
      </div>
      <div class="collab-card cc-edtech" style="animation-delay:0.5s">
        <div class="cc-icon">💻</div>
        <h4>Technology Partner</h4>
        <p>API access, white-labelling, integration with your existing platform.</p>
      </div>
      <div class="collab-card cc-indiv" style="animation-delay:0.6s">
        <div class="cc-icon">🙋</div>
        <h4>Individual Collaborator</h4>
        <p>Freelancers, researchers, educators, developers — all welcome.</p>
      </div>
    </div>
  </div>
</section>

<!-- FORM -->
<section class="form-section" id="apply">
  <div style="text-align:center;margin-bottom:48px">
    <div class="section-label">Apply Now</div>
    <div class="section-title">Express Your Interest</div>
    <p class="section-sub">Takes less than 3 minutes. We respond within 48 hours.</p>
  </div>

  <div class="form-container">
    <div class="form-header">
      <h2>🤝 Collaboration Application</h2>
      <p>Bhāva Tech · Open to schools, colleges, research orgs, NGOs, EdTech companies & individuals</p>
    </div>

    <!-- Progress -->
    <div class="form-progress">
      <div class="step-item active" data-step="1">
        <div class="step-num">1</div> About You
      </div>
      <div class="step-item" data-step="2">
        <div class="step-num">2</div> Collaboration
      </div>
      <div class="step-item" data-step="3">
        <div class="step-num">3</div> Contact
      </div>
    </div>

    <form id="collab-form" novalidate>

      <!-- STEP 1 -->
      <div class="form-step active" id="step-1">
        <div class="form-row">
          <div class="field-group">
            <label>Name / Institution Name <span class="req">*</span></label>
            <input type="text" id="org-name" placeholder="e.g. ABC School or Your Full Name" required/>
          </div>
          <div class="field-group">
            <label>Collaborator Type <span class="req">*</span></label>
            <select id="org-type" required>
              <option value="">— Select Type —</option>
              <option>School</option>
              <option>College / University</option>
              <option>Research Organization</option>
              <option>NGO / Social Organization</option>
              <option>EdTech Company</option>
              <option>Independent Educator</option>
              <option>Freelance Developer</option>
              <option>Independent Researcher</option>
              <option>Content Creator / Curriculum Designer</option>
              <option>Other Individual</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="field-group">
            <label>Your Name / Contact Person <span class="req">*</span></label>
            <input type="text" id="contact-name" placeholder="Full name" required/>
          </div>
          <div class="field-group">
            <label>Designation / Role <span class="req">*</span></label>
            <input type="text" id="designation" placeholder="e.g. Principal, PhD Researcher, Developer" required/>
          </div>
        </div>
        <div class="form-row">
          <div class="field-group">
            <label>City <span class="req">*</span></label>
            <input type="text" id="city" placeholder="Your city" required/>
          </div>
          <div class="field-group">
            <label>State / Country <span class="req">*</span></label>
            <input type="text" id="state" placeholder="State or Country" required/>
          </div>
        </div>
        <div class="step-nav">
          <span style="font-size:0.8rem;color:#aaa">Step 1 of 3</span>
          <button type="button" class="btn-next" onclick="goStep(2)">Next <i class="fas fa-arrow-right"></i></button>
        </div>
      </div>

      <!-- STEP 2 -->
      <div class="form-step" id="step-2">
        <div class="check-group-label">Collaboration Interests <span style="color:var(--accent2)">*</span> (select all that apply)</div>
        <div class="check-grid" id="collab-checks">
          <label class="check-item"><input type="checkbox" value="Deploy Tools in Institution"/> 🛠️ Deploy Tools in Institution</label>
          <label class="check-item"><input type="checkbox" value="Research & Data Partnership"/> 🔬 Research & Data Partnership</label>
          <label class="check-item"><input type="checkbox" value="Game / App Development"/> 💻 Game / App Development</label>
          <label class="check-item"><input type="checkbox" value="Content & Curriculum Design"/> ✍️ Content & Curriculum Design</label>
          <label class="check-item"><input type="checkbox" value="Teacher / Facilitator Training"/> 👩‍🏫 Teacher / Facilitator Training</label>
          <label class="check-item"><input type="checkbox" value="Social Impact Program"/> 🌱 Social Impact Program</label>
          <label class="check-item"><input type="checkbox" value="API / White-label Integration"/> 🔗 API / White-label Integration</label>
          <label class="check-item"><input type="checkbox" value="Sanskrit / Language AI (Rishi AI)"/> 🕉️ Sanskrit / Language AI (Rishi AI)</label>
        </div>

        <div class="form-row">
          <div class="field-group">
            <label>Approx. Number of Students / Users</label>
            <input type="number" id="user-count" placeholder="Leave blank if individual" min="0"/>
          </div>
          <div class="field-group">
            <label>Portfolio / LinkedIn / GitHub URL</label>
            <input type="url" id="portfolio" placeholder="https://...  (optional)"/>
          </div>
        </div>
        <div class="form-row full">
          <div class="field-group">
            <label>Brief Message / Proposal <span class="req">*</span></label>
            <textarea id="message" placeholder="Tell us what you bring to the table and what you hope to achieve with Bhāva Tech..." required></textarea>
          </div>
        </div>
        <div class="step-nav">
          <button type="button" class="btn-prev" onclick="goStep(1)"><i class="fas fa-arrow-left"></i> Back</button>
          <button type="button" class="btn-next" onclick="goStep(3)">Next <i class="fas fa-arrow-right"></i></button>
        </div>
      </div>

      <!-- STEP 3 -->
      <div class="form-step" id="step-3">
        <div class="form-row">
          <div class="field-group">
            <label>Email Address <span class="req">*</span></label>
            <input type="email" id="email" placeholder="your@email.com" required/>
          </div>
          <div class="field-group">
            <label>Phone / WhatsApp <span class="req">*</span></label>
            <input type="tel" id="phone" placeholder="+91 XXXXX XXXXX" required/>
          </div>
        </div>
        <div class="form-row full">
          <div class="field-group">
            <label>How did you hear about us?</label>
            <select id="source">
              <option value="">— Select —</option>
              <option>Google Search</option>
              <option>Social Media</option>
              <option>Referral from a Friend / Colleague</option>
              <option>Conference / Event</option>
              <option>Educational Forum</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <!-- Summary preview -->
        <div id="summary-box" style="background:#f8f6ff;border:2px solid #e8e4f4;border-radius:14px;padding:20px 24px;margin-bottom:24px;font-size:0.83rem;color:#4a4a6a;line-height:1.9;display:none;">
          <strong style="color:var(--primary);font-size:0.88rem;">📋 Your Application Summary</strong>
          <div id="summary-content" style="margin-top:10px;"></div>
        </div>

        <div class="step-nav">
          <button type="button" class="btn-prev" onclick="goStep(2)"><i class="fas fa-arrow-left"></i> Back</button>
          <button type="button" class="btn-submit" id="submit-btn" onclick="submitForm()">
            <i class="fas fa-paper-plane"></i> Submit Application
          </button>
        </div>
      </div>

    </form>

    <!-- SUCCESS -->
    <div class="success-screen" id="success-screen">
      <div class="success-anim">✅</div>
      <h2>Application Received!</h2>
      <p>Thank you! Your collaboration interest has been recorded. Our team at Bhāva Tech will review your application and get back to you within <strong>48 hours</strong>.</p>
      <div class="success-steps">
        <div class="ss-step"><div class="ss-icon">✅</div> Submitted</div>
        <div class="ss-step"><div class="ss-icon">📧</div> Check your email</div>
        <div class="ss-step"><div class="ss-icon">📞</div> We call in 48h</div>
      </div>
      <p style="margin-top:12px;font-size:0.82rem;">Meanwhile, you can <a href="https://wa.me/91XXXXXXXXXX?text=Hi!+I+just+applied+for+collaboration+with+Bhāva+Tech" style="color:var(--primary);font-weight:600;">WhatsApp us</a> for faster response.</p>
    </div>

  </div>
</section>

<!-- FOOTER -->
<div class="footer-strip">
  © 2026 Bhāva Tech · Visakhapatnam · <a href="index.html">Back to Home</a>
</div>

<script>
  // ─── PARTICLES ───
  const pContainer = document.getElementById('particles');
  for(let i=0;i<22;i++){
    const p = document.createElement('div');
    p.className='particle';
    const size = Math.random()*4+2;
    p.style.cssText = `
      width:${size}px;height:${size}px;
      left:${Math.random()*100}%;
      animation-duration:${Math.random()*15+10}s;
      animation-delay:${Math.random()*15}s;
      opacity:${Math.random()*0.5+0.1};
    `;
    pContainer.appendChild(p);
  }

  // ─── CHECK ITEMS TOGGLE ───
  document.querySelectorAll('.check-item').forEach(item => {
    item.addEventListener('change', () => {
      item.classList.toggle('checked', item.querySelector('input').checked);
    });
  });

  // ─── STEP NAVIGATION ───
  let currentStep = 1;
  function goStep(n) {
    if(n > currentStep && !validateStep(currentStep)) return;
    document.getElementById('step-'+currentStep).classList.remove('active');
    document.querySelectorAll('.step-item').forEach(s => {
      const sn = parseInt(s.dataset.step);
      s.classList.remove('active','done');
      if(sn === n) s.classList.add('active');
      if(sn < n)  s.classList.add('done');
    });
    currentStep = n;
    document.getElementById('step-'+currentStep).classList.add('active');
    if(n === 3) buildSummary();
    document.querySelector('.form-container').scrollIntoView({behavior:'smooth',block:'start'});
  }

  function validateStep(n) {
    const step = document.getElementById('step-'+n);
    let valid = true;
    step.querySelectorAll('[required]').forEach(el => {
      if(!el.value.trim()) {
        el.style.borderColor = '#e94f77';
        el.focus(); valid = false;
        el.addEventListener('input', ()=>el.style.borderColor='', {once:true});
      }
    });
    if(n===2) {
      const checked = document.querySelectorAll('#collab-checks input:checked');
      if(checked.length === 0) {
        document.querySelector('.check-group-label').style.color='#e94f77';
        valid = false;
        setTimeout(()=>document.querySelector('.check-group-label').style.color='',2000);
      }
    }
    return valid;
  }

  function buildSummary() {
    const interests = [...document.querySelectorAll('#collab-checks input:checked')].map(i=>i.value).join(', ');
    document.getElementById('summary-content').innerHTML = `
      <b>Name/Org:</b> ${v('org-name')} &nbsp;|&nbsp; <b>Type:</b> ${v('org-type')}<br/>
      <b>Contact:</b> ${v('contact-name')} — ${v('designation')}<br/>
      <b>Location:</b> ${v('city')}, ${v('state')}<br/>
      <b>Interests:</b> ${interests || '—'}<br/>
      <b>Message:</b> ${v('message').substring(0,120)}${v('message').length>120?'…':''}
    `;
    document.getElementById('summary-box').style.display='block';
  }

  const v = id => document.getElementById(id)?.value?.trim() || '';

  // ─── SUBMIT ───
  async function submitForm() {
    if(!validateStep(3)) return;
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting…';

    const interests = [...document.querySelectorAll('#collab-checks input:checked')].map(i=>i.value).join('; ');
    const payload = {
      timestamp:     new Date().toLocaleString('en-IN',{timeZone:'Asia/Kolkata'}),
      orgName:       v('org-name'),
      orgType:       v('org-type'),
      contactName:   v('contact-name'),
      designation:   v('designation'),
      city:          v('city'),
      state:         v('state'),
      interests:     interests,
      userCount:     v('user-count'),
      portfolio:     v('portfolio'),
      message:       v('message'),
      email:         v('email'),
      phone:         v('phone'),
      source:        v('source')
    };

    // ── REPLACE THIS URL with your deployed Apps Script Web App URL ──
    const GAS_URL = 'YOUR_APPS_SCRIPT_WEB_APP_URL_HERE';

    try {
      await fetch(GAS_URL, {
        method:'POST',
        body: JSON.stringify(payload)
      });
      document.getElementById('collab-form').style.display='none';
      document.querySelector('.form-progress').style.display='none';
      document.getElementById('success-screen').classList.add('show');
    } catch(err) {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Application';
      alert('Submission failed. Please try again or WhatsApp us directly.');
    }
  }

  // ─── URL PARAM: pre-select type ───
  const params = new URLSearchParams(window.location.search);
  const typeMap = {
    school:'School', college:'College / University',
    research:'Research Organization', ngo:'NGO / Social Organization',
    edtech:'EdTech Company', individual:'Independent Educator'
  };
  const preset = typeMap[params.get('type')];
  if(preset){
    const sel = document.getElementById('org-type');
    [...sel.options].forEach(o=>{ if(o.value===preset) o.selected=true; });
  }

  // ─── INTERSECTION OBSERVER for cards ───
  const observer = new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting) e.target.style.opacity='1'; });
  },{threshold:0.15});
  document.querySelectorAll('.why-card,.collab-card').forEach(c=>{
    c.style.opacity='0'; observer.observe(c);
  });
</script>
</body>
</html>