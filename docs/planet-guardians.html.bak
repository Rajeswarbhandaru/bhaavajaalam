<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Planet Guardians 🌍</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Nunito','Arial Rounded MT Bold',Arial,sans-serif;min-height:100vh;overflow-x:hidden;background:#1a1a2e;}
.screen{display:none;min-height:100vh;width:100%;flex-direction:column;align-items:center;justify-content:center;padding:20px;}
.screen.active{display:flex;}

/* ── INTRO ── */
#intro{background:linear-gradient(160deg,#0d1b2a 0%,#1b2d4f 50%,#0d1b2a 100%);position:relative;overflow:hidden;}
.stars{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;}
.star{position:absolute;border-radius:50%;background:white;}
@keyframes twinkle{0%,100%{opacity:0.2;}50%{opacity:1;}}

.earth-wrap{position:relative;width:200px;height:200px;margin-bottom:24px;z-index:1;}
.earth-globe{width:200px;height:200px;border-radius:50%;
  background:radial-gradient(circle at 35% 35%, #4fc3f7, #1565c0 50%, #0d47a1);
  box-shadow:0 0 50px rgba(79,195,247,0.5),0 0 100px rgba(79,195,247,0.2),inset -20px -20px 40px rgba(0,0,50,0.4);
  display:flex;align-items:center;justify-content:center;font-size:110px;line-height:1;
  animation:floatEarth 4s ease-in-out infinite;position:relative;z-index:1;}
@keyframes floatEarth{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-12px) scale(1.04);}}

/* Continents overlay */
.earth-globe::before{content:"";position:absolute;inset:0;border-radius:50%;
  background:radial-gradient(ellipse 60px 40px at 35% 45%, rgba(76,175,80,0.7) 0%, transparent 100%),
             radial-gradient(ellipse 40px 55px at 62% 40%, rgba(76,175,80,0.6) 0%, transparent 100%),
             radial-gradient(ellipse 30px 25px at 45% 65%, rgba(76,175,80,0.5) 0%, transparent 100%);
  z-index:2;}
.earth-globe::after{content:"";position:absolute;inset:0;border-radius:50%;
  background:linear-gradient(135deg,rgba(255,255,255,0.15) 0%,transparent 50%);z-index:3;}

.orbit-ring{position:absolute;top:50%;left:50%;width:280px;height:280px;
  transform:translate(-50%,-50%);animation:spinRing 12s linear infinite;z-index:0;}
.orbit-animal{position:absolute;font-size:30px;top:50%;left:50%;
  filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));}
.orbit-animal:nth-child(1){transform:translate(-50%,-50%) rotate(0deg)   translateY(-140px);}
.orbit-animal:nth-child(2){transform:translate(-50%,-50%) rotate(90deg)  translateY(-140px);}
.orbit-animal:nth-child(3){transform:translate(-50%,-50%) rotate(180deg) translateY(-140px);}
.orbit-animal:nth-child(4){transform:translate(-50%,-50%) rotate(270deg) translateY(-140px);}
@keyframes spinRing{from{transform:translate(-50%,-50%) rotate(0deg);}to{transform:translate(-50%,-50%) rotate(360deg);}}

.counter-rotate{display:inline-block;animation:counterSpin 12s linear infinite;}
@keyframes counterSpin{from{transform:rotate(0deg);}to{transform:rotate(-360deg);}}

.game-title{font-size:clamp(2rem,6vw,3.8rem);font-weight:900;color:#fff;text-align:center;
  text-shadow:0 0 30px rgba(79,195,247,0.8),0 0 60px rgba(79,195,247,0.3);letter-spacing:2px;z-index:1;}
.game-subtitle{font-size:clamp(0.95rem,3vw,1.3rem);color:#90caf9;text-align:center;
  margin:10px 0 30px;max-width:480px;line-height:1.6;z-index:1;}
.btn-start{background:linear-gradient(135deg,#ff8f00,#ff6f00);color:#fff;border:none;
  padding:18px 52px;border-radius:50px;font-size:1.4rem;font-weight:900;cursor:pointer;
  box-shadow:0 8px 28px rgba(255,111,0,0.55);transition:all 0.3s;z-index:1;
  font-family:'Nunito',Arial,sans-serif;letter-spacing:1px;}
.btn-start:hover{transform:translateY(-5px) scale(1.06);box-shadow:0 16px 40px rgba(255,111,0,0.7);}
.intro-hint{color:#64b5f6;font-size:0.9rem;margin-top:16px;z-index:1;}

/* ── LEARN ── */
#learn{background:linear-gradient(135deg,#1b5e20,#2e7d32);}
.learn-card{background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);border-radius:24px;
  padding:32px;max-width:680px;text-align:center;border:2px solid rgba(255,255,255,0.2);}
.learn-title{font-size:2rem;font-weight:900;color:#ffee58;margin-bottom:18px;}
.concept-box{background:rgba(0,0,0,0.25);border-radius:16px;padding:18px;margin:12px 0;}
.concept-box p{color:#e8f5e9;font-size:1rem;line-height:1.7;}
.big-emoji{font-size:3rem;display:block;margin-bottom:8px;}
.problem-list{list-style:none;text-align:left;margin:12px 0;}
.problem-list li{color:#c8e6c9;font-size:0.95rem;padding:6px 0;display:flex;align-items:flex-start;gap:10px;}
.problem-list li::before{content:"⚠️";flex-shrink:0;}

/* ── GAME SCREEN ── */
#game{background:#0d1b2a;padding:12px 16px 28px;justify-content:flex-start;}
.top-bar{width:100%;max-width:820px;display:flex;align-items:center;gap:12px;
  margin-bottom:12px;flex-wrap:wrap;justify-content:space-between;}
.level-badge{background:rgba(255,255,255,0.12);border-radius:20px;padding:8px 16px;
  color:#fff;font-weight:700;font-size:0.95rem;border:2px solid rgba(255,255,255,0.25);white-space:nowrap;}
.health-wrap{flex:1;min-width:180px;}
.health-label{color:#90caf9;font-size:0.82rem;margin-bottom:4px;
  display:flex;justify-content:space-between;align-items:center;}
.health-bg{height:20px;background:rgba(255,255,255,0.1);border-radius:10px;
  overflow:hidden;border:2px solid rgba(255,255,255,0.15);}
.health-fill{height:100%;border-radius:10px;transition:width 0.8s cubic-bezier(0.34,1.56,0.64,1),background 0.5s;
  background:linear-gradient(90deg,#43a047,#76c442);}
.score-badge{background:rgba(255,193,7,0.18);border:2px solid #ffc107;border-radius:20px;
  padding:8px 16px;color:#ffd54f;font-weight:700;white-space:nowrap;}
.prog-dots{display:flex;gap:7px;justify-content:center;margin-bottom:10px;}
.dot{width:11px;height:11px;border-radius:50%;background:rgba(255,255,255,0.18);transition:all 0.3s;}
.dot.done{background:#66bb6a;}
.dot.active{background:#ffc107;transform:scale(1.35);}

.scene-card{width:100%;max-width:820px;background:rgba(255,255,255,0.05);
  border-radius:22px;padding:20px;margin-bottom:14px;border:1px solid rgba(255,255,255,0.1);position:relative;}
.scene-emoji-bg{position:absolute;top:10px;right:15px;font-size:70px;opacity:0.08;pointer-events:none;}
.guide-row{display:flex;align-items:flex-start;gap:14px;margin-bottom:12px;}
.guide-face{width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,0.12);
  display:flex;align-items:center;justify-content:center;font-size:40px;flex-shrink:0;
  border:3px solid rgba(255,255,255,0.25);animation:guideBounce 2.5s ease-in-out infinite;}
@keyframes guideBounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-7px);}}
.bubble{background:rgba(255,255,255,0.12);border-radius:14px;padding:12px 16px;
  border:1px solid rgba(255,255,255,0.2);position:relative;flex:1;}
.bubble::before{content:"";position:absolute;left:-10px;top:22px;
  border:5px solid transparent;border-right-color:rgba(255,255,255,0.12);}
.guide-name{color:#ffd54f;font-weight:900;font-size:0.82rem;margin-bottom:3px;}
.guide-msg{color:#e0f7fa;font-size:0.95rem;line-height:1.5;}
.sc-title{font-size:1.25rem;font-weight:900;color:#fff;margin:10px 0 6px;}
.sc-desc{color:#b0bec5;font-size:0.92rem;line-height:1.55;}

.choices{width:100%;max-width:820px;display:flex;flex-direction:column;gap:10px;margin-bottom:12px;}
.choice-btn{background:rgba(255,255,255,0.07);border:2px solid rgba(255,255,255,0.18);
  border-radius:14px;padding:14px 18px;color:#fff;font-size:0.97rem;
  font-family:'Nunito',Arial,sans-serif;cursor:pointer;text-align:left;
  transition:all 0.22s;display:flex;align-items:center;gap:12px;font-weight:700;}
.choice-btn:hover{background:rgba(255,255,255,0.16);transform:translateX(7px);}
.choice-btn.bad{border-color:rgba(239,83,80,0.6);}
.choice-btn.bad:hover{background:rgba(239,83,80,0.2);}
.choice-btn.good{border-color:rgba(102,187,106,0.6);}
.choice-btn.good:hover{background:rgba(102,187,106,0.2);}
.choice-btn.medium{border-color:rgba(255,167,38,0.6);}
.choice-btn.medium:hover{background:rgba(255,167,38,0.2);}
.c-icon{font-size:1.5rem;flex-shrink:0;}
.q-label{color:#546e7a;font-size:0.82rem;text-align:center;width:100%;max-width:820px;}

/* ── FEEDBACK ── */
#feedback{background:#0d1b2a;}
.fb-card{max-width:660px;width:100%;text-align:center;}
.fb-big-emoji{font-size:5rem;display:block;margin-bottom:10px;
  animation:popIn 0.5s cubic-bezier(0.34,1.56,0.64,1);}
@keyframes popIn{from{transform:scale(0) rotate(-20deg);}to{transform:scale(1) rotate(0);}}
.fb-type{font-size:1.5rem;font-weight:900;margin-bottom:8px;}
.fb-type.good{color:#66bb6a;}
.fb-type.bad{color:#ef5350;}
.fb-type.medium{color:#ffa726;}
.hc-pill{display:inline-block;padding:7px 20px;border-radius:20px;font-weight:900;font-size:1rem;margin-bottom:14px;}
.hc-pill.pos{background:rgba(102,187,106,0.18);color:#81c784;border:2px solid #66bb6a;}
.hc-pill.neg{background:rgba(239,83,80,0.18);color:#e57373;border:2px solid #ef5350;}
.fb-explain{color:#b2dfdb;font-size:0.97rem;line-height:1.6;margin-bottom:14px;}
.fact-card{background:rgba(255,193,7,0.08);border:2px solid rgba(255,193,7,0.35);
  border-radius:16px;padding:15px 18px;margin-bottom:20px;}
.fact-label{color:#ffd54f;font-weight:900;font-size:0.85rem;margin-bottom:5px;}
.fact-body{color:#fff8e1;font-size:0.93rem;line-height:1.55;}
.btn-next{background:linear-gradient(135deg,#1565c0,#1e88e5);color:#fff;border:none;
  padding:14px 44px;border-radius:50px;font-size:1.15rem;font-weight:900;cursor:pointer;
  box-shadow:0 6px 22px rgba(30,136,229,0.45);transition:all 0.3s;font-family:'Nunito',Arial,sans-serif;}
.btn-next:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(30,136,229,0.65);}

/* ── LEVEL COMPLETE ── */
#levelcomplete{background:linear-gradient(135deg,#1a237e,#283593);}
.lc-inner{max-width:580px;text-align:center;}
.lc-big{font-size:5rem;display:block;animation:lvlBounce 1s ease-in-out infinite;}
@keyframes lvlBounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-18px);}}
.lc-title{font-size:2.2rem;font-weight:900;color:#fff;margin:14px 0 8px;}
.lc-sub{color:#9fa8da;font-size:1rem;margin-bottom:24px;}
.btn-lvl{background:linear-gradient(135deg,#d81b60,#e91e63);color:#fff;border:none;
  padding:15px 48px;border-radius:50px;font-size:1.25rem;font-weight:900;cursor:pointer;
  box-shadow:0 6px 22px rgba(233,30,99,0.45);transition:all 0.3s;font-family:'Nunito',Arial,sans-serif;}
.btn-lvl:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(233,30,99,0.65);}

/* ── RESULTS ── */
#results{background:linear-gradient(160deg,#0d1b2a,#1b2d4f,#0d1b2a);position:relative;overflow:hidden;}
#results::before{content:"🌍";position:absolute;font-size:420px;opacity:0.04;
  top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;}
.res-inner{max-width:700px;width:100%;text-align:center;position:relative;z-index:1;}
.res-planet{font-size:7rem;display:block;animation:popIn 0.8s cubic-bezier(0.34,1.56,0.64,1);}
.res-title{font-size:2.5rem;font-weight:900;color:#fff;margin:14px 0 5px;}
.res-sub{color:#90caf9;font-size:1rem;margin-bottom:18px;}
.fin-bar-wrap{width:100%;background:rgba(255,255,255,0.1);border-radius:15px;
  height:32px;overflow:hidden;margin:14px 0;border:2px solid rgba(255,255,255,0.18);}
.fin-bar{height:100%;border-radius:15px;transition:width 2s ease;
  display:flex;align-items:center;justify-content:flex-end;padding-right:12px;
  color:#fff;font-weight:900;font-size:0.9rem;}
.grade-box{border-radius:18px;padding:18px 22px;margin:14px 0;font-size:1rem;line-height:1.65;
  border:2px solid rgba(255,255,255,0.15);color:#e0f7fa;}
.lesson-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:10px;margin:18px 0;}
.lesson-cell{background:rgba(255,255,255,0.07);border-radius:14px;padding:14px;
  border:1px solid rgba(255,255,255,0.12);}
.lesson-cell .le{font-size:2rem;display:block;margin-bottom:6px;}
.lesson-cell p{color:#b2dfdb;font-size:0.86rem;line-height:1.45;}
.btn-replay{background:linear-gradient(135deg,#ff8f00,#ff6f00);color:#fff;border:none;
  padding:15px 48px;border-radius:50px;font-size:1.25rem;font-weight:900;cursor:pointer;
  margin-top:18px;box-shadow:0 6px 22px rgba(255,111,0,0.45);transition:all 0.3s;
  font-family:'Nunito',Arial,sans-serif;}
.btn-replay:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(255,111,0,0.65);}

/* confetti */
.confetti-wrap{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;}
.cp{position:absolute;top:-12px;border-radius:3px;animation:cfFall linear forwards;}
@keyframes cfFall{0%{transform:translateY(0) rotate(0);opacity:1;}100%{transform:translateY(105vh) rotate(720deg);opacity:0;}}

@media(max-width:600px){
  .game-title{font-size:1.9rem;}
  .guide-row{flex-direction:column;}
  .bubble::before{display:none;}
  .orbit-ring{width:220px;height:220px;}
  .orbit-animal:nth-child(1){transform:translate(-50%,-50%) rotate(0deg)   translateY(-110px);}
  .orbit-animal:nth-child(2){transform:translate(-50%,-50%) rotate(90deg)  translateY(-110px);}
  .orbit-animal:nth-child(3){transform:translate(-50%,-50%) rotate(180deg) translateY(-110px);}
  .orbit-animal:nth-child(4){transform:translate(-50%,-50%) rotate(270deg) translateY(-110px);}
}
</style>
</head>
<body>

<div class="confetti-wrap" id="cfWrap"></div>

<!-- ══ INTRO ══ -->
<div class="screen active" id="intro">
  <div class="stars" id="starField"></div>
  <div class="earth-wrap">
    <div class="orbit-ring">
      <span class="orbit-animal"><span class="counter-rotate">🦁</span></span>
      <span class="orbit-animal"><span class="counter-rotate">🐠</span></span>
      <span class="orbit-animal"><span class="counter-rotate">🦋</span></span>
      <span class="orbit-animal"><span class="counter-rotate">🐘</span></span>
    </div>
    <div class="earth-globe">🌍</div>
  </div>
  <h1 class="game-title">🌍 Planet Guardians</h1>
  <p class="game-subtitle">A fun adventure to discover why <strong>ALL living beings</strong> matter — not just humans!</p>
  <button class="btn-start" onclick="showLearn()">▶ Start Adventure</button>
  <p class="intro-hint">Ages 7–14 &nbsp;·&nbsp; 9 Scenarios &nbsp;·&nbsp; 3 Levels</p>
</div>

<!-- ══ LEARN ══ -->
<div class="screen" id="learn">
  <div class="learn-card">
    <h2 class="learn-title">🧠 What is Anthropocentrism?</h2>
    <div class="concept-box">
      <span class="big-emoji">👑</span>
      <p>Imagine someone who thinks <strong style="color:#ffee58;">they are the most important person in the universe</strong> — and everyone else barely matters.<br><br>
      <strong>Anthropocentrism</strong> means humans believe the whole Earth exists <em>only for them</em>, treating animals, plants, and nature as less important.</p>
    </div>
    <div class="concept-box" style="background:rgba(239,83,80,0.2);">
      <span class="big-emoji">❗</span>
      <p style="color:#ffcdd2;font-weight:700;">Why is this a big problem?</p>
      <ul class="problem-list">
        <li>Forests cut down for factories — animals lose their homes forever</li>
        <li>Oceans choked with plastic — fish and turtles die in silence</li>
        <li>Species going extinct because humans take all the space</li>
        <li>Rivers and air polluted for profit and convenience</li>
        <li>Climate change spiraling out of control</li>
      </ul>
    </div>
    <div class="concept-box" style="background:rgba(102,187,106,0.2);">
      <span class="big-emoji">💡</span>
      <p style="color:#c8e6c9;">Earth is a <strong>team</strong>! Every animal, plant, river, and human plays a vital role. Protecting nature means protecting ourselves!</p>
    </div>
    <button class="btn-start" style="margin-top:14px;" onclick="startGame()">🎮 Let's Play!</button>
  </div>
</div>

<!-- ══ GAME ══ -->
<div class="screen" id="game">
  <div class="top-bar">
    <div class="level-badge" id="lvlBadge">🌿 Level 1: The Forest</div>
    <div class="health-wrap">
      <div class="health-label">
        <span>🌍 Earth Health</span>
        <span id="hPct">100%</span>
      </div>
      <div class="health-bg"><div class="health-fill" id="hBar" style="width:100%"></div></div>
    </div>
    <div class="score-badge">⭐ <span id="scoreDisp">0</span> pts</div>
  </div>
  <div class="prog-dots" id="progDots"></div>
  <div class="scene-card">
    <div class="scene-emoji-bg" id="sceneBg">🌲</div>
    <div class="guide-row">
      <div class="guide-face" id="gFace">🦉</div>
      <div class="bubble">
        <div class="guide-name" id="gName">Oliver the Owl</div>
        <div class="guide-msg" id="gMsg">...</div>
      </div>
    </div>
    <div class="sc-title" id="scTitle"></div>
    <div class="sc-desc" id="scDesc"></div>
  </div>
  <div class="choices" id="choicesArea"></div>
  <div class="q-label" id="qLabel">Question 1 of 9</div>
</div>

<!-- ══ FEEDBACK ══ -->
<div class="screen" id="feedback">
  <div class="fb-card">
    <span class="fb-big-emoji" id="fbEmoji">✅</span>
    <div class="fb-type good" id="fbType">Great Choice!</div>
    <div class="hc-pill pos" id="fbHC">+10 Earth Health</div>
    <p class="fb-explain" id="fbExplain"></p>
    <div class="fact-card">
      <div class="fact-label">📚 DID YOU KNOW?</div>
      <div class="fact-body" id="fbFact"></div>
    </div>
    <button class="btn-next" id="btnNext" onclick="nextQ()">Next ➡</button>
  </div>
</div>

<!-- ══ LEVEL COMPLETE ══ -->
<div class="screen" id="levelcomplete">
  <div class="lc-inner">
    <span class="lc-big" id="lcEmoji">🎉</span>
    <h2 class="lc-title" id="lcTitle">Level Complete!</h2>
    <p class="lc-sub" id="lcSub"></p>
    <button class="btn-lvl" id="btnLvl" onclick="nextLevel()">Continue ➡</button>
  </div>
</div>

<!-- ══ RESULTS ══ -->
<div class="screen" id="results">
  <div class="res-inner">
    <span class="res-planet" id="resPlanet">🌍</span>
    <h2 class="res-title" id="resTitle">Adventure Complete!</h2>
    <p class="res-sub" id="resSub"></p>
    <div class="fin-bar-wrap"><div class="fin-bar" id="finBar" style="width:0%"></div></div>
    <div class="grade-box" id="gradeBox"></div>
    <h3 style="color:#90caf9;margin:14px 0 8px;font-size:1rem;">🌱 Always Remember:</h3>
    <div class="lesson-grid">
      <div class="lesson-cell"><span class="le">🌳</span><p>Every tree cut down destroys the home of hundreds of species.</p></div>
      <div class="lesson-cell"><span class="le">🐬</span><p>Oceans cover 71% of Earth — millions of species call them home.</p></div>
      <div class="lesson-cell"><span class="le">🕸️</span><p>Every species is connected. Lose one and the whole web of life can collapse.</p></div>
      <div class="lesson-cell"><span class="le">🤝</span><p>Humans and nature are partners. Together, all life thrives!</p></div>
    </div>
    <button class="btn-replay" onclick="replayGame()">🔄 Play Again</button>
  </div>
</div>

<script>
// ══════════════════════ DATA ══════════════════════
const LEVELS = [
  {
    name:"🌿 Level 1: The Forest", bg:"🌲",
    guide:{face:"🦉",name:"Oliver the Owl"},
    intro:"Welcome to the Ancient Forest! I've lived here for 200 years. Can you help protect it?",
    doneEmoji:"🌲", doneTitle:"Forest Protected!", doneSub:"Amazing! The animals of the forest thank you! 🦁🦊🐿️",
    scenarios:[
      {
        title:"The Mall vs. The Forest 🏗️", 
        desc:"A company wants to cut 500-year-old trees to build a shopping mall. Hundreds of animals and rare plants live here.",
        guide:"Trade ancient trees for a shopping mall? What would you decide?",
        choices:[
          {icon:"🏗️",text:"Allow it! Humans need jobs and places to shop.",type:"bad",delta:-20,
           explain:"Cutting this forest destroys homes of 300+ species permanently. Once an ancient forest is gone, it takes centuries to recover — if it ever does.",
           fact:"A single old tree can shelter over 500 species of insects, birds, fungi, and animals. Ancient forests store 2–3× more carbon than replanted ones."},
          {icon:"🌱",text:"Protect the forest! Build the mall on empty land instead.",type:"good",delta:+15,
           explain:"Excellent! The forest was saved. Animals kept their homes, the trees kept cleaning our air, and a new site was found in an already-developed area.",
           fact:"Old-growth forests store massive amounts of carbon and take centuries to grow. Protecting them is the single fastest action to fight climate change!"},
          {icon:"🔄",text:"Build a smaller mall and replant some trees nearby.",type:"medium",delta:+5,
           explain:"A compromise helped, but some habitat was still lost. Real conservation aims to cause zero loss to nature whenever possible.",
           fact:"Even partial deforestation creates 'edge effects' — wildlife near boundaries struggles due to noise, light changes, and temperature shifts."}
        ]
      },
      {
        title:"Burning the Jungle for Crops 🔥",
        desc:"Farmers want to burn a large section of jungle to grow crops. It's cheap, but destroys the forest and all its wildlife.",
        guide:"Burning forests releases smoke and wipes out wildlife in minutes. What's the right thing to do?",
        choices:[
          {icon:"🔥",text:"Let them burn it. People need food!",type:"bad",delta:-18,
           explain:"The fire killed thousands of animals and released enormous amounts of CO₂. Burned soil erodes quickly, often ruining the crops within a few years anyway.",
           fact:"About 80,000 acres of rainforest are burned every single day. This is one of the top causes of climate change globally."},
          {icon:"🌾",text:"Teach them sustainable farming on land they already have!",type:"good",delta:+12,
           explain:"Brilliant! By teaching sustainable methods like crop rotation and agroforestry, farmers grew MORE food without burning a single tree.",
           fact:"Sustainable agroforestry — growing crops alongside trees — can increase farm yields by 80% while keeping the forest completely intact!"},
          {icon:"🤝",text:"Help them find empty cleared land and support the move.",type:"medium",delta:+7,
           explain:"Helping farmers relocate to already-cleared land meant no new forest was burned. A fair solution that protected wildlife.",
           fact:"Much of the world's agriculture already happens on previously cleared land. Using it more efficiently could feed everyone without cutting more forest."}
        ]
      },
      {
        title:"A Rare Bird's Last Home 🐦",
        desc:"Only 200 of this bird remain on Earth. Its last habitat is directly in the path of a new highway being planned.",
        guide:"If this road is built as planned, that bird species could go extinct forever — and forever truly means never coming back.",
        choices:[
          {icon:"🚗",text:"Build it! Faster roads are important for humans.",type:"bad",delta:-22,
           explain:"The road split the forest in two. Animals couldn't cross safely. The rare bird lost its nesting site and within years the last ones disappeared — a species gone forever.",
           fact:"Roads fragment habitats, isolating animal populations. Isolated groups lose genetic diversity and eventually die out — even when forest surrounds them."},
          {icon:"🐦",text:"Reroute the road around the bird's habitat!",type:"good",delta:+15,
           explain:"The road was rerouted! It cost a little more — but the rare bird survived, and future generations can still marvel at this beautiful creature.",
           fact:"The California Condor was saved from extinction by habitat protection. From just 27 birds in 1987, there are now over 500 wild condors thanks to these efforts!"},
          {icon:"📋",text:"Pause construction and study how to protect both.",type:"medium",delta:+8,
           explain:"Choosing to study the problem first is responsible! An environmental review found wildlife tunnels under the road that let animals cross safely.",
           fact:"Wildlife crossing bridges and tunnels like those in Banff, Canada have reduced animal-vehicle collisions by over 80% while keeping habitats connected."}
        ]
      }
    ]
  },
  {
    name:"🌊 Level 2: The Ocean", bg:"🌊",
    guide:{face:"🐬",name:"Delia the Dolphin"},
    intro:"Hello! I'm Delia. I swim these oceans and I've seen so much plastic and poison dumped here. Will you help us?",
    doneEmoji:"🌊", doneTitle:"Ocean Protected!", doneSub:"The sea is cleaner! The dolphins and fish are celebrating! 🐠🐢🐋",
    scenarios:[
      {
        title:"Chemical Dumping 🏭",
        desc:"A factory is secretly dumping toxic chemicals into the ocean at night because proper disposal is too expensive. Fish are dying near the area.",
        guide:"Those chemicals are poison! My friends are getting sick. Humans eat fish from this ocean too — what do you decide?",
        choices:[
          {icon:"🏭",text:"Ignore it. The factory creates important jobs!",type:"bad",delta:-20,
           explain:"The chemicals spread through the food chain — small fish absorbed toxins, big fish ate small fish, and eventually the poison reached humans eating seafood. Everyone suffered.",
           fact:"Toxic chemicals like mercury bioaccumulate — meaning they get MORE concentrated up the food chain. Top predators (including humans) receive the highest doses."},
          {icon:"🛑",text:"Stop them! Clean water matters more than cutting corners.",type:"good",delta:+15,
           explain:"The factory was fined and forced to use proper waste treatment. Clean water is priceless. Marine life began recovering within just a few months.",
           fact:"The US Clean Water Act reduced water pollution so dramatically that rivers that once literally caught fire (like the Cuyahoga River in 1969) are now healthy ecosystems!"},
          {icon:"💰",text:"Fine the factory heavily and make them clean it up.",type:"medium",delta:+8,
           explain:"Making the factory pay to clean up the ocean was a step in the right direction. The large fine also discouraged other companies from illegal dumping.",
           fact:"The 'polluter pays' principle in environmental law means those who damage nature must fund cleanup — making pollution economically painful and therefore less likely."}
        ]
      },
      {
        title:"The Giant Fishing Nets 🎣",
        desc:"Fishing boats use massive drift nets that catch thousands of dolphins, sea turtles, and sharks accidentally each year along with the target fish.",
        guide:"My cousin was trapped in a net last month. We dolphins are intelligent and we feel pain. Please help us!",
        choices:[
          {icon:"🎣",text:"Use any nets needed — we need as much fish as possible!",type:"bad",delta:-18,
           explain:"Bycatch from these nets killed thousands of dolphins, sea turtles, and whales annually. Several species edged closer to extinction with every fishing season.",
           fact:"For every 1 kg of target fish caught with some net types, up to 5 kg of other sea life is accidentally killed and thrown back dead. This is called bycatch."},
          {icon:"🐬",text:"Require dolphin-safe nets and sustainable fishing limits!",type:"good",delta:+14,
           explain:"Dolphin-safe fishing methods were introduced! Special nets let dolphins escape. With monitored fish populations, the ocean stayed healthy for future generations.",
           fact:"After dolphin-safe tuna fishing rules were introduced in the 1990s, dolphin deaths from tuna fishing dropped by over 99%! One simple rule saved millions of animals."},
          {icon:"🤝",text:"Partner with fishermen to trial better net designs.",type:"medium",delta:+8,
           explain:"Partnering with fishermen to test new net designs reduced bycatch by 60%. Fishermen actually caught MORE target fish with less waste — a true win for everyone.",
           fact:"Turtle Excluder Devices (TEDs) — simple trapdoors in fishing nets — allow sea turtles to escape. They cost under $100 each but save thousands of turtles per year."}
        ]
      },
      {
        title:"The Dying Coral Reef 🪸",
        desc:"A beautiful coral reef is bleaching and dying from sunscreen chemicals from tourists and boats dropping heavy anchors directly onto it.",
        guide:"Coral reefs are called the rainforests of the sea! One quarter of ALL ocean life depends on them — and they're disappearing fast.",
        choices:[
          {icon:"⛵",text:"Let tourists visit freely. Tourism brings money!",type:"bad",delta:-17,
           explain:"Uncontrolled tourism accelerated the reef's death. Without the reef, fish vanished, coastlines eroded, and ironically the tourism itself died too. A costly mistake.",
           fact:"Coral reefs protect coastlines from storm waves, provide food to 500 million people, and support tourism worth $375 billion per year — yet we're destroying them."},
          {icon:"🪸",text:"Create marine protection zones and ban harmful practices!",type:"good",delta:+14,
           explain:"A marine protection zone was established! Reef-safe sunscreen only, anchor buoys instead of dropped anchors. Within years, coral began recovering — vibrant colors returned!",
           fact:"Marine Protected Areas increase fish populations by an average of 670% inside their boundaries! Fish spread to surrounding areas, helping nearby fishermen too."},
          {icon:"📚",text:"Launch an education campaign about reef safety rules.",type:"medium",delta:+9,
           explain:"An education campaign got tourists to use reef-safe sunscreen and not touch coral. The reef stabilized, though it still needs stronger protections.",
           fact:"A single snorkeler touching coral can kill organisms that took 100 years to grow. Coral polyps — the tiny animals that build reefs — are incredibly fragile."}
        ]
      }
    ]
  },
  {
    name:"🏙️ Level 3: The City", bg:"🏙️",
    guide:{face:"🐦",name:"Coco the City Bird"},
    intro:"Tweet tweet! Even in cities, nature tries to survive. Trees, rivers, and animals share space with us. Will you protect them?",
    doneEmoji:"🌳", doneTitle:"Green City!", doneSub:"You built a city where nature and humans live together! 🌳🦋🐕",
    scenarios:[
      {
        title:"Trees vs. Parking Lots 🌳",
        desc:"The city council wants to cut ALL trees in the central park to build a giant parking lot for shoppers. The trees are 80 years old.",
        guide:"Those trees are our homes! Also — trees cool the city, clean the air, and reduce flooding. Cutting them hurts everyone!",
        choices:[
          {icon:"🚗",text:"Cut the trees! Cars and shops are more important.",type:"bad",delta:-19,
           explain:"Without trees, the city became a heat island — 5°C hotter in summer. Air quality worsened, children had more asthma, and flooding increased. A very expensive mistake.",
           fact:"One mature tree can cool the surrounding area by 5°C, provide oxygen for 10 people, absorb 22 kg of CO₂ per year, and reduce air conditioning costs by 30%."},
          {icon:"🌳",text:"Keep the trees! Build a smart multi-story parking garage instead.",type:"good",delta:+15,
           explain:"A multi-story car park on a small footprint preserved all the trees. The park stayed green, cool, and clean — and nearby property values actually went up!",
           fact:"Cities with more trees have lower crime rates, better mental health outcomes, and higher real estate values. Urban nature directly benefits humans!"},
          {icon:"🌳",text:"Preserve most trees and build a small parking area.",type:"medium",delta:+7,
           explain:"A compromise preserved 70% of the trees. Not perfect, but the urban ecosystem stayed mostly intact. Next time, advocate strongly for zero tree removal!",
           fact:"Urban forests provide services worth over $500 billion globally per year — through cooling, air cleaning, mental health benefits, and flood prevention."}
        ]
      },
      {
        title:"Concreting the City River 💧",
        desc:"Developers want to cover the river running through the city with concrete to create more road space. The river has fish, birds, frogs, and insects.",
        guide:"That river is our drinking water, our home, and our wildlife highway! Please don't let them bury it!",
        choices:[
          {icon:"🏗️",text:"Cover it! More roads means less traffic jams!",type:"bad",delta:-20,
           explain:"Burying the river destroyed the local ecosystem. Without the river's natural filtering, water quality dropped. Paradoxically, floods got WORSE — concrete can't absorb rain. The city paid billions to fix this mistake.",
           fact:"Seoul, South Korea removed concrete from the Cheonggyecheon Stream in 2005. Wildlife returned within years and summer air temperatures dropped by 3.6°C!"},
          {icon:"💧",text:"Protect the river! Turn it into a beautiful green corridor.",type:"good",delta:+16,
           explain:"The river became a gorgeous green corridor with walking paths, wildlife habitat, and natural flood control. It became the most-loved spot in the entire city!",
           fact:"Rivers act as natural air conditioners, wildlife highways, and flood buffers. Restoring urban rivers has been shown to increase nearby property values by up to 20%."},
          {icon:"🌉",text:"Build bridges over the river to add road capacity.",type:"medium",delta:+9,
           explain:"Bridges kept the river open while adding road capacity. Fish, birds, and frogs kept their habitat. A smart solution that respected both nature and human needs.",
           fact:"Many great ancient cities — Rome, Paris, London, Baghdad — were built alongside rivers precisely because rivers provided water, food, transport, and waste removal."}
        ]
      },
      {
        title:"City Animals 🐕",
        desc:"The mayor wants to remove ALL stray dogs and cats from the city, declaring that 'cities are built only for humans and their chosen pets.'",
        guide:"Animals have lived alongside humans in cities for thousands of years! We're part of the city ecosystem too!",
        choices:[
          {icon:"🚫",text:"Remove them all. Cities exist only for people!",type:"bad",delta:-17,
           explain:"Removing all strays without care caused an explosion in rats and mice — natural prey of street cats. Disease risk increased. Every animal plays a role in the ecosystem.",
           fact:"Urban cats naturally control rodent populations. Studies show they kill millions of rats per year in cities, protecting food supplies and reducing disease transmission."},
          {icon:"🐕",text:"Create animal welfare programs, shelters, and TNR schemes!",type:"good",delta:+14,
           explain:"A compassionate Trap-Neuter-Return program plus shelters reduced the stray population humanely and effectively. Vaccinations protected both animals and humans. The city became kinder!",
           fact:"Cities with TNR (Trap-Neuter-Return) programs reduce stray cat populations by 50–80% within 10 years — far more effectively and humanely than removal programs."},
          {icon:"🏘️",text:"Sterilize and care for them through community programs.",type:"medium",delta:+9,
           explain:"Community-based animal care with sterilization managed the population kindly and effectively. Residents formed bonds with neighborhood animals, creating a more compassionate city.",
           fact:"Research shows children who grow up alongside animals develop higher empathy, lower stress levels, and better social skills — urban animals benefit human communities!"}
        ]
      }
    ]
  }
];

// ══════════════════════ STATE ══════════════════════
let health=100, score=0, lvlIdx=0, scIdx=0, globalQ=0;

// ══════════════════════ HELPERS ══════════════════════
function show(id){document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"));document.getElementById(id).classList.add("active");}

function updateBar(){
  const p=Math.max(0,Math.min(100,health));
  const b=document.getElementById("hBar");
  b.style.width=p+"%";
  if(p>70)b.style.background="linear-gradient(90deg,#43a047,#76c442)";
  else if(p>40)b.style.background="linear-gradient(90deg,#ffa726,#ffd54f)";
  else b.style.background="linear-gradient(90deg,#e53935,#ef9a9a)";
  document.getElementById("hPct").textContent=Math.round(p)+"%";
}

function buildDots(){
  const c=document.getElementById("progDots");c.innerHTML="";
  for(let i=0;i<9;i++){const d=document.createElement("div");d.className="dot"+(i<globalQ?" done":i===globalQ?" active":"");c.appendChild(d);}
}

function confetti(n=80){
  const w=document.getElementById("cfWrap");w.innerHTML="";
  const cols=["#f44336","#e91e63","#9c27b0","#3f51b5","#2196f3","#4caf50","#ffeb3b","#ff9800","#00bcd4","#ff5722"];
  for(let i=0;i<n;i++){
    const p=document.createElement("div");p.className="cp";
    const sz=5+Math.random()*9;
    p.style.cssText=`left:${Math.random()*100}%;background:${cols[Math.floor(Math.random()*cols.length)]};width:${sz}px;height:${sz}px;border-radius:${Math.random()>.5?"50%":"3px"};animation-duration:${1.8+Math.random()*2.2}s;animation-delay:${Math.random()*.8}s;`;
    w.appendChild(p);setTimeout(()=>p.remove(),5000);
  }
}

function makeStars(){
  const sf=document.getElementById("starField");
  for(let i=0;i<90;i++){
    const s=document.createElement("div");s.className="star";
    const sz=1+Math.random()*3;
    s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;animation:twinkle ${2+Math.random()*3}s ${Math.random()*3}s infinite;`;
    sf.appendChild(s);
  }
}

// ══════════════════════ FLOW ══════════════════════
function showLearn(){show("learn");}
function startGame(){health=100;score=0;lvlIdx=0;scIdx=0;globalQ=0;updateBar();loadQ();}
function replayGame(){startGame();}

function loadQ(){
  show("game");
  const lv=LEVELS[lvlIdx], sc=lv.scenarios[scIdx];
  document.getElementById("lvlBadge").textContent=lv.name;
  document.getElementById("sceneBg").textContent=lv.bg;
  document.getElementById("gFace").textContent=lv.guide.face;
  document.getElementById("gName").textContent=lv.guide.name;
  document.getElementById("gMsg").textContent=sc.guide;
  document.getElementById("scTitle").textContent=sc.title;
  document.getElementById("scDesc").textContent=sc.desc;
  document.getElementById("qLabel").textContent="Question "+(globalQ+1)+" of 9";
  document.getElementById("scoreDisp").textContent=score;
  updateBar(); buildDots();
  const ca=document.getElementById("choicesArea");ca.innerHTML="";
  sc.choices.forEach(ch=>{
    const b=document.createElement("button");
    b.className="choice-btn "+ch.type;
    b.innerHTML=`<span class="c-icon">${ch.icon}</span><span>${ch.text}</span>`;
    b.onclick=()=>pick(ch);ca.appendChild(b);
  });
}

function pick(ch){
  health=Math.max(0,Math.min(100,health+ch.delta));
  if(ch.type==="good")score+=20;else if(ch.type==="medium")score+=10;
  updateBar();
  // Feedback
  const emoji=ch.type==="good"?"🌟":ch.type==="bad"?"😟":"🤔";
  const typeText=ch.type==="good"?"Great Choice! 🌿":ch.type==="bad"?"Oops! Earth is hurting! 😢":"Not Bad… But We Can Do Better! 🤔";
  document.getElementById("fbEmoji").textContent=emoji;
  document.getElementById("fbType").textContent=typeText;
  document.getElementById("fbType").className="fb-type "+ch.type;
  const hcEl=document.getElementById("fbHC");
  hcEl.textContent=(ch.delta>=0?"+":"")+ch.delta+" Earth Health";
  hcEl.className="hc-pill "+(ch.delta>=0?"pos":"neg");
  document.getElementById("fbExplain").textContent=ch.explain;
  document.getElementById("fbFact").textContent=ch.fact;
  const isLastInLv=(scIdx===LEVELS[lvlIdx].scenarios.length-1);
  const isEnd=(globalQ===8);
  document.getElementById("btnNext").textContent=isEnd?"See Final Results 🏆":isLastInLv?"Level Complete! 🎉":"Next Question ➡";
  show("feedback");
}

function nextQ(){
  globalQ++;
  if(globalQ>=9){showResults();return;}
  scIdx++;
  if(scIdx>=LEVELS[lvlIdx].scenarios.length){showLvlComplete();return;}
  loadQ();
}

function showLvlComplete(){
  const lv=LEVELS[lvlIdx];
  document.getElementById("lcEmoji").textContent=lv.doneEmoji;
  document.getElementById("lcTitle").textContent=lv.doneTitle;
  document.getElementById("lcSub").textContent=lv.doneSub;
  const last=(lvlIdx===LEVELS.length-1);
  document.getElementById("btnLvl").textContent=last?"See Final Results 🏆":"Next Level ➡";
  confetti(70);show("levelcomplete");
}

function nextLevel(){
  lvlIdx++;scIdx=0;
  if(lvlIdx>=LEVELS.length){showResults();return;}
  loadQ();
}

function showResults(){
  const p=Math.round(Math.max(0,Math.min(100,health)));
  document.getElementById("resSub").textContent="Earth Health: "+p+"% · Score: "+score+" pts";
  let planet,title,msg,bg;
  if(p>=80){planet="🌟";title="Earth Champion!";bg="rgba(67,160,71,0.22)";
    msg="<strong style='color:#a5d6a7;'>WOW!</strong> You truly understand that ALL living beings matter equally. You chose nature, animals, and balance over short-term convenience. Earth is thriving because of guardians like you! 🦁🌳🐠";}
  else if(p>=60){planet="🌿";title="Nature Friend!";bg="rgba(255,167,38,0.2)";
    msg="<strong style='color:#ffe082;'>Great effort!</strong> You made many eco-friendly choices! Sometimes human-centred thinking crept in — but you're growing! Remember: every species has equal value on this planet. 🌱";}
  else if(p>=40){planet="⚠️";title="Earth Watcher!";bg="rgba(255,87,34,0.2)";
    msg="<strong style='color:#ffab91;'>Earth needs more care!</strong> Some choices put human convenience above nature. Anthropocentrism is a habit — but you can change it! Every animal and plant has a right to exist. Try again! 🌍";}
  else{planet="🆘";title="Earth in Danger!";bg="rgba(239,83,80,0.22)";
    msg="<strong style='color:#ef9a9a;'>Earth is struggling!</strong> Many choices placed human wants above all other life. Remember: without healthy ecosystems, humans cannot survive either. We need nature far more than nature needs us. Play again! 🙏";}
  document.getElementById("resPlanet").textContent=planet;
  document.getElementById("resTitle").textContent=title;
  const gb=document.getElementById("gradeBox");gb.innerHTML=msg;gb.style.background=bg;
  show("results");
  setTimeout(()=>{
    const fb=document.getElementById("finBar");fb.style.width=p+"%";fb.textContent=p+"%";
    if(p>70)fb.style.background="linear-gradient(90deg,#43a047,#76c442)";
    else if(p>40)fb.style.background="linear-gradient(90deg,#ffa726,#ffd54f)";
    else fb.style.background="linear-gradient(90deg,#e53935,#ef9a9a)";
  },500);
  if(p>=70)confetti(120);
}

// Init
makeStars();
</script>

<script src="session-tracker.js"></script>

</body>
</html>