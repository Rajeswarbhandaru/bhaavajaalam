/* ── Game State ───────────────────────────────────── */
var idx = 0, score = 0, MAX = T.length * 5;

/* ── Init ─────────────────────────────────────────── */
document.getElementById('playBtn').addEventListener('click', startGame);
initStars();

function initStars() {
  var c = document.getElementById('fstars');
  var em = ['⭐','✨','🌟','💫'];
  for (var i = 0; i < 24; i++) {
    var d = document.createElement('div');
    d.className = 'fstar';
    d.innerHTML = em[i % em.length];
    d.style.left = Math.random() * 94 + '%';
    d.style.fontSize = (12 + Math.random() * 20) + 'px';
    d.style.animationDuration = (3 + Math.random() * 6) + 's';
    d.style.animationDelay = Math.random() * 7 + 's';
    c.appendChild(d);
  }
}

function show(id) {
  ['intro','game','end'].forEach(function(s) {
    document.getElementById(s).classList.remove('active');
  });
  document.getElementById(id).classList.add('active');
}

function updateHud() {
  document.getElementById('hud').style.display = 'flex';
  var dots = document.getElementById('hdots');
  dots.innerHTML = '';
  for (var i = 0; i < T.length; i++) {
    var d = document.createElement('div');
    d.className = 'hdot' + (i < idx ? ' done' : i === idx ? ' now' : '');
    dots.appendChild(d);
  }
  document.getElementById('hscore').innerHTML = '⭐ ' + score;
  document.getElementById('hbar').style.width = Math.round(score / MAX * 100) + '%';
}

function gc(html) {
  document.getElementById('gc').innerHTML = html;
  window.scrollTo({top: 0, behavior: 'smooth'});
}

function startGame() {
  idx = 0; score = 0;
  playStart();
  show('game');
  document.getElementById('game').style.background = T[0].gbg;
  updateHud();
  renderScene();
}

/* ── Render Scene (comic panels) ─────────────────── */
function renderScene() {
  var s = T[idx];
  var comic = '';
  for (var i = 0; i < s.comic.length; i++) {
    comic += '<div class="panel"><div class="pe">' + s.comic[i].e + '</div><div class="ps">' + s.comic[i].s + '</div></div>';
    if (i < s.comic.length - 1) comic += '<div class="c-arrow">›</div>';
  }
  gc(
    '<div class="clabel">' + s.icon + ' ' + s.timeTag + ' &nbsp;&#9679;&nbsp; ' + (idx+1) + ' / ' + T.length + '</div>' +
    '<div class="card">' +
      '<div class="scene-title">' + s.icon + ' ' + s.title + '</div>' +
      '<div class="comic ' + s.bg + '">' + comic + '</div>' +
      '<button class="btn-next" style="background:linear-gradient(135deg,' + s.accent + ',' + s.accent + 'cc)" onclick="renderDetect()">&#128269; What is this about?</button>' +
    '</div>'
  );
}

/* ── Render Detect ────────────────────────────────── */
function renderDetect() {
  var s = T[idx];
  var db = '';
  for (var i = 0; i < s.detects.length; i++) {
    db += '<button class="dbtn" id="db' + i + '" onclick="pickDetect(' + i + ')">' +
            '<span class="de">' + s.detects[i].e + '</span>' +
            '<span class="dl">' + s.detects[i].l + '</span>' +
          '</button>';
  }
  gc(
    '<div class="clabel">&#128269; Spot the skill &nbsp;&#9679;&nbsp; ' + (idx+1) + ' / ' + T.length + '</div>' +
    '<div class="card">' +
      '<div class="detect-q">&#128161; &#128269; ?</div>' +
      '<div class="dgrid">' + db + '</div>' +
      '<div id="dfb"></div>' +
    '</div>'
  );
}

function pickDetect(i) {
  var s = T[idx];
  var ok = (i === s.correct);
  var btns = document.querySelectorAll('.dbtn');
  for (var j = 0; j < btns.length; j++) {
    btns[j].setAttribute('onclick','');
    btns[j].style.pointerEvents = 'none';
    if (j === s.correct) btns[j].classList.add('correct');
    else if (j === i && !ok) btns[j].classList.add('wrong');
  }
  if (ok) { score += 2; playCorrect(); updateHud(); }
  var fb = document.getElementById('dfb');
  fb.className = 'fb ' + (ok ? 'good' : 'bad');
  fb.innerHTML = ok
    ? '<div class="fb-ico">&#127919;</div><div class="fb-hd">2 ⭐</div>'
    : '<div class="fb-ico">&#128173;</div><div class="fb-hd">' + s.detects[s.correct].e + ' ' + s.revealWord + '</div>';
  setTimeout(renderChoice, 1200);
}

/* ── Render Choice ────────────────────────────────── */
function renderChoice() {
  var s = T[idx];
  var cb = '';
  for (var i = 0; i < s.choices.length; i++) {
    cb += '<button class="chbtn" onclick="pickChoice(' + i + ')">' +
            '<span class="ch-emoji">' + s.choices[i].e + '</span>' +
            '<span class="ch-label">' + s.choices[i].l + '</span>' +
          '</button>';
  }
  gc(
    '<div class="clabel">&#9889; Your move &nbsp;&#9679;&nbsp; ' + (idx+1) + ' / ' + T.length + '</div>' +
    '<div class="card">' +
      '<div style="text-align:center;font-size:52px;margin-bottom:10px;animation:float 3s ease-in-out infinite">' + s.icon + '</div>' +
      '<div style="background:linear-gradient(135deg,' + s.accent + ',' + s.accent + 'cc);color:#fff;border-radius:14px;padding:12px 16px;margin-bottom:16px;display:flex;align-items:center;gap:10px">' +
        '<div style="font-size:30px">' + s.revealEmoji + '</div>' +
        '<div style="font-size:15px;font-weight:900">' + s.revealWord + '</div>' +
      '</div>' +
      '<div class="cq">&#129300;</div>' +
      '<div class="ch-grid">' + cb + '</div>' +
    '</div>'
  );
}

function pickChoice(i) {
  var s = T[idx];
  var good = s.choices[i].good;
  if (good) { score += 3; playCorrect(); updateHud(); spawnConfetti(24); }
  renderResult(good);
}

/* ── Render Result ────────────────────────────────── */
function renderResult(good) {
  if (!good) { playWrong(); }
  var s = T[idx];
  var r = good ? s.rgood : s.rbad;
  var arrowCol = good ? '#00c853' : '#ff5722';
  var nextTxt = (idx + 1 < T.length) ? '&#10145;&#65038; Next' : '&#127942; My Results!';
  gc(
    '<div class="clabel">' + (good ? '&#127775; Great' : '&#128161; Learn') + '</div>' +
    '<div class="card">' +
      '<div class="res-stage ' + s.bg + '">' +
        '<span class="res-from">' + r.f + '</span>' +
        '<span class="res-arr" style="color:' + arrowCol + '">&#10132;</span>' +
        '<span class="res-to">' + r.t + '</span>' +
      '</div>' +
      '<div class="res-msg">' + r.msg + '</div>' +
      '<div class="lesson-strip" style="background:linear-gradient(135deg,' + s.accent + ',' + s.accent + 'cc)">' +
        '<div class="les-ico">' + s.lesIco + '</div>' +
        '<div class="les-txt">' + s.lesson + '</div>' +
      '</div>' +
      '<div class="star-row">' + (good ? '⭐⭐⭐' : '⭐') + '</div>' +
      '<button class="btn-next" style="background:linear-gradient(135deg,' + s.accent + ',' + s.accent + 'cc)" onclick="nextChallenge()">' + nextTxt + '</button>' +
    '</div>'
  );
}

function nextChallenge() {
  playNext();
  idx++;
  if (idx >= T.length) { endGame(); return; }
  document.getElementById('game').style.background = T[idx].gbg;
  updateHud();
  renderScene();
}

/* ── End Game ─────────────────────────────────────── */
function endGame() {
  try {
    if (window.BhavaSession && typeof BhavaSession.end === 'function') {
      BhavaSession.end(Math.round((score / MAX) * 100));
    }
  } catch(e) { console.warn('BhavaSession.end:', e.message); }

  document.getElementById('hud').style.display = 'none';
  show('end');

  if (score / MAX >= 0.5) { playWin(); } else { playLose(); }

  var pct = score / MAX;
  var rank, badge, msg;
  if (pct >= 0.8) {
    rank = 'RESPONSIBILITY HERO! &#127942;'; badge = '&#129464;'; msg = 'Amazing!';
  } else if (pct >= 0.5) {
    rank = 'RISING HERO! &#127775;'; badge = '&#128170;'; msg = 'Great progress!';
  } else {
    rank = 'HERO IN TRAINING! &#127807;'; badge = '&#127807;'; msg = 'Try again!';
  }

  var stars = '';
  for (var i = 0; i < Math.max(1, Math.round(pct * 5)); i++) stars += '⭐';

  var skills = [['&#9200;','TIME'],['&#129309;','HONEST'],['&#129529;','CLEAN'],['&#10084;','CARE'],['&#128101;','TEAM']];
  var skillCards = skills.map(function(sk) {
    return '<div class="skill-card"><div class="sk-ico">' + sk[0] + '</div><div class="sk-lbl">' + sk[1] + '</div></div>';
  }).join('');

  document.getElementById('cert').innerHTML =
    '<div class="c-badge">' + badge + '</div>' +
    '<div class="c-sub">You are a</div>' +
    '<div class="c-rank">' + rank + '</div>' +
    '<div class="c-stars">' + stars + '</div>' +
    '<div class="c-score">⭐ ' + score + ' / ' + MAX + '</div>' +
    '<div class="c-bar-bg"><div class="c-bar" id="cbar" style="width:0%"></div></div>' +
    '<div class="skills-row">' + skillCards + '</div>' +
    '<div class="c-msg">' + msg + '</div>' +
    '<button class="btn-replay" onclick="startGame()">&#128260; Play Again</button>';

  setTimeout(function() {
    var b = document.getElementById('cbar');
    if (b) b.style.width = Math.round(pct * 100) + '%';
  }, 300);
  spawnConfetti(44);
}

/* ── Confetti ─────────────────────────────────────── */
function spawnConfetti(n) {
  var cols = ['#ffd200','#f7971e','#38ef7d','#ff6b6b','#4ecdc4','#c850c0','#a1c4fd','#fff'];
  for (var i = 0; i < n; i++) {
    (function(delay) {
      setTimeout(function() {
        var p = document.createElement('div');
        p.className = 'cp';
        p.style.left = Math.random() * 100 + 'vw';
        p.style.width = (7 + Math.random() * 9) + 'px';
        p.style.height = (7 + Math.random() * 9) + 'px';
        p.style.background = cols[Math.floor(Math.random() * cols.length)];
        p.style.borderRadius = Math.random() > 0.5 ? '50%' : '3px';
        p.style.animationDuration = (2 + Math.random() * 3) + 's';
        document.body.appendChild(p);
        setTimeout(function() { if (p.parentNode) p.parentNode.removeChild(p); }, 5500);
      }, delay);
    })(i * 45);
  }
}
</script>


