/* ── Sound System ─────────────────────────────────── */
var soundOn = true;
function beep(freq, dur, type, vol) {
  if (!soundOn) return;
  try {
    var ctx = new (window.AudioContext || window.webkitAudioContext)();
    var osc = ctx.createOscillator();
    var gain = ctx.createGain();
    osc.type = type || 'sine';
    osc.frequency.value = freq || 440;
    gain.gain.value = vol || 0.06;
    osc.connect(gain); gain.connect(ctx.destination);
    osc.start(); osc.stop(ctx.currentTime + (dur || 0.15));
    osc.onended = function() { ctx.close(); };
  } catch(e2) {}
}
function playCorrect() { beep(600,0.12,'triangle',0.07); setTimeout(function(){beep(800,0.10,'triangle',0.05);},130); }
function playWrong()   { beep(200,0.18,'sawtooth',0.07); }
function playNext()    { beep(440,0.08,'sine',0.05); }
