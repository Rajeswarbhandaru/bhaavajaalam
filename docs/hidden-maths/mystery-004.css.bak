/* ============================================
   HIDDEN MATHS — mystery-003.css
   Mystery 003: Air Conditioner
   ============================================ */

.mystery-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  border-radius: 0;
  border-top: none;
  border-left: none;
  border-right: none;
  padding: 0.75rem 0;
}

.mystery-nav .nav-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  color: var(--text-secondary);
  font-weight: 500;
  font-size: 0.95rem;
  transition: color var(--transition-fast);
  padding: 0.4rem 0.8rem;
  border-radius: var(--radius-sm);
}

.nav-back:hover, .nav-back:focus {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.06);
  outline: none;
}

.nav-back:focus-visible {
  outline: 2px solid var(--accent-cyan);
  outline-offset: 3px;
}

.mystery-progress {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.progress-track {
  width: 120px;
  height: 4px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-gold));
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  width: 11%;
}

.progress-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-weight: 600;
  white-space: nowrap;
}

.mystery-main {
  position: relative;
  z-index: 1;
  padding-top: 5rem;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.mystery-step {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 5rem);
  padding: 3rem 1.5rem 5rem;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.mystery-step.active {
  display: flex;
  opacity: 1;
  transform: translateY(0);
}

.step-content {
  max-width: 720px;
  width: 100%;
  text-align: center;
}

.mystery-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  background: rgba(0, 217, 255, 0.08);
  border: 1px solid rgba(0, 217, 255, 0.18);
  border-radius: 100px;
  padding: 0.35rem 1rem;
  margin-bottom: 1rem;
}

.step-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-gold);
  background: rgba(255, 200, 87, 0.08);
  border: 1px solid rgba(255, 200, 87, 0.18);
  border-radius: 100px;
  padding: 0.35rem 1rem;
  margin-bottom: 1rem;
}

.step-title {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  background: linear-gradient(135deg, var(--text-primary), var(--accent-cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.step-hook {
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  color: var(--text-secondary);
  font-style: italic;
  max-width: 560px;
  margin: 0 auto 2rem;
  line-height: 1.6;
}

.step-desc {
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 auto 2rem;
  line-height: 1.7;
}

.step-hint {
  font-size: 0.95rem;
  color: var(--text-muted);
  max-width: 480px;
  margin: 1.5rem auto 0;
  line-height: 1.5;
}

/* ---- Curiosity: AC Scene ---- */
.curiosity-visual {
  margin: 2rem auto;
  max-width: 480px;
  height: 200px;
  position: relative;
}

.ac-scene {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.ac-unit {
  position: relative;
  width: 180px;
  height: 70px;
  margin-bottom: 1rem;
}

.ac-body {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 217, 255, 0.08);
  border: 2px solid rgba(0, 217, 255, 0.3);
  border-radius: 8px;
}

.ac-vents {
  position: absolute;
  bottom: 8px;
  left: 10%;
  right: 10%;
  height: 4px;
  background: rgba(0, 217, 255, 0.4);
  border-radius: 2px;
  animation: ventPulse 2s ease-in-out infinite;
}

@keyframes ventPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.ac-display {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--accent-cyan);
  font-family: 'Courier New', monospace;
}

.ac-airflow {
  position: relative;
  width: 120px;
  height: 80px;
  display: flex;
  justify-content: center;
  gap: 1rem;
}

.air-particle {
  width: 4px;
  height: 4px;
  background: rgba(0, 217, 255, 0.5);
  border-radius: 50%;
  animation: airFall 2s ease-in infinite;
}

.air-particle:nth-child(1) { animation-delay: 0s; left: 20%; }
.air-particle:nth-child(2) { animation-delay: 0.5s; left: 40%; }
.air-particle:nth-child(3) { animation-delay: 1s; left: 60%; }
.air-particle:nth-child(4) { animation-delay: 1.5s; left: 80%; }

@keyframes airFall {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(70px); opacity: 0; }
}

/* ---- Observation ---- */
.observation-stage {
  margin: 2rem auto;
  max-width: 520px;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.temp-timeline {
  position: relative;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-sm);
  padding: 0 1rem;
}

.temp-marker {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-secondary);
  position: relative;
  z-index: 2;
}

.temp-marker.target {
  color: var(--accent-cyan);
}

.temp-marker.stop {
  color: var(--accent-lime);
}

.temp-arrow {
  position: absolute;
  left: 5%;
  right: 5%;
  top: 50%;
  height: 3px;
  background: linear-gradient(90deg, var(--accent-pink), var(--accent-cyan));
  border-radius: 2px;
  transform: translateY(-50%);
  z-index: 1;
}

.ac-status-indicator {
  display: flex;
  justify-content: center;
  gap: 1rem;
}

.status-light {
  padding: 0.5rem 1rem;
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.status-light.on {
  background: rgba(0, 217, 255, 0.15);
  color: var(--accent-cyan);
  border: 1px solid rgba(0, 217, 255, 0.3);
}

.status-light.off {
  background: rgba(255, 255, 255, 0.06);
  color: var(--text-muted);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.obs-facts {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1.5rem;
  max-width: 520px;
  margin-left: auto;
  margin-right: auto;
}

.fact-card {
  padding: 1rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  animation: fadeInUp 0.5s ease-out both;
}

.fact-card:nth-child(1) { animation-delay: 0.1s; }
.fact-card:nth-child(2) { animation-delay: 0.25s; }
.fact-card:nth-child(3) { animation-delay: 0.4s; }

.fact-number {
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--accent-cyan);
}

.fact-label {
  font-size: 0.8rem;
  color: var(--text-muted);
}

/* ---- Experiment: Thermostat ---- */
.experiment-stage {
  max-width: 560px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

.thermostat-panel {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.thermostat-display {
  position: relative;
  padding: 1.5rem;
  background: rgba(0, 217, 255, 0.06);
  border: 1px solid rgba(0, 217, 255, 0.15);
  border-radius: var(--radius-md);
  text-align: center;
}

.room-temp {
  font-size: 3rem;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
  font-family: 'Courier New', monospace;
}

.temp-unit {
  font-size: 1rem;
  color: var(--text-muted);
  font-weight: 500;
}

.ac-state {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--accent-cyan);
  margin-top: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.ac-state.off {
  color: var(--text-muted);
}

.thermostat-controls {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.control-group {
  text-align: left;
}

.control-group label {
  display: block;
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
  font-weight: 600;
}

.control-value {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.thermo-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  outline: none;
}

.thermo-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px;
  height: 20px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-gold));
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 2px 10px rgba(0, 217, 255, 0.4);
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.thermo-slider::-moz-range-thumb {
  width: 20px;
  height: 20px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-gold));
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.thermostat-visual {
  position: relative;
  height: 50px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.temp-bar {
  position: relative;
  width: 100%;
  height: 100%;
}

.temp-fill {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0%;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-gold));
  border-radius: var(--radius-sm);
  transition: width 0.5s ease-out;
}

.temp-target-line {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--text-primary);
  left: 50%;
  transition: left 0.3s ease;
}

.temp-band {
  position: absolute;
  top: 0;
  bottom: 0;
  background: rgba(92, 255, 133, 0.15);
  border-left: 2px solid var(--accent-lime);
  border-right: 2px solid var(--accent-lime);
  left: 45%;
  width: 10%;
  transition: all 0.3s ease;
}

.temp-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-top: 0.4rem;
}

.exp-readout {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.readout-item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.readout-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.readout-value {
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--text-primary);
}

.exp-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}

.exp-actions .btn {
  padding: 0.75rem 1.5rem;
  font-size: 0.95rem;
}

.exp-actions .btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
}

/* ---- Prediction Gauge ---- */
.prediction-gauge {
  max-width: 480px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

.gauge-display {
  margin-bottom: 1.5rem;
}

.gauge-value {
  font-size: 3.5rem;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}

.gauge-unit {
  font-size: 1rem;
  color: var(--text-muted);
  font-weight: 500;
  display: block;
  margin-top: 0.25rem;
}

.gauge-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  outline: none;
  margin-bottom: 0.75rem;
}

.gauge-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 22px;
  height: 22px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-gold));
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 2px 12px rgba(0, 217, 255, 0.4);
  border: 2px solid rgba(255, 255, 255, 0.8);
  transition: transform var(--transition-fast);
}

.gauge-slider::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}

.gauge-slider::-moz-range-thumb {
  width: 22px;
  height: 22px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-gold));
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.gauge-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: var(--text-muted);
}

/* ---- Discovery Reveal ---- */
.discovery-reveal {
  max-width: 560px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

.reveal-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.reveal-label {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 0.5rem 1rem;
  background: rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.reveal-label.highlight {
  background: rgba(0, 217, 255, 0.1);
  border-color: rgba(0, 217, 255, 0.3);
  color: var(--accent-cyan);
}

.reveal-arrow {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--accent-violet);
}

.reveal-formula {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 800;
}

.formula-num {
  color: var(--text-primary);
  transition: color 0.3s;
}

.formula-op {
  color: var(--accent-violet);
  font-weight: 600;
}

.formula-res {
  color: var(--accent-cyan);
  transition: color 0.3s;
}

.formula-unit {
  font-size: 0.6em;
  color: var(--text-muted);
  font-weight: 500;
}

/* ---- Explanation Cards ---- */
.explanation-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.5rem;
  max-width: 800px;
  margin: 2rem auto 0;
}

.explanation-card {
  padding: 1.5rem;
  text-align: left;
  position: relative;
  overflow: hidden;
  transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
}

.explanation-card:hover {
  transform: translateY(-6px);
}

.expl-number {
  position: absolute;
  top: -0.5rem;
  right: -0.5rem;
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-gold));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  font-weight: 800;
  color: var(--bg-deep);
  opacity: 0.3;
}

.explanation-card:hover .expl-number {
  opacity: 0.8;
  transform: scale(1.1);
}

.explanation-card h3 {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  color: var(--text-primary);
}

.explanation-card p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.expl-visual {
  margin-top: 1rem;
  height: 60px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.setpoint-display {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--accent-cyan);
}

.band-display {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--accent-gold);
}

.calc-visual {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--accent-violet);
}

/* ---- Applications Grid ---- */
.apps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.25rem;
  max-width: 900px;
  margin: 2rem auto 0;
}

.app-card {
  padding: 1.5rem;
  text-align: left;
  transition: transform var(--transition-smooth);
}

.app-card:hover {
  transform: translateY(-6px);
}

.app-icon {
  font-size: 2.5rem;
  margin-bottom: 0.75rem;
  line-height: 1;
}

.app-card h3 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.app-card p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ---- Quiz / Challenge ---- */
.quiz-container {
  max-width: 560px;
  margin: 2rem auto;
}

.quiz-question {
  display: none;
  text-align: center;
}

.quiz-question.active {
  display: block;
}

.quiz-text {
  font-size: 1.1rem;
  color: var(--text-primary);
  margin-bottom: 1.5rem;
  line-height: 1.5;
}

.quiz-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.quiz-option {
  padding: 1rem;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  font-family: inherit;
}

.quiz-option:hover {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.25);
  transform: translateY(-2px);
}

.quiz-option:focus-visible {
  outline: 3px solid var(--accent-cyan);
  outline-offset: 2px;
}

.quiz-option.correct {
  background: rgba(92, 255, 133, 0.15);
  border-color: var(--accent-lime);
  color: var(--accent-lime);
}

.quiz-option.incorrect {
  background: rgba(255, 92, 171, 0.15);
  border-color: var(--accent-pink);
  color: var(--accent-pink);
}

.quiz-option.disabled {
  pointer-events: none;
  opacity: 0.7;
}

.quiz-feedback {
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 1rem;
  min-height: 1.5rem;
}

.quiz-feedback.correct {
  color: var(--accent-lime);
}

.quiz-feedback.incorrect {
  color: var(--accent-pink);
}

.quiz-score {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 2rem;
  margin-top: 1rem;
}

.score-label {
  font-size: 0.85rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.score-value {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--accent-cyan);
}

/* ---- Celebration ---- */
.celebration-visual {
  height: 120px;
  margin-bottom: 1rem;
  position: relative;
  overflow: hidden;
}

.celebration-particle {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  pointer-events: none;
  animation: confettiFall 3s ease-out forwards;
}

@keyframes confettiFall {
  0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(120px) rotate(720deg); opacity: 0; }
}

.celebration-badge {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.5rem;
  margin-bottom: 1.5rem;
  text-align: left;
}

.badge-icon {
  font-size: 2.5rem;
}

.badge-title {
  display: block;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.badge-desc {
  display: block;
  font-size: 0.8rem;
  color: var(--text-muted);
}

.celebration-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  max-width: 600px;
  margin: 2rem auto;
}

.cstat {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.cstat-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.cstat-value {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.celebration-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 2rem;
  flex-wrap: wrap;
}

/* ---- Mystery Controls ---- */
.mystery-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  justify-content: space-between;
  padding: 1rem 1.5rem;
  border-radius: 0;
  border-bottom: none;
  border-left: none;
  border-right: none;
}

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .obs-facts { grid-template-columns: 1fr; }
  .thermostat-controls { grid-template-columns: 1fr; }
  .exp-readout { grid-template-columns: 1fr; gap: 0.5rem; }
  .quiz-options { grid-template-columns: 1fr; }
  .explanation-cards { grid-template-columns: 1fr; }
  .apps-grid { grid-template-columns: 1fr; }
  .celebration-stats { grid-template-columns: 1fr; }
  .reveal-line { flex-direction: column; gap: 0.5rem; }
  .reveal-formula { flex-direction: column; gap: 0.5rem; }
  .mystery-controls { flex-direction: column; gap: 0.75rem; }
  .mystery-controls .btn { width: 100%; }
  .exp-actions { flex-direction: column; }
  .exp-actions .btn { width: 100%; }
  .temp-timeline { flex-wrap: wrap; gap: 0.5rem; height: auto; padding: 1rem; }
  .temp-arrow { display: none; }
}

@media (max-width: 480px) {
  .step-title { font-size: 1.8rem; }
  .gauge-value { font-size: 2.5rem; }
  .experiment-stage { padding: 1.25rem; }
  .curiosity-visual { height: 180px; }
  .room-temp { font-size: 2.5rem; }
}

@media (prefers-reduced-motion: reduce) {
  .ac-vents, .air-particle {
    animation: none !important;
  }
}