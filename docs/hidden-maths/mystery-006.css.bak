/* ============================================
   HIDDEN MATHS — mystery-006.css
   Mystery 006: Rocket Launch
   ============================================ */

.mystery-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  border-radius: 0;
  border-top: none; border-left: none; border-right: none;
  padding: 0.75rem 0;
}

.mystery-nav .nav-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  color: var(--text-secondary);
  font-weight: 500;
  font-size: 0.95rem;
  transition: color var(--transition-fast);
  padding: 0.4rem 0.8rem;
  border-radius: var(--radius-sm);
}

.nav-back:hover, .nav-back:focus {
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.06);
  outline: none;
}

.nav-back:focus-visible {
  outline: 2px solid var(--accent-gold);
  outline-offset: 3px;
}

.mystery-progress {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.progress-track {
  width: 120px;
  height: 4px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-gold), var(--accent-pink));
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  width: 11%;
}

.progress-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-weight: 600;
  white-space: nowrap;
}

.mystery-main {
  position: relative;
  z-index: 1;
  padding-top: 5rem;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.mystery-step {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 5rem);
  padding: 3rem 1.5rem 5rem;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.mystery-step.active {
  display: flex;
  opacity: 1;
  transform: translateY(0);
}

.step-content {
  max-width: 720px;
  width: 100%;
  text-align: center;
}

.mystery-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-gold);
  background: rgba(255, 200, 87, 0.08);
  border: 1px solid rgba(255, 200, 87, 0.18);
  border-radius: 100px;
  padding: 0.35rem 1rem;
  margin-bottom: 1rem;
}

.step-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent-gold);
  background: rgba(255, 200, 87, 0.08);
  border: 1px solid rgba(255, 200, 87, 0.18);
  border-radius: 100px;
  padding: 0.35rem 1rem;
  margin-bottom: 1rem;
}

.step-title {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  background: linear-gradient(135deg, var(--text-primary), var(--accent-gold));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.step-hook {
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  color: var(--text-secondary);
  font-style: italic;
  max-width: 560px;
  margin: 0 auto 2rem;
  line-height: 1.6;
}

.step-desc {
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 auto 2rem;
  line-height: 1.7;
}

.step-hint {
  font-size: 0.95rem;
  color: var(--text-muted);
  max-width: 480px;
  margin: 1.5rem auto 0;
  line-height: 1.5;
}

/* ---- Curiosity: Rocket Scene ---- */
.curiosity-visual {
  margin: 2rem auto;
  max-width: 480px;
  height: 220px;
  position: relative;
}

.rocket-scene {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.launch-pad {
  position: relative;
  width: 140px;
  height: 160px;
}

.pad-tower {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 8px;
  height: 100px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4px;
}

.rocket-body {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 80px;
  background: rgba(255, 255, 255, 0.08);
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-radius: 12px 12px 4px 4px;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: rocketHover 2s ease-in-out infinite;
}

@keyframes rocketHover {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(-5px); }
}

.rocket-nose {
  width: 0;
  height: 0;
  border-left: 12px solid transparent;
  border-right: 12px solid transparent;
  border-bottom: 16px solid rgba(255, 200, 87, 0.6);
  position: absolute;
  top: -16px;
  left: 50%;
  transform: translateX(-50%);
}

.rocket-fin {
  position: absolute;
  bottom: 0;
  width: 0;
  height: 0;
  border-bottom: 16px solid rgba(255, 255, 255, 0.15);
}

.rocket-fin:nth-child(2) { left: -8px; border-right: 8px solid transparent; }
.rocket-fin:nth-child(3) { right: -8px; border-left: 8px solid transparent; }

.rocket-flame {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 16px;
  height: 0;
  background: linear-gradient(180deg, var(--accent-gold), var(--accent-pink));
  border-radius: 0 0 50% 50%;
  animation: flameFlicker 0.3s ease-in-out infinite alternate;
}

@keyframes flameFlicker {
  from { height: 20px; opacity: 0.8; }
  to { height: 30px; opacity: 1; }
}

.trajectory-arc {
  position: absolute;
  top: 20px;
  left: 50%;
  width: 200px;
  height: 120px;
  border: 2px dashed rgba(255, 200, 87, 0.2);
  border-radius: 0 100px 0 0;
  border-bottom: none;
  border-left: none;
  transform: translateX(-30%);
  opacity: 0.6;
}

/* ---- Observation ---- */
.observation-stage {
  margin: 2rem auto;
  max-width: 520px;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.path-trace {
  position: relative;
  height: 100px;
  margin-bottom: 1.5rem;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.trace-line {
  position: absolute;
  bottom: 0;
  left: 10%;
  width: 2px;
  height: 90%;
  background: linear-gradient(180deg, transparent, var(--accent-gold));
  border-radius: 2px;
  animation: traceGrow 2s ease-out infinite;
}

@keyframes traceGrow {
  0% { height: 0; }
  50% { height: 90%; }
  100% { height: 90%; }
}

.trace-points {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 10%;
}

.t-point {
  font-size: 0.7rem;
  color: var(--text-muted);
  padding: 0.25rem 0.5rem;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4px;
  transform: translateY(50%);
}

.path-shape {
  text-align: center;
}

.shape-label {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

.shape-options {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.shape-opt {
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-sm);
  transition: all 0.3s;
}

.shape-opt.highlight {
  background: rgba(255, 200, 87, 0.15);
  border-color: var(--accent-gold);
  color: var(--accent-gold);
  transform: scale(1.05);
}

.obs-facts {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1.5rem;
}

.fact-card {
  padding: 1rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  animation: fadeInUp 0.5s ease-out both;
}

.fact-card:nth-child(1) { animation-delay: 0.1s; }
.fact-card:nth-child(2) { animation-delay: 0.25s; }
.fact-card:nth-child(3) { animation-delay: 0.4s; }

.fact-number {
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--accent-gold);
}

.fact-label {
  font-size: 0.8rem;
  color: var(--text-muted);
}

/* ---- Experiment: Launch Sim ---- */
.experiment-stage {
  max-width: 560px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

.launch-sim {
  position: relative;
  margin-bottom: 1.5rem;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

#launchCanvas {
  width: 100%;
  height: auto;
  display: block;
}

.launch-overlay {
  padding: 1rem;
  background: rgba(0, 0, 0, 0.3);
}

.launch-readout {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.readout-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.readout-label {
  font-size: 0.7rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.readout-value {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.launch-controls {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.control-group {
  text-align: left;
}

.control-group label {
  display: block;
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
  font-weight: 600;
}

.control-value {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.launch-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  outline: none;
  margin-bottom: 0.5rem;
}

.launch-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px;
  height: 20px;
  background: linear-gradient(135deg, var(--accent-gold), var(--accent-pink));
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 2px 10px rgba(255, 200, 87, 0.4);
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.launch-slider::-moz-range-thumb {
  width: 20px;
  height: 20px;
  background: linear-gradient(135deg, var(--accent-gold), var(--accent-pink));
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.angle-visual {
  width: 60px;
  height: 60px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
  margin-top: 0.5rem;
}

.angle-line {
  position: absolute;
  bottom: 4px;
  left: 4px;
  width: 50px;
  height: 2px;
  background: var(--accent-gold);
  transform-origin: bottom left;
  transition: transform 0.3s ease;
}

.exp-actions {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}

.exp-actions .btn {
  padding: 0.75rem 1.5rem;
  font-size: 0.95rem;
}

/* ---- Prediction Gauge ---- */
.prediction-gauge {
  max-width: 480px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

.gauge-display {
  margin-bottom: 1.5rem;
}

.gauge-value {
  font-size: 3.5rem;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}

.gauge-unit {
  font-size: 1rem;
  color: var(--text-muted);
  font-weight: 500;
  display: block;
  margin-top: 0.25rem;
}

.gauge-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3px;
  outline: none;
  margin-bottom: 0.75rem;
}

.gauge-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 22px;
  height: 22px;
  background: linear-gradient(135deg, var(--accent-gold), var(--accent-pink));
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 2px 12px rgba(255, 200, 87, 0.4);
  border: 2px solid rgba(255, 255, 255, 0.8);
  transition: transform var(--transition-fast);
}

.gauge-slider::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}

.gauge-slider::-moz-range-thumb {
  width: 22px;
  height: 22px;
  background: linear-gradient(135deg, var(--accent-gold), var(--accent-pink));
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid rgba(255, 255, 255, 0.8);
}

.gauge-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: var(--text-muted);
}

/* ---- Discovery Reveal ---- */
.discovery-reveal {
  max-width: 560px;
  margin: 2rem auto;
  padding: 2rem;
  text-align: center;
}

.reveal-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.reveal-label {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 0.5rem 1rem;
  background: rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.reveal-label.highlight {
  background: rgba(255, 200, 87, 0.1);
  border-color: rgba(255, 200, 87, 0.3);
  color: var(--accent-gold);
}

.reveal-arrow {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--accent-pink);
}

.reveal-formula {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  font-size: clamp(1.3rem, 3.5vw, 2rem);
  font-weight: 800;
}

.formula-num {
  color: var(--text-primary);
  transition: color 0.3s;
}

.formula-op {
  color: var(--accent-pink);
  font-weight: 600;
}

.formula-res {
  color: var(--accent-gold);
  transition: color 0.3s;
}

.formula-unit {
  font-size: 0.6em;
  color: var(--text-muted);
  font-weight: 500;
}

/* ---- Explanation Cards ---- */
.explanation-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.5rem;
  max-width: 800px;
  margin: 2rem auto 0;
}

.explanation-card {
  padding: 1.5rem;
  text-align: left;
  position: relative;
  overflow: hidden;
  transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
}

.explanation-card:hover {
  transform: translateY(-6px);
}

.expl-number {
  position: absolute;
  top: -0.5rem;
  right: -0.5rem;
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--accent-gold), var(--accent-pink));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  font-weight: 800;
  color: var(--bg-deep);
  opacity: 0.3;
}

.explanation-card:hover .expl-number {
  opacity: 0.8;
  transform: scale(1.1);
}

.explanation-card h3 {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  color: var(--text-primary);
}

.explanation-card p {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.expl-visual {
  margin-top: 1rem;
  height: 60px;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.calc-text {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--accent-gold);
}

/* ---- Applications Grid ---- */
.apps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.25rem;
  max-width: 900px;
  margin: 2rem auto 0;
}

.app-card {
  padding: 1.5rem;
  text-align: left;
  transition: transform var(--transition-smooth);
}

.app-card:hover {
  transform: translateY(-6px);
}

.app-icon {
  font-size: 2.5rem;
  margin-bottom: 0.75rem;
  line-height: 1;
}

.app-card h3 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

.app-card p {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ---- Quiz ---- */
.quiz-container {
  max-width: 560px;
  margin: 2rem auto;
}

.quiz-question {
  display: none;
  text-align: center;
}

.quiz-question.active {
  display: block;
}

.quiz-text {
  font-size: 1.1rem;
  color: var(--text-primary);
  margin-bottom: 1.5rem;
  line-height: 1.5;
}

.quiz-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.quiz-option {
  padding: 1rem;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  font-family: inherit;
}

.quiz-option:hover {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.25);
  transform: translateY(-2px);
}

.quiz-option:focus-visible {
  outline: 3px solid var(--accent-gold);
  outline-offset: 2px;
}

.quiz-option.correct {
  background: rgba(92, 255, 133, 0.15);
  border-color: var(--accent-lime);
  color: var(--accent-lime);
}

.quiz-option.incorrect {
  background: rgba(255, 92, 171, 0.15);
  border-color: var(--accent-pink);
  color: var(--accent-pink);
}

.quiz-option.disabled {
  pointer-events: none;
  opacity: 0.7;
}

.quiz-feedback {
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 1rem;
  min-height: 1.5rem;
}

.quiz-feedback.correct {
  color: var(--accent-lime);
}

.quiz-feedback.incorrect {
  color: var(--accent-pink);
}

.quiz-score {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 2rem;
  margin-top: 1rem;
}

.score-label {
  font-size: 0.85rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.score-value {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--accent-gold);
}

/* ---- Celebration ---- */
.celebration-visual {
  height: 120px;
  margin-bottom: 1rem;
  position: relative;
  overflow: hidden;
}

.celebration-particle {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  pointer-events: none;
  animation: confettiFall 3s ease-out forwards;
}

@keyframes confettiFall {
  0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(120px) rotate(720deg); opacity: 0; }
}

.celebration-badge {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.5rem;
  margin-bottom: 1.5rem;
  text-align: left;
}

.badge-icon {
  font-size: 2.5rem;
}

.badge-title {
  display: block;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.badge-desc {
  display: block;
  font-size: 0.8rem;
  color: var(--text-muted);
}

.celebration-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  max-width: 600px;
  margin: 2rem auto;
}

.cstat {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.cstat-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.cstat-value {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
}

.celebration-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 2rem;
  flex-wrap: wrap;
}

/* ---- Controls ---- */
.mystery-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  justify-content: space-between;
  padding: 1rem 1.5rem;
  border-radius: 0;
  border-bottom: none;
  border-left: none;
  border-right: none;
}

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .obs-facts { grid-template-columns: 1fr; }
  .launch-controls { grid-template-columns: 1fr; }
  .launch-readout { grid-template-columns: repeat(2, 1fr); }
  .quiz-options { grid-template-columns: 1fr; }
  .explanation-cards { grid-template-columns: 1fr; }
  .apps-grid { grid-template-columns: 1fr; }
  .celebration-stats { grid-template-columns: 1fr; }
  .reveal-line { flex-direction: column; gap: 0.5rem; }
  .reveal-formula { flex-direction: column; gap: 0.5rem; }
  .mystery-controls { flex-direction: column; gap: 0.75rem; }
  .mystery-controls .btn { width: 100%; }
  .exp-actions { flex-direction: column; }
  .exp-actions .btn { width: 100%; }
  .shape-options { flex-direction: column; align-items: center; }
}

@media (max-width: 480px) {
  .step-title { font-size: 1.8rem; }
  .gauge-value { font-size: 2.5rem; }
  .experiment-stage { padding: 1.25rem; }
  .curiosity-visual { height: 180px; }
  .launch-pad { height: 140px; }
  .rocket-body { height: 70px; }
}

@media (prefers-reduced-motion: reduce) {
  .rocket-body, .rocket-flame, .trace-line {
    animation: none !important;
  }
}