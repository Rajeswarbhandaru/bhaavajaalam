<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>BCS Lite — Bhāva Cognitive Screen</title>
<style>
/* ======== CSS VARIABLES & RESET ======== */
:root {
  --bg: #07111f;
  --bg2: #0d1b2e;
  --card: rgba(255,255,255,0.06);
  --card-border: rgba(255,255,255,0.12);
  --accent: #7c9cff;
  --accent2: #48d7c4;
  --accent3: #ffd166;
  --accent4: #ff8a8a;
  --text: #e8eaf2;
  --text-muted: rgba(232,234,242,0.55);
  --success: #44cc88;
  --danger: #ff5566;
  --radius: 18px;
  --radius-sm: 10px;
  --shadow: 0 8px 40px rgba(0,0,0,0.5);
  --glow: 0 0 24px rgba(124,156,255,0.3);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  overflow-x: hidden;
}

body { min-height: 100vh; position: relative; }

/* ======== STARFIELD ======== */
#starfield {
  position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
}
.star {
  position: absolute; border-radius: 50%; background: #fff;
  animation: twinkle var(--dur, 3s) ease-in-out infinite var(--delay, 0s);
}
@keyframes twinkle {
  0%,100% { opacity: 0.1; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.3); }
}

/* ======== LAYOUT ======== */
#app {
  position: relative; z-index: 1;
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center;
  padding: 20px 16px 40px;
}

.screen { width: 100%; max-width: 680px; display: none; }
.screen.active { display: block; }

/* ======== HEADER ======== */
.logo-bar {
  display: flex; align-items: center; gap: 14px; margin-bottom: 28px;
}
.logo-icon {
  width: 52px; height: 52px; border-radius: 14px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; box-shadow: var(--glow);
}
.logo-text h1 { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.5px; }
.logo-text p { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }

/* ======== CARD ======== */
.card {
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: var(--radius);
  padding: 28px 24px;
  backdrop-filter: blur(16px);
  box-shadow: var(--shadow);
  margin-bottom: 18px;
}

/* ======== FORMS ======== */
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 480px) { .form-grid { grid-template-columns: 1fr; } }

.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-group.full { grid-column: 1 / -1; }
.form-group label { font-size: 0.78rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

input, select {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: var(--radius-sm);
  color: var(--text);
  padding: 10px 14px;
  font-size: 0.95rem;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  width: 100%;
}
input:focus, select:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(124,156,255,0.15);
}
select option { background: #1a2a3a; }

/* ======== BUTTONS ======== */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 13px 28px;
  border-radius: var(--radius-sm);
  border: none;
  font-size: 1rem; font-weight: 600; cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
  text-decoration: none;
}
.btn:active { transform: scale(0.97); }
.btn-primary {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff;
  box-shadow: 0 4px 20px rgba(124,156,255,0.35);
}
.btn-primary:hover { box-shadow: 0 6px 28px rgba(124,156,255,0.5); }
.btn-secondary {
  background: rgba(255,255,255,0.1);
  border: 1px solid var(--card-border);
  color: var(--text);
}
.btn-full { width: 100%; }
.btn-sm { padding: 8px 16px; font-size: 0.87rem; }

/* ======== BADGES ======== */
.badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 600;
}
.badge-success { background: rgba(68,204,136,0.18); color: var(--success); border: 1px solid rgba(68,204,136,0.3); }
.badge-info { background: rgba(124,156,255,0.18); color: var(--accent); border: 1px solid rgba(124,156,255,0.3); }
.badge-warn { background: rgba(255,209,102,0.18); color: var(--accent3); border: 1px solid rgba(255,209,102,0.3); }

/* ======== PROGRESS BAR ======== */
.progress-bar-wrap {
  background: rgba(255,255,255,0.08);
  border-radius: 8px; height: 8px; overflow: hidden; margin-bottom: 6px;
}
.progress-bar-fill {
  height: 100%;
  border-radius: 8px;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  transition: width 0.4s ease;
}
.progress-labels {
  display: flex; justify-content: space-between;
  font-size: 0.72rem; color: var(--text-muted);
}

/* ======== MODULE HEADER ======== */
.module-header {
  display: flex; align-items: center; gap: 14px; margin-bottom: 22px;
}
.module-icon {
  width: 48px; height: 48px; border-radius: 12px;
  background: rgba(124,156,255,0.15);
  border: 1px solid rgba(124,156,255,0.25);
  display: flex; align-items: center; justify-content: center; font-size: 24px;
  flex-shrink: 0;
}
.module-meta h2 { font-size: 1.2rem; font-weight: 700; }
.module-meta p { font-size: 0.8rem; color: var(--text-muted); margin-top: 3px; }

/* ======== COUNTDOWN OVERLAY ======== */
#countdown-overlay {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(7,17,31,0.92);
  backdrop-filter: blur(8px);
  display: none;
  flex-direction: column; align-items: center; justify-content: center;
  gap: 16px; text-align: center;
}
#countdown-overlay.visible { display: flex; }
#countdown-num {
  font-size: 5rem; font-weight: 900; line-height: 1;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: popIn 0.3s ease;
}
@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
#countdown-label { font-size: 1.1rem; color: var(--text-muted); max-width: 320px; }

/* ======== TIMER RING ======== */
.timer-display {
  display: flex; align-items: center; gap: 8px;
  font-size: 1.1rem; font-weight: 700; color: var(--accent3);
}
.timer-display.urgent { color: var(--danger); animation: pulse 0.5s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.5} }

/* ======== MEMORY MODULE ======== */
#mem-sequence-display {
  font-size: 2.8rem; font-weight: 900; letter-spacing: 12px;
  text-align: center; padding: 28px;
  background: rgba(124,156,255,0.1);
  border-radius: var(--radius); border: 1px solid rgba(124,156,255,0.2);
  margin: 18px 0; min-height: 90px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Courier New', monospace;
}
#mem-input-area { display: none; }
#mem-input {
  font-size: 2rem; text-align: center; letter-spacing: 8px;
  font-family: 'Courier New', monospace; font-weight: 700;
}

/* ======== ATTENTION MODULE ======== */
#att-grid {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;
  margin: 18px 0;
}
.att-item {
  aspect-ratio: 1; border-radius: 12px; font-size: 1.8rem;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.06);
  border: 2px solid transparent;
  cursor: pointer;
  transition: transform 0.15s, border-color 0.15s, background 0.15s;
  user-select: none;
}
.att-item:active { transform: scale(0.9); }
.att-item.selected {
  border-color: var(--accent);
  background: rgba(124,156,255,0.2);
}
.att-item.wrong-select {
  border-color: var(--danger);
  background: rgba(255,85,102,0.2);
}
.att-stats {
  display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px;
}

/* ======== FOCUS (STROOP) MODULE ======== */
.stroop-word {
  font-size: 3rem; font-weight: 900; text-align: center;
  padding: 28px; border-radius: var(--radius);
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--card-border);
  margin: 18px 0; letter-spacing: 3px;
  transition: opacity 0.15s;
  min-height: 100px; display: flex; align-items: center; justify-content: center;
}
.stroop-prompt {
  text-align: center; font-size: 0.9rem; color: var(--text-muted); margin-bottom: 14px;
}
.stroop-options {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 8px;
}
.stroop-btn {
  padding: 14px; border-radius: var(--radius-sm); border: 2px solid transparent;
  font-size: 0.95rem; font-weight: 700; cursor: pointer;
  transition: transform 0.12s, border-color 0.12s;
  text-align: center; color: #fff;
}
.stroop-btn:active { transform: scale(0.96); }
.stroop-btn.correct-flash { border-color: var(--success) !important; box-shadow: 0 0 16px rgba(68,204,136,0.5); }
.stroop-btn.wrong-flash { border-color: var(--danger) !important; box-shadow: 0 0 16px rgba(255,85,102,0.5); }
.stroop-progress-row {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;
}
.stroop-trial-dots {
  display: flex; gap: 5px; flex-wrap: wrap;
}
.trial-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: rgba(255,255,255,0.2);
}
.trial-dot.correct { background: var(--success); }
.trial-dot.wrong { background: var(--danger); }

/* ======== LOGIC MODULE ======== */
.logic-question {
  font-size: 1.15rem; font-weight: 600; line-height: 1.5;
  padding: 20px; border-radius: var(--radius);
  background: rgba(124,156,255,0.08);
  border: 1px solid rgba(124,156,255,0.2);
  margin-bottom: 18px;
  text-align: center;
}
.logic-options { display: flex; flex-direction: column; gap: 10px; }
.logic-opt-btn {
  padding: 13px 18px; border-radius: var(--radius-sm);
  border: 1.5px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.05);
  color: var(--text); font-size: 0.95rem; text-align: left; cursor: pointer;
  transition: border-color 0.15s, background 0.15s, transform 0.1s;
}
.logic-opt-btn:hover { border-color: var(--accent); background: rgba(124,156,255,0.1); }
.logic-opt-btn:active { transform: scale(0.98); }
.logic-opt-btn.correct { border-color: var(--success); background: rgba(68,204,136,0.15); }
.logic-opt-btn.wrong { border-color: var(--danger); background: rgba(255,85,102,0.15); }
.logic-explanation {
  margin-top: 12px; padding: 12px 16px; border-radius: var(--radius-sm);
  background: rgba(72,215,196,0.1); border: 1px solid rgba(72,215,196,0.25);
  font-size: 0.85rem; color: var(--accent2); display: none;
}
.logic-progress { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 14px; }
.logic-score-row {
  display: flex; gap: 8px; align-items: center; margin-bottom: 6px; flex-wrap: wrap;
}

/* ======== OBSERVATION MODULE ======== */
.obs-canvases {
  display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 18px 0;
}
@media (max-width: 480px) { .obs-canvases { grid-template-columns: 1fr; } }
.obs-canvas-wrap {
  position: relative; border-radius: var(--radius-sm); overflow: hidden;
  border: 2px solid var(--card-border);
}
.obs-canvas-wrap canvas {
  display: block; width: 100%; height: auto; cursor: crosshair;
}
.obs-canvas-label {
  text-align: center; font-size: 0.75rem; color: var(--text-muted);
  padding: 5px; background: rgba(0,0,0,0.3);
}
.diff-markers { display: none; }
.obs-diffs-list { display: flex; flex-direction: column; gap: 8px; margin-top: 14px; }
.obs-diff-item {
  padding: 10px 14px; border-radius: var(--radius-sm);
  border: 1.5px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04);
  font-size: 0.87rem; display: flex; align-items: center; gap: 10px;
  cursor: pointer; transition: border-color 0.15s;
}
.obs-diff-item:hover { border-color: var(--accent); }
.obs-diff-item.found { border-color: var(--success); background: rgba(68,204,136,0.12); }
.obs-diff-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--card-border); flex-shrink: 0; }
.obs-diff-item.found .obs-diff-dot { background: var(--success); }
.obs-hint { font-size: 0.78rem; color: var(--text-muted); margin-top: 8px; text-align: center; }
/* Click hotspot on canvas */
.canvas-highlight {
  position: absolute; border: 3px solid var(--success);
  border-radius: 50%; pointer-events: none;
  animation: ringPop 0.4s ease forwards;
}
@keyframes ringPop {
  0% { transform: scale(0.5); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* ======== RESULTS SCREEN ======== */
.results-header {
  text-align: center; padding: 28px 0 18px;
}
.results-score-big {
  font-size: 4rem; font-weight: 900; line-height: 1;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.results-grade {
  font-size: 1.1rem; font-weight: 700; margin-top: 8px;
  padding: 6px 18px; border-radius: 20px; display: inline-block;
}
.grade-excellent { background: rgba(68,204,136,0.2); color: var(--success); border: 1px solid rgba(68,204,136,0.4); }
.grade-good { background: rgba(124,156,255,0.2); color: var(--accent); border: 1px solid rgba(124,156,255,0.4); }
.grade-developing { background: rgba(255,209,102,0.2); color: var(--accent3); border: 1px solid rgba(255,209,102,0.4); }
.grade-early { background: rgba(255,85,102,0.2); color: var(--danger); border: 1px solid rgba(255,85,102,0.4); }

.score-breakdown {
  display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin: 18px 0;
}
@media (max-width: 480px) { .score-breakdown { grid-template-columns: 1fr 1fr; } }
.score-card {
  padding: 14px 8px; border-radius: var(--radius-sm); text-align: center;
  background: rgba(255,255,255,0.05); border: 1px solid var(--card-border);
}
.score-card .score-icon { font-size: 1.5rem; }
.score-card .score-label { font-size: 0.68rem; color: var(--text-muted); margin: 4px 0; text-transform: uppercase; }
.score-card .score-val { font-size: 1.3rem; font-weight: 800; color: var(--accent); }

/* Journey Bar */
.journey-bar-wrap { margin-top: 10px; }
.journey-track {
  display: flex; align-items: center; gap: 0;
  background: rgba(255,255,255,0.05);
  border-radius: 40px; padding: 6px 8px;
  border: 1px solid var(--card-border);
  margin: 12px 0;
}
.journey-node {
  flex: 1; text-align: center; position: relative;
  padding: 8px 4px;
}
.journey-node .j-dot {
  width: 16px; height: 16px; border-radius: 50%;
  background: rgba(255,255,255,0.15);
  margin: 0 auto 5px;
  border: 2px solid rgba(255,255,255,0.2);
}
.journey-node.active .j-dot {
  background: var(--accent);
  border-color: var(--accent);
  box-shadow: 0 0 12px rgba(124,156,255,0.6);
}
.journey-node .j-label { font-size: 0.65rem; color: var(--text-muted); }
.journey-node.active .j-label { color: var(--accent); font-weight: 700; }
.journey-connector {
  flex: 0.5; height: 2px;
  background: rgba(255,255,255,0.1);
}
.journey-connector.done { background: linear-gradient(90deg, var(--accent), var(--accent2)); }

/* Save status */
#save-status {
  text-align: center; font-size: 0.82rem; color: var(--text-muted);
  margin-top: 8px; min-height: 20px;
}

/* ======== SECTION TITLE ======== */
.section-title {
  font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px;
  color: var(--text-muted); font-weight: 700; margin-bottom: 10px;
}

/* ======== UTILITY ======== */
.mt-12 { margin-top: 12px; }
.mt-18 { margin-top: 18px; }
.mb-12 { margin-bottom: 12px; }
.text-center { text-align: center; }
.text-muted { color: var(--text-muted); }
.flex-row { display: flex; align-items: center; gap: 10px; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.hidden { display: none !important; }
.divider { height: 1px; background: rgba(255,255,255,0.08); margin: 18px 0; }

/* ======== PRINT ======== */
@media print {
  #starfield, #countdown-overlay { display: none !important; }
  body { background: #fff; color: #000; }
  .card { background: #f5f5f5; border: 1px solid #ccc; box-shadow: none; }
  .btn { display: none; }
  .results-score-big { -webkit-text-fill-color: #333; }
  .score-val { color: #333 !important; }
}

/* ======== FLASH OVERLAY for correct/wrong ======== */
#feedback-flash {
  position: fixed; inset: 0; z-index: 90; pointer-events: none;
  opacity: 0; transition: opacity 0.12s;
}
#feedback-flash.show-correct { background: rgba(68,204,136,0.12); opacity: 1; }
#feedback-flash.show-wrong { background: rgba(255,85,102,0.12); opacity: 1; }
</style>
</head>
