<div id="starfield"></div>
<div id="feedback-flash"></div>

<!-- COUNTDOWN OVERLAY -->
<div id="countdown-overlay">
  <div id="countdown-num">3</div>
  <div id="countdown-label">Get ready for the next module</div>
</div>

<div id="app">
  <!-- ===== PERSISTENT NAV BAR ===== -->
  <div id="bcs-nav" style="position:fixed;top:0;left:0;right:0;z-index:999;display:flex;align-items:center;justify-content:space-between;padding:8px 16px;background:rgba(10,18,40,0.85);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.08);">
    <button onclick="goBack()" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);color:#fff;font-family:inherit;font-size:0.82rem;font-weight:700;padding:7px 18px;border-radius:20px;cursor:pointer;" onmouseover="this.style.background='rgba(255,255,255,0.18)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'">&#8592; Back</button>
