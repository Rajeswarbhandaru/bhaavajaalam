<script>
/* ============================================================
   STARFIELD
============================================================ */
(function(){
  const sf = document.getElementById('starfield');
  for(let i=0;i<80;i++){
    const s = document.createElement('div');
    s.className='star';
    const sz = Math.random()*2.5+0.5;
    s.style.cssText=`width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--dur:${2+Math.random()*4}s;--delay:${-Math.random()*4}s`;
    sf.appendChild(s);
  }
})();

/* ============================================================
   STATE
============================================================ */
const BCS = {
  student: {},
  scores: { memory:0, attention:0, focus:0, logic:0, observation:0 },
  rawMetrics: {},
  currentModule: null,
  startTime: null,
  activeTimers: []
};

/* ============================================================
   SCREEN ROUTER
============================================================ */
function showScreen(id) {
  // Kill all timers
  BCS.activeTimers.forEach(clearInterval);
  BCS.activeTimers.forEach(clearTimeout);
  BCS.activeTimers = [];

  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(id);
  if(el) { el.classList.add('active'); window.scrollTo(0,0); }
}

/* ============================================================
   SHUFFLE HELPER
============================================================ */
function shuffle(arr) {
  const a = [...arr];
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}
function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }
function pick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }

/* ============================================================
   FEEDBACK FLASH
============================================================ */
function flashFeedback(correct) {
  const el = document.getElementById('feedback-flash');
  el.className = correct ? 'show-correct' : 'show-wrong';
  const t = setTimeout(() => { el.className = ''; }, 300);
  BCS.activeTimers.push(t);
}

/* ============================================================
   INTAKE / LOCALSTORAGE PRE-FILL
============================================================ */
window.addEventListener('DOMContentLoaded', () => {
  try {
    const stored = localStorage.getItem('bhava_current_student');
    if(stored) {
      const s = JSON.parse(stored);
      const wrap = document.getElementById('login-badge-wrap');
      wrap.innerHTML = `<div class="badge badge-success" style="margin-bottom:8px">✓ Logged in as ${s.name || 'Student'}</div>`;
      wrap.classList.remove('hidden');
      if(s.name) document.getElementById('f-name').value = s.name;
      if(s.roll_no) document.getElementById('f-roll').value = s.roll_no;
      if(s.school_id) document.getElementById('f-school-id').value = s.school_id;
      if(s.school) document.getElementById('f-school').value = s.school;
      if(s.grade) {
        const sel = document.getElementById('f-grade');
        for(let i=0;i<sel.options.length;i++){
          if(sel.options[i].value === s.grade || sel.options[i].text === s.grade) sel.selectedIndex=i;
        }
      }
    }
  } catch(e){}
});

function startAssessment() {
  const name = document.getElementById('f-name').value.trim();
  const age = parseInt(document.getElementById('f-age').value);
  const grade = document.getElementById('f-grade').value;
  const school = document.getElementById('f-school').value.trim();

  if(!name) { alert('Please enter the student name.'); return; }
  if(!age || age<8 || age>17) { alert('Please enter a valid age (8–17).'); return; }
  if(!grade) { alert('Please select a grade.'); return; }
  if(!school) { alert('Please enter the school name.'); return; }

  BCS.student = {
    name, age, grade, school,
    roll_no: document.getElementById('f-roll').value.trim(),
    school_id: document.getElementById('f-school-id').value.trim(),
    facilitator: document.getElementById('f-facilitator').value.trim(),
    assessment_type: document.getElementById('f-assessment-type').value,
    date: new Date().toISOString().slice(0,10)
  };
  BCS.startTime = Date.now();
  startMemoryModule();
}

/* ============================================================
   COUNTDOWN BETWEEN MODULES
============================================================ */
function showCountdown(label, callback) {
  const overlay = document.getElementById('countdown-overlay');
  const numEl = document.getElementById('countdown-num');
  const lblEl = document.getElementById('countdown-label');
  lblEl.textContent = label;
  overlay.classList.add('visible');
  let n = 3;
  numEl.textContent = n;

  const iv = setInterval(() => {
    n--;
    if(n <= 0){
      clearInterval(iv);
      overlay.classList.remove('visible');
      callback();
    } else {
      numEl.textContent = n;
      numEl.style.animation='none';
      void numEl.offsetWidth;
      numEl.style.animation='popIn 0.3s ease';
    }
  }, 900);
}

/* ============================================================
   MODULE 1 — MEMORY
============================================================ */
let memSequence = '';

function startMemoryModule() {
  showScreen('screen-memory');

  const age = BCS.student.age;
  const len = age <= 10 ? 5 : age <= 14 ? 6 : 7;
  memSequence = Array.from({length:len}, () => randInt(1,9)).join('');

  const dispEl = document.getElementById('mem-sequence-display');
  const timerVal = document.getElementById('mem-timer-val');
  const timerBar = document.getElementById('mem-timer-bar');
  const studyDiv = document.getElementById('mem-phase-study');
  const inputDiv = document.getElementById('mem-input-area');
  const inputEl = document.getElementById('mem-input');

  dispEl.textContent = memSequence;
  studyDiv.style.display = 'block';
  inputDiv.style.display = 'none';
  inputEl.value = '';

  // Timer: 5 seconds display
  let timeLeft = 5;
  timerVal.textContent = timeLeft;
  timerBar.style.width = '100%';
  const timerEl = document.getElementById('mem-timer');
  timerEl.classList.remove('urgent');

  const iv = setInterval(() => {
    timeLeft--;
    timerVal.textContent = timeLeft;
    timerBar.style.width = (timeLeft/5*100) + '%';
    if(timeLeft <= 2) timerEl.classList.add('urgent');
    if(timeLeft <= 0){
      clearInterval(iv);
      BCS.activeTimers = BCS.activeTimers.filter(x=>x!==iv);
      dispEl.textContent = '• • • • •'.split('').slice(0, memSequence.length*2-1).join('');
      studyDiv.style.display = 'none';
      inputDiv.style.display = 'block';
      inputEl.focus();
    }
  }, 1000);
  BCS.activeTimers.push(iv);
}

function submitMemory() {
  const input = document.getElementById('mem-input').value.replace(/\D/g,'');
  const seq = memSequence;
  let correct = 0;
  for(let i=0;i<seq.length;i++){
    if(i < input.length && input[i] === seq[i]) correct++;
  }
  const score = Math.round((correct/seq.length)*20);
  BCS.scores.memory = score;
  BCS.rawMetrics.memory = { seq, input, correct, total:seq.length };

  showCountdown('Module 2: Attention — Tap only the blue items!', startAttentionModule);
}

/* ============================================================
   MODULE 2 — ATTENTION
============================================================ */
let attItems = [];

function startAttentionModule() {
  showScreen('screen-attention');

  const TARGET_POOL = ['🔵','💙','🫐','🔷','🌀','💎','🫧','🔹','🌊','💠'];
  const DISTRACTOR_POOL = ['🔴','❌','🚫','🛑','⛔','🔺','❗','💢','🔻','⭕'];

  // Pick 12 targets (with possible repeats from pool, but shuffle guarantees variety)
  const tPool = shuffle(TARGET_POOL);
  const targets = [];
  while(targets.length < 12) targets.push(...tPool);
  const pickedTargets = targets.slice(0,12);

  // Pick 8 distractors
  const dPool = shuffle(DISTRACTOR_POOL);
  const pickedDistractors = dPool.slice(0,8);

  // Combine and shuffle
  attItems = shuffle([
    ...pickedTargets.map(e => ({emoji:e, isTarget:true, selected:false})),
    ...pickedDistractors.map(e => ({emoji:e, isTarget:false, selected:false}))
  ]);

  document.getElementById('att-hits').textContent = '0';
  document.getElementById('att-false').textContent = '0';

  const grid = document.getElementById('att-grid');
  grid.innerHTML = '';
  attItems.forEach((item,i) => {
    const div = document.createElement('div');
    div.className = 'att-item';
    div.textContent = item.emoji;
    div.dataset.idx = i;
    div.addEventListener('click', () => toggleAttItem(i, div));
    grid.appendChild(div);
  });
}

function toggleAttItem(idx, el) {
  attItems[idx].selected = !attItems[idx].selected;
  if(attItems[idx].selected) el.classList.add('selected');
  else el.classList.remove('selected');
  updateAttStats();
}

function updateAttStats() {
  let hits=0, falseTaps=0;
  attItems.forEach(it => {
    if(it.selected && it.isTarget) hits++;
    if(it.selected && !it.isTarget) falseTaps++;
  });
  document.getElementById('att-hits').textContent = hits;
  document.getElementById('att-false').textContent = falseTaps;
}

function submitAttention() {
  let hits=0, falseTaps=0;
  attItems.forEach(it => {
    if(it.selected && it.isTarget) hits++;
    if(it.selected && !it.isTarget) falseTaps++;
  });
  const score = Math.round(Math.max(0,(hits-falseTaps)/12)*20);
  BCS.scores.attention = score;
  BCS.rawMetrics.attention = {hits, falseTaps, total:12};

  showCountdown('Module 3: Focus — Tap the INK COLOR of the word!', startFocusModule);
}

/* ============================================================
   MODULE 3 — FOCUS (STROOP)
============================================================ */
const STROOP_WORDS = ['RED','BLUE','GREEN','YELLOW','ORANGE','PURPLE','PINK','BROWN'];
const STROOP_COLORS = {
  'RED':   { hex:'#ff4444', name:'Red' },
  'BLUE':  { hex:'#4488ff', name:'Blue' },
  'GREEN': { hex:'#44cc44', name:'Green' },
  'YELLOW':{ hex:'#ffdd44', name:'Yellow' },
  'ORANGE':{ hex:'#ff8844', name:'Orange' },
  'PURPLE':{ hex:'#9944ff', name:'Purple' },
  'PINK':  { hex:'#ff44aa', name:'Pink' },
  'BROWN': { hex:'#aa6633', name:'Brown' }
};

let stroopTrials = [];
let stroopCurrentTrial = 0;
let stroopCorrect = 0;
let stroopTimeLeft = 30;
let stroopDone = false;
let stroopTotalTrials = 10; // set per-age in startFocusModule

function buildStroopTrials() {
  // Incongruent: word ≠ ink color (harder — interference effect)
  const incongruent = [];
  STROOP_WORDS.forEach(word => {
    STROOP_WORDS.forEach(inkWord => {
      if(inkWord !== word) {
        incongruent.push({ word, inkColor: STROOP_COLORS[inkWord].hex, inkName: STROOP_COLORS[inkWord].name, inkWord, congruent: false });
      }
    });
  });
  // Congruent: word = ink color (breaks predictable pattern, catches off-guard)
  const congruent = STROOP_WORDS.map(word => ({
    word, inkColor: STROOP_COLORS[word].hex, inkName: STROOP_COLORS[word].name, inkWord: word, congruent: true
  }));
  const picked = [...shuffle(incongruent).slice(0,7), ...shuffle(congruent).slice(0,3)];
  return shuffle(picked);
}

function startFocusModule() {
  showScreen('screen-focus');

  // Age gateway: adjust trial count and time
  const focusAge = BCS.student.age || 12;
  if(focusAge <= 10)      { stroopTotalTrials = 8;  stroopTimeLeft = 40; } // Junior: 8 trials, 40s
  else if(focusAge <= 13) { stroopTotalTrials = 10; stroopTimeLeft = 30; } // Middle: 10 trials, 30s
  else                    { stroopTotalTrials = 12; stroopTimeLeft = 25; } // Senior: 12 trials, 25s
  BCS._stroopInitTime = stroopTimeLeft;

  stroopTrials = buildStroopTrials().slice(0, stroopTotalTrials);
  stroopCurrentTrial = 0;
  stroopCorrect = 0;
  stroopDone = false;

  // Build dots
  const dotsEl = document.getElementById('stroop-dots');
  dotsEl.innerHTML = '';
  for(let i=0;i<stroopTotalTrials;i++){
    const d = document.createElement('div');
    d.className='trial-dot'; d.id=`sdot-${i}`;
    dotsEl.appendChild(d);
  }

  document.getElementById('stroop-bar').style.width='100%';
  document.getElementById('stroop-time-val').textContent=stroopTimeLeft;
  document.getElementById('stroop-timer').classList.remove('urgent');

  // Global timer
  const iv = setInterval(() => {
    stroopTimeLeft--;
    document.getElementById('stroop-time-val').textContent = stroopTimeLeft;
    document.getElementById('stroop-bar').style.width = (stroopTimeLeft/BCS._stroopInitTime*100)+'%';
    if(stroopTimeLeft <= Math.round(stroopTotalTrials*0.8)) document.getElementById('stroop-timer').classList.add('urgent');
    if(stroopTimeLeft <= 0){
      clearInterval(iv);
      BCS.activeTimers = BCS.activeTimers.filter(x=>x!==iv);
      finishStroop();
    }
  },1000);
  BCS.activeTimers.push(iv);

  renderStroopTrial();
}

function renderStroopTrial() {
  if(stroopCurrentTrial >= stroopTotalTrials || stroopDone) { finishStroop(); return; }

  const trial = stroopTrials[stroopCurrentTrial];
  document.getElementById('stroop-trial-num').textContent = stroopCurrentTrial+1;
  document.getElementById('stroop-word').textContent = trial.word;
  document.getElementById('stroop-word').style.color = trial.inkColor;

  // Build 4 choices: correct ink + 3 wrong
  const correct = { hex: trial.inkColor, name: trial.inkName };
  const others = Object.values(STROOP_COLORS)
    .filter(c => c.hex !== trial.inkColor);
  const wrong3 = shuffle(others).slice(0,3);
  const choices = shuffle([correct, ...wrong3]);

  const optEl = document.getElementById('stroop-options');
  optEl.innerHTML = '';
  choices.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'stroop-btn';
    btn.style.background = c.hex;
    btn.textContent = c.name;
    btn.style.opacity = '0.9';
    btn.addEventListener('click', () => handleStroopAnswer(c.hex === trial.inkColor, btn, c.hex));
    optEl.appendChild(btn);
  });
}

function handleStroopAnswer(isCorrect, btn, chosenHex) {
  if(stroopDone) return;
  // Disable all buttons
  document.querySelectorAll('.stroop-btn').forEach(b => b.style.pointerEvents='none');

  if(isCorrect){
    stroopCorrect++;
    btn.classList.add('correct-flash');
    flashFeedback(true);
    document.getElementById(`sdot-${stroopCurrentTrial}`).classList.add('correct');
  } else {
    btn.classList.add('wrong-flash');
    // Show correct
    document.querySelectorAll('.stroop-btn').forEach(b => {
      if(b.style.background === stroopTrials[stroopCurrentTrial].inkColor) b.classList.add('correct-flash');
    });
    flashFeedback(false);
    document.getElementById(`sdot-${stroopCurrentTrial}`).classList.add('wrong');
  }

  stroopCurrentTrial++;
  if(stroopCurrentTrial >= 10){
    const t = setTimeout(() => finishStroop(), 500);
    BCS.activeTimers.push(t);
  } else {
    const t = setTimeout(() => renderStroopTrial(), 500);
    BCS.activeTimers.push(t);
  }
}

function finishStroop() {
  if(stroopDone) return;
  stroopDone = true;
  // Kill the interval timer
  BCS.activeTimers.forEach(clearInterval);
  BCS.activeTimers = [];
  const score = Math.round((stroopCorrect/stroopTotalTrials)*20);
  BCS.scores.focus = score;
  BCS.rawMetrics.focus = { correct:stroopCorrect, total:stroopTotalTrials, timeLeft:stroopTimeLeft };
  showCountdown('Module 4: Logic — Choose the best answer!', startLogicModule);
}

