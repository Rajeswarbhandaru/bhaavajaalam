async function saveData(payload) {
  const statusEl = document.getElementById('save-status');
  statusEl.textContent = 'Saving report...';

  let gasSaved = false, cloudSaved = false;

  // 1. Google Apps Script
  if(GOOGLE_SCRIPT_URL && !GOOGLE_SCRIPT_URL.includes('PLACEHOLDER')) {
    try {
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify(payload)
      });
      gasSaved = true; // no-cors responses are opaque — success if no exception
    } catch(e) {}
  }

  // 2. Bhava Cloud
  try {
    const res = await fetch(BHAVA_CLOUD_URL, {
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'x-sync-key': BHAVA_CLOUD_KEY
      },
      body: JSON.stringify(payload)
    });
    if(res.ok) cloudSaved = true;
  } catch(e){}

  if(gasSaved || cloudSaved) {
    statusEl.textContent = 'Report saved ✓';
    statusEl.style.color = 'var(--success)';
  } else {
    statusEl.textContent = 'Saved offline — will sync later';
    statusEl.style.color = 'var(--text-muted)';
  }
}


