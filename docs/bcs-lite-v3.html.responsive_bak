const LOGIC_CAT_NAMES = { A:'Number Patterns', B:'Letter Sequences', C:'Syllogisms', D:'Analogies', E:'Spatial/Math' };

let logicQuestions = [];
let logicIdx = 0;
let logicScore = 0;
let logicAnswered = false;

function pickLogicQuestions() {
  let history = [];
  try { history = JSON.parse(localStorage.getItem('bcs_logic_history')||'[]'); } catch(e){}

  // Age gateway: Junior (8-10) gets simpler first 3 questions per category,
  // Senior (14+) gets harder last 3 questions per category
  const logicAge = BCS.student.age || 12;
  const cats = ['A','B','C','D','E'];
  const picked = [];
  cats.forEach(cat => {
    const allQ = LOGIC_BANK[cat];
    // Tier pools: first half = easier, second half = harder
    let tierPool;
    if(logicAge <= 10)      tierPool = allQ.slice(0, 3);  // Junior: questions 1-3 (easier)
    else if(logicAge <= 13) tierPool = allQ;               // Middle: all questions
    else                    tierPool = allQ.slice(3);      // Senior: questions 4-6 (harder)
    const available = tierPool.filter(q => !history.includes(q.id));
    const src = available.length > 0 ? available : tierPool;
    const q = shuffle(src)[0];
    picked.push({...q, category:cat});
  });
  // Update history
  const usedIds = picked.map(q=>q.id);
  const newHistory = [...history, ...usedIds];
  // Reset if all 30 used
  const allIds = Object.values(LOGIC_BANK).flat().map(q=>q.id);
  const filtered = newHistory.filter(id => allIds.includes(id));
  const unique = [...new Set(filtered)];
  localStorage.setItem('bcs_logic_history', JSON.stringify(unique.length >= 30 ? [] : unique));
  return shuffle(picked); // shuffle category order too
}

function startLogicModule() {
  showScreen('screen-logic');
  logicQuestions = pickLogicQuestions();
  logicIdx = 0;
  logicScore = 0;
  renderLogicQuestion();
}

function renderLogicQuestion() {
  if(logicIdx >= logicQuestions.length){ finishLogic(); return; }
  logicAnswered = false;
  const q = logicQuestions[logicIdx];
  document.getElementById('logic-q-num').textContent = logicIdx+1;
  document.getElementById('logic-cat-badge').textContent = LOGIC_CAT_NAMES[q.category];
  document.getElementById('logic-score-badge').textContent = `${logicScore} / ${logicIdx} correct`;
  document.getElementById('logic-bar').style.width = (logicIdx/5*100)+'%';
  document.getElementById('logic-q-text').textContent = q.q;
  document.getElementById('logic-expl').style.display = 'none';
  document.getElementById('logic-next-btn').classList.add('hidden');

  // Shuffle options
  const shuffledOpts = shuffle([...q.opts]);
  const optEl = document.getElementById('logic-options');
  optEl.innerHTML = '';
  shuffledOpts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'logic-opt-btn';
    btn.textContent = opt;
    btn.addEventListener('click', () => handleLogicAnswer(opt === q.ans, btn, optEl, q));
    optEl.appendChild(btn);
  });
}

function handleLogicAnswer(isCorrect, btn, optEl, q) {
  if(logicAnswered) return;
  logicAnswered = true;

  if(isCorrect){
    btn.classList.add('correct');
    logicScore++;
    flashFeedback(true);
  } else {
    btn.classList.add('wrong');
    flashFeedback(false);
    // Show correct
    optEl.querySelectorAll('.logic-opt-btn').forEach(b => {
      if(b.textContent === q.ans) b.classList.add('correct');
    });
  }

  // Show explanation
  const explEl = document.getElementById('logic-expl');
  explEl.textContent = '💡 ' + q.expl;
  explEl.style.display = 'block';

  // Disable all buttons
  optEl.querySelectorAll('.logic-opt-btn').forEach(b => b.style.pointerEvents='none');
  document.getElementById('logic-next-btn').classList.remove('hidden');
}

function nextLogicQuestion() {
  logicIdx++;
  if(logicIdx >= 5) {
    finishLogic();
  } else {
    renderLogicQuestion();
  }
}

function finishLogic() {
  document.getElementById('logic-bar').style.width='100%';
  document.getElementById('logic-score-badge').textContent = `${logicScore} / 5 correct`;
  BCS.scores.logic = Math.round((logicScore/5)*20);
  BCS.rawMetrics.logic = { correct:logicScore, total:5 };
  showCountdown('Module 5: Observation — Find 3 differences!', startObservationModule);
}

