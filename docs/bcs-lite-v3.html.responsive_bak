        </div>
        <div style="padding:12px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid var(--card-border);">
          <div style="font-size:1.2rem">🧘</div>
          <div style="font-size:0.78rem;color:var(--accent);font-weight:600;margin-top:4px;">Focus</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">Stroop interference</div>
        </div>
        <div style="padding:12px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid var(--card-border);">
