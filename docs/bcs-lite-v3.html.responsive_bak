let obsScene = null;
let obsFound = [];
let obsTimerStart = 0;
let obsTimerIv = null;
let obsRequired = 3; // set per-age in startObservationModule

function pickObsScene() {
  let history = [];
  try { history = JSON.parse(localStorage.getItem('bcs_scene_history')||'[]'); } catch(e){}
  const available = [0,1,2,3,4].filter(i => !history.includes(i));
  const src = available.length > 0 ? available : [0,1,2,3,4];
  const idx = src[Math.floor(Math.random()*src.length)];
  const newHistory = [...history, idx].filter(i => [0,1,2,3,4].includes(i));
  const unique = [...new Set(newHistory)];
  localStorage.setItem('bcs_scene_history', JSON.stringify(unique.length >= 5 ? [] : unique));
  return idx;
}

function startObservationModule() {
  showScreen('screen-observation');
  const idx = pickObsScene();
  obsScene = OBS_SCENES[idx];

  // Age gateway: Junior (8-10) only needs to find 2 differences; others find all 3
  const obsAge = BCS.student.age || 12;
  obsRequired = obsAge <= 10 ? 2 : 3;
  obsFound = [false, false, false];

  // Draw canvases
  const canvA = document.getElementById('obs-canvas-a');
  const canvB = document.getElementById('obs-canvas-b');
  const ctxA = canvA.getContext('2d');
  const ctxB = canvB.getContext('2d');
  obsScene.drawA(ctxA);
  obsScene.drawB(ctxB);

  // Build diff list
  const list = document.getElementById('obs-diffs-list');
  list.innerHTML = '';
  obsScene.diffs.forEach((d,i) => {
    const item = document.createElement('div');
    item.className = 'obs-diff-item';
    item.id = `obs-diff-${i}`;
    item.innerHTML = `<div class="obs-diff-dot"></div><span>Difference ${i+1}</span>`;
    list.appendChild(item);
  });

  // Update badge to show required count
  document.getElementById('obs-found').textContent='0';
  const badge = document.querySelector('.badge-success');
  if(badge) badge.innerHTML = '<span id="obs-found">0</span>/' + obsRequired + ' found';
  document.getElementById('obs-done-btn').classList.add('hidden');

  // Timer
  obsTimerStart = Date.now();
  document.getElementById('obs-time-val').textContent='0';
  document.getElementById('obs-timer').classList.remove('urgent');

  const iv = setInterval(() => {
    const elapsed = Math.floor((Date.now()-obsTimerStart)/1000);
    document.getElementById('obs-time-val').textContent = elapsed;
    if(elapsed > 40) document.getElementById('obs-timer').classList.add('urgent');
  },500);
  BCS.activeTimers.push(iv);
}

function handleObsClick(evt, canvas) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = 260/rect.width;
  const scaleY = 200/rect.height;
  const cx = (evt.clientX - rect.left)*scaleX;
  const cy = (evt.clientY - rect.top)*scaleY;

  let foundNew = false;
  obsScene.diffs.forEach((d,i) => {
    if(obsFound[i]) return;
    const dx = cx - d.hotspot.x;
    const dy = cy - d.hotspot.y;
    const dist = Math.sqrt(dx*dx + dy*dy);
    if(dist <= d.hotspot.r) {
      obsFound[i] = true;
      foundNew = true;
      document.getElementById(`obs-diff-${i}`).classList.add('found');
      document.getElementById(`obs-diff-${i}`).querySelector('span').textContent = d.label;
      flashFeedback(true);
      // Ring animation
      const ring = document.createElement('div');
      ring.className = 'canvas-highlight';
      ring.style.cssText=`left:${(d.hotspot.x/260*100)}%;top:${(d.hotspot.y/200*100)}%;width:${d.hotspot.r*2/260*100}%;height:${d.hotspot.r*2/200*100}%;transform:translate(-50%,-50%)`;
      canvas.parentElement.appendChild(ring);
      setTimeout(()=>ring.remove(),500);
    }
  });

  if(!foundNew) {
    flashFeedback(false);
  }

  const count = obsFound.filter(Boolean).length;
  document.getElementById('obs-found').textContent = count;
  // Show submit button as soon as at least 1 found; highlight when all found
  const btn = document.getElementById('obs-done-btn');
  btn.classList.remove('hidden');
  if(count >= obsRequired) {
    btn.textContent = '🎉 ' + (count >= 3 ? 'All' : count) + ' Found! Submit →';
    btn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
}

function submitObservation() {
  const elapsed = Math.floor((Date.now()-obsTimerStart)/1000);
  const found = obsFound.filter(Boolean).length;
  // Score out of 20 based on required count; bonus for speed
  let score = Math.round((Math.min(found, obsRequired)/obsRequired)*18);
  if(found >= obsRequired && elapsed<20) score = Math.min(20, score+2);
  else if(found >= obsRequired && elapsed<35) score = Math.min(20, score+1);
  BCS.scores.observation = score;
  BCS.rawMetrics.observation = { found, total:obsRequired, elapsed };
  showResults();
}

