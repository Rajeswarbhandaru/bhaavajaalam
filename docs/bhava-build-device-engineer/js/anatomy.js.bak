// anatomy-2.js — Interactive "Real Device Anatomy" explorer.
// Updated to stay compatible with app.js and make device visuals clearly visible.

export class AnatomyExplorer {
  constructor(container, anatomyData) {
    this.container = container;
    this.anatomyData = anatomyData;
    this.activeDevice = "Mobile";
    this.activePartIndex = null;
  }

  render(deviceType = this.activeDevice) {
    this.activeDevice = deviceType;

    const rawProfile = this.anatomyData ? this.anatomyData[deviceType] : [];
    const profile = Array.isArray(rawProfile) ? rawProfile : [];
    const isMobile = deviceType === "Mobile";

    const activePart =
      this.activePartIndex !== null && profile[this.activePartIndex]
        ? profile[this.activePartIndex]
        : profile[0] || null;

    const title = isMobile ? "Real Phone Anatomy" : "Real Laptop Anatomy";
    const subtitle = isMobile
      ? "Tap the glowing parts to discover what lives inside a real phone."
      : "Tap the glowing parts to discover what lives inside a real laptop.";

    const essentialText = isMobile
      ? "A basic phone needs a motherboard, CPU, RAM, storage, battery, charging and power-management chips, display, SIM slot, firmware, and an operating system."
      : "A basic laptop needs a motherboard, CPU, RAM, storage, battery, charging and power-management chips, display, keyboard/trackpad, cooling, firmware, and an operating system.";

    const extraText = isMobile
      ? "Cameras, GPS, Wi‑Fi, speakers, and sensors add extra features later."
      : "A GPU, webcam, Wi‑Fi, speakers, and Bluetooth add extra features later.";

    const partsMarkup = profile
      .map((part, index) => {
        return `
          <button class="anatomy-hotspot ${this.activePartIndex === index ? "active" : ""}"
                  data-index="${index}"
                  aria-label="${part.label || "Device part"}"
                  type="button">
            <span class="anatomy-hotspot-core"></span>
            <span class="anatomy-hotspot-ring"></span>
            <span class="anatomy-spot-label">${part.label || ""}</span>
          </button>
        `;
      })
      .join("");

    const legendMarkup = profile
      .map((part, index) => {
        return `
          <button class="legend-chip ${this.activePartIndex === index ? "active" : ""}" data-index="${index}" type="button">
            <span class="legend-dot"></span>
            ${part.label || "Part"}
          </button>
        `;
      })
      .join("");

    this.container.innerHTML = `
      <style>
        .anatomy-wrap {
          display: grid;
          grid-template-columns: minmax(420px, 1.15fr) minmax(320px, 0.85fr);
          gap: 20px;
          align-items: start;
          color: #eaf2ff;
        }

        .anatomy-card {
          position: relative;
          border-radius: 26px;
          background:
            radial-gradient(circle at top left, rgba(96, 165, 250, 0.18), transparent 34%),
            radial-gradient(circle at bottom right, rgba(236, 72, 153, 0.14), transparent 30%),
            linear-gradient(180deg, rgba(18, 24, 40, 0.96), rgba(12, 16, 30, 0.98));
          border: 1px solid rgba(148, 163, 184, 0.14);
          box-shadow:
            0 20px 60px rgba(0, 0, 0, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
          overflow: hidden;
        }

        .anatomy-left, .anatomy-right {
          padding: 18px;
          min-height: 760px;
        }

        .anatomy-header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          margin-bottom: 14px;
          gap: 12px;
        }

        .anatomy-title {
          font-size: 1.15rem;
          font-weight: 800;
          letter-spacing: 0.2px;
          color: #f8fbff;
          margin: 0;
        }

        .anatomy-badge {
          padding: 8px 12px;
          border-radius: 999px;
          background: linear-gradient(135deg, rgba(34, 211, 238, 0.22), rgba(168, 85, 247, 0.18));
          border: 1px solid rgba(125, 211, 252, 0.22);
          color: #dff8ff;
          font-size: 0.82rem;
          font-weight: 700;
        }

        .anatomy-subtitle {
          margin: 0 0 14px 0;
          color: rgba(226, 232, 240, 0.82);
          font-size: 0.98rem;
          line-height: 1.5;
        }

        .anatomy-stage {
          position: relative;
          height: 640px;
          min-height: 640px;
          border-radius: 22px;
          background:
            radial-gradient(circle at 50% 15%, rgba(56, 189, 248, 0.12), transparent 28%),
            linear-gradient(180deg, rgba(15, 23, 42, 0.72), rgba(2, 6, 23, 0.36));
          border: 1px solid rgba(148, 163, 184, 0.12);
          overflow: hidden;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .anatomy-stage::before {
          content: "";
          position: absolute;
          inset: 0;
          background-image:
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
          background-size: 34px 34px;
          opacity: 0.22;
          pointer-events: none;
        }

        .anatomy-device-shell {
          position: relative;
          z-index: 1;
          filter: drop-shadow(0 22px 28px rgba(0, 0, 0, 0.4));
          pointer-events: none;
        }

        .anatomy-phone-shell {
          width: 270px;
          height: 540px;
          border-radius: 38px;
          background: linear-gradient(145deg, #2a2f3d, #0f1421);
          border: 1px solid rgba(255,255,255,0.08);
          padding: 10px;
          box-shadow:
            inset 0 1px 0 rgba(255,255,255,0.06),
            inset 0 -10px 30px rgba(0,0,0,0.35);
        }

        .anatomy-phone-screen {
          position: relative;
          width: 100%;
          height: 100%;
          border-radius: 30px;
          overflow: hidden;
          background:
            radial-gradient(circle at 30% 20%, rgba(56,189,248,0.18), transparent 26%),
            radial-gradient(circle at 75% 10%, rgba(168,85,247,0.16), transparent 24%),
            linear-gradient(160deg, #1d2437, #101728 60%, #0a0f1c);
          border: 1px solid rgba(255,255,255,0.06);
        }

        .anatomy-phone-gradient {
          position: absolute;
          inset: 0;
          background:
            linear-gradient(180deg, rgba(255,255,255,0.06), transparent 18%),
            radial-gradient(circle at 50% 100%, rgba(14, 165, 233, 0.08), transparent 30%);
        }

        .anatomy-phone-notch {
          position: absolute;
          top: 16px;
          left: 50%;
          transform: translateX(-50%);
          width: 92px;
          height: 24px;
          border-radius: 999px;
          background: #0c1120;
          z-index: 3;
          box-shadow: inset 0 1px 1px rgba(255,255,255,0.04);
        }

        .anatomy-phone-camera {
          position: absolute;
          top: 22px;
          left: 50%;
          transform: translateX(-54px);
          width: 10px;
          height: 10px;
          border-radius: 50%;
          background: radial-gradient(circle at 35% 35%, #7dd3fc, #0f172a 72%);
          z-index: 4;
        }

        .anatomy-phone-speaker {
          position: absolute;
          top: 28px;
          left: 50%;
          transform: translateX(-8px);
          width: 34px;
          height: 4px;
          border-radius: 999px;
          background: rgba(148, 163, 184, 0.65);
          z-index: 4;
        }

        .anatomy-laptop-shell {
          width: min(100%, 480px);
          margin: 0 auto;
        }

        .anatomy-laptop-lid {
          width: 100%;
          height: 300px;
          border-radius: 24px 24px 18px 18px;
          padding: 14px;
          background: linear-gradient(145deg, #2a3142, #111827);
          border: 1px solid rgba(255,255,255,0.08);
        }

        .anatomy-laptop-screen {
          position: relative;
          width: 100%;
          height: 100%;
          border-radius: 16px;
          overflow: hidden;
          background:
            radial-gradient(circle at 50% 30%, rgba(34, 211, 238, 0.13), transparent 30%),
            linear-gradient(180deg, #1b2335, #0b1020);
          border: 1px solid rgba(255,255,255,0.06);
        }

        .anatomy-laptop-glow {
          position: absolute;
          inset: 0;
          background:
            linear-gradient(135deg, rgba(255,255,255,0.08), transparent 24%),
            radial-gradient(circle at 40% 70%, rgba(168,85,247,0.12), transparent 28%);
        }

        .anatomy-laptop-base {
          position: relative;
          width: 108%;
          left: -4%;
          height: 92px;
          margin-top: -2px;
          border-radius: 0 0 26px 26px;
          background: linear-gradient(180deg, #1a2230, #0c1220);
          border: 1px solid rgba(255,255,255,0.06);
          box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
        }

        .anatomy-laptop-keyboard {
          display: grid;
          grid-template-columns: repeat(10, 1fr);
          gap: 4px;
          padding: 14px 16px 8px;
        }

        .anatomy-key {
          height: 8px;
          border-radius: 3px;
          background: linear-gradient(180deg, rgba(226,232,240,0.25), rgba(148,163,184,0.14));
          border: 1px solid rgba(255,255,255,0.04);
        }

        .anatomy-laptop-trackpad {
          width: 92px;
          height: 22px;
          margin: 4px auto 0;
          border-radius: 12px;
          background: linear-gradient(180deg, rgba(148,163,184,0.18), rgba(255,255,255,0.06));
          border: 1px solid rgba(255,255,255,0.05);
        }

        .anatomy-device-label {
          position: absolute;
          left: 16px;
          bottom: 16px;
          padding: 7px 11px;
          border-radius: 999px;
          background: rgba(8, 15, 30, 0.66);
          border: 1px solid rgba(148, 163, 184, 0.12);
          color: #eef6ff;
          font-size: 0.82rem;
          font-weight: 700;
          letter-spacing: 0.2px;
        }

        .anatomy-hotspot {
          position: absolute;
          width: 46px;
          height: 46px;
          border: 0;
          border-radius: 999px;
          background: transparent;
          cursor: pointer;
          padding: 0;
          transform: translate(-50%, -50%);
          z-index: 20;
          pointer-events: auto;
        }

        .anatomy-hotspot-core {
          position: absolute;
          inset: 9px;
          border-radius: 999px;
          background: radial-gradient(circle at 35% 35%, #f8fbff, #22d3ee 28%, #0891b2 74%);
          box-shadow:
            0 0 0 6px rgba(34, 211, 238, 0.16),
            0 0 18px rgba(34, 211, 238, 0.5),
            inset 0 1px 2px rgba(255,255,255,0.35);
        }

        .anatomy-hotspot-ring {
          position: absolute;
          inset: 0;
          border-radius: 999px;
          border: 2px solid rgba(125, 211, 252, 0.7);
          animation: anatomyPulse 1.8s ease-in-out infinite;
        }

        .anatomy-hotspot.active .anatomy-hotspot-core {
          background: radial-gradient(circle at 35% 35%, #fff8cc, #f59e0b 28%, #d97706 74%);
          box-shadow:
            0 0 0 8px rgba(245, 158, 11, 0.18),
            0 0 22px rgba(245, 158, 11, 0.65);
        }

        .anatomy-hotspot.active .anatomy-hotspot-ring {
          border-color: rgba(245, 158, 11, 0.9);
        }

        .anatomy-spot-label {
          position: absolute;
          left: 50%;
          top: 100%;
          transform: translate(-50%, 10px);
          white-space: nowrap;
          font-size: 0.72rem;
          color: rgba(226, 232, 240, 0.92);
          text-shadow: 0 1px 2px rgba(0,0,0,0.5);
          pointer-events: none;
        }

        @keyframes anatomyPulse {
          0%, 100% { transform: scale(1); opacity: 0.7; }
          50% { transform: scale(1.18); opacity: 0.35; }
        }

        .anatomy-panel {
          display: flex;
          flex-direction: column;
          gap: 16px;
        }

        .anatomy-info {
          padding: 18px;
          border-radius: 20px;
          background: linear-gradient(180deg, rgba(19, 25, 40, 0.95), rgba(10, 15, 28, 0.95));
          border: 1px solid rgba(148, 163, 184, 0.14);
        }

        .anatomy-info h3 {
          margin: 0 0 8px;
          font-size: 1.25rem;
          color: #f8fbff;
        }

        .anatomy-info p {
          margin: 0 0 10px;
          color: rgba(226, 232, 240, 0.84);
          line-height: 1.55;
        }

        .anatomy-detail {
          margin-top: 12px;
          padding: 14px;
          border-radius: 16px;
          background: rgba(15, 23, 42, 0.7);
          border: 1px solid rgba(148, 163, 184, 0.12);
        }

        .anatomy-detail strong {
          display: block;
          color: #dff8ff;
          margin-bottom: 6px;
        }

        .anatomy-legend {
          display: flex;
          flex-wrap: wrap;
          gap: 10px;
        }

        .legend-chip {
          appearance: none;
          border: 1px solid rgba(148, 163, 184, 0.16);
          background: rgba(15, 23, 42, 0.72);
          color: #e2e8f0;
          padding: 10px 12px;
          border-radius: 999px;
          font-size: 0.88rem;
          font-weight: 700;
          cursor: pointer;
          display: inline-flex;
          align-items: center;
          gap: 8px;
        }

        .legend-chip.active {
          border-color: rgba(34, 211, 238, 0.48);
          background: rgba(34, 211, 238, 0.12);
          color: #f8fbff;
        }

        .legend-dot {
          width: 9px;
          height: 9px;
          border-radius: 999px;
          background: linear-gradient(180deg, #67e8f9, #0891b2);
          box-shadow: 0 0 12px rgba(34, 211, 238, 0.7);
        }

        .anatomy-tip {
          font-size: 0.9rem;
          color: rgba(226, 232, 240, 0.72);
          line-height: 1.5;
        }

        @media (max-width: 900px) {
          .anatomy-wrap {
            grid-template-columns: 1fr;
          }
          .anatomy-left, .anatomy-right {
            min-height: auto;
          }
          .anatomy-stage {
            height: 500px;
            min-height: 500px;
          }
        }

        @media (max-width: 560px) {
          .anatomy-left, .anatomy-right {
            padding: 14px;
          }
          .anatomy-stage {
            height: 440px;
            min-height: 440px;
          }
          .anatomy-phone-shell {
            transform: scale(1);
          }
          .anatomy-laptop-shell {
            transform: scale(1);
            transform-origin: center top;
          }
        }
      </style>

      <div class="anatomy-wrap">
        <section class="anatomy-card anatomy-left">
          <div class="anatomy-header">
            <h2 class="anatomy-title">${title}</h2>
            <div class="anatomy-badge">Level 1 · Essential Build</div>
          </div>
          <p class="anatomy-subtitle">${subtitle}</p>

          <div class="anatomy-stage">
            ${
              isMobile
                ? `
                  <div class="anatomy-device-shell anatomy-phone-shell">
                    <div class="anatomy-phone-notch"></div>
                    <div class="anatomy-phone-camera"></div>
                    <div class="anatomy-phone-speaker"></div>
                    <div class="anatomy-phone-screen">
                      <div class="anatomy-phone-gradient"></div>
                      <div class="anatomy-device-label">Smartphone</div>
                    </div>
                  </div>
                `
                : `
                  <div class="anatomy-device-shell anatomy-laptop-shell">
                    <div class="anatomy-laptop-lid">
                      <div class="anatomy-laptop-screen">
                        <div class="anatomy-laptop-glow"></div>
                        <div class="anatomy-device-label">Laptop</div>
                      </div>
                    </div>
                    <div class="anatomy-laptop-base">
                      <div class="anatomy-laptop-keyboard">
                        ${Array.from({ length: 30 }).map(() => `<span class="anatomy-key"></span>`).join("")}
                      </div>
                      <div class="anatomy-laptop-trackpad"></div>
                    </div>
                  </div>
                `
            }
            ${partsMarkup}
          </div>
        </section>

        <aside class="anatomy-card anatomy-right">
          <div class="anatomy-panel">
            <div class="anatomy-info">
              <h3>${activePart ? activePart.label : "Pick a part"}</h3>
              <p>
                ${activePart ? `Where it really is: ${activePart.realLocation}` : "Select a glowing point on the device to reveal what part lives there in a real machine."}
              </p>

              <div class="anatomy-detail">
                <strong>Matches in Build Mode</strong>
                <div>${activePart ? `“${activePart.type}”` : "Tap any hotspot to see the match."}</div>
              </div>

              <div class="anatomy-detail">
                <strong>What it does</strong>
                <div>${activePart ? activePart.why : "Each part helps the device work in a specific way, from power to processing to display."}</div>
              </div>

              <div class="anatomy-detail">
                <strong>Core build idea</strong>
                <div>${essentialText} ${extraText}</div>
              </div>
            </div>

            <div class="anatomy-info">
              <h3>Parts</h3>
              <div class="anatomy-legend">${legendMarkup}</div>
            </div>

            <div class="anatomy-tip">
              The hotspots are now larger, layered above the silhouette, and easier to tap on phones and tablets.
            </div>
          </div>
        </aside>
      </div>
    `;

    this.container.querySelectorAll(".anatomy-hotspot").forEach((el) => {
      el.addEventListener("click", () => {
        this.activePartIndex = Number(el.dataset.index);
        this.render(deviceType);
      });
    });

    this.container.querySelectorAll(".legend-chip").forEach((el) => {
      el.addEventListener("click", () => {
        this.activePartIndex = Number(el.dataset.index);
        this.render(deviceType);
      });
    });

    this._positionHotspots(deviceType, profile);
  }

  _positionHotspots(deviceType, profile) {
    const hotspots = Array.from(this.container.querySelectorAll(".anatomy-hotspot"));
    const isMobile = deviceType === "Mobile";

    const mobilePositions = [
      { top: "12%", left: "50%" },
      { top: "28%", left: "42%" },
      { top: "36%", left: "58%" },
      { top: "51%", left: "50%" },
      { top: "66%", left: "40%" },
      { top: "78%", left: "58%" }
    ];

    const laptopPositions = [
      { top: "18%", left: "50%" },
      { top: "60%", left: "28%" },
      { top: "60%", left: "72%" },
      { top: "83%", left: "50%" },
      { top: "34%", left: "35%" },
      { top: "34%", left: "65%" }
    ];

    const positions = isMobile ? mobilePositions : laptopPositions;

    hotspots.forEach((hotspot, index) => {
      const pos = positions[index] || { top: "50%", left: "50%" };
      hotspot.style.top = pos.top;
      hotspot.style.left = pos.left;
    });
  }
}