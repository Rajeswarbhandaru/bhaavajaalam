 <script>
  // On Android Capacitor, open game links in same tab (not new tab)
  // On browser, keep opening in new tab as before
// ── Student Login Gate ────────────────────────────────────────────────────
// Shows login modal before launching any game.
// On Electron: window.bhava already set by preload, login done in Electron context.
// On Android/browser: uses bhava-bridge.js (loaded before this script).

var _pendingGameUrl = null;
var GOOGLE_CLIENT_ID = '236194435527-lioshsrq94528622ppo0n439da52ep45.apps.googleusercontent.com';

function openLoginModal(gameUrl) {
  _pendingGameUrl = gameUrl;
  // If already logged in as student, go straight to game
  if (window.bhava && window.bhava.getCurrentStudent) {
    var s = window.bhava.getCurrentStudent();
    if (s) { launchGame(gameUrl); return; }
  }
  document.getElementById('bhava-login-modal').style.display = 'flex';
  document.getElementById('login-error').textContent = '';
  document.getElementById('login-roll').value = '';
  document.getElementById('login-class').value = '';
  document.getElementById('login-pin').value = '';
}

function closeLoginModal() {
  document.getElementById('bhava-login-modal').style.display = 'none';
  _pendingGameUrl = null;
}

function launchGame(url) {
  closeLoginModal();
  var isAndroid = navigator.userAgent.toLowerCase().includes('wv');
  if (isAndroid) {
    window.location.href = url;
  } else {
    window.open(url, '_blank');
  }
}

async function submitStudentLogin() {
  var roll  = document.getElementById('login-roll').value.trim();
  var cls   = document.getElementById('login-class').value.trim();
  var pin   = document.getElementById('login-pin').value.trim();
  var errEl = document.getElementById('login-error');
  var btn   = document.getElementById('login-submit-btn');

  if (!roll || !cls) {
    errEl.textContent = 'Please fill Roll No and Class.';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Verifying…';
  errEl.textContent = '';

  try {
    var loginResult;
    // Use bhava bridge if available (Android/Capacitor), else call cloud directly
    if (window.bhava && typeof window.bhava.login === 'function') {
      loginResult = await window.bhava.login(roll, cls, pin);
    } else {
      // Direct cloud call for plain website browser
      var CLOUD = 'https://bhava-cloud.onrender.com';
      var SYNC_KEY = '0042bfd36ef4a5a219e0bbb206e58ec7b84c7d9334b75c7e';
      var url = CLOUD + '/sync/student-lookup?roll=' + encodeURIComponent(roll) + '&class=' + encodeURIComponent(cls);
      var resp = await fetch(url, { headers: { 'x-bhava-sync-key': SYNC_KEY } });
      var data = await resp.json();
      if (!resp.ok) {
        loginResult = { ok: false, error: data.error || 'Login failed' };
      } else {
        // Cache for report page
        localStorage.setItem('current_student', JSON.stringify(data));
        loginResult = { ok: true, student: data };
      }
    }
    if (loginResult && loginResult.ok) {
      if (loginResult.offline) {
        errEl.style.color = '#facc15';
        errEl.textContent = 'Offline — using cached data.';
      }
      setTimeout(() => launchGame(_pendingGameUrl), loginResult.offline ? 800 : 0);
    } else {
      errEl.style.color = '#f87171';
      errEl.textContent = (loginResult && loginResult.error) || 'Login failed. Check your details.';
      btn.disabled = false;
      btn.textContent = 'Login & Play →';
    }
  } catch(e) {
    errEl.style.color = '#f87171';
    errEl.textContent = 'Something went wrong. Try again.';
    btn.disabled = false;
    btn.textContent = 'Login & Play →';
  }
}

async function loginAsGuest() {
  // Google One Tap / GSI
  if (typeof google === 'undefined' || !google.accounts) {
    document.getElementById('login-error').textContent = 'Google Sign-In not available. Check internet.';
    return;
  }
  google.accounts.id.initialize({
    client_id: GOOGLE_CLIENT_ID,
    callback: async function(resp) {
      var result = await window.bhava.loginGuest(resp.credential);
      if (result && result.ok) {
        launchGame(_pendingGameUrl);
      } else {
        document.getElementById('login-error').textContent = result.error || 'Google login failed.';
      }
    }
  });
  google.accounts.id.prompt();
}

// Intercept all game card clicks
document.querySelectorAll('a.game-card').forEach(function(link) {
  link.addEventListener('click', function(e) {
    e.preventDefault();
    // In Electron without bridge — allow direct (Electron has own session mgmt)
    if (window.bhava && !window.bhava.getCurrentStudent) {
      // Old Electron path — direct launch
      var isAndroid = navigator.userAgent.toLowerCase().includes('wv');
      if (isAndroid) window.location.href = link.getAttribute('href');
      else window.open(link.getAttribute('href'), '_blank');
      return;
    }
    openLoginModal(link.getAttribute('href'));
  });
});
</script>


<script>
  const hamburger = document.getElementById('hamburger');
  let navLinks = document.querySelector('.nav-links');

  // Ensure nav is CLOSED on load
  navLinks.classList.remove('open');
  hamburger.classList.remove('active');

  hamburger.addEventListener('click', () => {
    const open = navLinks.classList.toggle('open');
    hamburger.classList.toggle('active');
    hamburger.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // Auto-close menu when a link is tapped
  navLinks.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      navLinks.classList.remove('open');
      hamburger.classList.remove('active');
    });
  });
</script>
