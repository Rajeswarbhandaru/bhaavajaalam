        <div class="btrw-inner">
          <div class="btrw-left">
            <div class="btrw-pill">⭐ Referral Offer</div>
            <div class="btrw-title">Were you referred by someone?</div>
            <div class="btrw-sub">Enter a referral code and get <strong>10% OFF</strong> on any course or subscription.</div>
          </div>

          <div class="btrw-form">
            <div class="btrw-label">Enter Referral Code</div>
            <div class="btrw-row">
              <input class="btrw-input" id="btrwInput" type="text" placeholder="e.g. BT-B6XQ5Q" maxlength="10" autocomplete="off"
                oninput="this.value=this.value.toUpperCase().replace(/[^A-Z0-9-]/g,'')">
              <button class="btrw-btn" onclick="btrwApply()">Apply</button>
            </div>
            <div class="btrw-feedback" id="btrwFeedback"></div>
            <div class="btrw-chip" id="btrwChip">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              <span id="btrwChipText">Code applied</span>
              <span class="btrw-discount">10% OFF</span>
              <button class="btrw-chip-remove" onclick="btrwRemove()">✕ Remove</button>
            </div>
          </div>
        </div>

        <script>
        // ── Config ─────────────────────────────────────────────────────
        var BTRW_SHEETS_URL = ''; // ← paste your Apps Script /exec URL here

        var BTRW_FALLBACK = {
          'BT-K7XQ2M':'Deepikaa Sharma',
          'BT-9XPMN3':'Ravi Kumar',
          'BT-A2VQKR':'Ananya Reddy'
        };
        var _btrwCache = null, _btrwCacheTime = 0;

        async function _btrwFetchCodes(){
          if(_btrwCache && Date.now()-_btrwCacheTime < 300000) return _btrwCache;
          if(!BTRW_SHEETS_URL){ _btrwCache=BTRW_FALLBACK; return _btrwCache; }
          try{
            var r = await fetch(BTRW_SHEETS_URL+'?action=getCodes&t='+Date.now());
            var j = await r.json();
            if(j.status==='ok'&&j.codes){ _btrwCache=j.codes; _btrwCacheTime=Date.now(); return _btrwCache; }
          }catch(e){}
          _btrwCache=BTRW_FALLBACK; return _btrwCache;
        }

        async function btrwApply(){
          var input   = document.getElementById('btrwInput');
          var fb      = document.getElementById('btrwFeedback');
          var chip    = document.getElementById('btrwChip');
          var code    = input.value.trim().toUpperCase();
          fb.className='btrw-feedback'; fb.textContent='';
          chip.classList.remove('show');
          if(!code){ fb.className='btrw-feedback err'; fb.textContent='Please enter a referral code.'; return; }
          var btn = document.querySelector('.btrw-btn');
          btn.textContent='…'; btn.disabled=true;
          var codes = await _btrwFetchCodes();
          btn.textContent='Apply'; btn.disabled=false;
          if(codes[code]){
            document.getElementById('btrwChipText').textContent = '✓ '+code+' — referred by '+codes[code];
            chip.classList.add('show');
            if(input){input.style.display='none'; if(btn){btn.style.display='none';
            sessionStorage.setItem('referral_code', code);
            sessionStorage.setItem('referral_by', codes[code]);
            sessionStorage.setItem('referral_discount', '10');
            fb.className='btrw-feedback'; fb.textContent='';
          } else {
            fb.className='btrw-feedback err'; fb.textContent='❌ Invalid code. Please check and try again.';
          }
        }

        function btrwRemove(){
          sessionStorage.removeItem('referral_code');
          sessionStorage.removeItem('referral_by');
          sessionStorage.removeItem('referral_discount');
          document.getElementById('btrwInput').value='';
          document.getElementById('btrwInput').style.display='';
          document.querySelector('.btrw-btn').style.display='';
          document.getElementById('btrwChip').classList.remove('show');
          document.getElementById('btrwFeedback').textContent='';
        }

        // Pre-warm cache
        if(BTRW_SHEETS_URL) _btrwFetchCodes();
        </script>
