<style>

/* ═══════════════════════════════════════════
   BASE
═══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: #0a0a1a;
  font-family: 'Segoe UI', Arial, sans-serif;
  color: #e2e8f0;
}

/* ═══════════════════════════════════════════
   SECTION WRAPPER
═══════════════════════════════════════════ */
#bhava-unified {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, #0a0a1a 0%, #0f0c29 40%, #1a0a2e 100%);
  padding: 0 0 100px;
}

/* ── Ambient Orbs ── */
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
  z-index: 0;
  animation: orbDrift 10s ease-in-out infinite;
}
.orb-1 { width:500px; height:500px; background:#6d28d9; opacity:.12; top:-150px; left:-150px; }
.orb-2 { width:400px; height:400px; background:#0891b2; opacity:.10; top:30%; right:-100px; animation-delay:3s; }
.orb-3 { width:300px; height:300px; background:#d97706; opacity:.08; bottom:10%; left:30%; animation-delay:6s; }
.orb-4 { width:350px; height:350px; background:#059669; opacity:.09; bottom:-80px; right:20%; animation-delay:2s; }

@keyframes orbDrift {
  0%,100% { transform: translateY(0) scale(1); }
  50%      { transform: translateY(-40px) scale(1.08); }
}

/* ── Particle Canvas ── */
#bv-canvas {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  pointer-events: none; z-index: 0;
}

/* ── Inner Container ── */
.bv-wrap {
  position: relative; z-index: 1;
  max-width: 1060px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ═══════════════════════════════════════════
   SCROLL REVEAL
═══════════════════════════════════════════ */
.sr {
  opacity: 0;
  transform: translateY(44px);
  transition: opacity .9s ease, transform .9s ease;
}
.sr.up   { transform: translateY(44px); }
.sr.left { transform: translateX(-44px); }
.sr.right{ transform: translateX(44px); }
.sr.visible { opacity:1; transform: translate(0,0); }
.sr.d1 { transition-delay:.1s; }
.sr.d2 { transition-delay:.2s; }
.sr.d3 { transition-delay:.3s; }
.sr.d4 { transition-delay:.4s; }
.sr.d5 { transition-delay:.5s; }
.sr.d6 { transition-delay:.6s; }

/* ═══════════════════════════════════════════
   ZONE 1 — OPENING HERO
═══════════════════════════════════════════ */
.z1 {
  text-align: center;
  padding: 100px 20px 70px;
}

.z1-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #a78bfa;
  border: 1px solid rgba(167,139,250,.35);
  background: rgba(167,139,250,.08);
  padding: 6px 18px;
  border-radius: 30px;
  margin-bottom: 28px;
}

.z1-heading {
  font-size: clamp(28px, 5.5vw, 54px);
  font-weight: 900;
  line-height: 1.15;
  background: linear-gradient(90deg,#f7971e,#ffd200,#21d4fd,#b721ff,#f7971e);
  background-size: 400%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 5s linear infinite;
  margin-bottom: 32px;
}

@keyframes shimmer {
  0%   { background-position: 0% }
  100% { background-position: 400% }
}

.z1-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
}

.z1-pill {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 22px;
  border-radius: 40px;
  font-size: 14px;
  font-weight: 700;
  border: 1px solid;
  transition: transform .3s, box-shadow .3s;
  cursor: default;
}
.z1-pill:hover { transform: translateY(-4px); }
.z1-pill.p1 { background: rgba(6,182,212,.1);  border-color: rgba(6,182,212,.4);  color:#67e8f9; }
.z1-pill.p2 { background: rgba(251,191,36,.08); border-color: rgba(251,191,36,.4); color:#fde68a; }
.z1-pill.p3 { background: rgba(167,139,250,.1); border-color: rgba(167,139,250,.4);color:#c4b5fd; }
.z1-pill.p1:hover { box-shadow: 0 8px 24px rgba(6,182,212,.3); }
.z1-pill.p2:hover { box-shadow: 0 8px 24px rgba(251,191,36,.3); }
.z1-pill.p3:hover { box-shadow: 0 8px 24px rgba(167,139,250,.3); }

/* ═══════════════════════════════════════════
   ZONE 2 — STATS
═══════════════════════════════════════════ */
.z2 {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
  padding: 0 20px 80px;
}

.stat-card {
  flex: 1 1 160px; max-width: 190px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.09);
  border-radius: 18px;
  padding: 26px 16px;
  text-align: center;
  transition: transform .35s, box-shadow .35s, border-color .35s;
  cursor: default;
  position: relative; overflow: hidden;
}
.stat-card::after {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(circle at 50% 0%, var(--glow) 0%, transparent 70%);
  opacity:0; transition: opacity .4s;
  pointer-events:none;
}
.stat-card:hover { transform: translateY(-8px); }
.stat-card:hover::after { opacity:1; }
.stat-card:hover { box-shadow: 0 16px 40px rgba(0,0,0,.4); border-color: var(--glow); }

.stat-card.s1 { --glow: rgba(6,182,212,.35); }
.stat-card.s2 { --glow: rgba(167,139,250,.35); }
.stat-card.s3 { --glow: rgba(52,211,153,.35); }
.stat-card.s4 { --glow: rgba(251,191,36,.35); }
.stat-card.s5 { --glow: rgba(249,115,22,.35); }

.stat-num {
  font-size: 2.2rem;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 8px;
}
.s1 .stat-num { color: #67e8f9; }
.s2 .stat-num { color: #c4b5fd; }
.s3 .stat-num { color: #6ee7b7; }
.s4 .stat-num { color: #fde68a; }
.s5 .stat-num { color: #fdba74; }

.stat-label {
  font-size: 12px;
  color: #94a3b8;
  font-weight: 600;
  letter-spacing: .5px;
}

.location-bar {
  width: 100%;
  max-width: 420px;
  margin: 0 auto;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(6,182,212,.2);
  border-radius: 14px;
  padding: 16px 24px;
  display: flex; align-items: center; gap: 12px;
  justify-content: center;
  font-size: 13px; color: #94a3b8;
}
.location-bar span { color: #67e8f9; font-weight: 600; }

/* ═══════════════════════════════════════════
   ZONE 3 — BRIDGE
═══════════════════════════════════════════ */
.z3 {
  margin: 0 20px 90px;
  background: linear-gradient(135deg, rgba(109,40,217,.15), rgba(8,145,178,.15));
  border: 1px solid rgba(167,139,250,.25);
  border-radius: 24px;
  padding: 56px 40px;
  text-align: center;
  position: relative; overflow: hidden;
}
.z3::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(ellipse at 50% 0%, rgba(167,139,250,.12) 0%, transparent 60%);
  pointer-events:none;
}

.z3-question {
  font-size: clamp(17px,2.5vw,22px);
  color: #c4b5fd;
  font-weight: 400;
  letter-spacing: .3px;
  margin-bottom: 32px;
}

.z3-word {
  font-size: clamp(52px, 10vw, 96px);
  font-weight: 900;
  letter-spacing: 18px;
  background: linear-gradient(135deg, #a78bfa, #21d4fd, #ffd200);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: breathe 3.5s ease-in-out infinite;
  display: block;
  margin-bottom: 24px;
}

@keyframes breathe {
  0%,100% { transform: scale(1);   opacity:1; }
  50%      { transform: scale(1.06); opacity:.85; }
}

.z3-tagline {
  font-size: 15px;
  color: #94a3b8;
  letter-spacing: .5px;
}
.z3-tagline em { color: #fde68a; font-style: normal; font-weight: 600; }

/* ═══════════════════════════════════════════
   ZONE 4 — AI ERA BLOCK
═══════════════════════════════════════════ */
.z4 { padding: 0 20px 90px; }

.zone-label {
  text-align: center;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #64748b;
  margin-bottom: 36px;
}

.ai-grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
  max-width: 760px;
  margin: 0 auto;
}

.ai-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 12px;
}

.ai-cell {
  border-radius: 14px;
  padding: 18px 20px;
  display: flex; align-items: center; gap: 12px;
  font-size: 14px; font-weight: 600;
  transition: transform .3s;
}
.ai-cell:hover { transform: scale(1.03); }

.ai-cell.bot {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  color: #64748b;
  justify-content: flex-end;
  flex-direction: row-reverse;
}
.ai-cell.child {
  border: 1px solid;
  justify-content: flex-start;
}
.ai-cell.child.c1 { background:rgba(6,182,212,.08);  border-color:rgba(6,182,212,.3);  color:#67e8f9; }
.ai-cell.child.c2 { background:rgba(251,191,36,.08); border-color:rgba(251,191,36,.3); color:#fde68a; }
.ai-cell.child.c3 { background:rgba(167,139,250,.08);border-color:rgba(167,139,250,.3);color:#c4b5fd; }

.ai-vs {
  font-size: 11px; font-weight: 800;
  color: #475569; letter-spacing: 1px;
  text-align: center; white-space: nowrap;
}

.ai-cell-icon { font-size: 22px; flex-shrink:0; }

/* ═══════════════════════════════════════════
   ZONE 5 — BEFORE / AFTER
═══════════════════════════════════════════ */
.z5 { padding: 0 20px 90px; }

.ba-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  max-width: 760px;
  margin: 0 auto;
}

.ba-panel {
  border-radius: 20px;
  padding: 30px 24px;
  overflow: hidden;
}
.ba-panel.before {
  background: linear-gradient(145deg, #1c1c2e, #2a1a1a);
  border: 1px solid rgba(239,68,68,.2);
}
.ba-panel.after {
  background: linear-gradient(145deg, #0a1a14, #0d2d1e);
  border: 1px solid rgba(52,211,153,.25);
}

.ba-title {
  font-size: 16px; font-weight: 700;
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 8px;
}
.before .ba-title { color: #fca5a5; }
.after  .ba-title { color: #6ee7b7; }

.ba-item {
  display: flex; align-items: center; gap: 10px;
  font-size: 14px;
  padding: 10px 12px;
  border-radius: 10px;
  margin-bottom: 10px;
  transition: background .3s;
  opacity: 0;
  transform: translateX(-20px);
  transition: opacity .5s ease, transform .5s ease, background .3s;
}
.ba-item.show { opacity:1; transform:translateX(0); }

.before .ba-item { background:rgba(239,68,68,.07); color:#fca5a5; }
.after  .ba-item { background:rgba(52,211,153,.07); color:#6ee7b7; }
.before .ba-item:hover { background:rgba(239,68,68,.14); }
.after  .ba-item:hover { background:rgba(52,211,153,.14); }

.ba-item .bi { font-size:16px; flex-shrink:0; }

/* ═══════════════════════════════════════════
   ZONE 6 — FLOW PIPELINE
═══════════════════════════════════════════ */
.z6 { padding: 0 20px 90px; }

.flow-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
  max-width: 800px;
  margin: 0 auto;
}

.flow-node {
  display: flex; flex-direction: column; align-items: center;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 18px;
  padding: 22px 24px;
  text-align: center;
  transition: transform .3s, box-shadow .3s;
  cursor: default;
  position: relative;
  min-width: 110px;
}
.flow-node:hover { transform: scale(1.1); }
.flow-node.fn1:hover { box-shadow:0 0 28px rgba(52,211,153,.5); border-color:rgba(52,211,153,.5); }
.flow-node.fn2:hover { box-shadow:0 0 28px rgba(6,182,212,.5);  border-color:rgba(6,182,212,.5); }
.flow-node.fn3:hover { box-shadow:0 0 28px rgba(251,191,36,.5); border-color:rgba(251,191,36,.5); }
.flow-node.fn4:hover { box-shadow:0 0 28px rgba(255,255,255,.4);border-color:rgba(255,255,255,.4); }

.fn-emoji { font-size: 32px; margin-bottom: 8px; }
.fn-name  { font-size: 13px; font-weight: 700; color: #e2e8f0; }
.fn-sub   { font-size: 10px; color: #64748b; margin-top: 3px; letter-spacing:.3px; }

/* Travelling dots connector */
.flow-connector {
  width: 60px; height: 20px;
  position: relative; overflow: hidden; flex-shrink: 0;
}
.flow-connector::before {
  content:'';
  position:absolute;
  top:50%; left:-60px;
  transform:translateY(-50%);
  width:60px; height:2px;
  background:linear-gradient(90deg,transparent,#a78bfa,transparent);
  animation: flowDot 1.6s linear infinite;
}
@keyframes flowDot {
  0%   { left:-60px; opacity:0; }
  20%  { opacity:1; }
  80%  { opacity:1; }
  100% { left:60px; opacity:0; }
}

/* ═══════════════════════════════════════════
   ZONE 7 — METHOD CARDS
═══════════════════════════════════════════ */
.z7 { padding: 0 20px; }

.method-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px,1fr));
  gap: 20px;
  max-width: 920px;
  margin: 0 auto;
}

.method-card {
  border-radius: 22px;
  padding: 34px 22px;
  text-align: center;
  border: 1px solid rgba(255,255,255,.08);
  transition: transform .35s, box-shadow .35s;
  cursor: default;
  position: relative; overflow:hidden;
}
.method-card::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:1px;
  background: linear-gradient(90deg,transparent,var(--accent),transparent);
  opacity:.6;
}
.method-card:hover { transform:translateY(-10px); box-shadow:0 24px 50px rgba(0,0,0,.5); }

.mc1 { background:linear-gradient(145deg,#0f1a3a,#1a2d6b); --accent:#67e8f9; }
.mc2 { background:linear-gradient(145deg,#0d2010,#1a4a1e); --accent:#6ee7b7; }
.mc3 { background:linear-gradient(145deg,#2a1000,#5a2a00); --accent:#fde68a; }
.mc4 { background:linear-gradient(145deg,#1a0a38,#3d1478); --accent:#c4b5fd; }

.mc-icon {
  font-size: 38px;
  display: block;
  margin-bottom: 14px;
  animation: floatIcon 3s ease-in-out infinite;
}
.method-card:nth-child(2) .mc-icon { animation-delay:.6s; }
.method-card:nth-child(3) .mc-icon { animation-delay:1.2s; }
.method-card:nth-child(4) .mc-icon { animation-delay:1.8s; }

@keyframes floatIcon {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-7px); }
}

.mc-title {
  font-size: 16px; font-weight: 800;
  color: #fff;
  margin-bottom: 8px;
}
.mc-sub {
  font-size: 12px;
  color: #94a3b8;
  letter-spacing: .4px;
}
.mc1 .mc-sub { color:#67e8f9; opacity:.7; }
.mc2 .mc-sub { color:#6ee7b7; opacity:.7; }
.mc3 .mc-sub { color:#fde68a; opacity:.7; }
.mc4 .mc-sub { color:#c4b5fd; opacity:.7; }

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
@media (max-width:640px) {
  .ba-split { grid-template-columns:1fr; }
  .ai-row   { grid-template-columns:1fr; gap:8px; }
  .ai-vs    { display:none; }
  .flow-connector { width:30px; }
  .flow-connector::before { width:30px; }
  .z3 { padding:40px 24px; }
  .z3-word { letter-spacing:10px; }
}

</style>

