<script>
// Age filter — scoped to the new cap-tile system only
(function () {
  const chips = document.querySelectorAll('.age-filter-chip');
  const tiles = document.querySelectorAll('.cap-tile[data-age]');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      const age = chip.dataset.age;
      tiles.forEach(tile => {
        const show = age === 'all' || tile.dataset.age === age;
        tile.classList.toggle('age-hidden', !show);
      });
    });
  });
})();
</script>

<script>
// Category filter — scoped to #games only
(function () {
  const tabs  = document.querySelectorAll('#games .g-tab');
  const cards = document.querySelectorAll('#games .g-card');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const filter = tab.dataset.filter;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.cat === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
})();
</script>
