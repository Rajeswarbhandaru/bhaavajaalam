    .c-attention  .bhv-cap-name { color: #34d399; }
    .c-memory     .bhv-cap-name { color: #a78bfa; }
    .c-imagination .bhv-cap-name { color: #fb7185; }
    .c-creativity .bhv-cap-name { color: #4ade80; }
    .c-awareness  .bhv-cap-name { color: #7dd3fc; }

    .bhv-cap-quote {
      font-size: 0.78rem;
      line-height: 1.55;
      color: rgba(255,255,255,0.62);
      font-style: italic;
      margin-bottom: 12px;
    }

    .bhv-cap-tag {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 20px;
      letter-spacing: 0.04em;
      opacity: 0.75;
    }
    .c-focus      .bhv-cap-tag { background: rgba(251,191,36,0.15); color: #fbbf24; }
    .c-attention  .bhv-cap-tag { background: rgba(52,211,153,0.15); color: #34d399; }
    .c-memory     .bhv-cap-tag { background: rgba(167,139,250,0.15); color: #a78bfa; }
    .c-imagination .bhv-cap-tag { background: rgba(251,113,133,0.15); color: #fb7185; }
    .c-creativity .bhv-cap-tag { background: rgba(74,222,128,0.15); color: #4ade80; }
    .c-awareness  .bhv-cap-tag { background: rgba(125,211,252,0.15); color: #7dd3fc; }

    /* ── Animations ─────────────────────────────────── */

    /* Focus — candle flame */
    .anim-focus { display:flex; align-items:flex-end; justify-content:center; height:64px; }
    .candle-body { width:14px; height:28px; background:linear-gradient(to bottom,#fef3c7,#fbbf24); border-radius:3px 3px 0 0; position:relative; }
    .candle-wick { width:2px; height:10px; background:#92400e; position:absolute; top:-10px; left:6px; border-radius:1px; }
    .candle-flame {
      width:12px; height:18px;
      background: radial-gradient(ellipse at 50% 80%, #fde68a 0%, #f59e0b 40%, #ef4444 90%, transparent 100%);
      border-radius: 50% 50% 30% 30%;
      position: absolute; top: -28px; left: 1px;
      animation: flicker 1.8s ease-in-out infinite alternate;
      transform-origin: bottom center;
    }
    @keyframes flicker {
      0%   { transform: scaleX(1) scaleY(1) rotate(-2deg); opacity: 1; }
      30%  { transform: scaleX(0.88) scaleY(1.08) rotate(2deg); opacity: 0.95; }
      60%  { transform: scaleX(1.06) scaleY(0.95) rotate(-1deg); opacity: 1; }
      100% { transform: scaleX(0.92) scaleY(1.05) rotate(3deg); opacity: 0.9; }
    }

    /* Attention — radar pulse */
    .anim-attention { display:flex; align-items:center; justify-content:center; height:64px; }
    .radar-wrap { position:relative; width:56px; height:56px; }
    .radar-dot  { width:8px; height:8px; background:#34d399; border-radius:50%; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); z-index:2; }
    .radar-ring {
      position:absolute; border-radius:50%; border:2px solid #34d399;
      top:50%; left:50%; transform:translate(-50%,-50%);
      animation: radarPulse 2.2s ease-out infinite;
      opacity:0;
    }
    .radar-ring:nth-child(2){ animation-delay:0s;   width:16px; height:16px; }
    .radar-ring:nth-child(3){ animation-delay:0.6s; width:32px; height:32px; }
    .radar-ring:nth-child(4){ animation-delay:1.2s; width:50px; height:50px; }
    @keyframes radarPulse {
      0%   { opacity:0.9; transform:translate(-50%,-50%) scale(0.4); }
      100% { opacity:0;   transform:translate(-50%,-50%) scale(1); }
    }

    /* Memory — constellation dots connecting */
    .anim-memory { display:flex; align-items:center; justify-content:center; height:64px; }
    .memory-svg { width:56px; height:56px; }
    .mem-line { stroke:#a78bfa; stroke-width:1.5; stroke-dasharray:40; stroke-dashoffset:40; animation: drawLine 2.4s ease-in-out infinite; }
    .mem-line:nth-child(2){ animation-delay:0.5s; }
    .mem-line:nth-child(3){ animation-delay:1s; }
    @keyframes drawLine {
      0%,10%   { stroke-dashoffset:40; opacity:0.3; }
      50%,60%  { stroke-dashoffset:0;  opacity:1; }
      90%,100% { stroke-dashoffset:0;  opacity:0.3; }
    }
    .mem-dot { fill:#a78bfa; animation: memDotPulse 2.4s ease-in-out infinite; }
    .mem-dot:nth-child(5){ animation-delay:0.3s; }
    .mem-dot:nth-child(6){ animation-delay:0.8s; }
    .mem-dot:nth-child(7){ animation-delay:1.3s; }
    @keyframes memDotPulse {
      0%,100% { r:3; opacity:0.6; }
      50%     { r:4.5; opacity:1; }
    }

    /* Imagination — seed to tree */
    .anim-imagination { display:flex; align-items:flex-end; justify-content:center; height:64px; }
    .imag-svg { width:48px; height:60px; }
    .imag-stem   { stroke:#fb7185; stroke-width:2; stroke-linecap:round;
                   stroke-dasharray:30; stroke-dashoffset:30;
                   animation: growStem 2s ease-in-out infinite alternate; }
    .imag-leaf-l { fill:rgba(251,113,133,0.7); transform-origin:24px 30px;
                   animation: leafGrow 2s ease-in-out infinite alternate; transform:scale(0); }
    .imag-leaf-r { fill:rgba(251,113,133,0.55); transform-origin:24px 26px;
                   animation: leafGrow 2s 0.3s ease-in-out infinite alternate; transform:scale(0); }
    .imag-bloom  { fill:#fda4af; transform-origin:24px 12px;
                   animation: bloom 2s 0.6s ease-in-out infinite alternate; transform:scale(0); opacity:0; }
    @keyframes growStem  { from{ stroke-dashoffset:30; } to{ stroke-dashoffset:0; } }
    @keyframes leafGrow  { from{ transform:scale(0); } to{ transform:scale(1); } }
    @keyframes bloom     { from{ transform:scale(0); opacity:0; } to{ transform:scale(1); opacity:1; } }

    /* Creativity — shapes rearranging */
    .anim-creativity { display:flex; align-items:center; justify-content:center; height:64px; }
    .creat-svg { width:56px; height:56px; }
    .creat-tri { fill:none; stroke:#4ade80; stroke-width:2;
                 animation: triSpin 3s ease-in-out infinite; transform-origin:28px 28px; }
    .creat-sq  { fill:none; stroke:#86efac; stroke-width:2;
                 animation: sqPulse 3s 0.5s ease-in-out infinite; transform-origin:28px 28px; }
    .creat-circ { fill:none; stroke:#bbf7d0; stroke-width:2;
                  animation: circPop 3s 1s ease-in-out infinite; transform-origin:28px 28px; }
    @keyframes triSpin  { 0%,100%{transform:rotate(0deg) scale(1);}   50%{transform:rotate(60deg) scale(0.85);} }
    @keyframes sqPulse  { 0%,100%{transform:rotate(0deg) scale(1);}   50%{transform:rotate(45deg) scale(1.1);} }
    @keyframes circPop  { 0%,100%{transform:scale(1);opacity:1;}       50%{transform:scale(0.7);opacity:0.5;} }

    /* Self-Awareness — ripple in still water */
    .anim-awareness { display:flex; align-items:center; justify-content:center; height:64px; }
    .aware-svg { width:56px; height:40px; }
    .aware-ripple {
      fill:none; stroke:#7dd3fc; stroke-width:1.5;
      animation: ripple 2.6s ease-out infinite;
      transform-origin:28px 20px;
      opacity:0;
    }
    .aware-ripple:nth-child(1){ animation-delay:0s; }
    .aware-ripple:nth-child(2){ animation-delay:0.65s; }
    .aware-ripple:nth-child(3){ animation-delay:1.3s; }
    .aware-dot { fill:#7dd3fc; }
    @keyframes ripple {
      0%   { opacity:0.9; transform:scale(0.15); }
      100% { opacity:0;   transform:scale(1); }
    }

    /* ── "How We Strengthen Them" bridge ─── */
    .bhv-method-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 32px;
    }
    @media (max-width: 600px) { .bhv-method-row { grid-template-columns: 1fr; } }

    .bhv-method-card {
      border-radius: 16px;
      padding: 20px 18px;
      text-align: center;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.09);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .bhv-method-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.3);
    }
    .bhv-method-icon { font-size: 1.8rem; margin-bottom: 8px; }
    .bhv-method-title {
      font-size: 0.9rem; font-weight: 700;
      color: #e2e8f0; margin-bottom: 6px;
    }
    .bhv-method-desc {
      font-size: 0.76rem; color: rgba(255,255,255,0.5);
      line-height: 1.5;
    }
    </style>

    <div class="bhv-cap-grid bgt-fade d3">

      <!-- 1. Focus -->
      <div class="bhv-cap-card c-focus">
        <div class="bhv-cap-anim">
          <div class="anim-focus">
            <div class="candle-body">
              <div class="candle-wick"></div>
              <div class="candle-flame"></div>
            </div>
          </div>
        </div>
        <div class="bhv-cap-name">Focus</div>
        <div class="bhv-cap-quote">"The potter whose hands are steady for three hours — seeing only the form in her mind."</div>
        <span class="bhv-cap-tag">Games · Brain Gym</span>
      </div>

      <!-- 2. Attention -->
      <div class="bhv-cap-card c-attention">
        <div class="bhv-cap-anim">
          <div class="anim-attention">
            <div class="radar-wrap">
              <div class="radar-dot"></div>
              <div class="radar-ring"></div>
              <div class="radar-ring"></div>
              <div class="radar-ring"></div>
            </div>
          </div>
        </div>
        <div class="bhv-cap-name">Attention</div>
        <div class="bhv-cap-quote">"The grandmother who notices the slight fever in her grandchild's eyes — before he says a word."</div>
        <span class="bhv-cap-tag">Games · Assessment</span>
      </div>

      <!-- 3. Memory -->
      <div class="bhv-cap-card c-memory">
        <div class="bhv-cap-anim">
          <div class="anim-memory">
            <svg class="memory-svg" viewBox="0 0 56 56" fill="none">
              <line class="mem-line" x1="10" y1="40" x2="28" y2="18"/>
              <line class="mem-line" x1="28" y1="18" x2="46" y2="36"/>
              <line class="mem-line" x1="46" y1="36" x2="22" y2="46"/>
              <circle class="mem-dot" cx="10" cy="40" r="3"/>
              <circle class="mem-dot" cx="28" cy="18" r="3"/>
              <circle class="mem-dot" cx="46" cy="36" r="3"/>
              <circle class="mem-dot" cx="22" cy="46" r="3"/>
            </svg>
          </div>
        </div>
        <div class="bhv-cap-name">Memory</div>
        <div class="bhv-cap-quote">"The vendor who remembers every customer's face and favourite — across ten years of mornings."</div>
        <span class="bhv-cap-tag">Games · Spaced Recall</span>
      </div>

      <!-- 4. Imagination -->
      <div class="bhv-cap-card c-imagination">
        <div class="bhv-cap-anim">
          <div class="anim-imagination">
            <svg class="imag-svg" viewBox="0 0 48 60" fill="none">
              <line class="imag-stem" x1="24" y1="56" x2="24" y2="22"/>
              <ellipse class="imag-leaf-l" cx="16" cy="32" rx="10" ry="6" transform="rotate(-30 16 32)"/>
              <ellipse class="imag-leaf-r" cx="32" cy="28" rx="10" ry="6" transform="rotate(30 32 28)"/>
              <circle class="imag-bloom" cx="24" cy="14" r="8"/>
            </svg>
          </div>
        </div>
        <div class="bhv-cap-name">Imagination</div>
        <div class="bhv-cap-quote">"The child who turns a cardboard box into a rocket, a boat, and a cave — all in one afternoon."</div>
        <span class="bhv-cap-tag">Games · Creative Play</span>
      </div>

      <!-- 5. Creativity -->
      <div class="bhv-cap-card c-creativity">
        <div class="bhv-cap-anim">
          <div class="anim-creativity">
            <svg class="creat-svg" viewBox="0 0 56 56" fill="none">
              <polygon class="creat-tri" points="28,8 48,44 8,44"/>
              <rect class="creat-sq" x="16" y="16" width="24" height="24" rx="2"/>
              <circle class="creat-circ" cx="28" cy="28" r="11"/>
            </svg>
          </div>
        </div>
        <div class="bhv-cap-name">Creativity</div>
        <div class="bhv-cap-quote">"The cook with three ingredients and no recipe — who makes something the whole family asks for again."</div>
        <span class="bhv-cap-tag">Games · Brain Gym</span>
      </div>

      <!-- 6. Self-Awareness -->
      <div class="bhv-cap-card c-awareness">
        <div class="bhv-cap-anim">
          <div class="anim-awareness">
            <svg class="aware-svg" viewBox="0 0 56 40" fill="none">
              <circle class="aware-dot" cx="28" cy="20" r="3"/>
              <ellipse class="aware-ripple" cx="28" cy="20" rx="26" ry="16"/>
              <ellipse class="aware-ripple" cx="28" cy="20" rx="26" ry="16"/>
              <ellipse class="aware-ripple" cx="28" cy="20" rx="26" ry="16"/>
            </svg>
          </div>
        </div>
        <div class="bhv-cap-name">Self-Awareness</div>
        <div class="bhv-cap-quote">"The teacher who reads the room mid-lesson and changes her whole approach — in one breath."</div>
        <span class="bhv-cap-tag">EQ Games · Reflection</span>
      </div>

    </div>

    <!-- How Bhāva Strengthens Them -->
    <div class="bgt-h bgt-fade" style="margin-top:40px; margin-bottom:16px;">
      <h3 style="font-size:1.1rem; color:#94a3b8; font-weight:500;">How Bhāva strengthens what you already have</h3>
    </div>

    <div class="bhv-method-row bgt-fade">
      <div class="bhv-method-card">
        <div class="bhv-method-icon">🎮</div>
        <div class="bhv-method-title"> Cognitive Games</div>
        <div class="bhv-method-desc">Play-based challenges that train Focus, Memory, Logic and Emotional Intelligence — without the child knowing they are training.</div>
      </div>
      <div class="bhv-method-card">
        <div class="bhv-method-icon">🏋️</div>
        <div class="bhv-method-title">Brain Gym Activities</div>
        <div class="bhv-method-desc">Offline physical exercises that strengthen the mind-body connection — movements that directly activate cognitive circuits.</div>
      </div>
      <div class="bhv-method-card">
        <div class="bhv-method-icon">📊</div>
        <div class="bhv-method-title">IQ · EQ · SQ Assessment</div>
        <div class="bhv-method-desc">Precise scores across three dimensions — showing exactly where each child stands and what to strengthen next.</div>
      </div>
    </div>

  </div>
</section>

