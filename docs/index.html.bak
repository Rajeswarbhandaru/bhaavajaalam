<!-- ════════════════════════════════════════════════
     JS — Toggle, Mode Switch, Scroll Fade-In
════════════════════════════════════════════════ -->
<script>
function bgtToggle(id){
  var el=document.getElementById(id);
  if(el) el.classList.toggle('open');
}
function bgtMode(mode){
  var offBtn=document.getElementById('btn-offline');
  var onBtn=document.getElementById('btn-online2');
  var offPanel=document.getElementById('panel-offline');
  var onPanel=document.getElementById('panel-online');
  if(mode==='offline'){
    offBtn.className='bgt-mode-btn active-offline';
    onBtn.className='bgt-mode-btn';
    offPanel.classList.add('active');
    onPanel.classList.remove('active');
  } else {
    onBtn.className='bgt-mode-btn active-online';
    offBtn.className='bgt-mode-btn';
    onPanel.classList.add('active');
    offPanel.classList.remove('active');
  }
}
(function(){
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}
    });
  },{threshold:0.10});
  document.querySelectorAll('.bgt-fade').forEach(function(el){obs.observe(el);});
})();
</script>



<style>
/* ── ALL STYLES SCOPED TO #games — won't affect other sections ── */

#games {
  padding: 60px 20px 80px;
  background: linear-gradient(160deg, #0f0c29, #302b63, #24243e);
  position: relative;
  overflow: hidden;
}

/* Animated background orbs */
#games::before,
#games::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.18;
  animation: gOrb 8s ease-in-out infinite alternate;
  pointer-events: none;
}
#games::before {
  width: 500px; height: 500px;
  background: radial-gradient(circle, #a259ff, #6c47ff);
  top: -100px; left: -100px;
}
#games::after {
  width: 400px; height: 400px;
  background: radial-gradient(circle, #00c6fb, #005bea);
  bottom: -80px; right: -80px;
  animation-delay: -4s;
}
@keyframes gOrb {
  0%   { transform: translate(0, 0) scale(1); }
  100% { transform: translate(40px, 30px) scale(1.15); }
}

/* Section header */
#games .g-header {
  text-align: center;
  margin-bottom: 10px;
  position: relative; z-index: 2;
}
#games .g-header h2 {
  font-family: 'Nunito', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.5px;
  margin: 0 0 10px;
}
#games .g-header h2 span {
  background: linear-gradient(90deg, #a259ff, #ff6fd8, #00c6fb);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
#games .g-header p {
  color: rgba(255,255,255,0.55);
  font-size: 1rem;
  margin: 0;
}

/* Category filter tabs */
#games .g-tabs {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
  margin: 24px 0 36px;
  position: relative; z-index: 2;
}
#games .g-tab {
  padding: 6px 18px;
  border-radius: 999px;
  border: 1.5px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.7);
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  font-family: 'Nunito', sans-serif;
  letter-spacing: 0.03em;
  user-select: none;
}
#games .g-tab:hover,
#games .g-tab.active {
  background: rgba(255,255,255,0.18);
  border-color: rgba(255,255,255,0.5);
  color: #fff;
  transform: translateY(-1px);
}

/* Grid */
#games .g-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
  gap: 20px;
  max-width: 1200px;
  margin: 0 auto;
  position: relative; z-index: 2;
}

/* Game Card */
#games .g-card {
  position: relative;
  border-radius: 20px;
  padding: 26px 16px 20px;
  text-align: center;
  text-decoration: none;
  color: #fff;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  transition: transform 0.28s cubic-bezier(0.16,1,0.3,1),
              box-shadow 0.28s cubic-bezier(0.16,1,0.3,1);
  opacity: 0;
  transform: translateY(30px);
  animation: cardIn 0.5s cubic-bezier(0.16,1,0.3,1) forwards;
}
@keyframes cardIn {
  to { opacity: 1; transform: translateY(0); }
}

/* Glassy shimmer overlay */
#games .g-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.14) 0%, transparent 60%);
  border-radius: inherit;
  pointer-events: none;
}
/* Bottom shine line */
#games .g-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  pointer-events: none;
}

#games .g-card:hover {
  transform: translateY(-8px) scale(1.03);
  box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

/* Card animation delay cascade */
#games .g-card:nth-child(1)  { animation-delay: 0.04s; }
#games .g-card:nth-child(2)  { animation-delay: 0.08s; }
#games .g-card:nth-child(3)  { animation-delay: 0.12s; }
#games .g-card:nth-child(4)  { animation-delay: 0.16s; }
#games .g-card:nth-child(5)  { animation-delay: 0.20s; }
#games .g-card:nth-child(6)  { animation-delay: 0.24s; }
#games .g-card:nth-child(7)  { animation-delay: 0.28s; }
#games .g-card:nth-child(8)  { animation-delay: 0.32s; }
#games .g-card:nth-child(9)  { animation-delay: 0.36s; }
#games .g-card:nth-child(10) { animation-delay: 0.40s; }
#games .g-card:nth-child(11) { animation-delay: 0.44s; }
#games .g-card:nth-child(12) { animation-delay: 0.48s; }
#games .g-card:nth-child(13) { animation-delay: 0.52s; }
#games .g-card:nth-child(14) { animation-delay: 0.56s; }
#games .g-card:nth-child(15) { animation-delay: 0.60s; }
#games .g-card:nth-child(16) { animation-delay: 0.64s; }
#games .g-card:nth-child(17) { animation-delay: 0.68s; }
#games .g-card:nth-child(18) { animation-delay: 0.72s; }
#games .g-card:nth-child(19) { animation-delay: 0.76s; }

/* Category colour themes */
#games .g-card.iq       { background: linear-gradient(145deg, #4f46e5, #7c3aed); box-shadow: 0 8px 30px rgba(79,70,229,0.45); }
#games .g-card.emotion  { background: linear-gradient(145deg, #e11d48, #f97316); box-shadow: 0 8px 30px rgba(225,29,72,0.45); }
#games .g-card.memory   { background: linear-gradient(145deg, #0891b2, #06b6d4); box-shadow: 0 8px 30px rgba(8,145,178,0.45); }
#games .g-card.math     { background: linear-gradient(145deg, #059669, #10b981); box-shadow: 0 8px 30px rgba(5,150,105,0.45); }
#games .g-card.language { background: linear-gradient(145deg, #d97706, #f59e0b); box-shadow: 0 8px 30px rgba(217,119,6,0.45); }
#games .g-card.logic    { background: linear-gradient(145deg, #7c3aed, #a855f7); box-shadow: 0 8px 30px rgba(124,58,237,0.45); }
#games .g-card.science  { background: linear-gradient(145deg, #16a34a, #4ade80); box-shadow: 0 8px 30px rgba(22,163,74,0.45); }
#games .g-card.kindness { background: linear-gradient(145deg, #db2777, #f472b6); box-shadow: 0 8px 30px rgba(219,39,119,0.45); }

/* Card inner elements */
#games .g-card .g-icon {
  font-size: 2.4rem;
  line-height: 1;
  filter: drop-shadow(0 3px 8px rgba(0,0,0,0.3));
  transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
}
#games .g-card:hover .g-icon { transform: scale(1.2) rotate(-5deg); }

#games .g-card h4 {
  font-family: 'Nunito', sans-serif;
  font-size: 0.95rem;
  font-weight: 800;
  color: #fff;
  margin: 0;
  line-height: 1.3;
  text-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

#games .g-card .g-tag {
  font-size: 0.72rem;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  background: rgba(0,0,0,0.2);
  padding: 3px 10px;
  border-radius: 999px;
  letter-spacing: 0.03em;
}

/* NEW badge */
#games .g-card .g-new {
  position: absolute;
  top: 10px; right: 10px;
  background: #fbbf24;
  color: #1a1a1a;
  font-size: 0.6rem;
  font-weight: 800;
  padding: 2px 7px;
  border-radius: 999px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  #games .g-card { animation: none; opacity: 1; transform: none; }
  #games .g-card:hover { transform: none; }
  #games::before, #games::after { animation: none; }
}

/* Mobile */
@media (max-width: 480px) {
  #games .g-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
}
</style>

