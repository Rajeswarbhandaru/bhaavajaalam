        <span class="stat-label" style="display:block; color:#94a3b8; font-size:0.85rem; margin-top:8px; letter-spacing:0.5px;">Brain Gym Sessions</span>
        <div style="position:absolute; bottom:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#a78bfa,#7c3aed);"></div>
