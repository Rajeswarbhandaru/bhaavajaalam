  <style>
    /* ---- INLINE ADDITIONS ---- */
    .online-badge {
      display:inline-block; background:#22c55e; color:#fff;
      font-size:0.7rem; font-weight:700; padding:2px 8px;
      border-radius:20px; margin-left:6px; vertical-align:middle;
      letter-spacing:.5px;
    }
    .worldwide-banner {
      background: linear-gradient(135deg,#1e40af,#7c3aed);
      color:#fff; text-align:center; padding:10px 16px;
      font-size:0.88rem; letter-spacing:.3px;
    }
    .worldwide-banner a { color:#fde68a; font-weight:600; text-decoration:none; }
    .pay-options { display:flex; gap:12px; flex-wrap:wrap; margin:10px 0; }
    .pay-option-btn {
      flex:1; min-width:130px; padding:10px 14px; border:2px solid #e5e7eb;
      border-radius:10px; background:#fff; cursor:pointer; font-size:0.9rem;
      transition:all .2s; text-align:center;
    }
    .pay-option-btn:hover, .pay-option-btn.active {
      border-color:#6366f1; background:#eff6ff;
    }
    .testimonials-section { background:#f8faff; padding:60px 0; }
    .testimonials-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:24px; margin-top:32px; }
    .testi-card {
      background:#fff; border-radius:14px; padding:24px;
      box-shadow:0 2px 12px rgba(0,0,0,.07); position:relative;
    }
    .testi-card::before { content:'"'; font-size:3rem; color:#6366f1; line-height:1; position:absolute; top:12px; left:18px; }
    .testi-text { font-size:0.92rem; color:#374151; margin:24px 0 14px; line-height:1.6; }
    .testi-author { font-weight:600; color:#1e1b4b; font-size:0.88rem; }
    .testi-role { font-size:0.8rem; color:#6b7280; }
    .stars { color:#f59e0b; font-size:0.9rem; margin-bottom:6px; }
    .online-flow { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:0; margin-top:32px; }
    .oflow-step {
      text-align:center; padding:20px 16px; position:relative;
    }
    .oflow-step:not(:last-child)::after {
      content:"→"; position:absolute; right:-10px; top:50%;
      transform:translateY(-50%); font-size:1.4rem; color:#6366f1;
    }
    .oflow-num {
      width:40px; height:40px; background:#6366f1; color:#fff;
      border-radius:50%; display:flex; align-items:center; justify-content:center;
      font-weight:700; font-size:1rem; margin:0 auto 10px;
    }
    .oflow-step h4 { font-size:0.9rem; color:#1e1b4b; margin-bottom:4px; }
    .oflow-step p { font-size:0.78rem; color:#6b7280; }
    .sample-report-box {
      background:linear-gradient(135deg,#eff6ff,#f5f3ff);
      border:2px dashed #6366f1; border-radius:14px;
      padding:28px; text-align:center; margin-top:24px;
    }
    .sample-report-box h4 { color:#1e1b4b; margin-bottom:8px; }
    .sample-report-box p { font-size:0.88rem; color:#6b7280; margin-bottom:14px; }
    .timezone-note { font-size:0.8rem; color:#6b7280; margin-top:4px; }
    .course-duration.online { color:#16a34a; font-weight:600; }
    .pricing-usd { font-size:0.75rem; color:#6b7280; display:block; }
    table.pricing-table td { vertical-align:top; }
    .faq-item { border-bottom:1px solid #e5e7eb; padding:18px 0; }
    .faq-question { font-weight:600; color:#1e1b4b; cursor:pointer; display:flex; justify-content:space-between; align-items:center; }
    .faq-answer { font-size:0.9rem; color:#374151; margin-top:10px; line-height:1.7; display:none; }
    .faq-item.open .faq-answer { display:block; }
    .faq-item.open .faq-arrow { transform:rotate(180deg); }
    .faq-arrow { transition:transform .3s; }
    #whatsapp-float {
      position:fixed; bottom:24px; right:24px; z-index:999;
      background:#25d366; border:none; border-radius:50%;
      width:56px; height:56px; cursor:pointer;
      box-shadow:0 4px 16px rgba(37,211,102,.5);
      display:flex; align-items:center; justify-content:center;
    }
</style>
