<style id="bhava-chatbot-styles">

/* ── Chatbot Bubble Button ── */
#bj-chat-bubble {
  position: fixed;
  bottom: 92px;          /* sits ABOVE the WhatsApp button */
  right: 24px;
  z-index: 1000;
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, #2d6a4f, #e07a1f);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(45,106,79,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s, box-shadow 0.2s;
}
#bj-chat-bubble:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 28px rgba(45,106,79,0.7);
}
#bj-chat-bubble img {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  object-fit: cover;
}

/* Notification badge */
#bj-chat-bubble .bj-badge {
  position: absolute;
  top: -2px; right: -2px;
  width: 16px; height: 16px;
  background: #e07a1f;
  border: 2px solid #0a0a1a;
  border-radius: 50%;
  animation: bj-ping 2s infinite;
}
@keyframes bj-ping {
  0%,100%{transform:scale(1);opacity:1}
  50%{transform:scale(1.3);opacity:.7}
}

/* Tooltip on hover */
#bj-chat-bubble .bj-tooltip {
  position: absolute;
  right: 64px;
  background: #1c1b18;
  color: #e4e8e2;
  font-size: 0.78rem;
  font-family: 'Poppins', sans-serif;
  padding: 6px 12px;
  border-radius: 8px;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  border: 1px solid #2c302a;
}
#bj-chat-bubble:hover .bj-tooltip { opacity: 1; }

/* ── Chatbot Window ── */
#bj-chat-window {
  position: fixed;
  bottom: 160px;
  right: 24px;
  z-index: 1000;
  width: 380px;
  height: 560px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 12px 48px rgba(0,0,0,0.55);
  border: 1px solid rgba(255,255,255,0.08);
  display: none;
  flex-direction: column;
  transform: scale(0.85) translateY(20px);
  transform-origin: bottom right;
  opacity: 0;
  transition: transform 0.28s cubic-bezier(.16,1,.3,1),
              opacity 0.28s cubic-bezier(.16,1,.3,1);
}
#bj-chat-window.bj-open {
  display: flex;
  transform: scale(1) translateY(0);
  opacity: 1;
}

/* ── Iframe inside window ── */
#bj-chat-window iframe {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* ── Close button ── */
#bj-close-btn {
  position: absolute;
  top: 10px; right: 10px;
  z-index: 10;
  width: 28px; height: 28px;
  background: rgba(0,0,0,0.35);
  border: none;
  border-radius: 50%;
  color: #fff;
  font-size: 14px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
#bj-close-btn:hover { background: rgba(0,0,0,0.6); }

/* Mobile: full screen chatbot */
@media (max-width: 480px) {
  #bj-chat-window {
    width: calc(100vw - 24px);
    height: calc(100vh - 180px);
    bottom: 160px;
    right: 12px;
    left: 12px;
  }
  #bj-chat-bubble {
    right: 16px;
    bottom: 88px;
  }
}
</style>
</style>

