#careers .co2 { width:360px; height:360px; background:#0891b2; opacity:.09; bottom:-60px; left:-80px; animation: cOrb 13s ease-in-out infinite 4s; }
#careers .co3 { width:280px; height:280px; background:#d97706; opacity:.07; top:42%; left:38%; animation: cOrb 9s ease-in-out infinite 7s; }
@keyframes cOrb { 0%,100%{ transform:translateY(0) scale(1); } 50%{ transform:translateY(-40px) scale(1.08); } }

#careers .cw { position:relative; z-index:1; max-width:1060px; margin:0 auto; padding:0 24px; }

/* Header */
#careers .c-hdr { text-align:center; margin-bottom:60px; }
#careers .c-badge { display:inline-block; font-size:11px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:#a78bfa; border:1px solid rgba(167,139,250,.35); background:rgba(167,139,250,.08); padding:6px 18px; border-radius:30px; margin-bottom:22px; }
#careers .c-h1 { font-size:clamp(26px,4.5vw,46px); font-weight:900; line-height:1.2; background:linear-gradient(90deg,#f7971e,#ffd200,#21d4fd,#b721ff,#f7971e); background-size:400%; -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation: cSlideUp .8s ease both .1s, cShimmer 5s linear 1s infinite; margin-bottom:14px; }
@keyframes cShimmer { 0%{ background-position:0% } 100%{ background-position:400% } }
#careers .c-sub { font-size:15px; color:#cbd5e1; max-width:580px; margin:0 auto; line-height:1.7; }
#careers .c-sub em { color:#fde68a; font-style:normal; font-weight:600; }

/* Role Cards */
#careers .c-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:20px; margin-bottom:56px; }
#careers .c-card { position:relative; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.09); border-radius:22px; padding:32px 22px 26px; text-align:center; overflow:hidden; cursor:default; transition:transform .35s, box-shadow .35s, border-color .35s; }
#careers .c-card::before { content:''; position:absolute; inset:0; background:radial-gradient(circle at 50% 0, var(--cg) 0%, transparent 65%); opacity:0; transition:opacity .4s; pointer-events:none; }
#careers .c-card:hover { transform:translateY(-10px); }
#careers .c-card:hover::before { opacity:1; }
#careers .c-card:hover { box-shadow:0 20px 50px rgba(0,0,0,.5); border-color:var(--cb); }
#careers .r1 { --cg:rgba(6,182,212,.25); --cb:rgba(6,182,212,.6); }
#careers .r2 { --cg:rgba(251,191,36,.22); --cb:rgba(251,191,36,.6); }
#careers .r3 { --cg:rgba(167,139,250,.25); --cb:rgba(167,139,250,.6); }
#careers .r4 { --cg:rgba(52,211,153,.22); --cb:rgba(52,211,153,.6); }
#careers .c-icon { font-size:40px; display:block; margin-bottom:14px; animation:cFloat 3s ease-in-out infinite; }
#careers .r2 .c-icon { animation-delay:.7s; }
#careers .r3 .c-icon { animation-delay:1.4s; }
#careers .r4 .c-icon { animation-delay:2.1s; }
@keyframes cFloat { 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-7px); } }
#careers .c-name { font-size:17px; font-weight:800; margin-bottom:8px; letter-spacing:.3px; }
#careers .r1 .c-name { color:#67e8f9; }
#careers .r2 .c-name { color:#fde68a; }
#careers .r3 .c-name { color:#c4b5fd; }
#careers .r4 .c-name { color:#6ee7b7; }
#careers .c-desc { font-size:13px; color:#94a3b8; line-height:1.6; margin-bottom:16px; }
#careers .c-tags { display:flex; flex-wrap:wrap; gap:6px; justify-content:center; margin-bottom:16px; }
#careers .c-tag { font-size:11px; font-weight:600; padding:4px 12px; border-radius:20px; letter-spacing:.4px; }
#careers .r1 .c-tag { background:rgba(6,182,212,.12); color:#67e8f9; border:1px solid rgba(6,182,212,.3); }
#careers .r2 .c-tag { background:rgba(251,191,36,.10); color:#fde68a; border:1px solid rgba(251,191,36,.3); }
#careers .r3 .c-tag { background:rgba(167,139,250,.12); color:#c4b5fd; border:1px solid rgba(167,139,250,.3); }
#careers .r4 .c-tag { background:rgba(52,211,153,.10); color:#6ee7b7; border:1px solid rgba(52,211,153,.3); }
#careers .c-wbs { display:flex; flex-wrap:wrap; gap:6px; justify-content:center; }
#careers .c-wb { font-size:10px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; padding:3px 10px; border-radius:20px; }
#careers .c-wb.ft { background:rgba(167,139,250,.12); color:#c4b5fd; border:1px solid rgba(167,139,250,.3); }
#careers .c-wb.pt { background:rgba(6,182,212,.10); color:#67e8f9; border:1px solid rgba(6,182,212,.3); }
#careers .c-wb.fl { background:rgba(251,191,36,.10); color:#fde68a; border:1px solid rgba(251,191,36,.3); }

/* Divider */
#careers .c-div { text-align:center; margin:48px auto 44px; position:relative; }
#careers .c-div::before { content:''; position:absolute; top:50%; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(167,139,250,.3),transparent); }
#careers .c-div span { position:relative; background:#0a0a1a; padding:0 20px; font-size:12px; font-weight:700; letter-spacing:2px; color:#475569; text-transform:uppercase; }

/* Application Form Box */
#careers .c-form-box { background:rgba(255,255,255,.03); border:1px solid rgba(167,139,250,.22); border-radius:28px; padding:48px 40px; max-width:760px; margin:0 auto; position:relative; overflow:hidden; }
#careers .c-form-box::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,#06b6d4,#a78bfa,#fbbf24,#34d399); background-size:400%; animation:cShimmer 3s linear infinite; }
#careers .c-sheets-bar { display:flex; align-items:center; justify-content:center; gap:8px; background:rgba(52,211,153,.07); border:1px solid rgba(52,211,153,.2); border-radius:10px; padding:8px 16px; margin-bottom:28px; font-size:12px; color:#6ee7b7; font-weight:600; }
#careers .c-sheets-bar span { font-size:16px; }
#careers .c-form-ttl { font-size:22px; font-weight:800; color:#e2e8f0; margin-bottom:6px; text-align:center; }
#careers .c-form-st { font-size:13px; color:#64748b; text-align:center; margin-bottom:28px; }
#careers .c-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px; }
#careers .c-fld { display:flex; flex-direction:column; gap:6px; }
#careers .c-fld label { font-size:11px; font-weight:700; letter-spacing:.9px; text-transform:uppercase; color:#64748b; }
#careers .c-fld input, #careers .c-fld select { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:12px; padding:13px 16px; font-size:14px; color:#e2e8f0; outline:none; font-family:inherit; width:100%; transition:border-color .3s, box-shadow .3s, background .3s; }
#careers .c-fld input:focus, #careers .c-fld select:focus { border-color:rgba(167,139,250,.6); background:rgba(167,139,250,.06); box-shadow:0 0 0 3px rgba(167,139,250,.12); }
#careers .c-fld select option { background:#1a1033; color:#e2e8f0; }

/* Work type */
#careers .c-wt-lbl { font-size:11px; font-weight:700; letter-spacing:.9px; text-transform:uppercase; color:#64748b; display:block; margin-bottom:10px; }
#careers .c-wt-row { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
#careers .c-wt-opt input { display:none; }
#careers .c-wt-opt label { display:flex; align-items:center; gap:7px; padding:10px 20px; border-radius:30px; border:1.5px solid rgba(255,255,255,.12); background:rgba(255,255,255,.04); color:#94a3b8; font-size:13px; font-weight:600; cursor:pointer; transition:all .25s; font-family:inherit; }
#careers .c-wt-opt input:checked + label { border-color:#a78bfa; background:rgba(167,139,250,.15); color:#c4b5fd; box-shadow:0 0 14px rgba(167,139,250,.25); }
#careers .c-wt-opt label:hover { border-color:rgba(167,139,250,.5); color:#cbd5e1; }

/* Unique textarea */
#careers .c-uq-lbl { font-size:13px; font-weight:700; letter-spacing:.4px; color:#c4b5fd; display:block; margin-bottom:6px; }
#careers .c-uq-hint { font-size:12px; color:#94a3b8; margin-bottom:10px; line-height:1.6; }
#careers .c-uq-ta { background:rgba(167,139,250,.05); border:1.5px solid rgba(167,139,250,.22); border-radius:14px; padding:16px 18px; font-size:14px; color:#e2e8f0; outline:none; font-family:inherit; width:100%; min-height:140px; resize:vertical; line-height:1.7; transition:border-color .3s, box-shadow .3s; margin-bottom:4px; }
#careers .c-uq-ta:focus { border-color:rgba(167,139,250,.65); box-shadow:0 0 0 4px rgba(167,139,250,.12); }
#careers .c-uq-cnt { font-size:11px; color:#94a3b8; text-align:right; margin-bottom:24px; }

/* Submit Button */
#careers .c-btn { width:100%; padding:16px 32px; border:none; border-radius:14px; background:linear-gradient(135deg,#7c3aed,#06b6d4); color:#fff; font-size:16px; font-weight:800; letter-spacing:.5px; cursor:pointer; position:relative; overflow:hidden; transition:transform .3s, box-shadow .3s; font-family:inherit; }
#careers .c-btn::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,#a78bfa,#21d4fd); opacity:0; transition:opacity .3s; }
#careers .c-btn:hover { transform:translateY(-3px); box-shadow:0 16px 40px rgba(124,58,237,.5); }
#careers .c-btn:hover::after { opacity:1; }
#careers .c-btn span { position:relative; z-index:1; }
#careers .c-btn:disabled { opacity:.6; cursor:not-allowed; transform:none; }

/* Sending */
#careers .c-sending { display:none; align-items:center; justify-content:center; gap:10px; font-size:14px; color:#94a3b8; margin-top:16px; text-align:center; }
#careers .c-sending.on { display:flex; }
#careers .c-spinner { width:20px; height:20px; border:2px solid rgba(167,139,250,.3); border-top-color:#a78bfa; border-radius:50%; animation:cSpin .8s linear infinite; }
@keyframes cSpin { to{ transform:rotate(360deg); } }

/* Success */
#careers .c-ok { display:none; text-align:center; padding:36px; background:rgba(52,211,153,.07); border:1px solid rgba(52,211,153,.3); border-radius:16px; margin-top:20px; }
#careers .c-ok.on { display:block; animation:cFadeUp .5s ease; }
@keyframes cFadeUp { from{ opacity:0; transform:translateY(20px); } to{ opacity:1; transform:translateY(0); } }
#careers .c-ok-icon { font-size:48px; margin-bottom:12px; }
#careers .c-ok h4 { color:#6ee7b7; font-size:20px; margin-bottom:8px; }
#careers .c-ok p { color:#94a3b8; font-size:14px; line-height:1.7; }

/* Error */
#careers .c-err { display:none; padding:14px 18px; margin-top:14px; background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.3); border-radius:12px; font-size:13px; color:#fca5a5; text-align:center; }
#careers .c-err.on { display:block; }

/* Entrance animations */
@keyframes cSlideUp { from{ opacity:0; transform:translateY(36px); } to{ opacity:1; transform:translateY(0); } }
#careers .c-hdr         { animation: cSlideUp .8s ease both .1s; }
#careers .c-card.r1     { animation: cSlideUp .7s ease both .2s; }
#careers .c-card.r2     { animation: cSlideUp .7s ease both .32s; }
#careers .c-card.r3     { animation: cSlideUp .7s ease both .44s; }
#careers .c-card.r4     { animation: cSlideUp .7s ease both .56s; }
#careers .c-div         { animation: cSlideUp .6s ease both .6s; }
#careers .c-form-box    { animation: cSlideUp .8s ease both .7s; }

/* Responsive */
@media (max-width:600px) {
  #careers .c-row { grid-template-columns:1fr; }
  #careers .c-form-box { padding:32px 20px; }
  #careers .c-grid { grid-template-columns:1fr 1fr; }
}
@media (max-width:420px) {
  #careers .c-grid { grid-template-columns:1fr; }
}
</style>

<!-- ======== CAREERS HTML ======== -->
<section id="careers" data-public-only>

  <!-- ══ Careers Collapsible Toggle ══ -->
  <div style="max-width:1060px;margin:0 auto;padding:0 24px;">
    <div id="careers-toggle-btn"
         onclick="toggleCareers()"
         style="display:flex;align-items:center;justify-content:center;gap:14px;
                background:rgba(255,255,255,0.04);border:1.5px solid rgba(167,139,250,0.3);
                border-radius:16px;padding:18px 32px;cursor:pointer;
                transition:background 0.25s,border-color 0.25s;"
         onmouseover="this.style.background='rgba(167,139,250,0.1)';this.style.borderColor='rgba(167,139,250,0.6)'"
         onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.borderColor='rgba(167,139,250,0.3)'">
      <span style="font-size:1.2rem;">🚀</span>
      <span style="font-size:1rem;font-weight:800;color:#c4b5fd;letter-spacing:0.04em;">Join Our Mission — We Are Hiring</span>
      <span id="careers-arrow" style="font-size:0.85rem;color:#a78bfa;transition:transform 0.3s;display:inline-block;">▶</span>
    </div>
  </div>

  <!-- Careers Body — hidden by default -->
  <div id="careers-body" style="display:none;opacity:0;transition:opacity 0.4s ease;">

  <div class="co co1"></div>
  <div class="co co2"></div>
  <div class="co co3"></div>
  <div class="cw">

    <!-- Header -->
    <div class="c-hdr">
      <div class="c-badge">&#x2728; We Are Hiring — 2026</div>
      <h2 class="c-h1">Join the Bhāva Tech Mission</h2>
      <p class="c-sub">We are building the future of whole-brain education in India and beyond. If you have the <em>spark</em>, your role is waiting here.</p>
    </div>

    <!-- Role Cards -->
    <div class="c-grid">
      <div class="c-card r1">
        <span class="c-icon">🎨</span>
        <div class="c-name">Designing Tools</div>
        <p class="c-desc">Craft beautiful UI/UX for cognitive games, assessment tools, and learning dashboards. Your designs shape how children think and grow.</p>
        <div class="c-tags">
          <span class="c-tag">Figma</span><span class="c-tag">UI/UX</span>
          <span class="c-tag">Prototyping</span><span class="c-tag">Design Systems</span>
        </div>
      </div>
      <div class="c-card r2">
        <span class="c-icon">✍️</span>
        <div class="c-name">Content Creator</div>
        <p class="c-desc">Write research-backed educational content, scripts, blogs, and guides translating neuroscience into engaging, child-friendly language.</p>
        <div class="c-tags">
          <span class="c-tag">Copywriting</span><span class="c-tag">Research</span>
          <span class="c-tag">EdTech Writing</span><span class="c-tag">Storytelling</span>
        </div>
      </div>
      <div class="c-card r3">
        <span class="c-icon">📣</span>
        <div class="c-name">Marketing Expert</div>
        <p class="c-desc">Drive awareness of Bhāva programs across India and globally. Design campaigns that reach the right parents, schools, and changemakers.</p>
        <div class="c-tags">
          <span class="c-tag">Digital Marketing</span><span class="c-tag">SEO/SEM</span>
          <span class="c-tag">Campaigns</span><span class="c-tag">Analytics</span>
        </div>
      </div>
      <div class="c-card r4">
        <span class="c-icon">📲</span>
        <div class="c-name">Social Media Expert</div>
        <p class="c-desc">Build and grow our community on Instagram, YouTube, LinkedIn, and X. Create content that spreads the Bhāva philosophy virally.</p>
        <div class="c-tags">
          <span class="c-tag">Reels / Shorts</span><span class="c-tag">Community Growth</span>
          <span class="c-tag">Content Calendar</span><span class="c-tag">Analytics</span>
        </div>
      </div>
    </div><!-- end c-grid -->

    <!-- Divider -->
    <div class="c-div"><span>Apply Now</span></div>

    <!-- Application Form -->
    <div class="c-form-box">

      <h3 class="c-form-ttl">Tell Us About Yourself</h3>
      <p class="c-form-st">Takes less than 3 minutes &mdash; Every application is read personally</p>

      <form id="c-appform" novalidate>
        <div class="c-row">
          <div class="c-fld">
            <label for="cf-name">Your Name</label>
            <input type="text" id="cf-name" placeholder="Full name" />
          </div>
          <div class="c-fld">
            <label for="cf-contact">Email / WhatsApp</label>
            <input type="text" id="cf-contact" placeholder="email or +91 XXXXX XXXXX" />
          </div>
        </div>
        <div class="c-row">
          <div class="c-fld">
            <label for="cf-role">Role Applying For</label>
            <select id="cf-role">
              <option value="" disabled selected>Select a role</option>
              <option value="Designing Tools">Designing Tools</option>
              <option value="Content Creator">Content Creator</option>
              <option value="Marketing Expert">Marketing Expert</option>
              <option value="Social Media Expert">Social Media Expert</option>
            </select>
          </div>
          <div class="c-fld">
            <label for="cf-city">Your City</label>
            <input type="text" id="cf-city" placeholder="e.g. Visakhapatnam, AP" />
          </div>
        </div>

        <span class="c-wt-lbl">Preferred Work Type</span>
        <div class="c-wt-row">
          <div class="c-wt-opt"><input type="radio" name="cwt" id="cwt-ft" value="Full Time"><label for="cwt-ft">&#x1F4BC; Full Time</label></div>
          <div class="c-wt-opt"><input type="radio" name="cwt" id="cwt-pt" value="Part Time"><label for="cwt-pt">&#x23F0; Part Time</label></div>
          <div class="c-wt-opt"><input type="radio" name="cwt" id="cwt-fl" value="Freelancing"><label for="cwt-fl">&#x1F4BB; Freelancing</label></div>
        </div>

        <span class="c-uq-lbl">How Do You Uniquely Help Bhāva Tech?</span>
        <p class="c-uq-hint">This is the heart of your application. Tell us what makes you different — your specific skills, tools, ideas, or experience that can move Bhāva Tech forward. Be real and direct.</p>
        <textarea class="c-uq-ta" id="cf-unique" maxlength="1500" placeholder="E.g. I have designed gamified dashboards for 3 EdTech startups. I understand how children interact with visual interfaces and can improve your assessment screens to increase completion rates…"></textarea>
        <div class="c-uq-cnt"><span id="cf-cnt">0</span> / 1500</div>

        <button type="submit" class="c-btn" id="c-submit-btn">
          <span>Submit My Application</span>
        </button>
      </form>

      <div class="c-sending" id="c-sending">
        <div class="c-spinner"></div> Saving your application&hellip;
      </div>
      <div class="c-err" id="c-err">
        &#x26A0;&#xFE0F; Could not reach the server. Your application was still sent via WhatsApp — we have received it!
      </div>
      <div class="c-ok" id="c-ok">
        <div class="c-ok-icon">&#x2705;</div>
        <h4>Application Received!</h4>
        <p>Your details are saved <strong style="color:#6ee7b7"></strong>.<br>
        We will review your application and reach out within <strong>3–5 working days</strong> via WhatsApp or email.</p>
      </div>
    </div><!-- end c-form-box -->

  </div><!-- end cw -->

  </div><!-- /careers-body -->

</section>


<script>
(function () {
  var SHEETSURL = "https://script.google.com/macros/s/AKfycbx08on_iG3_6Y5mLUv1RgIAsNnI95ibadU8StZo_P0IKyVANi0YRKnW12etN_ahkZsH6g/exec";

  /* Char counter */
  var ta  = document.getElementById('cf-unique');
  var cnt = document.getElementById('cf-cnt');
  if (ta && cnt) {
    ta.addEventListener('input', function () { cnt.textContent = ta.value.length; });
  }

  /* showSuccess — declared BEFORE addEventListener */
  function showSuccess() {
    document.getElementById('c-sending').classList.remove('on');
    document.getElementById('c-appform').style.display = 'none';
    document.getElementById('c-ok').classList.add('on');
  }

  /* Form submit */
  document.getElementById('c-appform').addEventListener('submit', function (e) {
    e.preventDefault(); /* MUST be first */

    var name    = document.getElementById('cf-name').value.trim();
    var contact = document.getElementById('cf-contact').value.trim();
    var role    = document.getElementById('cf-role').value.trim();
    var city    = document.getElementById('cf-city').value.trim();
    var wtEl    = document.querySelector('input[name="cwt"]:checked');
    var wt      = wtEl ? wtEl.value : 'Not specified';
    var unique  = document.getElementById('cf-unique').value.trim();

    if (!name || !contact || !role || !unique) {
      alert('Please fill in your name, contact, role, and the unique value field.');
      return;
    }

    var btn     = document.getElementById('c-submit-btn');
    var sending = document.getElementById('c-sending');
    var errBox  = document.getElementById('c-err');

    btn.disabled = true;
    sending.classList.add('on');
    errBox.classList.remove('on');

    var payload = { name: name, contact: contact, role: role, city: city, workType: wt, unique: unique };

    fetch(SHEETSURL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function () {
      /* no-cors: response is opaque but data IS saved when URL is correct */
      showSuccess();
    })
    .catch(function () {
      /* Network error fallback — show error note but still acknowledge */
      errBox.classList.add('on');
      showSuccess();
    });

    /* WhatsApp backup — always fires so you never miss an application */
    var msg = 'Career Application — Bhāva Tech\n'
            + 'Name: ' + name + '\n'
            + 'Contact: ' + contact + '\n'
            + 'Role: ' + role + '\n'
            + 'Work Type: ' + wt + (city ? '\nCity: ' + city : '') + '\n'
            + 'Unique Value: ' + unique;
    window.open('https://wa.me/919573057516?text=' + encodeURIComponent(msg), '_blank');
  });
})();
</script>

