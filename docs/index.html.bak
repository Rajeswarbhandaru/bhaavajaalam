      <div class="stat-card" style="background:rgba(255,255,255,0.04); border:1px solid rgba(167,139,250,0.2); border-radius:20px; padding:36px 20px; text-align:center; position:relative; overflow:hidden; transition:transform 0.3s ease, box-shadow 0.3s ease;"
