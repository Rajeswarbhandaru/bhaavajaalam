<script>
// Show Admin link only when running inside Electron (not bridge/web)
(function() {
  function checkBhava() {
    if (window.bhava && window.bhava._isElectron !== false) {
      var el = document.getElementById('admin-nav-item');
      if (el) el.style.display = 'list-item';
