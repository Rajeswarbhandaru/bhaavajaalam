  <!-- INTERNAL STYLE -->
  <style>
    #gain-section .gain-card {
      background: rgba(255,255,255,0.05);
      border-radius:18px;
      padding:25px;
      backdrop-filter: blur(12px);
      border:1px solid rgba(255,255,255,0.1);
      transition: all 0.4s ease;
      transform: translateY(50px);
      opacity:0;
      position:relative;
      overflow:hidden;
    }

    #gain-section .gain-card span {
      font-size:2rem;
    }

    #gain-section .gain-card h3 {
      margin:15px 0 10px;
    }

    #gain-section .gain-card p {
      font-size:0.9rem;
      opacity:0.8;
    }

    /* HOVER GLOW */
    #gain-section .gain-card:hover {
      transform: translateY(-10px) scale(1.05);
      background: linear-gradient(135deg,#38bdf8,#6366f1);
      box-shadow: 0 10px 40px rgba(56,189,248,0.4);
    }

    /* SHIMMER EFFECT */
    #gain-section .gain-card::before {
      content:"";
      position:absolute;
      top:-100%;
      left:-100%;
      width:200%;
      height:200%;
      background: linear-gradient(120deg,transparent,rgba(255,255,255,0.2),transparent);
      transform: rotate(25deg);
      transition:0.6s;
    }

    #gain-section .gain-card:hover::before {
      top:100%;
      left:100%;
    }
  </style>

  <!-- INTERNAL SCRIPT -->
  <script>
    (function(){
      const cards = document.querySelectorAll('#gain-section .gain-card');

      const observer = new IntersectionObserver(entries => {
        entries.forEach((entry, i) => {
          if(entry.isIntersecting){
            setTimeout(()=>{
              entry.target.style.transform = "translateY(0)";
              entry.target.style.opacity = "1";
            }, i * 120);
          }
        });
      }, { threshold: 0.2 });

      cards.forEach(card => observer.observe(card));
    })();
  </script>

</section>
