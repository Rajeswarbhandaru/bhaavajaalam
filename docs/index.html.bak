<script>
// Show Admin nav link only if running inside Electron as verified admin
(function () {
  async function checkAdminNav() {
    if (!window.bhava || window.bhava._isElectron === false) return; // not in Electron
    const verified = sessionStorage.getItem('bhava_admin_verified') === '1';
    if (!verified) return;
    // Double-check config role
    try {
      const cfg = await window.bhava.getConfig();
      if (cfg.role === 'admin') {
        const el = document.getElementById('admin-nav-item');
        if (el) el.style.display = '';
      }
    } catch (e) {}
  }
  // Run immediately and after short delay (for preload timing)
  checkAdminNav();
  setTimeout(checkAdminNav, 400);
})();
</script>


<script>
// ── Scroll Spy — highlight active nav item ──────────────────────────────────
(function initScrollSpy() {
  // Map nav links to their target section IDs
  var sections = [
    { id: 'about',         link: 'a[href="#about"]' },
    { id: 'brain-gym',     link: 'a[href="#brain-gym"]' },
    { id: 'games',         link: 'a[href="#games"]' },
    { id: 'benefits',      link: 'a[href="#benefits"]' },
    { id: 'faq',           link: 'a[href="#faq"]' },
    { id: 'contact',       link: 'a[href="#contact"]' },
  ];

  function onScroll() {
    var scrollY = window.scrollY || window.pageYOffset;
    var active  = null;

    sections.forEach(function(s) {
      var el = document.getElementById(s.id);
      if (!el) return;
      if (el.offsetTop - 120 <= scrollY) active = s;
    });

    // Remove active from all nav links
    document.querySelectorAll('.nav-links a').forEach(function(a) {
      a.classList.remove('active');
    });

    // Add active to current section link
    if (active) {
      var link = document.querySelector('.nav-links ' + active.link);
      if (link) link.classList.add('active');
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // run once on load
})();

// ── School / Public context mode ─────────────────────────────────────────
(function () {
  // Detect Android WebView / Capacitor app
  var ua = navigator.userAgent || '';
  var isWebView = (typeof window.Capacitor !== 'undefined')
               || /wv/.test(ua)
               || (/android/i.test(ua) && !/chrome\/[.0-9]* mobile/i.test(ua));

  async function applyContext() {
    // In Android WebView — always hide public-only (app mode)
    if (isWebView) {
      document.querySelectorAll('[data-public-only]').forEach(el => el.style.display = 'none');
      document.querySelectorAll('[data-public-only-inline]').forEach(el => el.style.display = 'none');
      return;
    }

    if (!window.bhava) return; // not in Electron — always public (website)

    let cfg = {};
    try { cfg = await window.bhava.getConfig(); } catch(e) {}

    if (cfg.context !== 'school') return; // public mode — show everything

    // ── School mode: hide public-only elements ────────────────────────────
    document.querySelectorAll('[data-public-only]').forEach(el => {
      el.style.display = 'none';
    });
    document.querySelectorAll('[data-public-only-inline]').forEach(el => {
      el.style.display = 'none';
    });

    // Hide hero public CTA, show school CTA
    const pubCta = document.getElementById('hero-cta-public');
    const scCta  = document.getElementById('hero-cta-school');
    if (pubCta) pubCta.style.display = 'none';
    if (scCta)  scCta.style.display  = '';

    // Hide the main hero section, show school banner
    const heroSection = document.getElementById('bhava-unified');
    const schoolBanner = document.getElementById('school-hero-banner');
    if (heroSection)  heroSection.style.display  = 'none';
    if (schoolBanner) schoolBanner.style.display = '';

    // Hide the stat-boxes row (100% online ready etc.)
    const statRow = document.querySelector('.hero-stats') || document.querySelector('.stat-boxes');
    if (statRow) statRow.style.display = 'none';

    // Add school-mode body class for any CSS targeting
    document.body.classList.add('school-mode');
  }

  applyContext();
  setTimeout(applyContext, 400);
})();
</script>


<!-- ══ Student Login Modal ══ -->
<div id="bhava-login-modal" style="display:none;position:fixed;inset:0;z-index:99999;
  background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);
  align-items:center;justify-content:center;padding:20px;">
  <div style="background:linear-gradient(145deg,#0f172a,#1e293b);border:1px solid rgba(99,102,241,0.3);
    border-radius:24px;padding:32px 28px;width:100%;max-width:360px;position:relative;
    box-shadow:0 20px 60px rgba(0,0,0,0.6);">
    <button onclick="closeLoginModal()" style="position:absolute;top:14px;right:16px;
      background:rgba(255,255,255,0.08);border:none;color:#94a3b8;font-size:18px;
      width:30px;height:30px;border-radius:50%;cursor:pointer;line-height:1;">✕</button>

    <div style="text-align:center;margin-bottom:22px;">
      <div style="font-size:28px;margin-bottom:6px;">🎮</div>
      <h3 style="color:#e2e8f0;font-size:1.1rem;font-weight:700;margin:0 0 4px;">
        Login to Play
      </h3>
      <p style="color:#64748b;font-size:0.78rem;margin:0;">
        Use your school credentials or continue as guest
      </p>
    </div>

    <!-- Student Login -->
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px;">
      <input id="login-roll" type="text" placeholder="Roll Number"
        style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);
        border-radius:12px;padding:11px 14px;color:#e2e8f0;font-size:0.9rem;
        font-family:inherit;outline:none;width:100%;box-sizing:border-box;"
        onkeydown="if(event.key==='Enter')document.getElementById('login-class').focus()" />
      <input id="login-class" type="text" placeholder="Class (e.g. 6 or 10)"
        style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);
        border-radius:12px;padding:11px 14px;color:#e2e8f0;font-size:0.9rem;
        font-family:inherit;outline:none;width:100%;box-sizing:border-box;"
        onkeydown="if(event.key==='Enter')document.getElementById('login-pin').focus()" />
      <input id="login-pin" type="password" placeholder="4-digit PIN (optional)"
        maxlength="6"
        style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);
        border-radius:12px;padding:11px 14px;color:#e2e8f0;font-size:0.9rem;
        font-family:inherit;outline:none;width:100%;box-sizing:border-box;display:none;"
        onkeydown="if(event.key==='Enter')submitStudentLogin()" />
      <div id="login-error" style="min-height:18px;font-size:0.78rem;color:#f87171;text-align:center;"></div>
      <button id="login-submit-btn" onclick="submitStudentLogin()"
        style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;
        border:none;border-radius:12px;padding:12px;font-size:0.9rem;font-weight:700;
        font-family:inherit;cursor:pointer;width:100%;transition:opacity 0.2s;">
        Login &amp; Play →
      </button>
    </div>

    <!-- Divider -->
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
      <div style="flex:1;height:1px;background:rgba(255,255,255,0.08);"></div>
      <span style="color:#475569;font-size:0.72rem;font-weight:600;">OR</span>
      <div style="flex:1;height:1px;background:rgba(255,255,255,0.08);"></div>
    </div>

    <!-- Google Guest -->
    <button onclick="loginAsGuest()"
      style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);
      border-radius:12px;padding:11px;font-size:0.85rem;font-weight:600;color:#cbd5e1;
      font-family:inherit;cursor:pointer;width:100%;display:flex;align-items:center;
      justify-content:center;gap:10px;transition:background 0.2s;">
      <svg width="18" height="18" viewBox="0 0 18 18">
        <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
        <path fill="#FBBC05" d="M3.964 10.706A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.038l3.007-2.332z"/>
        <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58z"/>
      </svg>
      Continue as Guest (Google)
    </button>

    <p style="text-align:center;color:#334155;font-size:0.7rem;margin-top:12px;">
      Guest scores are saved to your Google account
    </p>
  </div>
</div>

<!-- Google Sign-In SDK (for guest login) -->
<script>

// ══ Silent Visitor Tracker (no login required) ══════════════════════════════
(function trackSilentVisit() {
  var ua     = navigator.userAgent || '';
  var device = /tablet|ipad|playbook|silk/i.test(ua) ? 'tablet'
             : /mobile|android|iphone|ipod|blackberry|iemobile|opera mini/i.test(ua) ? 'mobile'
             : 'desktop';
  var browser = /edg/i.test(ua) ? 'Edge'
              : /chrome/i.test(ua) ? 'Chrome'
              : /safari/i.test(ua) ? 'Safari'
              : /firefox/i.test(ua) ? 'Firefox'
              : /opr|opera/i.test(ua) ? 'Opera' : 'Other';
  var os = /windows/i.test(ua) ? 'Windows'
         : /android/i.test(ua) ? 'Android'
         : /iphone|ipad|ipod/i.test(ua) ? 'iOS'
         : /mac/i.test(ua) ? 'macOS'
         : /linux/i.test(ua) ? 'Linux' : 'Other';

  fetch('https://bhava-cloud.onrender.com/track/visit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      google_sub: 'anonymous_' + Math.random().toString(36).slice(2,9),
      name:    'Anonymous Visitor',
      email:   '',
      device:  device,
      browser: browser,
      os:      os,
      referrer: document.referrer || ''
    })
  }).catch(function() {}); // silent fail — never blocks page

  // Google Analytics pageview
  if (typeof gtag !== 'undefined') {
    gtag('event', 'page_view', { device_type: device });
  }
})();
// ══ End Silent Tracker ═══════════════════════════════════════════════════

</script>

<script>
// ── Explore All Games Toggle ──
function toggleAllGames() {
  var wrap = document.getElementById('all-games-wrap');
  var icon = document.getElementById('explore-btn-icon');
  var txt  = document.getElementById('explore-btn-text');
  var btn  = document.getElementById('explore-all-btn');
  if (!wrap) return;
  if (wrap.style.display === 'none' || wrap.style.display === '') {
    wrap.style.display = 'block';
    setTimeout(function(){ wrap.style.opacity = '1'; }, 10);
    if (icon) icon.textContent = '▼';
    if (txt)  txt.textContent  = 'Hide Games';
    if (btn)  btn.style.background = 'rgba(255,255,255,0.18)';
    setTimeout(function(){ wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 120);
  } else {
    wrap.style.opacity = '0';
    setTimeout(function(){ wrap.style.display = 'none'; }, 400);
    if (icon) icon.textContent = '▶';
    if (txt)  txt.textContent  = 'Explore All Games';
    if (btn)  btn.style.background = 'rgba(255,255,255,0.08)';
  }
}

// ── Careers Collapsible Toggle ──
function toggleCareers() {
  var body  = document.getElementById('careers-body');
  var arrow = document.getElementById('careers-arrow');
  if (!body) return;
  if (body.style.display === 'none' || body.style.display === '') {
    body.style.display = 'block';
    setTimeout(function(){ body.style.opacity = '1'; }, 10);
    if (arrow) { arrow.textContent = '▼'; arrow.style.transform = 'rotate(0deg)'; }
  } else {
    body.style.opacity = '0';
    setTimeout(function(){ body.style.display = 'none'; }, 400);
    if (arrow) { arrow.textContent = '▶'; arrow.style.transform = ''; }
  }
}

// ── Scroll Spy: highlight active nav link as user scrolls ──
(function() {
  var sectionIds = ['about','brain-gym','games','games-to-skills','pricing','careers','faq','contact'];
  var navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
  if (!navLinks.length) return;

  function getActiveId() {
    var scrollY = window.scrollY || window.pageYOffset;
    var offset  = 120; // px below nav to trigger
    var active  = sectionIds[0];
    for (var i = 0; i < sectionIds.length; i++) {
      var el = document.getElementById(sectionIds[i]);
      if (el && el.getBoundingClientRect().top + scrollY - offset <= scrollY) {
        active = sectionIds[i];
      }
    }
    return active;
  }

  function updateNav() {
    var activeId = getActiveId();
    navLinks.forEach(function(a) {
      var href = a.getAttribute('href');
      if (href === '#' + activeId) {
        a.classList.add('active');
      } else {
        a.classList.remove('active');
      }
    });
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav(); // run once on load
})();
</script>

