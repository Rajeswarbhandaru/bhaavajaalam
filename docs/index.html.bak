<!-- ════════════════════════════════════════════════
     F — HOLISTIC CHILD DEVELOPMENT + ADULT STRESS RELIEF
════════════════════════════════════════════════ -->
<section id="holistic" class="bgt-section bgt-holistic">
  <div class="bgt-inner">

    <div class="bgt-h bgt-fade">
      <h2>🌈 Holistic Development</h2>
      <p>Not building exam-toppers. Building complete human beings.</p>
    </div>

