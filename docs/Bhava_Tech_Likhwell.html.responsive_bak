function endBhavaSession() {
  const attempts = state.sessionAttempts;
  const modal = document.getElementById("sessionSummaryModal");
  const body = document.getElementById("sessionSummaryBody");

  if (!attempts.length) {
    body.innerHTML = `<p>No attempts recorded yet this session. Write a few letters first!</p>`;
  } else {
    const avg = Math.round(attempts.reduce((s, a) => s + a.finalScore, 0) / attempts.length);
    const best = Math.max(...attempts.map(a => a.finalScore));
    const durationMin = Math.max(1, Math.round((Date.now() - state.sessionStartTime) / 60000));
    const dims = ["accuracy", "boundary", "clarity"].map(k => ({
      k, v: attempts.reduce((s, a) => s + a[k], 0) / attempts.length
    })).sort((a, b) => a.v - b.v);
    const weakest = dims[0];

    body.innerHTML = `
      <p><b>Duration:</b> ${durationMin} min &nbsp; <b>Attempts:</b> ${attempts.length}</p>
      <p><b>Average score:</b> ${avg}/100 &nbsp; <b>Best:</b> ${best}/100</p>
      <p><b>Focus area for next session:</b> ${weakest.k} (avg ${Math.round(weakest.v)}/100)</p>
    `;
  }

  const sessions = JSON.parse(localStorage.getItem("bhava_sessions") || "[]");
  sessions.unshift({ date: new Date().toISOString(), attempts: state.sessionAttempts });
  localStorage.setItem("bhava_sessions", JSON.stringify(sessions.slice(0, 50)));

  modal.style.display = "flex";

  // Sync score to Bhava platform
  try {
    if (window.BhavaSession && typeof BhavaSession.end === 'function') {
      const syncScore = attempts.length
        ? Math.round(attempts.reduce((s, a) => s + a.finalScore, 0) / attempts.length)
        : 0;
      BhavaSession.end(syncScore);
    }
  } catch(e) { console.warn('BhavaSession.end:', e.message); }
}

