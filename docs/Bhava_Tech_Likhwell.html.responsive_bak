/* ---------------------------------------------------------------------
   27) MULTI-LETTER PRACTICE SHEET (A-Z / Selected / Random, one page)
   ---------------------------------------------------------------------
   This section is self-contained: it builds its own small canvases,
   captures ink on each one independently, generates a target letter
   shape for each, and scores every letter at once when "Submit all"
   is clicked. It reuses the generic math helpers already defined above
   (distance, resampleOrderedPath, sampleUnorderedPoints, normalizePoints,
   averageNearestDistance, getBoundingBox, clamp) so the scoring logic
   stays consistent with the main single-letter practice area.
--------------------------------------------------------------------- */
const sheetModeSelectEl = document.getElementById("sheetModeSelect");
const sheetCaseSelectEl = document.getElementById("sheetCaseSelect");
const sheetRandomCountField = document.getElementById("sheetRandomCountField");
const sheetRandomCountEl = document.getElementById("sheetRandomCount");
const sheetPickerBoxEl = document.getElementById("sheetPickerBox");
const sheetCheckboxGridEl = document.getElementById("sheetCheckboxGrid");
const sheetContainerEl = document.getElementById("sheetContainer");
const sheetResultsEl = document.getElementById("sheetResults");
const generateSheetBtn = document.getElementById("generateSheetBtn");
const submitSheetBtn = document.getElementById("submitSheetBtn");

// Small-canvas layout constants (each letter gets its own mini copybook)
const MINI_W = 190, MINI_H = 150;
const MINI_TOP = 20, MINI_MID = 60, MINI_BASE = 105, MINI_DESC = 135;
const MINI_LEFT_PAD = 14, MINI_RIGHT_PAD = 14;

// Holds one entry per letter card: { letter, canvas, ctx, strokes, target }
let sheetCards = [];

function getSheetCaseLetters() {
  return sheetCaseSelectEl.value === "uppercase" ? UPPERCASE : LOWERCASE;
}

// Build the A-Z checkbox picker (used only in "Selected letters" mode)
function buildSheetCheckboxes() {
  const letters = getSheetCaseLetters();
  sheetCheckboxGridEl.innerHTML = "";
  letters.forEach(letter => {
    const wrap = document.createElement("label");
    wrap.style.cssText = "display:flex;align-items:center;gap:4px;font-size:14px;justify-content:center;background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:6px;";
    wrap.innerHTML = `<input type="checkbox" value="${letter}" class="sheetLetterCheckbox" /> ${letter}`;
    sheetCheckboxGridEl.appendChild(wrap);
  });
}

sheetModeSelectEl.addEventListener("change", () => {
  const mode = sheetModeSelectEl.value;
