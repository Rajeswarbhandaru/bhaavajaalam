});

// Draw the mini copybook lines onto a given mini canvas
function drawMiniGuideLines(mctx) {
  mctx.fillStyle = "#fffdf8";
  mctx.fillRect(0, 0, MINI_W, MINI_H);

  mctx.strokeStyle = "#d6d6d6";
  mctx.lineWidth = 1;
  mctx.setLineDash([]);
  mctx.beginPath(); mctx.moveTo(6, MINI_TOP); mctx.lineTo(MINI_W - 6, MINI_TOP); mctx.stroke();

  mctx.strokeStyle = "#c9c9c9";
  mctx.setLineDash([5, 5]);
  mctx.beginPath(); mctx.moveTo(6, MINI_MID); mctx.lineTo(MINI_W - 6, MINI_MID); mctx.stroke();

  mctx.strokeStyle = "#bdbdbd";
  mctx.setLineDash([]);
  mctx.beginPath(); mctx.moveTo(6, MINI_BASE); mctx.lineTo(MINI_W - 6, MINI_BASE); mctx.stroke();

  mctx.strokeStyle = "#d6d6d6";
  mctx.beginPath(); mctx.moveTo(6, MINI_DESC); mctx.lineTo(MINI_W - 6, MINI_DESC); mctx.stroke();
}

// Generate a target point-cloud for one letter, scaled to the mini canvas
function generateMiniTargetCloud(letter) {
  const off = document.createElement("canvas");
  off.width = MINI_W; off.height = MINI_H;
  const octx = off.getContext("2d");

  const fontFamily = getTargetFontFamily();
  let fontSize = 80;
  octx.font = `${fontSize}px ${fontFamily}`;
  let metrics = octx.measureText(letter);

  while ((metrics.width > MINI_W - MINI_LEFT_PAD - MINI_RIGHT_PAD - 10 ||
          fontSize > (MINI_DESC - MINI_TOP + 10)) && fontSize > 20) {
    fontSize -= 2;
    octx.font = `${fontSize}px ${fontFamily}`;
    metrics = octx.measureText(letter);
  }

  octx.clearRect(0, 0, MINI_W, MINI_H);
  octx.fillStyle = "#000";
  octx.textBaseline = "alphabetic";
  octx.font = `${fontSize}px ${fontFamily}`;
  const x = Math.max(MINI_LEFT_PAD, (MINI_W - metrics.width) / 2);
  const y = MINI_BASE;
  octx.fillText(letter, x, y);

  const img = octx.getImageData(0, 0, MINI_W, MINI_H).data;
  const points = [];
  for (let py = 0; py < MINI_H; py += 2) {
    for (let px = 0; px < MINI_W; px += 2) {
      const idx = (py * MINI_W + px) * 4;
      if (img[idx + 3] > 20) points.push({ x: px, y: py });
    }
  }

  return { letter, fontSize, fontFamily, x, y, points, bbox: getBoundingBox(points) };
}

// Draw the faint guide + any captured ink for one card
function renderMiniCard(card) {
  const mctx = card.ctx;
  drawMiniGuideLines(mctx);

  const fillMode = guideStyleSelectEl.value;
  if (fillMode !== "none") {
    mctx.save();
    mctx.globalAlpha = fillMode === "solid" ? 0.18 : 0.5;
    mctx.textBaseline = "alphabetic";
    mctx.font = `${card.target.fontSize}px ${card.target.fontFamily}`;
    if (fillMode === "solid") {
      mctx.fillStyle = "#2563eb";
      mctx.fillText(card.target.letter, card.target.x, card.target.y);
    } else {
      mctx.strokeStyle = "#2563eb";
      mctx.lineWidth = fillMode === "hollow" ? 0.75 : 1.2;
      if (fillMode === "dotted") mctx.setLineDash([2, 3]);
      mctx.strokeText(card.target.letter, card.target.x, card.target.y);
      mctx.setLineDash([]);
    }
    mctx.restore();
  }

  const inkColor = inkColorSelectEl.value;
  mctx.save();
  mctx.strokeStyle = inkColor;
  mctx.fillStyle = inkColor;
  mctx.lineCap = "round";
  mctx.lineJoin = "round";
  mctx.lineWidth = 3;

  card.strokes.forEach(stroke => {
    const pts = stroke.points;
    if (pts.length === 1) {
      mctx.beginPath(); mctx.arc(pts[0].x, pts[0].y, 2, 0, Math.PI * 2); mctx.fill();
    } else {
      mctx.beginPath();
      mctx.moveTo(pts[0].x, pts[0].y);
      for (let i = 1; i < pts.length; i++) mctx.lineTo(pts[i].x, pts[i].y);
      mctx.stroke();
    }
  });
  mctx.restore();
}

// Build one letter card: title, canvas, clear button, per-card score readout
function buildLetterCard(letter) {
  const wrap = document.createElement("div");
  wrap.style.cssText = "background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;padding:10px;text-align:center;";

  const title = document.createElement("div");
  title.textContent = letter;
  title.style.cssText = "font-size:14px;color:#6b7280;margin-bottom:6px;font-weight:700;";

  const miniCanvas = document.createElement("canvas");
  miniCanvas.width = MINI_W;
  miniCanvas.height = MINI_H;
  miniCanvas.style.cssText = "width:100%;border-radius:8px;border:1px solid #ece7dd;touch-action:none;cursor:crosshair;background:#fffdf8;";

  const scoreLine = document.createElement("div");
  scoreLine.style.cssText = "margin-top:6px;font-size:13px;color:#374151;min-height:18px;";
  scoreLine.textContent = "Not yet checked";

  const miniClear = document.createElement("button");
  miniClear.textContent = "Clear";
  miniClear.className = "secondary";
  miniClear.style.cssText = "margin-top:6px;height:30px;padding:0 10px;font-size:12px;margin-right:6px;";

  const miniSpeak = document.createElement("button");
  miniSpeak.textContent = "🔊";
  miniSpeak.title = "Hear this letter";
  miniSpeak.className = "secondary";
  miniSpeak.style.cssText = "margin-top:6px;height:30px;padding:0 10px;font-size:12px;";
  miniSpeak.addEventListener("click", () => speakText(letter));

  const miniBtnRow = document.createElement("div");
  miniBtnRow.appendChild(miniClear);
  miniBtnRow.appendChild(miniSpeak);

  wrap.appendChild(title);
  wrap.appendChild(miniCanvas);
  wrap.appendChild(scoreLine);
  wrap.appendChild(miniBtnRow);

  const mctx = miniCanvas.getContext("2d");
  const card = {
    letter,
    canvas: miniCanvas,
    ctx: mctx,
    strokes: [],
    currentStroke: null,
    isDrawing: false,
    target: generateMiniTargetCloud(letter),
    scoreLine
  };

  function getMiniCoords(evt) {
    const rect = miniCanvas.getBoundingClientRect();
    const scaleX = miniCanvas.width / rect.width;
    const scaleY = miniCanvas.height / rect.height;
    return {
      x: (evt.clientX - rect.left) * scaleX,
      y: (evt.clientY - rect.top) * scaleY,
      t: Date.now(),
      pressure: evt.pressure !== undefined && evt.pressure > 0 ? evt.pressure : 0.5
    };
  }

  miniCanvas.addEventListener("pointerdown", (evt) => {
    evt.preventDefault();
    card.isDrawing = true;
    card.currentStroke = { points: [getMiniCoords(evt)] };
    card.strokes.push(card.currentStroke);
    renderMiniCard(card);
  });
  miniCanvas.addEventListener("pointermove", (evt) => {
    if (!card.isDrawing || !card.currentStroke) return;
    evt.preventDefault();
    card.currentStroke.points.push(getMiniCoords(evt));
    renderMiniCard(card);
  });
  const endMini = () => { card.isDrawing = false; card.currentStroke = null; };
  miniCanvas.addEventListener("pointerup", endMini);
  miniCanvas.addEventListener("pointercancel", endMini);
  miniCanvas.addEventListener("pointerleave", endMini);

  miniClear.addEventListener("click", () => {
    card.strokes = [];
    card.scoreLine.textContent = "Not yet checked";
    card.scoreLine.style.color = "#374151";
    renderMiniCard(card);
  });

  renderMiniCard(card);
  return { wrap, card };
}

// Decide which letters go on the sheet based on the selected mode
function getSheetLetterList() {
  const mode = sheetModeSelectEl.value;
  const allLetters = getSheetCaseLetters();

  if (mode === "all") return allLetters.slice();

  if (mode === "selected") {
    const checked = Array.from(document.querySelectorAll(".sheetLetterCheckbox:checked")).map(cb => cb.value);
    return checked.length ? checked : allLetters.slice(0, 5); // fallback if nothing picked
  }

  // random mode
  const count = parseInt(sheetRandomCountEl.value, 10) || 10;
  const pool = allLetters.slice();
  const chosen = [];
  for (let i = 0; i < count && pool.length; i++) {
    const idx = Math.floor(Math.random() * pool.length);
    chosen.push(pool.splice(idx, 1)[0]);
  }
  return chosen;
}

function generateSheet() {
  const letters = getSheetLetterList();
  sheetContainerEl.innerHTML = "";
  sheetResultsEl.innerHTML = "";
  sheetCards = [];

  letters.forEach(letter => {
    const { wrap, card } = buildLetterCard(letter);
    sheetContainerEl.appendChild(wrap);
    sheetCards.push(card);
  });
}

// Score every card at once using the same geometric approach as the
// main single-letter practice area (resample -> normalize -> compare).
function submitSheet() {
  if (!sheetCards.length) {
    sheetResultsEl.innerHTML = `<p style="color:#c62828;">Generate a sheet first.</p>`;
    return;
  }

  let totalScore = 0;
  let scoredCount = 0;

  sheetCards.forEach(card => {
    const rawPoints = [];
    card.strokes.forEach(s => rawPoints.push(...s.points));

    if (rawPoints.length < 6) {
      card.scoreLine.textContent = "Skipped (not drawn)";
      card.scoreLine.style.color = "#9ca3af";
      return;
    }

    const userResampled = resampleOrderedPath(rawPoints, 100);
    const targetSampled = sampleUnorderedPoints(card.target.points, 100);
    const userNorm = normalizePoints(userResampled, 160);
    const targetNorm = normalizePoints(targetSampled, 160);

    const d1 = averageNearestDistance(userNorm, targetNorm);
    const d2 = averageNearestDistance(targetNorm, userNorm);
    const avg = (d1 + d2) / 2;
    const accuracy = clamp(Math.round(100 - (avg / 28) * 100), 0, 100);

    const userBox = getBoundingBox(rawPoints);
    const outsideCount = rawPoints.filter(p => p.y < MINI_TOP - 14 || p.y > MINI_DESC + 14).length;
    const outsideRatio = outsideCount / rawPoints.length;
    const boundary = clamp(Math.round(100 - outsideRatio * 80), 0, 100);

    const finalScore = Math.round(accuracy * 0.7 + boundary * 0.3);
    totalScore += finalScore;
    scoredCount++;

    card.scoreLine.textContent = `${card.letter}: ${finalScore}/100`;
    card.scoreLine.style.color = finalScore >= 75 ? "#2e7d32" : finalScore >= 50 ? "#e65100" : "#c62828";
  });

  const avgScore = scoredCount ? Math.round(totalScore / scoredCount) : 0;
  sheetResultsEl.innerHTML = `
    <div class="metric" style="max-width:260px;">
      <div class="label">Sheet average (${scoredCount}/${sheetCards.length} completed)</div>
      <div class="value">${avgScore}</div>
    </div>
  `;

  if (scoredCount) playScoreTone(avgScore); // one chime/tone for the whole sheet result
}

generateSheetBtn.addEventListener("click", generateSheet);
submitSheetBtn.addEventListener("click", submitSheet);


